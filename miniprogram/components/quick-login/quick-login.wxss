/* components/quick-login/quick-login.wxss — Stitch 设计稿 1:1 还原 */

/* ── 根容器（全屏覆盖） ── */

.ql-root {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background-color: #F6F1E9;
}

.ql-page {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #F6F1E9;
  opacity: 0;
  transform: scale(0.95);
  transition: opacity 0.3s, transform 0.3s;
}

.ql-page.ql-show {
  opacity: 1;
  transform: scale(1);
}

/* ── 关闭按钮 ── */

.ql-close {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 10;
  padding-right: 32rpx;
  padding-bottom: 16rpx;
}

.ql-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ql-close-icon {
  font-size: 46rpx;
  color: #454545;
}

/* ── Body（可滚动主区域，填满剩余空间） ── */

.ql-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 0 40rpx;
}

.ql-main {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── Logo ── */

.ql-logo-wrap {
  margin-bottom: 194rpx;
}

.ql-logo-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(28, 186, 84, 0.25);
}

/* ── 欢迎文字 ── */

.ql-heading {
  position: relative;
  bottom: 150rpx;
  font-size: 60rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.ql-subtitle {
  position: relative;
  bottom: 150rpx;
  font-size: 30rpx;
  color: #6b7280;
  margin-bottom: 100rpx;
}

/* ── 按钮区 ── */

.ql-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

/* ── 主按钮（微信一键登录） ── */

.ql-btn-wrap {
  width: 100%;
}

.ql-btn-primary {
  position: relative;
  bottom: 40rpx;
  width: 100%;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1aad19;
  border-radius: 112rpx;
  border: none;
  padding: 0;
  margin: 0;
  gap: 12rpx;
}

.ql-btn-primary::after {
  border: none;
  display: none;
}

.ql-btn-primary:active {
  background: #189b17;
  transform: scale(0.98);
}

.ql-btn-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.ql-btn-text {
  font-size: 38rpx;
  font-weight: 500;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* ── 协议勾选 ── */

.ql-agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  position: relative;
  bottom: 40rpx;
  margin-top: 32rpx;
  line-height: 40rpx;
}

.ql-agree-check {
  padding: 4rpx;
}

.ql-checkbox {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ql-checkbox.ql-checked {
  background: #1aad19;
  border-color: #1aad19;
}

.ql-checkmark {
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
}

.ql-agree-text {
  font-size: 24rpx;
  color: #9ca3af;
}

.ql-agree-link {
  font-size: 24rpx;
  color: #576b95;
}

/* ── 底部：其他方式登录 ── */

.ql-footer {
  position: relative;
  bottom: 100rpx;
  padding-bottom: 60rpx;
  padding-left: 64rpx;
  padding-right: 64rpx;
}

.ql-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 34rpx;
}

.ql-divider-line {
  width: 128rpx;
  height: 2rpx;
  background: #e5e7eb;
}

.ql-divider-text {
  padding: 0 32rpx;
  font-size: 26rpx;
  color: #9ca3af;
  letter-spacing: 2rpx;
  white-space: nowrap;
}

.ql-other-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.ql-other-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #e5e7eb;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.ql-other-icon-emoji {
  font-size: 36rpx;
}

.ql-other-label {
  font-size: 24rpx;
  color: #9ca3af;
}
