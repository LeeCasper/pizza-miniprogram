/* components/quick-login/quick-login.wxss — Stitch 设计稿 1:1 还原 */

/* ── 根容器（全屏覆盖） ── */

.ql-root {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background-color: #FDF8F2;
}

.ql-page {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #FDF8F2;
  opacity: 0;
  transform: scale(0.95);
  transition: opacity 0.3s, transform 0.3s;
}

.ql-page.ql-show {
  opacity: 1;
  transform: scale(1);
}

/* ── 关闭按钮 ── */

.ql-close {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 10;
  padding-right: 32rpx;
  padding-bottom: 16rpx;
}

.ql-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ql-close-icon {
  font-size: 46rpx;
  color: #454545;
}

/* ── Body（可滚动主区域，填满剩余空间） ── */

.ql-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 0 48rpx;
  overflow-y: auto;
}

.ql-main {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── Logo ── */

.ql-logo-wrap {
  margin-bottom: 48rpx;
}

.ql-logo-img {
  width: 256rpx;
  height: 256rpx;
  border-radius: 50%;
  border: 8rpx solid #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  background: #ffffff;
}

/* ── 欢迎文字 ── */

.ql-heading {
  font-size: 56rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.ql-subtitle {
  font-size: 30rpx;
  color: #9ca3af;
  margin-bottom: 56rpx;
}

/* ══════════════════════════════════════════
   信息卡片区（Stitch 设计稿 1:1 还原）
   ══════════════════════════════════════════ */

.ql-cards {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  margin-bottom: 64rpx;
}

/* ── 卡片容器 ── */

.ql-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

/* ── 卡片行（标题行：左侧 icon+文字，右侧操作区） ── */

.ql-card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 36rpx;
}

/* ── 左侧：icon + 文字 ── */

.ql-card-info {
  display: flex;
  align-items: center;
  gap: 28rpx;
  overflow: hidden;
  flex: 1;
  min-width: 0;
}

.ql-card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFF5EB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ql-card-icon-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.ql-card-text {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-width: 0;
}

.ql-card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
  white-space: nowrap;
  line-height: 1.3;
}

.ql-card-desc {
  font-size: 26rpx;
  color: #9ca3af;
  white-space: nowrap;
  line-height: 1.4;
}

/* ── 右侧：操作区 ── */

.ql-card-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  position: relative;
}

.ql-card-chevron {
  font-size: 48rpx;
  color: #d1d5db;
  line-height: 1;
  font-weight: 300;
}

.ql-card-chevron-sm {
  font-size: 36rpx;
  color: #9ca3af;
}

/* ── 头像预览圆圈 ── */

.ql-avatar-pick {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: visible;
  border: 2rpx solid #f3f4f6;
  background: #ffffff;
  padding: 0;
  margin: 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ql-avatar-pick::after {
  border: none;
  display: none;
}

.ql-avatar-preview-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.ql-avatar-empty-circle {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f9fafb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ql-avatar-empty-emoji {
  font-size: 52rpx;
  opacity: 0.35;
}

/* ── 头像相机角标 ── */

.ql-avatar-camera-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5a623;
  border: 4rpx solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.ql-avatar-camera-badge-icon {
  font-size: 24rpx;
  line-height: 1;
}

/* ── 卡片底部按钮（更换头像） ── */

.ql-card-btn {
  width: 100%;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #f9fafb;
  border-radius: 72rpx;
  border: none;
  padding: 0;
  margin: 0;
  font-size: 28rpx;
  color: #4b5563;
}

.ql-card-btn::after {
  border: none;
  display: none;
}

.ql-card-btn:active {
  background: #f3f4f6;
}

.ql-card-btn-icon {
  font-size: 32rpx;
  line-height: 1;
}

.ql-card-btn-text {
  font-size: 28rpx;
  color: #4b5563;
}

/* ── 昵称 chip 按钮 ── */

.ql-nickname-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(0, 0, 0, 0.04);
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
}

.ql-nickname-chip:active {
  background: rgba(0, 0, 0, 0.08);
}

.ql-nickname-chip-text {
  font-size: 28rpx;
  color: #4b5563;
  font-weight: 500;
  white-space: nowrap;
}

/* ── 昵称输入框（编辑态，内联显示） ── */

.ql-nickname-input-inline {
  width: 220rpx;
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #4b5563;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 16rpx;
  border: 2rpx solid #e5e7eb;
  text-align: center;
}

/* ── 卡片底部提示文字 ── */

.ql-card-hint {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.ql-card-hint-text {
  font-size: 22rpx;
  color: #9ca3af;
  white-space: nowrap;
}

/* ── 按钮区 ── */

.ql-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

/* ── 主按钮（微信一键登录） ── */

.ql-btn-primary {
  width: 100%;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07C160;
  border-radius: 24rpx;
  border: none;
  padding: 0;
  margin: 0;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.18);
}

.ql-btn-primary::after {
  border: none;
  display: none;
}

.ql-btn-primary:active {
  background: #06ad56;
  transform: scale(0.98);
}

.ql-btn-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.ql-btn-text {
  font-size: 36rpx;
  font-weight: 500;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* ── 协议勾选 ── */

.ql-agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 32rpx;
  line-height: 40rpx;
}

.ql-agree-check {
  padding: 4rpx;
}

.ql-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ql-checkbox.ql-checked {
  background: #07C160;
  border-color: #07C160;
}

.ql-checkmark {
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
}

.ql-agree-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.ql-agree-link {
  font-size: 26rpx;
  color: #576b95;
}
