<!-- components/quick-login/quick-login.wxml — 微信快捷登录（Stitch 设计稿 1:1 还原） -->
<view class="ql-root" wx:if="{{visible}}" catchtouchmove="noop">
  <view class="ql-page {{animating ? 'ql-show' : ''}}">

    <!-- 关闭按钮 -->
    <view class="ql-close" style="padding-top: {{statusBarHeight + 1}}px">
      <view class="ql-close-btn" bindtap="onSkip">
        <text class="ql-close-icon">✕</text>
      </view>
    </view>

    <!-- 微信一键登录 -->
    <view class="ql-body">
      <view class="ql-main">
        <!-- 微信 Logo -->
        <view class="ql-logo-wrap">
          <image class="ql-logo-img" src="/images/wechat-logo.jpg" mode="aspectFit"></image>
        </view>

        <!-- 欢迎文字 -->
        <text class="ql-heading">欢迎使用</text>
        <text class="ql-subtitle">微信一键登录，更快更安全</text>

        <!-- 信息卡片区（头像 + 昵称）—— Stitch 设计稿 1:1 还原 -->
        <view class="ql-cards">

          <!-- 头像卡片 -->
          <view class="ql-card">
            <view class="ql-card-row">
              <view class="ql-card-info">
                <view class="ql-card-icon-wrap">
                  <image class="ql-card-icon-img" src="/images/icon-avatar.png" mode="aspectFit"></image>
                </view>
                <view class="ql-card-text">
                  <text class="ql-card-title">头像</text>
                  <text class="ql-card-desc">设置头像，让朋友更容易认识你</text>
                </view>
              </view>
              <view class="ql-card-right">
                <button class="ql-avatar-pick" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
                  <image wx:if="{{avatarUrl}}" class="ql-avatar-preview-img" src="{{avatarUrl}}" mode="aspectFill"></image>
                  <view wx:else class="ql-avatar-empty-circle">
                    <text class="ql-avatar-empty-emoji">👤</text>
                  </view>
                  <view class="ql-avatar-camera-badge">
                    <image class="ql-avatar-camera-badge-icon" src="/images/camera-badge.png" mode="aspectFit"></image>
                  </view>
                </button>
                <text class="ql-card-chevron">›</text>
              </view>
            </view>
            <!-- 更换头像按钮 -->
            <button class="ql-card-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
              <image class="ql-card-btn-icon-img" src="/images/icon-camera.png" mode="aspectFit"></image>
              <text class="ql-card-btn-text">更换头像</text>
            </button>
          </view>

          <!-- 昵称卡片 -->
          <view class="ql-card">
            <view class="ql-card-row">
              <view class="ql-card-info">
                <view class="ql-card-icon-wrap">
                  <image class="ql-card-icon-img" src="/images/icon-nickname.png" mode="aspectFit"></image>
                </view>
                <view class="ql-card-text">
                  <text class="ql-card-title">昵称</text>
                  <text class="ql-card-desc">设置昵称，展示个性自我</text>
                </view>
              </view>
              <view class="ql-card-right">
                <!-- 昵称输入（编辑态） -->
                <view class="ql-nickname-chip" wx:if="{{!nicknameEditing}}" bindtap="onNicknameTap">
                  <text class="ql-nickname-chip-text">{{nickname || '微信昵称'}}</text>
                  <text class="ql-card-chevron ql-card-chevron-sm">›</text>
                </view>
                <!-- 昵称输入框（编辑态） -->
                <input wx:else class="ql-nickname-input-inline" type="nickname"
                       placeholder="微信昵称" value="{{nickname}}"
                       bindinput="onNicknameInput" bindblur="onNicknameBlur"
                       maxlength="30" focus="{{nicknameEditing}}"></input>
              </view>
            </view>
            <view class="ql-card-hint">
              <text class="ql-card-hint-text">自动获取微信昵称，可点击修改</text>
            </view>
          </view>

        </view>

        <!-- 登录按钮组 -->
        <view class="ql-actions">
          <!-- 微信一键登录按钮（原生 getPhoneNumber） -->
          <button class="ql-btn-primary" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber" style="margin:0;padding:0;width:100%;display:flex;align-items:center;justify-content:center;">
            <image class="ql-btn-icon-img" src="/images/wechat-icon.png" mode="aspectFit"></image>
            <text class="ql-btn-text">微信一键登录</text>
          </button>

          <!-- 协议勾选 -->
          <view class="ql-agreement">
            <view class="ql-agree-check" bindtap="onToggleAgree">
              <view class="ql-checkbox {{agreed ? 'ql-checked' : ''}}">
                <text class="ql-checkmark" wx:if="{{agreed}}">✓</text>
              </view>
            </view>
            <text class="ql-agree-text">已阅读并同意</text>
            <text class="ql-agree-link" catchtap="onShowTerms">《用户协议》</text>
            <text class="ql-agree-text">和</text>
            <text class="ql-agree-link" catchtap="onShowPrivacy">《隐私政策》</text>
          </view>
        </view>
      </view>
    </view>

  </view>
</view>
