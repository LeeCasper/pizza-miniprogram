<!-- custom-tab-bar -->
<view class="tab-bar" style="{{tabBarBg}}">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-bar-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <image
      class="tab-icon-img"
      src="{{item.icon}}"
    />
    <text class="tab-label">{{item.text}}</text>
  </view>
</view>
