/* === 设计系统 Design Tokens — Candy Glass ===
   四色糖果配色 + 超强毛玻璃：紫/黄/绿/青
   彩色渐变底层让玻璃效果一眼可见 */
page {
  /* ── 主色 - 糖果紫 Candy Purple ── */
  --color-primary: #C583FF;
  --color-price: #C583FF;
  --color-primary-dark: #9B4DDB;
  --color-primary-light: #E8D0FF;
  --color-on-primary: #FFFFFF;
  --color-primary-container: #F0E0FF;
  --color-on-primary-container: #6A1B9A;

  /* ── 辅色 - 柠檬黄 Lemon Yellow ── */
  --color-secondary: #FFF292;
  --color-secondary-dark: #C6A700;
  --color-secondary-container: #FFF8C4;
  --color-on-secondary: #3E2D00;
  --color-on-secondary-container: #5D4300;

  /* ── 第三色 - 薄荷绿 Mint Green ── */
  --color-tertiary: #A0FF92;
  --color-tertiary-container: #C8FFB8;
  --color-on-tertiary: #1B5E20;

  /* ── 表面/背景色 - 淡薰衣草 Soft Lavender ── */
  --color-background: #F5F0FF;
  --color-surface: #F5F0FF;
  --color-surface-container: #EDE6F7;
  --color-surface-container-low: #F3EDF9;
  --color-surface-container-lowest: #FFFFFF;
  --color-surface-container-high: #E5DDF0;
  --color-surface-container-highest: #DDD5E8;
  --color-surface-dim: #D5CCE0;
  --color-surface-bright: #F8F4FF;

  /* ── 文字色 - 冷深色 ── */
  --color-on-background: #1A1B2E;
  --color-on-surface: #1A1B2E;
  --color-on-surface-variant: #5B4D6E;

  /* ── 描边 - 薰衣草灰调 ── */
  --color-outline: #9B8EC4;
  --color-outline-variant: #D4C8E8;
  --color-divider: #E5DDF0;

  /* ── 错误（语义色，不随品牌变） ── */
  --color-error: #D32F2F;
  --color-error-container: #FFDAD6;

  /* ── 阴影 - 紫调层次系统 ──
     阴影掺入微量 Primary Purple
     L1 卡片 / L2 按钮 / L3 模态 */
  --shadow-xs: 0 1rpx 4rpx rgba(197, 131, 255, 0.05);
  --shadow-sm: 0 2rpx 8rpx rgba(197, 131, 255, 0.07);
  --shadow-card: 0 4rpx 20rpx rgba(197, 131, 255, 0.10);
  --shadow-button: 0 8rpx 24rpx rgba(197, 131, 255, 0.18);
  --shadow-elevated: 0 8rpx 28rpx rgba(197, 131, 255, 0.10);
  --shadow-modal: 0 12rpx 40rpx rgba(100, 50, 150, 0.12);
  --shadow-primary: 0 4rpx 16rpx rgba(197, 131, 255, 0.25);

  /* ── 圆角 - 8px 基准 (16rpx) ── */
  --radius-card: 24rpx;
  --radius-lg: 32rpx;
  --radius-full: 9999rpx;
  --radius-sm: 16rpx;

  /* ── 间距 - 8px 软基准 ── */
  --spacing-xs: 8rpx;
  --spacing-sm: 24rpx;
  --spacing-md: 32rpx;
  --spacing-lg: 48rpx;
  --spacing-xl: 80rpx;
  --spacing-container: 40rpx;

  /* ── 字体 ── */
  --font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  --font-size-display: 48rpx;
  --font-size-headline: 32rpx;
  --font-size-headline-mobile: 28rpx;
  --font-size-body-lg: 18rpx;
  --font-size-body: 16rpx;
  --font-size-body-sm: 14rpx;
  --font-size-label: 12rpx;

  --font-weight-bold: 700;
  --font-weight-semibold: 600;
  --font-weight-medium: 500;
  --font-weight-regular: 400;

  /* ── 毛玻璃 Glassmorphism Tokens ──
     大幅降低不透明度 + 加强 blur + 白色发光边框
     彩色渐变底层让磨砂效果一眼可见 */
  --glass-bg-card: rgba(255, 255, 255, 0.50);
  --glass-bg-elevated: rgba(255, 255, 255, 0.62);
  --glass-bg-light: rgba(255, 255, 255, 0.30);
  --glass-bg-nav: rgba(245, 240, 255, 0.60);
  --glass-bg-primary: rgba(197, 131, 255, 0.82);
  --glass-bg-primary-light: rgba(197, 131, 255, 0.10);
  --glass-bg-primary-container: rgba(240, 224, 255, 0.65);
  --glass-bg-dark: rgba(26, 27, 46, 0.82);
  --glass-bg-overlay: rgba(0, 0, 0, 0.40);

  --glass-blur-sm: saturate(200%) blur(16px);
  --glass-blur: saturate(200%) blur(28px);
  --glass-blur-lg: saturate(200%) blur(40px);

  --glass-border: 2rpx solid rgba(255, 255, 255, 0.55);
  --glass-border-subtle: 1rpx solid rgba(255, 255, 255, 0.30);
  --glass-border-colored: 2rpx solid rgba(197, 131, 255, 0.25);
  --glass-border-dark: 1rpx solid rgba(255, 255, 255, 0.12);

  --glass-shadow-card: 0 4rpx 20rpx rgba(197, 131, 255, 0.08);
  --glass-shadow-elevated: 0 6rpx 28rpx rgba(197, 131, 255, 0.12);
  --glass-shadow-button: 0 6rpx 20rpx rgba(197, 131, 255, 0.22);

  /* ── 渐变色变量 ── */
  --gradient-1: #E8D4FF;
  --gradient-2: #D0FFCE;
  --gradient-3: #FFF4B0;
  --gradient-4: #C0F2FF;
}

/* === 全局基础样式 === */
page, view, text, image, scroll-view, swiper, swiper-item, navigator, button, input, textarea, form {
  box-sizing: border-box;
}

page {
  height: 100vh;
  background-color: #F0EAFF;
  /* page 自身渐变中和：彩色渐变改由 .app-root / .page-container（带 themeStyle 主题变量）绘制。
     page 是祖先元素，读不到子元素内联的 --gradient-* 覆盖值，会永远停留在硬编码彩色渐变，
     并从半透明导航栏（top-bar/tab-bar）背后漏出 —— 这正是「导航栏不跟随背景色」的根因。 */
  background-image: none;
  color: var(--color-on-background);
  font-family: var(--font-family);
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

scroll-view {
  will-change: scroll-position;
}

swiper, swiper-item {
  background: transparent;
}

/* 主内容滚动区域 — 四色糖果渐变背景（scroll-view 合成层需单独设置） */
.tab-scroll,
.orders-scroll,
.shop-scroll,
.member-scroll,
.main-scroll {
  background-image: linear-gradient(135deg, var(--gradient-1) 0%, var(--gradient-2) 25%, var(--gradient-3) 50%, var(--gradient-4) 75%, var(--gradient-1) 100%);
}

/* 全屏根容器 — 主题渐变权威层。
   themeStyle（含后台覆盖的 --gradient-1~4）内联在 .app-root 上，故此处读到的是主题值（如白色），
   而非 page 上的硬编码默认值。100vh 全覆盖盖住 page，半透明导航栏 backdrop 采样到的就是这层主题渐变。 */
.app-root {
  min-height: 100vh;
  background-image: linear-gradient(135deg, var(--gradient-1) 0%, var(--gradient-2) 25%, var(--gradient-3) 50%, var(--gradient-4) 75%, var(--gradient-1) 100%);
}

/* === 通用工具类 === */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-on-surface-variant); }
.text-center { text-align: center; }
.font-bold { font-weight: var(--font-weight-bold); }
.font-semibold { font-weight: var(--font-weight-semibold); }

/* 卡片基础样式 — 毛玻璃 */
.card {
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
}

.card-cream {
  background: var(--glass-bg-light);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
}

/* 按钮样式 */
.btn-primary {
  background: var(--glass-bg-primary);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  color: var(--color-on-primary);
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-bold);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-primary);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.2s;
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-outline {
  background: var(--glass-bg-light);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border-radius: var(--radius-card);
  color: var(--color-on-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border);
  transition: all 0.2s;
}

.btn-outline:active {
  background: var(--color-surface-container-low);
  transform: scale(0.97);
}

/* 节标题 */
.section-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-background);
}

/* 页面容器 — flexbox 布局，scroll-view 自动填充剩余空间 */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-image: linear-gradient(
    135deg,
    var(--gradient-1) 0%,
    var(--gradient-2) 25%,
    var(--gradient-3) 50%,
    var(--gradient-4) 75%,
    var(--gradient-1) 100%
  );
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
