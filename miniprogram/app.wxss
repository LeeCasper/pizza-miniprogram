/* === 设计系统 Design Tokens — Candy Glass ===
   四色糖果配色 + 超强毛玻璃：紫/黄/绿/青
   彩色渐变底层让玻璃效果一眼可见 */
page {
  /* ── 主色 - 暖陶土 Warm Terracotta ── */
  --color-primary: #C0563A;
  --color-price: #C0392B;
  --color-primary-dark: #9E4329;
  --color-primary-light: #E0B8A8;
  --color-on-primary: #FFFFFF;
  --color-primary-container: #F5E2D8;
  --color-on-primary-container: #7A3220;

  /* ── 辅色 - 柠檬黄 Lemon Yellow ── */
  --color-secondary: #FFF292;
  --color-secondary-dark: #C6A700;
  --color-secondary-container: #FFF8C4;
  --color-on-secondary: #3E2D00;
  --color-on-secondary-container: #5D4300;

  /* ── 第三色 - 薄荷绿 Mint Green ── */
  --color-tertiary: #A0FF92;
  --color-tertiary-container: #C8FFB8;
  --color-on-tertiary: #1B5E20;

  /* ── 表面/背景色 - 暖奶油 Warm Cream ── */
  --color-background: #F7F1E9;
  --color-surface: #F7F1E9;
  --color-surface-container: #F1EADD;
  --color-surface-container-low: #F5EFE4;
  --color-surface-container-lowest: #FFFFFF;
  --color-surface-container-high: #ECE3D5;
  --color-surface-container-highest: #E4DAC9;
  --color-surface-dim: #DDD2BE;
  --color-surface-bright: #FAF6EF;

  /* ── 文字色 - 冷深色 ── */
  --color-on-background: #1A1B2E;
  --color-on-surface: #1A1B2E;
  --color-on-surface-variant: #8A7B66;

  /* ── 描边 - 暖灰调 ── */
  --color-outline: #B0A593;
  --color-outline-variant: #E0D6C6;
  --color-divider: #E8E0D4;

  /* ── 错误（语义色，不随品牌变） ── */
  --color-error: #D32F2F;
  --color-error-container: #FFDAD6;

  /* ── 阴影 - 暖灰层次系统 ──
     阴影掺入微量暖灰（与黏土投影一致）
     L1 卡片 / L2 按钮 / L3 模态 */
  --shadow-xs: 0 1rpx 4rpx rgba(120, 108, 94, 0.06);
  --shadow-sm: 0 2rpx 8rpx rgba(120, 108, 94, 0.08);
  --shadow-card: 0 4rpx 20rpx rgba(120, 108, 94, 0.12);
  --shadow-button: 0 8rpx 24rpx rgba(120, 108, 94, 0.18);
  --shadow-elevated: 0 8rpx 28rpx rgba(120, 108, 94, 0.12);
  --shadow-modal: 0 12rpx 40rpx rgba(60, 50, 40, 0.16);
  --shadow-primary: 0 4rpx 16rpx rgba(120, 108, 94, 0.20);

  /* ── 圆角 - 8px 基准 (16rpx) ── */
  --radius-card: 24rpx;
  --radius-lg: 32rpx;
  --radius-full: 9999rpx;
  --radius-sm: 16rpx;

  /* ── 间距 - 8px 软基准 ── */
  --spacing-xs: 8rpx;
  --spacing-sm: 24rpx;
  --spacing-md: 32rpx;
  --spacing-lg: 48rpx;
  --spacing-xl: 80rpx;
  --spacing-container: 40rpx;

  /* ── 字体 ── */
  --font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  --font-size-display: 48rpx;
  --font-size-headline: 32rpx;
  --font-size-headline-mobile: 28rpx;
  --font-size-body-lg: 18rpx;
  --font-size-body: 16rpx;
  --font-size-body-sm: 14rpx;
  --font-size-label: 12rpx;

  --font-weight-bold: 700;
  --font-weight-semibold: 600;
  --font-weight-medium: 500;
  --font-weight-regular: 400;

  /* ── 玻璃 Tokens（静态「假玻璃」，无 backdrop-filter）──
     去实时模糊：App 切回前台时 WeChat 会把 backdrop-filter 层 tear-down→重栅格化→闪一帧。
     改为：不透明底 + 表面微渐变光泽 + 顶缘内高光(inset) + 浮起投影 —— 静态绘制立体感，
     既不闪又保玻璃质感。--glass-blur* 保留为 none 以中和全部 backdrop-filter 引用。
     例外：--glass-bg-overlay 是弹层蒙层，必须保持半透明（改不透明会盖黑弹层背后整屏）。 */
  --glass-bg-card: linear-gradient(160deg, #FFFFFF 0%, #F4F0E9 100%);
  --glass-bg-elevated: linear-gradient(160deg, #FFFFFF 0%, #F8F4EC 100%);
  --glass-bg-light: #F1ECE3;
  --glass-bg-nav: #F3ECE0;
  --glass-bg-primary: linear-gradient(160deg, #C0563A 0%, #A8492F 100%);
  --glass-bg-primary-light: #F7E9E2;
  --glass-bg-primary-container: #F5E2D8;
  --glass-bg-dark: #1F2138;
  --glass-bg-overlay: rgba(0, 0, 0, 0.40);

  /* --glass-blur* 已无引用：所有元素的 backdrop-filter 声明均已物理删除。
     关键教训：仅把值改 none 不够——WeChat 只要元素「声明了」backdrop-filter（哪怕解析成 none），
     就把它留在切回前台会被 tear-down→重栅格化的合成层上，照样闪一帧。必须删掉声明本身。
     这三个 token 保留为 none 仅作未来防御（万一有新代码再引用 var(--glass-blur*) 时不致出现模糊）。 */
  --glass-blur-sm: none;
  --glass-blur: none;
  --glass-blur-lg: none;

  --glass-border: 2rpx solid rgba(255, 255, 255, 0.55);
  --glass-border-subtle: 1rpx solid rgba(255, 255, 255, 0.30);
  --glass-border-colored: 2rpx solid rgba(120, 108, 94, 0.22);
  --glass-border-dark: 1rpx solid rgba(255, 255, 255, 0.12);

  /* inset 顶缘亮线 = 接光高光（静态，不重栅格化）；叠暖灰外投影 = 浮起立体感 */
  --glass-shadow-card: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 4rpx 20rpx rgba(120, 108, 94, 0.12);
  --glass-shadow-elevated: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 6rpx 28rpx rgba(120, 108, 94, 0.14);
  --glass-shadow-button: inset 0 1rpx 0 rgba(255, 255, 255, 0.35), 0 6rpx 20rpx rgba(120, 108, 94, 0.20);

  /* ── 黏土风 Tokens (Clay Style) ──
     暖色凸面质感 · 无 backdrop-filter · 暖棕投影 + 顶缘内高光
     用 Warm Terracotta / Warm Cream 色板，模拟黏土手工质感。
     会员商城专属（shop / shop-detail / shop-orders / shop-order-detail）。 */
  --clay-bg-nav: #FEFCF8;
  --clay-bg-card: #FDFBF7;
  --clay-bg-elevated: #F8F3EA;
  --clay-bg-light: #F5EFE5;
  --clay-bg-primary: linear-gradient(180deg, #D4846B 0%, #C0563A 100%);
  --clay-bg-primary-solid: #C0563A;
  --clay-bg-primary-light: #FDF0EB;
  --clay-bg-primary-container: #F5E2D8;

  --clay-border: 2rpx solid rgba(180, 160, 140, 0.28);
  --clay-border-subtle: 2rpx solid rgba(180, 160, 140, 0.18);
  --clay-border-colored: 2rpx solid rgba(192, 86, 58, 0.30);

  /* 黏土阴影：顶缘暖白内高光 + 暖棕外投影 = 凸面立体感 */
  --clay-shadow-card:
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.90),
    0 4rpx 12rpx rgba(120, 108, 94, 0.12),
    0 2rpx 4rpx rgba(120, 108, 94, 0.06);
  --clay-shadow-elevated:
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.85),
    0 8rpx 24rpx rgba(120, 108, 94, 0.16),
    0 2rpx 6rpx rgba(120, 108, 94, 0.08);
  --clay-shadow-button:
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.70),
    0 4rpx 12rpx rgba(192, 86, 58, 0.25),
    0 1rpx 3rpx rgba(120, 108, 94, 0.12);
  --clay-shadow-nav:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.80),
    0 2rpx 16rpx rgba(120, 108, 94, 0.10);

  /* ── 渐变色变量 - 暖奶油 ── */
  --gradient-1: #FBF6EE;
  --gradient-2: #F3ECE0;
  --gradient-3: #F7F1E6;
  --gradient-4: #EFE7D8;
}

/* === 全局基础样式 === */
page, view, text, image, scroll-view, swiper, swiper-item, navigator, button, input, textarea, form {
  box-sizing: border-box;
}

page {
  height: 100vh;
  background-color: #F6F1E9;
  /* page 渐变中和：彩色渐变改由 .app-root / .page-container 绘制（读静态 --gradient-* 暖奶油值）。
     page 是祖先元素，置 background-image:none，避免从固定导航栏背后漏出与内容区不一致的底色。 */
  background-image: none;
  color: var(--color-on-background);
  font-family: var(--font-family);
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

scroll-view {
  will-change: scroll-position;
}

swiper, swiper-item {
  background: transparent;
}

/* 主内容滚动区域 — 四色糖果渐变背景（scroll-view 合成层需单独设置） */
.tab-scroll,
.orders-scroll,
.shop-scroll,
.member-scroll,
.main-scroll {
  background-image: linear-gradient(135deg, var(--gradient-1) 0%, var(--gradient-2) 25%, var(--gradient-3) 50%, var(--gradient-4) 75%, var(--gradient-1) 100%);
}

/* 全屏根容器 — 背景渐变权威层（静态 --gradient-1~4，暖奶油）。
   100vh 全覆盖盖住 page，固定导航栏（不透明暖底）压在其上，整页底色统一。 */
.app-root {
  min-height: 100vh;
  background-image: linear-gradient(135deg, var(--gradient-1) 0%, var(--gradient-2) 25%, var(--gradient-3) 50%, var(--gradient-4) 75%, var(--gradient-1) 100%);
}

/* === 通用工具类 === */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-on-surface-variant); }
.text-center { text-align: center; }
.font-bold { font-weight: var(--font-weight-bold); }
.font-semibold { font-weight: var(--font-weight-semibold); }

/* 卡片基础样式 — 毛玻璃 */
.card {
  background: var(--glass-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
}

.card-cream {
  background: var(--glass-bg-light);
  border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
}

/* 按钮样式 */
.btn-primary {
  background: var(--glass-bg-primary);
  color: var(--color-on-primary);
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-bold);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-primary);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.2s;
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-outline {
  background: var(--glass-bg-light);
  border-radius: var(--radius-card);
  color: var(--color-on-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border);
  transition: all 0.2s;
}

.btn-outline:active {
  background: var(--color-surface-container-low);
  transform: scale(0.97);
}

/* 节标题 */
.section-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-background);
}

/* 页面容器 — flexbox 布局，scroll-view 自动填充剩余空间 */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-image: linear-gradient(
    135deg,
    var(--gradient-1) 0%,
    var(--gradient-2) 25%,
    var(--gradient-3) 50%,
    var(--gradient-4) 75%,
    var(--gradient-1) 100%
  );
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 商城停用标题呼吸动画 */
@keyframes shop-closed-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.96); }
}
