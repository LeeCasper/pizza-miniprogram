/* pages/shop/shop.wxss — 会员商城（黏土风，仿 Stitch 商城首页布局） */

/* ── 顶部导航 ── */
.shop-top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx 24rpx;
  background: var(--clay-bg-nav);
  border-bottom: var(--clay-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(120, 108, 94, 0.10);
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
}
.shop-top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* ── 滚动区 ── */
.shop-scroll { overflow-x: hidden; box-sizing: border-box; }
.shop-scroll-inner { padding: 0 32rpx; }

/* ── 顶部 Hero（促销 Banner，黏土卡） ── */
.shop-hero {
  margin: 24rpx 0 28rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--clay-shadow-elevated);
  border: var(--clay-border-subtle);
}
.shop-hero-swiper { height: 300rpx; }
.shop-hero-slide { width: 100%; height: 100%; position: relative; }
.shop-hero-img { width: 100%; height: 100%; }
.shop-hero-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(40, 28, 20, 0.72) 0%, transparent 100%);
  padding: 48rpx 32rpx 28rpx;
  display: flex; flex-direction: column; gap: 8rpx;
}
.shop-hero-title { font-size: 36rpx; font-weight: var(--font-weight-bold); color: #FFFFFF; }
.shop-hero-sub { font-size: 24rpx; color: rgba(255, 255, 255, 0.85); }

/* ── 分类网格模块（黏土风卡片，独立于精选好物） ── */
.shop-cat-module { margin: 0 0 20rpx; }
.shop-cat-header {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 14rpx;
}
.shop-cat-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.shop-cat-sub { font-size: 24rpx; color: var(--color-on-surface-variant); }
.shop-cat-grid { display: flex; flex-wrap: wrap; margin: 0 -4rpx; }
.shop-cat-card {
  width: calc(20% - 8rpx);
  margin: 0 4rpx 16rpx;
  display: flex; flex-direction: column; align-items: center;
  gap: 8rpx;
  transition: all 0.2s;
  box-sizing: border-box;
}
.shop-cat-card:active { transform: scale(0.95); }
.shop-cat-card.active .shop-cat-card-iconwrap {
  background: var(--clay-bg-primary-light);
}
.shop-cat-card.active .shop-cat-card-name {
  color: var(--color-primary); font-weight: var(--font-weight-bold);
}
.shop-cat-card-iconwrap {
  width: 64rpx; height: 64rpx;
  border-radius: var(--radius-full);
  background: var(--clay-bg-elevated);
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s;
}
.shop-cat-card-img { width: 100%; height: 100%; border-radius: var(--radius-full); }
.shop-cat-card-emoji { font-size: 36rpx; line-height: 1; }
.shop-cat-card-name {
  font-size: 24rpx; font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface); text-align: center;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  max-width: 100%;
}

/* ── 节标题 ── */
.shop-section-header {
  display: flex; align-items: baseline; justify-content: space-between;
  margin: 8rpx 0 20rpx;
}
.shop-section-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.shop-section-count { font-size: 24rpx; color: var(--color-on-surface-variant); }

/* ── 商品网格：2×2 双列 ── */
.shop-grid { display: flex; flex-wrap: wrap; margin: 0 -8rpx; }
.shop-grid-card {
  width: calc(50% - 16rpx);
  margin: 0 8rpx 20rpx;
  background: var(--clay-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--clay-shadow-card);
  border: var(--clay-border-subtle);
  transition: transform 0.2s;
  box-sizing: border-box;
}
.shop-grid-card:active { transform: scale(0.97); }
.shop-grid-imgwrap {
  position: relative; width: 100%; height: 0; padding-bottom: 100%;
  background: var(--color-surface-container-low);
  border-radius: 16rpx; overflow: hidden;
}
.shop-grid-img {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  border-radius: 16rpx;
}
.shop-grid-badge {
  position: absolute; top: 12rpx; left: 12rpx;
  padding: 4rpx 14rpx; border-radius: var(--radius-full);
  background: var(--clay-bg-primary); color: #FFFFFF;
  font-size: 18rpx; font-weight: var(--font-weight-bold); letter-spacing: 2rpx;
  box-shadow: var(--clay-shadow-button);
}
.shop-grid-body { padding: 18rpx 16rpx 16rpx; display: flex; flex-direction: column; gap: 10rpx; }
.shop-grid-name {
  font-size: 26rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.shop-grid-bottom { display: flex; align-items: center; justify-content: space-between; }

/* 价格 */
.shop-price-row { display: flex; align-items: baseline; gap: 6rpx; }
.shop-price-sym { font-size: 22rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }
.shop-price { font-size: 32rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }
.shop-price-sm { font-size: 28rpx; }
.shop-original { font-size: 20rpx; color: var(--color-outline-variant); text-decoration: line-through; margin-left: 4rpx; }

/* 商城收藏按钮 */
.shop-fav-btn { width: 52rpx; height: 52rpx; border-radius: var(--radius-full); background: var(--clay-bg-card); display: flex; align-items: center; justify-content: center; box-shadow: var(--clay-shadow-card); border: var(--clay-border-subtle); flex-shrink: 0; transition: all 0.2s; }
.shop-fav-btn:active { transform: scale(0.9); }
.shop-fav-btn.active { background: var(--clay-bg-primary-light); border: var(--clay-border-colored); }
.shop-fav-icon { font-size: 30rpx; line-height: 1; color: var(--color-on-surface-variant); }
.shop-fav-btn.active .shop-fav-icon { color: var(--color-primary); }

/* ── 列表末尾 ── */
.shop-list-end { display: flex; justify-content: center; padding: 36rpx 0 8rpx; }
.shop-list-end-text { font-size: 24rpx; color: var(--color-on-surface-variant); opacity: 0.7; }

/* ── 空状态 ── */
.shop-empty {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 8rpx;
}
.shop-empty-img { width: 600rpx; display: block; margin-bottom: 0; }
.shop-empty-text { font-size: 36rpx; color: var(--color-on-surface-variant); line-height: 1; margin-top: 0; margin-bottom: 12rpx; text-align: center; }
.shop-empty-sub { font-size: 28rpx; color: var(--color-on-surface-variant); opacity: 0.7; line-height: 1; margin-top: 0; text-align: center; }
