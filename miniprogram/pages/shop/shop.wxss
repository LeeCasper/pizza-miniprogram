/* pages/shop/shop.wxss — 会员商城 */

/* ── 顶部导航 ── */
.shop-top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx 24rpx;
  background: var(--glass-bg-nav);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  border-bottom: var(--glass-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
}
.shop-top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* ── 滚动区 ── */
.shop-scroll { overflow-x: hidden; box-sizing: border-box; }
.shop-scroll-inner { padding: 0 32rpx; }

/* ── Banner 轮播 ── */
.shop-banner-section {
  margin: 24rpx 0;
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.shop-banner-swiper { height: 320rpx; border-radius: var(--radius-card); }
.shop-banner-slide { width: 100%; height: 100%; position: relative; }
.shop-banner-img { width: 100%; height: 100%; }
.shop-banner-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
  padding: 40rpx 32rpx 24rpx;
  display: flex; flex-direction: column; gap: 8rpx;
}
.shop-banner-title {
  font-size: 36rpx; font-weight: var(--font-weight-bold); color: #FFFFFF;
}
.shop-banner-sub {
  font-size: 24rpx; color: rgba(255,255,255,0.8);
}

/* ── 分类导航 ── */
.shop-categories {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  padding: 24rpx 0 8rpx;
}
.shop-cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 16rpx;
  width: 20%;
  margin-bottom: 20rpx;
}
.shop-cat-icon-wrap {
  width: 96rpx; height: 96rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--glass-shadow-elevated);
  border: var(--glass-border-subtle);
  transition: all 0.3s;
}
.shop-cat-icon-wrap.cat-active {
  background: var(--glass-bg-primary-light);
  border: var(--glass-border-colored);
  box-shadow: 0 2rpx 8rpx rgba(197,131,255,0.15);
}
.shop-cat-icon { font-size: 48rpx; line-height: 1; }
.shop-cat-name { font-size: 22rpx; color: var(--color-on-surface); font-weight: 500; }
.shop-cat-icon-wrap.cat-active + .shop-cat-name { color: var(--color-primary); font-weight: 700; }

/* ── 限时优惠横条 ── */
.shop-flash-bar {
  display: flex; align-items: center; justify-content: space-between;
  margin: 16rpx 0 24rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(240,224,255,0.4) 0%, rgba(197,131,255,0.15) 100%);
  border-radius: var(--radius-card);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: 2rpx solid var(--glass-border-colored);
}
.flash-bar-left { display: flex; align-items: center; gap: 12rpx; flex: 1; min-width: 0; }
.flash-icon { font-size: 36rpx; }
.flash-title { font-size: 28rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); flex-shrink: 0; }
.flash-desc { font-size: 24rpx; color: var(--color-on-surface-variant); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.flash-bar-btn {
  padding: 14rpx 36rpx;
  background: var(--glass-bg-primary);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  color: var(--color-on-primary);
  border-radius: var(--radius-full);
  font-size: 26rpx; font-weight: var(--font-weight-bold);
  box-shadow: var(--glass-shadow-button);
  flex-shrink: 0; margin-left: 16rpx;
}
.flash-bar-btn:active { transform: scale(0.95); opacity: 0.9; }

/* ── 商品区域 ── */
.shop-products-section { padding-top: 8rpx; }
.shop-section-header {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 24rpx;
}
.shop-section-title {
  font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface);
}
.shop-section-count {
  font-size: 24rpx; color: var(--color-on-surface-variant);
}

/* ── 商品网格 (2列) ── */
.shop-product-grid {
  display: flex; flex-wrap: wrap;
  gap: 20rpx;
}
.shop-product-card {
  width: calc(50% - 10rpx);
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
  transition: transform 0.2s;
}
.shop-product-card:active { transform: scale(0.97); }
.shop-product-img {
  width: 100%; height: 280rpx;
  background: var(--color-surface-container-low);
}
.shop-product-info {
  padding: 20rpx 20rpx 24rpx;
  display: flex; flex-direction: column;
}
.shop-product-name {
  font-size: 28rpx; font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  margin-bottom: 8rpx;
}
.shop-product-desc {
  font-size: 22rpx; color: var(--color-on-surface-variant);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  margin-bottom: 16rpx;
}
.shop-product-bottom {
  display: flex; align-items: center; justify-content: space-between;
}
.shop-product-price-row {
  display: flex; align-items: baseline; gap: 8rpx;
}
.shop-product-price {
  font-size: 30rpx; font-weight: var(--font-weight-bold); color: var(--color-price);
}
.shop-product-original {
  font-size: 20rpx; color: var(--color-outline-variant); text-decoration: line-through;
}

/* 加购按钮 */
.shop-add-btn {
  width: 56rpx; height: 56rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-primary-light);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--glass-shadow-elevated);
  border: var(--glass-border-colored);
  flex-shrink: 0;
  transition: all 0.2s;
}
.shop-add-btn:active { transform: scale(0.9); }
.shop-add-icon {
  font-size: 36rpx; color: var(--color-primary); font-weight: 400; line-height: 1;
}
.shop-add-btn.has-qty {
  width: auto; padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-card);
  border: var(--glass-border-subtle);
}

.shop-mini-stepper {
  display: flex; align-items: center; gap: 12rpx;
}
.shop-mini-btn {
  width: 44rpx; height: 44rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-elevated);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-on-surface);
  border: var(--glass-border-subtle);
}
.shop-mini-btn:active { transform: scale(0.9); }
.shop-mini-plus {
  background: var(--glass-bg-primary-light);
  border: var(--glass-border-colored);
  color: var(--color-primary);
}
.shop-mini-qty {
  font-size: 26rpx; font-weight: var(--font-weight-bold);
  min-width: 32rpx; text-align: center;
}

/* ── 空状态 ── */
.shop-empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding-top: 160rpx;
}
.shop-empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.shop-empty-text { font-size: 32rpx; color: var(--color-on-surface-variant); margin-bottom: 12rpx; }
.shop-empty-sub { font-size: 26rpx; color: var(--color-on-surface-variant); opacity: 0.7; }
