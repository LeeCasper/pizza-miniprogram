/* pages/settings/settings.wxss */

.page-container { padding-bottom: 0; }

/* ======= 顶部导航 ======= */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 24rpx;
  background: var(--glass-bg-nav);
  border-bottom: var(--glass-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}
.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-primary);
}
.back-icon { width: 40rpx; height: 40rpx; }
.top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}
.top-spacer { width: 80rpx; }

.main-scroll { overflow-x: hidden; box-sizing: border-box; }
.scroll-inner { padding: 28rpx 40rpx 80rpx; }

/* ======= 设置分组卡片 ======= */
.settings-group {
  margin-bottom: 24rpx;
  overflow: hidden;
}

.settings-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  min-height: 96rpx;
}
.settings-item:active {
  background: rgba(0, 0, 0, 0.04);
}

.settings-item-icon {
  width: 40rpx; height: 40rpx;
  flex-shrink: 0;
}

.settings-item-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-on-surface);
  font-weight: var(--font-weight-medium);
}

.settings-item-arrow {
  font-size: 32rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.4;
  flex-shrink: 0;
}

.settings-item-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.settings-item-hint {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.55;
}

/* 开关行 */
.switch-item:active {
  background: none;
}

/* 客服按钮：透明覆盖层（避免 <button> 破坏布局） */
.contact-btn-wrap { position: relative; }
.contact-btn-cover { position: absolute; top: 0; left: 0; right: 0; bottom: 0; opacity: 0; z-index: 1; padding: 0; margin: 0; }
.contact-btn-cover::after { display: none; border: none; }

/* 设置页按钮行 */
.settings-item-btn {
  width: 100%;
}
.settings-item-btn:active {
  background: rgba(0, 0, 0, 0.04);
}

/* 分隔线 */
.settings-divider {
  height: 1rpx;
  background: var(--color-divider);
  opacity: 1;
  margin-left: 88rpx;
}

/* ======= 退出登录 ======= */
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  margin-top: 48rpx;
  font-size: 30rpx;
  color: var(--color-error);
  font-weight: var(--font-weight-semibold);
}
.logout-btn:active {
  opacity: 0.6;
}

/* ======= 底部抽屉覆盖层 ======= */
.drawer-overlay {
  position: fixed;
  inset: 0;
  z-index: 1100;
  visibility: hidden;
}
.drawer-overlay.show { visibility: visible; }
.drawer-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--glass-bg-overlay);
  opacity: 0;
  transition: opacity 0.3s;
}
.drawer-overlay.show::before { opacity: 1; }

.drawer-drawer {
  position: absolute;
  left: 0;
  right: 0;
  top: 190rpx;
  bottom: 0;
  background: var(--glass-bg-elevated);
  border-radius: 48rpx 48rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: var(--shadow-modal);
  border-top: var(--glass-border);
  overflow: hidden;
}
.drawer-drawer.show { transform: translateY(0); }

/* 抽屉导航栏 */
.drawer-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx 20rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}
.drawer-nav-back {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  padding: 12rpx 0;
}
.drawer-nav-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.drawer-nav-spacer { width: 80rpx; }

/* 抽屉内容区 */
.drawer-body {
  flex: 1;
  height: 0;
  min-height: 0;
  padding: 28rpx 40rpx 0;
}

.drawer-section {
  padding-bottom: 24rpx;
}

/* ======= 账号安全 ======= */
.account-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: var(--glass-bg-card);
  border-radius: var(--radius-sm);
  border: var(--glass-border-subtle);
  margin-bottom: 12rpx;
}
.account-label {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
}
.account-value {
  font-size: 30rpx;
  color: var(--color-on-surface);
  font-weight: var(--font-weight-bold);
  letter-spacing: 2rpx;
}
.account-hint {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.5;
  padding-left: 8rpx;
  margin-bottom: 32rpx;
}

/* 账号安全 — 编辑手机号 */
.input-field {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  background: var(--glass-bg-card);
  border-radius: var(--radius-sm);
  border: var(--glass-border-subtle);
  margin-bottom: 24rpx;
}
.field-label {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
}
.field-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-on-surface);
  text-align: right;
}
.field-placeholder {
  color: var(--color-on-surface-variant);
  opacity: 0.5;
}

.drawer-form-btns {
  display: flex;
  gap: 20rpx;
}

/* 抽屉通用按钮 */
.drawer-btn-primary {
  flex: 1;
  padding: 28rpx 32rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-primary);
  box-shadow: var(--glass-shadow-button);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: var(--color-on-primary);
  font-size: 30rpx;
  font-weight: var(--font-weight-bold);
  text-align: center;
}
.drawer-btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.drawer-btn-outline {
  flex-shrink: 0;
  padding: 28rpx 36rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-light);
  border: var(--glass-border-subtle);
  color: var(--color-on-surface-variant);
  font-size: 28rpx;
  font-weight: var(--font-weight-medium);
  text-align: center;
}
.drawer-btn-outline:active {
  background: var(--glass-bg-elevated);
  transform: scale(0.97);
}

.flex-1 { flex: 1; }

.drawer-btn-danger {
  padding: 28rpx 36rpx;
  border-radius: var(--radius-full);
  background: transparent;
  border: 2rpx solid var(--color-error);
  color: var(--color-error);
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  text-align: center;
}
.drawer-btn-danger:active {
  background: rgba(120, 108, 94, 0.08);
  transform: scale(0.97);
}

.account-danger-zone {
  margin-top: 60rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

/* ======= 关于我们 ======= */
.about-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 32rpx 0 28rpx;
}
.about-name {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}
.about-version {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.55;
}

/* 抽屉文本内容 */
.drawer-text {
  font-size: 28rpx;
  color: var(--color-on-surface);
  line-height: 1.8;
  white-space: pre-wrap;
}

.drawer-body-spacer { height: 48rpx; }

/* Rich text content from API */
.drawer-rich-text {
  display: block;
  width: 100%;
  font-size: 28rpx;
  color: var(--color-on-surface);
  line-height: 1.8;
  word-break: break-word;
}

.drawer-loading {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.5;
}
