<!--pages/settings/settings.wxml-->
<view class="page-container" style="padding-top: {{topBarTotalHeight}}px">
  <!-- 顶部导航 -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="back-btn" bindtap="onBack">
      <image src="/images/back.png" class="back-icon" mode="aspectFit"></image>
    </view>
    <text class="top-title">设置</text>
    <view class="top-spacer"></view>
  </view>

  <scroll-view scroll-y class="main-scroll" style="flex: 1; height: 0;">
    <view class="scroll-inner">

      <!-- 组1：账号 + 通知 -->
      <view class="settings-group card">
        <!-- 账号安全 -->
        <view class="settings-item" bindtap="onOpenDrawer" data-type="account">
          <text class="settings-item-icon">🔒</text>
          <text class="settings-item-label">账号安全</text>
          <text class="settings-item-arrow">→</text>
        </view>

        <view class="settings-divider"></view>

        <!-- 通知设置 -->
        <view class="settings-item switch-item">
          <text class="settings-item-icon">🔔</text>
          <text class="settings-item-label">通知设置</text>
          <switch
            checked="{{notificationEnabled}}"
            bindchange="onToggleNotification"
            color="#C0563A"
          />
        </view>
      </view>

      <!-- 组2：清除缓存 -->
      <view class="settings-group card">
        <view class="settings-item" bindtap="onClearCache">
          <text class="settings-item-icon">🗂️</text>
          <text class="settings-item-label">清除缓存</text>
          <view class="settings-item-right">
            <text class="settings-item-hint">{{cacheSize}}</text>
            <text class="settings-item-arrow">→</text>
          </view>
        </view>
      </view>

      <!-- 组3：关于 + 协议 + 隐私 -->
      <view class="settings-group card">
        <view class="settings-item" bindtap="onOpenDrawer" data-type="about">
          <text class="settings-item-icon">ℹ️</text>
          <text class="settings-item-label">关于我们</text>
          <text class="settings-item-arrow">→</text>
        </view>

        <view class="settings-divider"></view>

        <view class="settings-item" bindtap="onOpenDrawer" data-type="agreement">
          <text class="settings-item-icon">📄</text>
          <text class="settings-item-label">用户协议</text>
          <text class="settings-item-arrow">→</text>
        </view>

        <view class="settings-divider"></view>

        <view class="settings-item" bindtap="onOpenDrawer" data-type="privacy">
          <text class="settings-item-icon">🛡️</text>
          <text class="settings-item-label">隐私政策</text>
          <text class="settings-item-arrow">→</text>
        </view>
      </view>

      <!-- 退出登录 -->
      <view class="logout-btn" bindtap="onLogout">
        <text>退出登录</text>
      </view>

    </view>
  </scroll-view>

  <!-- ========== 底部抽屉覆盖层 ========== -->
  <view class="drawer-overlay {{drawerOpen ? 'show' : ''}}" catchtap="onCloseDrawer">
    <view class="drawer-drawer {{drawerOpen ? 'show' : ''}}" catchtap="noop">
      <!-- 抽屉导航栏 -->
      <view class="drawer-nav">
        <view class="drawer-nav-back" catchtap="onCloseDrawer">
          <text>取消</text>
        </view>
        <text class="drawer-nav-title">{{drawerTitle}}</text>
        <view class="drawer-nav-spacer"></view>
      </view>

      <!-- 抽屉内容区 -->
      <scroll-view scroll-y class="drawer-body" enhanced show-scrollbar="{{false}}">

        <!-- 账号安全 -->
        <block wx:if="{{drawerType === 'account'}}">
          <!-- 当前手机号（非编辑模式） -->
          <view wx:if="{{!editPhoneOpen}}" class="drawer-section">
            <view class="account-info-row">
              <text class="account-label">绑定手机号</text>
              <text class="account-value">{{phoneNumber}}</text>
            </view>
            <view class="account-hint">用于接收订单通知和配送信息</view>
            <view class="drawer-btn-primary" bindtap="onEditPhone">
              <text>修改手机号</text>
            </view>
          </view>

          <!-- 编辑手机号 -->
          <view wx:else class="drawer-section">
            <view class="input-field">
              <text class="field-label">新手机号</text>
              <input
                class="field-input"
                value="{{editPhone}}"
                bindinput="onPhoneInput"
                type="number"
                maxlength="11"
                placeholder="请输入11位手机号"
                placeholder-class="field-placeholder"
                focus="{{true}}"
              />
            </view>
            <view class="drawer-form-btns">
              <view class="drawer-btn-outline" bindtap="onCancelEditPhone">
                <text>取消</text>
              </view>
              <view class="drawer-btn-primary flex-1" bindtap="onSavePhone">
                <text>保存</text>
              </view>
            </view>
          </view>

          <!-- 注销账号 -->
          <view class="drawer-section account-danger-zone">
            <view class="account-hint" style="color: var(--color-error); margin-bottom: 16rpx;">
              注销后将删除您的个人信息、清零余额和积分，且无法恢复。
            </view>
            <view class="drawer-btn-danger" bindtap="onDeleteAccount">
              <text>注销账号</text>
            </view>
          </view>
        </block>
        <block wx:elif="{{drawerType === 'about'}}">
          <view class="drawer-section">
            <view class="about-header">
              <text class="about-name">王姐手工披萨</text>
              <text class="about-version">版本 1.0.0</text>
            </view>
            <text class="drawer-text">
              王姐手工披萨，用心做好每一张披萨。{"\n\n"}
              创始于2018年，坚持手工现做、新鲜食材、传统工艺。每一张披萨都承载着我们对美食的热爱与执着。{"\n\n"}
              从经典玛格丽特到至尊牛肉披萨，从招牌榴莲饼到手工凤梨酥，我们用心雕琢每一个细节，只为给您带来最纯正的手工披萨体验。{"\n\n"}
              感谢您选择王姐手工披萨！
            </text>
          </view>
        </block>

        <!-- 用户协议 -->
        <block wx:elif="{{drawerType === 'agreement'}}">
          <view class="drawer-section">
            <text class="drawer-text">
              用户服务协议{"\n\n"}
              一、总则{"\n"}
              1.1 欢迎使用王姐手工披萨小程序（以下简称"本小程序"）。{"\n"}
              1.2 本协议是您与王姐手工披萨之间关于使用本小程序服务所订立的协议。{"\n"}
              1.3 使用本小程序即表示您同意本协议的全部条款。{"\n\n"}
              二、账号注册与管理{"\n"}
              2.1 用户通过微信授权登录即完成注册，无需额外设置密码。{"\n"}
              2.2 用户应当对其账号下的所有活动负法律责任。{"\n"}
              2.3 您有权随时注销账号。注销后，您的个人信息将被删除或匿名化处理，余额和积分将清零且不可恢复。注销入口位于"设置 - 账号安全"。{"\n\n"}
              三、服务内容{"\n"}
              3.1 本小程序提供在线点单、积分兑换、优惠券使用、余额充值等服务。{"\n"}
              3.2 我们保留随时变更、中断或终止部分或全部服务的权利。{"\n\n"}
              四、订单与支付{"\n"}
              4.1 用户下单后应及时完成支付，未支付订单将在30分钟后自动关闭。{"\n"}
              4.2 支持微信支付和余额支付两种方式。{"\n"}
              4.3 订单金额以提交时系统计算为准，包含商品价格、会员折扣、优惠券减免。{"\n\n"}
              五、退款政策{"\n"}
              5.1 未开始制作的订单（"待取餐"状态）可随时取消并获得全额退款。{"\n"}
              5.2 制作中的订单可申请取消，系统将自动处理退款。{"\n"}
              5.3 余额支付的订单：退款即时到账，返还至账户余额。{"\n"}
              5.4 微信支付的订单：退款将原路退回，预计1-5个工作日到账。{"\n"}
              5.5 退款时，已使用的优惠券将恢复（未过期的情况下），已获得的积分将扣回。{"\n"}
              5.6 已完成取餐的订单不支持退款。{"\n\n"}
              六、用户行为规范{"\n"}
              6.1 用户不得利用本小程序从事违法违规活动。{"\n"}
              6.2 用户不得利用技术手段恶意刷单、套取优惠。{"\n\n"}
              七、知识产权{"\n"}
              7.1 本小程序所有内容的著作权、商标权等知识产权归王姐手工披萨所有。{"\n\n"}
              八、其他{"\n"}
              8.1 本协议的解释、效力及纠纷的解决，适用中华人民共和国法律。{"\n"}
              8.2 如本协议中的任何条款无论因何种原因完全或部分无效，其余条款仍应有效。{"\n\n"}
              更新日期：2026年6月18日
            </text>
          </view>
        </block>

        <!-- 隐私政策 -->
        <block wx:elif="{{drawerType === 'privacy'}}">
          <view class="drawer-section">
            <text class="drawer-text">
              隐私政策{"\n\n"}
              王姐手工披萨（以下简称"我们"）重视您的个人信息保护。本政策依据《中华人民共和国个人信息保护法》等法律法规制定。{"\n\n"}
              一、信息收集{"\n"}
              1.1 您主动提供的信息：昵称、手机号、收货地址。{"\n"}
              1.2 自动收集的信息：微信OpenID（用于账号识别）、设备信息、使用日志。{"\n"}
              1.3 交易信息：订单详情、支付金额、交易流水号（由微信支付提供）。{"\n"}
              1.4 位置信息：仅在您主动查看门店地图时获取，可随时关闭。{"\n\n"}
              二、信息使用{"\n"}
              2.1 处理订单：确认订单、计算价格、发放取餐码、通知取餐。{"\n"}
              2.2 会员服务：积分累计与兑换、等级计算、优惠券发放。{"\n"}
              2.3 通知推送：订单状态变更通知（可在设置中关闭）。{"\n"}
              2.4 服务改进：统计分析（匿名化处理后使用）。{"\n\n"}
              三、信息存储与保护{"\n"}
              3.1 您的信息存储在中国境内的安全服务器上。{"\n"}
              3.2 数据传输采用SSL/TLS加密，支付凭证加密存储。{"\n"}
              3.3 我们按照最小必要原则收集和存储信息。{"\n"}
              3.4 账号注销后，我们将在合理期限内删除或匿名化处理您的个人信息。{"\n\n"}
              四、信息共享{"\n"}
              4.1 我们不会出售您的个人信息。{"\n"}
              4.2 仅在以下情况共享：获得您明确同意时；法律法规要求时；与微信支付完成交易处理时。{"\n\n"}
              五、您的权利{"\n"}
              5.1 查询与更正：您可在"我的"页面查看和修改个人信息。{"\n"}
              5.2 账号注销：您可通过"设置 - 账号安全"注销账号，注销后我们将删除或匿名化处理您的个人信息。{"\n"}
              5.3 撤回授权：您可在微信设置中取消对本小程序的授权。{"\n"}
              5.4 投诉举报：如对个人信息处理有异议，可联系客服或向有关部门投诉。{"\n\n"}
              六、退款相关{"\n"}
              6.1 取消订单时，退款将退回原支付渠道。余额支付即时到账，微信支付1-5个工作日到账。{"\n"}
              6.2 退款涉及的积分和优惠券将按规则自动调整。{"\n\n"}
              七、本地存储{"\n"}
              7.1 我们使用本地存储保存您的登录状态和偏好设置。{"\n"}
              7.2 您可通过"设置 - 清除缓存"清除这些数据。{"\n\n"}
              八、未成年人保护{"\n"}
              8.1 未满14周岁的未成年人使用本服务需取得监护人同意。{"\n\n"}
              九、政策更新{"\n"}
              9.1 本政策如有重大变更，我们将在小程序内通知您。{"\n\n"}
              更新日期：2026年6月18日
            </text>
          </view>
        </block>

        <view class="drawer-body-spacer"></view>
      </scroll-view>
    </view>
  </view>
</view>
