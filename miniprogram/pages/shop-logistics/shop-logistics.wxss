/* pages/shop-logistics/shop-logistics.wxss — 物流追踪（黏土风） */

.log-page { min-height: 100vh; box-sizing: border-box; }

/* ── 顶部返回栏 ── */
.log-top-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx 20rpx;
  background: var(--clay-bg-nav);
  border-bottom: var(--clay-border-subtle);
  box-shadow: var(--clay-shadow-nav);
}
.log-back-btn {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-full);
  background: var(--clay-bg-card); border: var(--clay-border-subtle);
  display: flex; align-items: center; justify-content: center;
}
.log-back-btn:active { opacity: 0.7; }
.log-back-placeholder { background: transparent; border: none; box-shadow: none; }
.log-back-icon { font-size: 48rpx; line-height: 1; color: var(--color-on-surface); }
.log-top-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }

/* ── 列表 ── */
.log-list { padding: 0rpx 24rpx 0; display: flex; flex-direction: column; gap: 20rpx; }

/* ── 卡片 ── */
.log-card {
  background: var(--clay-bg-card);
  border-radius: var(--radius-card);
  border: var(--clay-border-subtle);
  box-shadow: var(--clay-shadow-card);
  overflow: hidden;
}
.log-card-hd {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 24rpx 12rpx;
  border-bottom: var(--clay-border-subtle);
}
.log-card-id { font-size: 24rpx; color: var(--color-on-surface-variant); }
.log-card-status { font-size: 24rpx; font-weight: var(--font-weight-semibold); }
.log-card-status.status-shipped { color: #7B5BB8; }
.log-card-status.status-completed { color: #52A854; }

/* ── 商品行 ── */
.log-card-body { display: flex; gap: 16rpx; padding: 16rpx 24rpx; }
.log-item-img {
  width: 120rpx; height: 120rpx; border-radius: var(--radius-sm);
  flex-shrink: 0; background: var(--clay-bg-light);
}
.log-item-info { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 8rpx; min-width: 0; }
.log-item-name { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.log-item-bottom { display: flex; align-items: baseline; justify-content: space-between; }
.log-item-price { font-size: 26rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }
.log-item-qty { font-size: 24rpx; color: var(--color-on-surface-variant); }

/* ── 物流信息行 ── */
.log-shipping-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx;
  border-top: var(--clay-border-subtle);
}
.log-shipping-left { display: flex; flex-direction: column; gap: 4rpx; }
.log-shipping-company { font-size: 26rpx; color: var(--color-on-surface); font-weight: var(--font-weight-semibold); }
.log-shipping-no { font-size: 22rpx; color: var(--color-on-surface-variant); }

/* ── 追踪状态徽章 ── */
.log-tracking-status {
  padding: 6rpx 20rpx; border-radius: var(--radius-full);
  font-size: 22rpx; font-weight: var(--font-weight-semibold);
  flex-shrink: 0;
}
.log-tracking-status.transit { background: #FFF3E0; color: #E65100; }
.log-tracking-status.delivered { background: #E8F5E9; color: #2E7D32; }
.log-tracking-status.pending { background: var(--clay-bg-light); color: var(--color-on-surface-variant); }
.log-tracking-status.unsupported { background: #FFF3E0; color: #E65100; }
.log-tracking-status.error { background: #FFEBEE; color: #C62828; }

/* ── 最新事件预览 ── */
.log-latest {
  padding: 0 24rpx 12rpx;
  display: flex; flex-direction: column; gap: 4rpx;
}
.log-latest-time { font-size: 22rpx; color: var(--color-on-surface-variant); }
.log-latest-context { font-size: 24rpx; color: var(--color-on-surface); }

/* ── 展开按钮 ── */
.log-expand-btn {
  display: flex; align-items: center; justify-content: center;
  padding: 12rpx 24rpx 20rpx;
  border-top: var(--clay-border-subtle);
  font-size: 24rpx; color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.log-expand-btn:active { opacity: 0.7; }

/* ── 物流时间线 ── */
.log-timeline {
  padding: 0 24rpx 28rpx 48rpx;
  border-top: var(--clay-border-subtle);
}
.log-timeline-loading { padding: 20rpx 0; text-align: center; color: var(--color-on-surface-variant); font-size: 24rpx; }
.log-timeline-empty { padding: 20rpx 0; text-align: center; color: var(--color-on-surface-variant); font-size: 24rpx; }

.log-event {
  position: relative;
  padding: 20rpx 0 0 28rpx;
  border-left: 3rpx solid rgba(180, 160, 140, 0.24);
}
.log-event:first-child { padding-top: 24rpx; }
.log-event.latest { border-left-color: var(--color-primary); }
.log-event-dot {
  position: absolute; left: -9rpx; top: 28rpx;
  width: 16rpx; height: 16rpx; border-radius: var(--radius-full);
  background: rgba(180, 160, 140, 0.30);
}
.log-event-dot.active {
  background: var(--color-primary);
  box-shadow: 0 0 0 6rpx var(--clay-bg-primary-light);
}
.log-event:first-child .log-event-dot { top: 32rpx; }
.log-event-content { display: flex; flex-direction: column; gap: 6rpx; }
.log-event-context { font-size: 26rpx; color: var(--color-on-surface); line-height: 1.5; }
.log-event-time { font-size: 22rpx; color: var(--color-on-surface-variant); }

/* ── 空态 ── */
.log-empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding-top: 200rpx; gap: 12rpx;
}
.log-empty-img { width: 200rpx; height: 200rpx; opacity: 0.6; }
.log-empty-text { font-size: 30rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.log-empty-sub { font-size: 24rpx; color: var(--color-on-surface-variant); }
