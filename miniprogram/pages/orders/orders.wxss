/* pages/orders/orders.wxss */

.top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx 24rpx;
  background: var(--glass-bg-nav);
  border-bottom: var(--glass-border-subtle);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* ── 状态 Tab：融入内容区，无硬分割 ── */
.order-tabs {
  padding: 20rpx 0 16rpx;
}
.tabs-scroll { white-space: nowrap; }
.tabs-list { display: flex; padding: 0 40rpx; gap: 20rpx; }

.tab-item {
  padding: 18rpx 40rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  color: #9B8B7A;
  background: rgba(180,160,140,0.10);
  flex-shrink: 0;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.tab-item:active { transform: scale(0.95); }

.tab-item.active { color: #FFFFFF; transform: scale(1.02); }
.tab-item.active.tab-all {
  background: linear-gradient(160deg, #8A7B6A 0%, #5C5040 100%);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.25), inset -2rpx -3rpx 5rpx rgba(40,30,20,0.35);
}
.tab-item.active.tab-waiting {
  background: linear-gradient(160deg, #D4846B 0%, #B04A32 100%);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.28), inset -2rpx -3rpx 5rpx rgba(140,40,20,0.40);
}
.tab-item.active.tab-completed {
  background: linear-gradient(160deg, #5CB860 0%, #2E7D32 100%);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.28), inset -2rpx -3rpx 5rpx rgba(20,70,25,0.40);
}
.tab-item.active.tab-cancelled {
  background: linear-gradient(160deg, #9E9E9E 0%, #616161 100%);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.25), inset -2rpx -3rpx 5rpx rgba(40,40,40,0.35);
}

/* 订单列表 */
.orders-scroll { padding: 24rpx 0 72rpx; overflow-x: hidden; box-sizing: border-box; }
.scroll-inner { padding: 0 40rpx; }

.order-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  overflow: hidden;
}

.order-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.order-header-left { display: flex; flex-direction: column; gap: 8rpx; flex: 1; overflow: hidden; min-width: 0; }
.order-store { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.order-time { font-size: 24rpx; color: var(--color-on-surface-variant); }
.order-pickup-time { font-size: 24rpx; color: #C0563A; background: #FFF3ED; padding: 4rpx 12rpx; border-radius: 8rpx; margin-top: 6rpx; display: inline-block; }
.order-header-right { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.order-status { padding: 8rpx 24rpx; border-radius: var(--radius-full); font-size: 24rpx; font-weight: var(--font-weight-semibold); flex-shrink: 0; box-shadow: inset 1rpx 1rpx 2rpx rgba(255,255,255,0.55), inset -1rpx -1rpx 3rpx rgba(120,108,94,0.2); }
.order-status.completed { background: linear-gradient(180deg, #E8F5E9 0%, #C8E6C9 100%); color: #2E7D32; box-shadow: inset 1rpx 1rpx 2rpx rgba(255,255,255,0.7), 0 2rpx 6rpx rgba(46,125,50,0.12); }
.order-status.waiting { background: linear-gradient(180deg, #FDF0EB 0%, #FCE4D8 100%); color: #C0563A; box-shadow: inset 1rpx 1rpx 2rpx rgba(255,255,255,0.7), 0 2rpx 6rpx rgba(192,86,58,0.12); }
.order-status.cancelled { background: linear-gradient(180deg, #FFEBEE 0%, #FFCDD2 100%); color: #C62828; box-shadow: inset 1rpx 1rpx 2rpx rgba(255,255,255,0.7), 0 2rpx 6rpx rgba(198,40,40,0.12); }
.payment-badge { padding: 6rpx 20rpx; border-radius: var(--radius-full); font-size: 22rpx; font-weight: var(--font-weight-semibold); flex-shrink: 0; box-shadow: inset 1rpx 1rpx 2rpx rgba(255,255,255,0.55), inset -1rpx -1rpx 3rpx rgba(120,108,94,0.2); }
.payment-badge.paid { background: var(--color-tertiary-container); color: var(--color-on-tertiary); }
.payment-badge.unpaid { background: var(--color-secondary-container); color: var(--color-secondary-dark); }

.order-items { border-top: 1rpx solid var(--color-divider); padding-top: 24rpx; }
.order-item { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 0; }
.order-item-name { font-size: 28rpx; color: var(--color-on-surface); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
.order-item-qty { display: flex; align-items: center; gap: 16rpx; font-size: 26rpx; color: var(--color-on-surface-variant); flex-shrink: 0; margin-left: 16rpx; }
.order-item-price { color: var(--color-on-surface); font-weight: var(--font-weight-semibold); min-width: 80rpx; text-align: right; }

/* 取餐码 */
.pickup-section { border-top: 1rpx solid var(--color-divider); padding: 28rpx 0 8rpx; }
.pickup-btn { display: flex; align-items: center; justify-content: center; gap: 12rpx; padding: 24rpx; background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); border-radius: 24rpx; box-shadow: inset 3rpx 3rpx 6rpx rgba(255,255,255,0.85), inset -3rpx -4rpx 8rpx rgba(120,108,94,0.16), 0 5rpx 14rpx rgba(120,108,94,0.14); }
.pickup-btn:active { transform: scale(0.97); }
.pickup-btn-icon { width: 44rpx; height: 44rpx; }
.pickup-btn-text { font-size: 28rpx; color: var(--color-primary); font-weight: var(--font-weight-semibold); }
.pickup-revealed { display: flex; flex-direction: column; align-items: center; gap: 20rpx; padding: 28rpx 24rpx; background: #EFE7DA; border-radius: 24rpx; box-shadow: inset 3rpx 3rpx 7rpx rgba(120,108,94,0.2), inset -3rpx -3rpx 7rpx rgba(255,255,255,0.85); }
.pickup-label { font-size: 22rpx; color: var(--color-on-surface-variant); letter-spacing: 6rpx; text-transform: uppercase; }
.pickup-code-row { display: flex; gap: 16rpx; }
.pickup-digit { width: 64rpx; height: 80rpx; line-height: 80rpx; text-align: center; font-size: 40rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); background: linear-gradient(160deg, #FFFFFF 0%, #F4EFE6 100%); border-radius: 14rpx; box-shadow: inset 2rpx 2rpx 5rpx rgba(120,108,94,0.22), inset -2rpx -2rpx 5rpx rgba(255,255,255,0.9); font-family: 'SF Mono', 'Menlo', 'Courier New', monospace; }
.pickup-hint { font-size: 22rpx; color: var(--color-on-surface-variant); opacity: 0.6; }
.pickup-hide-btn { padding: 12rpx 40rpx; border-radius: var(--radius-full); background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); font-size: 24rpx; color: var(--color-on-surface-variant); font-weight: var(--font-weight-medium); box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.85), inset -2rpx -3rpx 6rpx rgba(120,108,94,0.16), 0 3rpx 9rpx rgba(120,108,94,0.12); }
.pickup-hide-btn:active { transform: scale(0.95); }

.order-footer { display: flex; align-items: center; justify-content: space-between; border-top: 1rpx solid var(--color-divider); padding-top: 24rpx; margin-top: 16rpx; gap: 20rpx; }
.order-total-wrap { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; flex-shrink: 0; }
.order-discount-btn { display: inline-flex; align-items: center; gap: 4rpx; padding: 6rpx 14rpx; border-radius: 20rpx; white-space: nowrap; background: rgba(192,86,58,0.08); border: 1rpx solid rgba(192,86,58,0.20); }
.order-discount-btn-text { font-size: 22rpx; color: #C0563A; font-weight: var(--font-weight-semibold); }
.order-discount-btn-arrow { font-size: 24rpx; color: #C0563A; }
.order-total { font-size: 28rpx; color: var(--color-on-surface); flex-shrink: 0; white-space: nowrap; }
.total-price { font-size: 32rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }

.order-actions { display: flex; gap: 16rpx; flex-shrink: 0; }
.order-action-btn { padding: 14rpx 34rpx; border-radius: var(--radius-full); font-size: 26rpx; font-weight: var(--font-weight-semibold); white-space: nowrap; transition: transform 0.12s ease; }
.order-action-btn.outline { color: #8A7B66; background: #EFE7DA; box-shadow: inset 2rpx 2rpx 4rpx rgba(120,108,94,0.18), inset -2rpx -2rpx 4rpx rgba(255,255,255,0.85); }
.order-action-btn.primary { background: linear-gradient(160deg, #C9684C 0%, #A8472E 100%); color: #FFFFFF; box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.28), inset -3rpx -3rpx 7rpx rgba(120,40,28,0.4), 0 5rpx 13rpx rgba(150,60,40,0.28); }
.order-action-btn.pickup-btn { background: var(--clay-bg-primary); color: #FFFFFF; box-shadow: var(--clay-shadow-button); }
.order-action-btn.pickup-btn:active { transform: scale(0.96); opacity: 0.9; }
.order-action-btn.pay-btn { background: linear-gradient(160deg, #CE4636 0%, #A22A1E 100%); color: #FFFFFF; box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.3), inset -3rpx -4rpx 8rpx rgba(120,30,20,0.45), 0 6rpx 16rpx rgba(150,40,28,0.4); }
.order-action-btn.pay-btn:active { transform: scale(0.96); opacity: 0.9; }
.order-action-btn.disabled { color: #bbb; background: #F0EBE3; box-shadow: none; opacity: 0.7; }
.order-action-btn.disabled:active { transform: none; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.empty-text { font-size: 32rpx; color: var(--color-on-surface-variant); margin-bottom: 16rpx; }
.empty-sub { font-size: 26rpx; color: var(--color-on-surface-variant); opacity: 0.7; }

/* ===== 优惠明细弹窗 ===== */
.discount-popup-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300;
  background: rgba(0,0,0,0.35);
  visibility: hidden; opacity: 0;
  transition: visibility 0s 0.3s, opacity 0.3s;
}
.discount-popup-overlay.show { visibility: visible; opacity: 1; transition: visibility 0s, opacity 0.3s; }
.discount-popup {
  position: absolute; left: 0; right: 0; bottom: 0;
  background: var(--clay-bg-nav);
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.discount-popup.show { transform: translateY(0); }
.discount-popup-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: var(--clay-border-subtle);
}
.discount-popup-title { font-size: 32rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.discount-popup-close {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: var(--clay-bg-card); border: var(--clay-border-subtle);
  display: flex; align-items: center; justify-content: center;
}
.discount-popup-close text { font-size: 28rpx; color: var(--color-on-surface-variant); }
.discount-popup-body {
  padding: 28rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* ── 明细行 ── */
.dp-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0;
}
.dp-left { display: flex; align-items: center; gap: 16rpx; }
.dp-icon { width: 40rpx; height: 40rpx; flex-shrink: 0; }
.dp-label { font-size: 28rpx; color: var(--color-on-surface); font-weight: var(--font-weight-medium); }
.dp-val { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); text-align: right; min-width: 140rpx; flex-shrink: 0; }

/* ── 优惠明细区域 ── */
.dp-discounts {
  margin: 12rpx 0;
  padding: 16rpx 0 16rpx 24rpx;
  background: linear-gradient(160deg, #FDF7F3 0%, #FDF3EC 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(192, 86, 58, 0.10);
}
.dp-discounts .dp-row { padding: 12rpx 0; }
.dp-discounts .dp-row:first-child { padding-top: 0; }
.dp-discounts .dp-row:last-child { padding-bottom: 0; }
.dp-discounts .dp-row + .dp-row {
  border-top: 1rpx dashed rgba(192, 86, 58, 0.15);
}
.dp-save .dp-label { color: #8A6A55; }
.dp-val-save { color: #C0563A !important; }

/* ── 合计优惠 ── */
.dp-summary {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0 16rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid rgba(180,160,140,0.25);
}
.dp-summary-label { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.dp-summary-val { font-size: 30rpx; font-weight: var(--font-weight-bold); color: #C0563A; text-align: right; min-width: 140rpx; flex-shrink: 0; }

/* ── 实付 ── */
.dp-final {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
  background: linear-gradient(160deg, #FEFCFA 0%, #F9F4ED 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(180,160,140,0.18);
}
.dp-final-label { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.dp-final-price { display: flex; align-items: baseline; gap: 2rpx; }
.dp-final-sym { font-size: 28rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.dp-final-num { font-size: 40rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
