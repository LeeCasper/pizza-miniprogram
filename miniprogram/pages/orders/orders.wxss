/* pages/orders/orders.wxss */

.top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx 24rpx;
  background: var(--glass-bg-nav);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  border-bottom: var(--glass-border-subtle);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* 订单Tab */
.order-tabs {
  background: var(--glass-bg-nav);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  border-bottom: var(--glass-border-subtle);
  padding: 16rpx 0;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-list {
  display: flex;
  padding: 0 40rpx;
  gap: 16rpx;
}

.tab-item {
  padding: 16rpx 36rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface-variant);
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: var(--glass-border-subtle);
  flex-shrink: 0;
}

.tab-item.active {
  background: var(--glass-bg-primary-container);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: var(--glass-border-colored);
  color: var(--color-on-primary-container);
}

/* 订单列表 */
.orders-scroll {
  padding: 24rpx 0 72rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

.scroll-inner {
  padding: 0 40rpx;
}

.order-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.order-header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  overflow: hidden;
  min-width: 0;
}

.order-store {
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-time {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
}

.order-header-right { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.order-status {
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: var(--font-weight-semibold);
  flex-shrink: 0;
}
.payment-badge { padding: 6rpx 20rpx; border-radius: var(--radius-full); font-size: 22rpx; font-weight: var(--font-weight-semibold); flex-shrink: 0; }
.payment-badge.paid { background: var(--color-tertiary-container); color: var(--color-on-tertiary); }
.payment-badge.unpaid { background: var(--color-secondary-container); color: var(--color-secondary-dark); }

.order-status.completed {
  background: var(--color-tertiary-container);
  color: var(--color-tertiary);
}

.order-status.preparing {
  background: var(--color-secondary-container);
  color: var(--color-secondary-dark);
}

.order-status.waiting {
  background: var(--color-primary-container);
  color: var(--color-primary);
}

.order-items {
  border-top: 1rpx solid var(--color-divider);
  padding-top: 24rpx;
}

.order-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.order-item-name {
  font-size: 28rpx;
  color: var(--color-on-surface);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.order-item-qty {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.order-item-price {
  color: var(--color-on-surface);
  font-weight: var(--font-weight-semibold);
  min-width: 80rpx;
  text-align: right;
}

/* 取餐码 */
.pickup-section {
  border-top: 1rpx solid var(--color-divider);
  padding: 28rpx 0 8rpx;
}

/* 按钮态 */
.pickup-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: var(--glass-bg-primary-light);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border-radius: var(--radius-card);
  border: 2rpx dashed rgba(0, 0, 0, 0.08);
  transition: all 0.2s;
}

.pickup-btn:active {
  background: rgba(0, 0, 0, 0.04);
  transform: scale(0.98);
}

.pickup-btn-icon {
  width: 44rpx;
  height: 44rpx;
}

.pickup-btn-text {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* 已展示态 */
.pickup-revealed {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  border: var(--glass-border-subtle);
  border-radius: var(--radius-card);
}

.pickup-label {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  letter-spacing: 6rpx;
  text-transform: uppercase;
}

.pickup-code-row {
  display: flex;
  gap: 16rpx;
}

.pickup-digit {
  width: 64rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: var(--glass-border-subtle);
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  font-family: 'SF Mono', 'Menlo', 'Courier New', monospace;
}

.pickup-hint {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.6;
}

.pickup-hide-btn {
  padding: 12rpx 40rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: var(--glass-border-subtle);
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  font-weight: var(--font-weight-medium);
  transition: all 0.2s;
}

.pickup-hide-btn:active {
  background: var(--color-surface-container-high);
  transform: scale(0.96);
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid var(--color-divider);
  padding-top: 24rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
  gap: 16rpx;
}

.order-total {
  font-size: 28rpx;
  color: var(--color-on-surface);
  flex-shrink: 0;
}

.total-price {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.order-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.order-action-btn {
  padding: 12rpx 32rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: var(--font-weight-semibold);
  white-space: nowrap;
}

.order-action-btn.outline {
  color: var(--color-on-surface-variant);
  background: var(--glass-bg-light);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: var(--glass-border);
  box-shadow: var(--shadow-elevated);
}

.order-action-btn.primary {
  background: var(--glass-bg-primary);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: 1rpx solid rgba(255,255,255,0.2);
  color: var(--color-on-primary);
}
.order-action-btn.pay-btn { background: linear-gradient(135deg, #C583FF, #9B4DDB); color: #FFFFFF; box-shadow: 0 4rpx 16rpx rgba(197, 131, 255, 0.3); }
.order-action-btn.pay-btn:active { transform: scale(0.96); opacity: 0.9; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-on-surface-variant);
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.7;
}
