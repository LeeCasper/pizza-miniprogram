<!-- pages/tiers/tiers.wxml -->
<view class="page-container" style="padding-top: {{topBarTotalHeight}}px">
  <!-- 顶部导航 -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="onBack"><text>←</text></view>
    <text class="top-title">会员权益</text>
    <view class="top-spacer"></view>
  </view>

  <scroll-view scroll-y class="main-scroll" enhanced show-scrollbar="{{false}}"
      style="flex: 1; height: 0;">
    <view class="scroll-inner">

      <!-- ====== HERO: 当前等级卡片 ====== -->
      <view class="hero-card tier-bg-{{currentTier.levelIndex}}" wx:if="{{currentTier}}">
        <view class="hero-card-content">
          <view class="hero-name-row">
            <text class="hero-tier-name" style="color: {{currentTier.accentColor}}">{{currentTier.name}}</text>
            <view class="hero-vip-badge" style="border-color: {{currentTier.accentColor}}">
              <text class="hero-vip-text" style="color: {{currentTier.accentColor}}">VIP.{{currentTier.levelIndex}}</text>
            </view>
          </view>
          <text class="hero-subtitle">当前等级</text>

          <!-- 进度条 -->
          <view class="hero-progress-section" wx:if="{{hasNext}}">
            <text class="hero-progress-text">还差¥{{spentToNext}}升级{{nextTier.name}}</text>
            <view class="hero-progress-row">
              <view class="hero-progress-bar-bg">
                <view class="hero-progress-bar-fill" style="width: {{progressPercent}}%; background: {{currentTier.accentColor}}"></view>
              </view>
              <text class="hero-progress-fraction">{{progressFraction}}</text>
            </view>
          </view>
          <view class="hero-max-badge" wx:else>
            <text class="hero-max-text">✦ 已达最高等级 ✦</text>
          </view>
        </view>

        <!-- 装饰性 VIP 卡片 -->
        <view class="hero-decorative-card" style="border-color: {{currentTier.accentColor}}20">
          <view class="hero-decorative-inner">
            <text class="hero-decorative-text" style="color: {{currentTier.accentColor}}">VIP.{{currentTier.levelIndex}}</text>
          </view>
        </view>
      </view>

      <!-- ====== 等级对比横向滚动 ====== -->
      <view class="section-header">
        <text class="section-title">会员等级对比</text>
        <text class="section-icon">💎</text>
      </view>

      <scroll-view scroll-x class="tier-compare-scroll" enhanced show-scrollbar="{{false}}">
        <view class="tier-compare-list">
          <view class="tier-compare-card tier-bg-{{item.levelIndex}} {{item.status === 'current' ? 'compare-card-active' : ''}} {{item.status === 'upcoming' ? 'compare-card-dimmed' : ''}} {{item.levelKey === selectedTierKey ? 'compare-card-selected' : ''}}"
              wx:for="{{tiers}}" wx:key="levelKey" id="tier-{{item.levelKey}}"
              bindtap="onSelectTier" data-level-key="{{item.levelKey}}">
            <text class="compare-card-name" style="color: {{item.accentColor}}">{{item.name}}</text>
            <view class="compare-card-badge" wx:if="{{item.status === 'current'}}" style="border-color: {{item.accentColor}}">
              <text class="compare-card-badge-text" style="color: {{item.accentColor}}">VIP.{{item.levelIndex}}</text>
            </view>
            <text class="compare-card-badge" wx:else>VIP.{{item.levelIndex}}</text>
            <text class="compare-card-range">{{item.rangeText}}</text>
            <!-- 已达成对勾 -->
            <view class="compare-card-check" wx:if="{{item.status === 'achieved'}}" style="background: {{item.accentColor}}">
              <text class="compare-card-check-text">✓</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- ====== 选中等级专属权益 ====== -->
      <view class="section-header" wx:if="{{selectedTier}}">
        <text class="section-title">{{selectedTier.name}}专属权益</text>
      </view>

      <view class="benefits-grid" wx:if="{{selectedTier}}">
        <view class="benefit-grid-item" wx:for="{{selectedTier.benefitItems}}" wx:key="label" wx:for-item="b">
          <view class="benefit-grid-icon {{b.iconBg}}">
            <text class="benefit-grid-emoji">{{b.icon}}</text>
          </view>
          <view class="benefit-grid-info">
            <text class="benefit-grid-label">{{b.label}}</text>
            <text class="benefit-grid-desc">{{b.desc}}</text>
          </view>
          <text class="benefit-grid-value">{{b.value}}</text>
        </view>
      </view>

      <!-- ====== 等级规则 ====== -->
      <view class="section-header">
        <text class="section-title">等级规则</text>
        <text class="section-icon">✍️</text>
      </view>

      <view class="rules-card">
        <view class="rules-row" wx:for="{{tiers}}" wx:key="levelKey" wx:for-item="rule">
          <view class="rules-dot" style="background: {{rule.accentColor}}"></view>
          <view class="rules-info">
            <text class="rules-tier-name">{{rule.name}}</text>
            <text class="rules-tier-range">{{rule.rangeText}}</text>
          </view>
          <view class="rules-discount" wx:if="{{rule.discountRate < 1}}">
            <text class="rules-discount-text">{{rule.discountText}}</text>
          </view>
        </view>
      </view>

      <view class="rules-footer">
        <text class="rules-footer-icon">ℹ️</text>
        <text class="rules-footer-text">会员权益长期有效，等级规则如有调整以公告为准</text>
      </view>

      <view style="height: calc(120rpx + env(safe-area-inset-bottom))"></view>
    </view>
  </scroll-view>
</view>
