<!-- pages/tiers/tiers.wxml -->
<view class="page-container" style="padding-top: {{topBarTotalHeight}}px">
  <!-- 顶部导航 -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="onBack"><text>←</text></view>
    <text class="top-title">会员等级权益</text>
    <view class="top-spacer"></view>
  </view>

  <scroll-view scroll-y class="main-scroll" enhanced show-scrollbar="{{false}}"
      scroll-into-view="{{scrollToView}}" scroll-with-animation
      style="flex: 1; height: 0;">
    <view class="scroll-inner">

      <!-- ====== HERO: 当前等级 ====== -->
      <view class="hero-card tier-bg-{{currentTier.levelIndex}}">
        <view class="hero-card-content">
          <text class="hero-label">CURRENT TIER</text>
          <view class="hero-name-row">
            <text class="hero-tier-name" style="color: {{currentTier.accentColor}}">{{currentTier.name}}</text>
            <view class="hero-vip-badge" style="border-color: {{currentTier.accentColor}}">
              <text class="hero-vip-text" style="color: {{currentTier.accentColor}}">VIP.{{currentTier.levelIndex}}</text>
            </view>
          </view>
          <view class="hero-accent-bar" style="background: {{currentTier.accentColor}}"></view>
          <view class="hero-spent-row">
            <text class="hero-spent-label">累计消费</text>
            <text class="hero-spent-value">¥{{totalSpentText}}</text>
          </view>
          <!-- 进度条 -->
          <view class="hero-progress-section" wx:if="{{hasNext}}">
            <view class="hero-progress-bar-bg">
              <view class="hero-progress-bar-fill" style="width: {{progressPercent}}%; background: {{currentTier.accentColor}}"></view>
            </view>
            <text class="hero-progress-text">还差 ¥{{spentToNext}} 升级 {{nextTier.name}}</text>
          </view>
          <view class="hero-max-badge" wx:else>
            <text class="hero-max-text">✦ 已达最高等级 ✦</text>
          </view>
        </view>
      </view>

      <!-- Hero 快捷权益 -->
      <view class="hero-quick-benefits" wx:if="{{currentTier}}">
        <view class="quick-item" wx:if="{{currentTier.discountRate < 1}}">
          <text class="quick-icon">🏷️</text>
          <text class="quick-value">{{heroDiscountText}}</text>
          <text class="quick-label">折扣</text>
        </view>
        <view class="quick-item" wx:if="{{currentTier.pointsRewardRate > 1}}">
          <text class="quick-icon">⭐</text>
          <text class="quick-value">{{heroPointsText}}</text>
          <text class="quick-label">积分</text>
        </view>
        <view class="quick-item" wx:if="{{currentTier.birthdayGift}}">
          <text class="quick-icon">🎂</text>
          <text class="quick-value">专属</text>
          <text class="quick-label">生日礼</text>
        </view>
        <view class="quick-item" wx:if="{{currentTier.couponValue > 0}}">
          <text class="quick-icon">🎫</text>
          <text class="quick-value">¥{{currentTier.couponValue}}</text>
          <text class="quick-label">升级礼券</text>
        </view>
      </view>

      <!-- ====== 全部等级列表 ====== -->
      <text class="section-title">全部等级</text>

      <view class="tier-detail-card {{item.status === 'current' ? 'tier-card-highlight' : ''}} {{item.status === 'upcoming' ? 'tier-card-dimmed' : ''}}"
          wx:for="{{tiers}}" wx:key="levelKey" id="tier-{{item.levelKey}}">

        <!-- 等级头部 -->
        <view class="tier-detail-header tier-bg-{{item.levelIndex}}">
          <view class="tier-detail-header-inner">
            <view class="tier-detail-name-row">
              <text class="tier-detail-name" style="color: {{item.accentColor}}">{{item.name}}</text>
              <view class="tier-detail-mini-badge" style="border-color: {{item.accentColor}}">
                <text class="tier-detail-mini-badge-text" style="color: {{item.accentColor}}">VIP.{{item.levelIndex}}</text>
              </view>
            </view>
            <text class="tier-detail-threshold">累计消费满 ¥{{item.minSpent}}</text>
            <!-- 状态标签 -->
            <view class="tier-status-chip tier-status-{{item.status}}">
              <text wx:if="{{item.status === 'achieved'}}">✓ 已达成</text>
              <text wx:elif="{{item.status === 'current'}}">★ 当前等级</text>
              <text wx:else>🔒 未解锁</text>
            </view>
          </view>
        </view>

        <!-- 权益明细 -->
        <view class="tier-detail-body">
          <view class="benefit-row" wx:if="{{item.discountRate < 1}}">
            <view class="benefit-icon-wrap benefit-icon-discount">
              <text class="benefit-icon">🏷️</text>
            </view>
            <view class="benefit-info">
              <text class="benefit-label">折扣优惠</text>
              <text class="benefit-value">{{item.discountText}}</text>
            </view>
          </view>
          <view class="benefit-row" wx:if="{{item.pointsRewardRate > 1}}">
            <view class="benefit-icon-wrap benefit-icon-points">
              <text class="benefit-icon">⭐</text>
            </view>
            <view class="benefit-info">
              <text class="benefit-label">积分倍率</text>
              <text class="benefit-value">消费积分 x{{item.pointsText}}</text>
            </view>
          </view>
          <view class="benefit-row" wx:if="{{item.pointsRewardRate === 1}}">
            <view class="benefit-icon-wrap benefit-icon-points">
              <text class="benefit-icon">⭐</text>
            </view>
            <view class="benefit-info">
              <text class="benefit-label">积分倍率</text>
              <text class="benefit-value">基础积分</text>
            </view>
          </view>
          <view class="benefit-row">
            <view class="benefit-icon-wrap benefit-icon-birthday">
              <text class="benefit-icon">🎂</text>
            </view>
            <view class="benefit-info">
              <text class="benefit-label">生日特权</text>
              <text class="benefit-value">{{item.birthdayGift}}</text>
            </view>
          </view>
          <view class="benefit-row benefit-row-last" wx:if="{{item.couponValue > 0}}">
            <view class="benefit-icon-wrap benefit-icon-coupon">
              <text class="benefit-icon">🎫</text>
            </view>
            <view class="benefit-info">
              <text class="benefit-label">升级礼券</text>
              <text class="benefit-value">¥{{item.couponValue}} 优惠券</text>
            </view>
          </view>
        </view>

        <!-- 等级内进度条（仅当前等级且有下一级时） -->
        <view class="tier-progress-wrap" wx:if="{{item.status === 'current' && hasNext}}">
          <view class="tier-progress-bar-bg">
            <view class="tier-progress-bar-fill" style="width: {{progressPercent}}%; background: {{item.accentColor}}"></view>
          </view>
          <text class="tier-progress-label">还需 ¥{{spentToNext}} 升级 {{nextTier.name}}</text>
        </view>
      </view>

      <view style="height: calc(120rpx + env(safe-area-inset-bottom))"></view>
    </view>
  </scroll-view>
</view>
