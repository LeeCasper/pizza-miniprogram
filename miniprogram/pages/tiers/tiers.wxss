/* pages/tiers/tiers.wxss */

/* ── 页面底色 ── */
.page-container {
  background: var(--color-background);
  min-height: 100vh;
}

/* ── 顶部导航 ── */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 20rpx;
  background: var(--glass-bg-nav);
  border-bottom: var(--glass-border-subtle);
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.06);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--color-primary);
}
.back-icon { width: 36rpx; height: 36rpx; }

.top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.top-spacer {
  width: 72rpx;
}

.main-scroll {
  overflow-x: hidden;
  box-sizing: border-box;
}

.scroll-inner {
  padding: 28rpx 28rpx 0;
}

/* ── 区块标题 ── */
.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  margin-top: 36rpx;
  padding-left: 4rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--color-on-surface);
  position: relative;
  padding-left: 20rpx;
  border-left: 6rpx solid var(--color-primary);
  border-radius: 3rpx;
}

.section-icon {
  font-size: 24rpx;
  margin-left: -8rpx;
}

/* ── 对比卡片背景由 tier 数据的 bgStartColor / bgEndColor 内联渲染 ── */

/* ==============================
   HERO 卡片
   ============================== */
.hero-card {
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 36rpx;
  box-shadow: 0 12rpx 40rpx -10rpx rgba(0, 0, 0, 0.35);
  position: relative;
}

.hero-card-bg-img {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}

.hero-card-content {
  padding: 40rpx 36rpx 32rpx;
  position: relative;
  z-index: 1;
}

.hero-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.hero-tier-name {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.hero-vip-badge {
  border: 2rpx solid;
  border-radius: 16rpx;
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.25);
}

.hero-vip-text {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
  margin-bottom: 36rpx;
}

/* Hero 进度条 */
.hero-progress-section {
  margin-top: 0;
}

.hero-progress-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 14rpx;
}

.hero-progress-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-progress-bar-bg {
  flex: 1;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  overflow: hidden;
}

.hero-progress-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.6s ease;
}

.hero-progress-fraction {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.75);
  white-space: nowrap;
}

.hero-max-badge {
  margin-top: 0;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.08);
  display: inline-block;
}

.hero-max-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: var(--font-weight-semibold);
  letter-spacing: 2rpx;
}

/* 装饰性 VIP 卡片（右上角） */
.hero-decorative-card {
  position: absolute;
  right: -16rpx;
  top: -12rpx;
  width: 180rpx;
  height: 200rpx;
  border-radius: 24rpx;
  border: 2rpx solid;
  transform: rotate(12deg);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.4);
}

.hero-decorative-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.hero-decorative-text {
  font-size: 24rpx;
  font-weight: 800;
  font-style: italic;
  letter-spacing: 4rpx;
  opacity: 0.7;
}

/* ==============================
   等级对比 - 横向滚动卡片
   ============================== */
.tier-compare-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 40rpx;
  -webkit-overflow-scrolling: touch;
}

.tier-compare-list {
  display: inline-flex;
  gap: 20rpx;
  padding: 4rpx 4rpx 12rpx 4rpx;
}

.tier-compare-card {
  display: inline-flex;
  flex-direction: column;
  width: 260rpx;
  min-width: 260rpx;
  padding: 28rpx 24rpx 24rpx;
  border-radius: 24rpx;
  position: relative;
  white-space: normal;
  overflow: hidden;
  border: 4rpx solid transparent;
  transition: all 0.25s ease;
}

/* 所有卡片默认统一外观，不再区分 current/active */
.tier-compare-card.compare-card-active {
  /* 保持与默认一致的样式，不做特殊处理 */
}

.tier-compare-card.compare-card-dimmed {
  opacity: 0.55;
}

/* 选中态：红色边框 + 发光 + 微提亮 */
.tier-compare-card.compare-card-selected {
  border-color: var(--color-primary);
  transform: translateY(-4rpx);
}

.compare-card-name {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.compare-card-badge {
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
  display: inline-block;
  letter-spacing: 2rpx;
}

.compare-card-range {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: auto;
}

/* 已达成对勾 */
.compare-card-check {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.compare-card-check-text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

/* ==============================
   权益网格 - 2列
   ============================== */
.benefits-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 40rpx;
  background: var(--glass-bg-card);
  /* 去 backdrop-filter：切回前台时 WeChat 会重栅格化毛玻璃→闪烁；保留半透明底色即可 */
  border-radius: 28rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  border: var(--glass-border-subtle);
}

.benefit-grid-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: calc(50% - 6rpx);
  padding: 18rpx 16rpx;
  box-sizing: border-box;
  background: var(--glass-bg-light);
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.benefit-grid-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.benefit-grid-emoji {
  font-size: 30rpx;
}

.benefit-grid-info {
  flex: 1;
  min-width: 0;
}

.benefit-grid-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-on-surface);
  display: block;
  margin-bottom: 2rpx;
}

.benefit-grid-desc {
  font-size: 18rpx;
  color: var(--color-on-surface-variant);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.benefit-grid-value {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary-dark);
  flex-shrink: 0;
}

/* 权益图标背景色 */
.benefit-icon-discount { background: #fcead7; }
.benefit-icon-points   { background: #fdf2d7; }
.benefit-icon-cashback { background: #e6f0fa; }
.benefit-icon-birthday { background: #e8f2e9; }
.benefit-icon-coupon   { background: #f4e6ec; }
.benefit-icon-shipping { background: #fae8db; }
.benefit-icon-service  { background: #e6f3f5; }
.benefit-icon-new      { background: #f0e6fa; }

/* ==============================
   等级规则卡片
   ============================== */
.rules-card {
  background: var(--glass-bg-card);
  border-radius: 28rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  border: var(--glass-border-subtle);
}

.rules-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.07);
}

.rules-row:last-child {
  border-bottom: none;
}

.rules-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.rules-info {
  flex: 1;
  min-width: 0;
}

.rules-tier-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-on-surface);
  display: block;
  margin-bottom: 2rpx;
}

.rules-tier-range {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
}

.rules-discount {
  flex-shrink: 0;
}

.rules-discount-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary-dark);
}

/* 规则底部说明 */
.rules-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 32rpx;
  margin-bottom: 8rpx;
  padding: 16rpx 24rpx;
  background: var(--glass-bg-light);
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.rules-footer-icon {
  font-size: 20rpx;
  flex-shrink: 0;
}

.rules-footer-text {
  font-size: 20rpx;
  color: var(--color-on-surface-variant);
  text-align: center;
}
