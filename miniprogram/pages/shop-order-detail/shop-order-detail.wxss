/* pages/shop-order-detail/shop-order-detail.wxss — 商城订单详情（黏土风；无 backdrop-filter） */
.sod-page { min-height: 100vh; box-sizing: border-box; }

/* 顶部返回栏 */
.sod-top-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx 20rpx;
  background: var(--clay-bg-nav);
  border-bottom: var(--clay-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(120, 108, 94, 0.10);
}
.sod-back-btn {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-full);
  background: var(--clay-bg-card); border: var(--clay-border-subtle);
  display: flex; align-items: center; justify-content: center;
}
.sod-back-placeholder { background: transparent; border: none; box-shadow: none; }
.sod-back-icon { font-size: 48rpx; line-height: 1; color: var(--color-on-surface); }
.sod-top-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }

/* 状态头部 */
.sod-status-card {
  margin: 24rpx 32rpx; padding: 36rpx 28rpx; border-radius: var(--radius-card);
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  background: var(--clay-bg-card); border: var(--clay-border-subtle); box-shadow: var(--clay-shadow-card);
  position: relative; overflow: hidden;
}
.sod-status-bg {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0;
}
.sod-status-card.status-pending { border-color: #F0A030; }
.sod-status-card.status-paid { border-color: #4A90D9; }
.sod-status-card.status-shipped { border-color: #7B5BB8; }
.sod-status-card.status-completed { border-color: #52A854; }
.sod-status-card.status-cancelled { border-color: #C0C0C0; }
.sod-status-icon { font-size: 72rpx; line-height: 1.2; position: relative; z-index: 1; }
.sod-status-label { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); position: relative; z-index: 1; }
.sod-status-desc { font-size: 24rpx; color: var(--color-on-surface-variant); position: relative; z-index: 1; }

/* section */
.sod-section { margin: 0 32rpx 20rpx; padding: 24rpx 28rpx; display: flex; flex-direction: column; gap: 16rpx; background: var(--clay-bg-card); box-shadow: var(--clay-shadow-card); border: var(--clay-border-subtle); }
.sod-section-title { font-size: 28rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); padding-bottom: 12rpx; border-bottom: var(--clay-border-subtle); }

/* 收货信息 */
.sod-recipient { display: flex; flex-direction: column; gap: 6rpx; }
.sod-recipient-name { font-size: 28rpx; color: var(--color-on-surface); }
.sod-recipient-addr { font-size: 24rpx; color: var(--color-on-surface-variant); }

/* 物流 */
.sod-shipping { display: flex; flex-direction: column; gap: 6rpx; font-size: 26rpx; color: var(--color-on-surface); }
.sod-tracking { font-size: 24rpx; color: var(--color-on-surface-variant); }
.sod-shipping-action {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 16rpx; padding-top: 16rpx;
  border-top: var(--clay-border-subtle);
  font-size: 26rpx; color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.sod-shipping-action:active { opacity: 0.7; }
.sod-shipping-arrow { font-size: 36rpx; line-height: 1; }

/* 商品 */
.sod-item { display: flex; gap: 16rpx; }
.sod-item + .sod-item { padding-top: 16rpx; border-top: var(--clay-border-subtle); }
.sod-item-img { width: 120rpx; height: 120rpx; border-radius: var(--radius-sm); flex-shrink: 0; background: var(--color-surface-container); }
.sod-item-info { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 8rpx; min-width: 0; }
.sod-item-name { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.sod-item-bottom { display: flex; align-items: baseline; justify-content: space-between; }
.sod-item-price { font-size: 26rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }
.sod-item-qty { font-size: 24rpx; color: var(--color-on-surface-variant); }

/* 订单信息 */
.sod-info-row { display: flex; justify-content: space-between; align-items: center; padding: 4rpx 0; }
.sod-info-label { font-size: 26rpx; color: var(--color-on-surface-variant); }
.sod-info-val { font-size: 26rpx; color: var(--color-on-surface); }
.sod-info-total { padding-top: 16rpx; border-top: var(--clay-border-subtle); }
.sod-info-price { display: flex; align-items: baseline; gap: 2rpx; }
.sod-price-sym { font-size: 24rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }
.sod-price-val { font-size: 40rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }

/* 操作栏 */
.sod-actions { display: flex; gap: 16rpx; padding: 20rpx 32rpx; }
.sod-action-btn { flex: 1; height: 80rpx; border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: var(--font-weight-semibold); }
.sod-action-btn.primary { background: var(--clay-bg-primary); color: #FFFFFF; box-shadow: var(--clay-shadow-button); }
.sod-action-btn.outline { border: 1rpx solid var(--color-primary); color: var(--color-primary); background: transparent; }
.sod-action-btn.disabled { border: 1rpx solid rgba(180,160,140,0.28); color: var(--color-on-surface-variant); background: var(--clay-bg-light); opacity: 0.6; }
.sod-action-btn:active { transform: scale(0.97); }
.sod-action-btn.disabled:active { transform: none; }

/* 退款状态颜色 */
.sod-refund-success { color: #52A854; font-weight: var(--font-weight-semibold); }
.sod-refund-processing { color: #F0A030; font-weight: var(--font-weight-semibold); }
.sod-refund-failed { color: #BA1A1A; font-weight: var(--font-weight-semibold); }

/* 加载态 */
.sod-loading { display: flex; align-items: center; justify-content: center; padding-top: 240rpx; color: var(--color-on-surface-variant); font-size: 28rpx; }
