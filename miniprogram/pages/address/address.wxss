/* pages/address/address.wxss */

.page-container { padding-bottom: 0; }

/* ======= 顶部导航 ======= */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 24rpx;
  /* background & backdrop-filter 由 inline style {{navBarBg}} 控制 */
  border-bottom: var(--glass-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}
.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-primary);
}
.back-icon { width: 40rpx; height: 40rpx; }
.top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}
.top-spacer { width: 80rpx; }

.main-scroll { overflow-x: hidden; box-sizing: border-box; }
.scroll-inner { padding: 28rpx 40rpx 40rpx; }

/* ======= 地址卡片 ======= */
.address-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.address-card {
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.address-card:active {
  background: var(--glass-bg-elevated);
  transform: scale(0.985);
}

/* 头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
.card-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.card-name {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.default-badge {
  font-size: 20rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  background: var(--glass-bg-primary-light);
  border: var(--glass-border-colored);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  white-space: nowrap;
}
.card-phone {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
  flex-shrink: 0;
}

/* 地址 */
.card-address {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.card-region {
  font-size: 26rpx;
  color: var(--color-on-surface);
  font-weight: var(--font-weight-medium);
}
.card-detail {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.45;
}

/* 底部标签 + 操作 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.card-tags { display: flex; gap: 12rpx; }
.tag-badge {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  background: var(--glass-bg-light);
  border: var(--glass-border-subtle);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
}
.card-actions {
  display: flex;
  gap: 16rpx;
}
.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--glass-bg-light);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: var(--glass-border-subtle);
  font-size: 28rpx;
}
.action-btn:active {
  background: var(--glass-bg-elevated);
  transform: scale(0.9);
}

/* ======= 空状态 ======= */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx 100rpx;
  gap: 12rpx;
}
.empty-icon { font-size: 80rpx; opacity: 0.5; }
.empty-text {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
  font-weight: var(--font-weight-semibold);
  margin-top: 16rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.45;
}

/* ======= FAB 按钮 ======= */
.fab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(245,240,255,0) 0%, var(--glass-bg-nav) 40%);
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
  z-index: 50;
}
.fab-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
  padding: 28rpx 32rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-primary);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  box-shadow: var(--glass-shadow-button);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: var(--color-on-primary);
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
}
.fab-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
.fab-icon {
  font-size: 40rpx;
  font-weight: var(--font-weight-medium);
}

/* ======= 表单覆盖层 ======= */
.form-overlay {
  position: fixed;
  inset: 0;
  z-index: 1100;
  visibility: hidden;
}
.form-overlay.show { visibility: visible; }
.form-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--glass-bg-overlay);
  -webkit-backdrop-filter: blur(6px);
  backdrop-filter: blur(6px);
  opacity: 0;
  transition: opacity 0.3s;
}
.form-overlay.show::before { opacity: 1; }

.form-drawer {
  position: absolute;
  left: 0;
  right: 0;
  top: 190rpx;
  bottom: 0;
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  border-radius: 48rpx 48rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: var(--shadow-modal);
  border-top: var(--glass-border);
  overflow: hidden;
}
.form-drawer.show { transform: translateY(0); }

/* 表单导航 */
.form-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx 20rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}
.form-nav-back {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  padding: 12rpx 0;
}
.form-nav-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.form-nav-spacer { width: 80rpx; }

/* 表单滚动区 */
.form-body {
  flex: 1;
  height: 0;
  min-height: 0;
  padding: 28rpx 40rpx 0;
}

/* 表单区块 */
.form-section {
  margin-bottom: 24rpx;
}

/* 字段通用 */
.field-label {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
}

/* 选择器字段 */
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  background: var(--glass-bg-card);
  border-radius: var(--radius-sm);
  border: var(--glass-border-subtle);
}
.picker-value-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.picker-value {
  font-size: 28rpx;
  color: var(--color-on-surface);
}
.picker-value.placeholder {
  color: var(--color-on-surface-variant);
  opacity: 0.5;
}
.picker-arrow {
  font-size: 40rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.4;
  line-height: 1;
}

/* 输入字段 */
.input-field {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  background: var(--glass-bg-card);
  border-radius: var(--radius-sm);
  border: var(--glass-border-subtle);
}
.textarea-field {
  flex-direction: column;
  align-items: stretch;
  gap: 16rpx;
}
.field-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-on-surface);
  text-align: right;
}
.field-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: var(--color-on-surface);
  line-height: 1.5;
}
.field-placeholder {
  color: var(--color-on-surface-variant);
  opacity: 0.5;
}

/* 标签选择 */
.section-label {
  display: block;
  margin-bottom: 20rpx;
}
.tag-selector {
  display: flex;
  gap: 20rpx;
}
.tag-chip {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  background: var(--glass-bg-card);
  border-radius: var(--radius-full);
  border: var(--glass-border-subtle);
  transition: all 0.2s;
}
.tag-chip.active {
  color: var(--color-primary);
  background: var(--glass-bg-primary-light);
  border-color: rgba(0, 0, 0, 0.1);
  font-weight: var(--font-weight-semibold);
}

/* 开关行 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: var(--glass-bg-card);
  border-radius: var(--radius-sm);
  border: var(--glass-border-subtle);
}

.form-body-spacer { height: 40rpx; }

/* 表单底部 */
.form-footer {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  flex-shrink: 0;
}
.delete-outline-btn {
  flex-shrink: 0;
  padding: 28rpx 36rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-light);
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  text-align: center;
}
.delete-outline-btn:active {
  background: var(--glass-bg-primary-light);
  transform: scale(0.97);
}
.save-btn {
  flex: 1;
  padding: 28rpx 32rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-primary);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  box-shadow: var(--glass-shadow-button);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: var(--color-on-primary);
  font-size: 30rpx;
  font-weight: var(--font-weight-bold);
  text-align: center;
}
.save-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
