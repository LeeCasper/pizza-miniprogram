/* pages/member/member.wxss */

.top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx 24rpx;
  background: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.main-scroll {
  padding: 32rpx 0 72rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

.scroll-inner {
  padding: 0 40rpx;
}

/* 会员卡 */
.member-card {
  margin-bottom: 40rpx;
}

.member-card-inner {
  background: linear-gradient(135deg, #1a1c1c 0%, #303031 100%);
  border-radius: var(--radius-card);
  padding: 48rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 380rpx;
}

.card-glow {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 256rpx;
  height: 256rpx;
  background: rgba(255,255,255,0.05);
  border-radius: var(--radius-full);
  filter: blur(40rpx);
  pointer-events: none;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-status-label {
  display: block;
  font-size: 22rpx;
  color: #C8C6C5;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.card-level {
  font-size: 48rpx;
  font-weight: var(--font-weight-bold);
  color: #FFFFFF;
  letter-spacing: -2rpx;
}

.card-badge {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-card);
  border: 2rpx solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(20rpx);
}

.badge-icon {
  font-size: 48rpx;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.card-id-label {
  display: block;
  font-size: 22rpx;
  color: #C8C6C5;
  margin-bottom: 8rpx;
}

.card-id {
  font-size: 30rpx;
  color: #FFFFFF;
  letter-spacing: 6rpx;
}

.card-qr {
  width: 96rpx;
  height: 96rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-icon {
  font-size: 56rpx;
}

/* 积分区域 */
.points-section {
  padding: 48rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.points-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  text-transform: uppercase;
  letter-spacing: 6rpx;
  margin-bottom: 8rpx;
}

.points-value-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
  letter-spacing: -2rpx;
}

.points-unit {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
}

.points-actions {
  display: flex;
  gap: 16rpx;
}

.points-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  text-align: center;
}

.points-btn.primary {
  background: var(--color-primary);
  color: var(--color-on-primary);
}

.points-btn.outline {
  color: var(--color-on-surface);
  background: var(--color-surface);
  box-shadow: var(--shadow-elevated);
}

/* 会员权益 */
.benefits-section {
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  text-transform: uppercase;
  letter-spacing: 6rpx;
  margin-bottom: 24rpx;
}

.benefits-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.benefit-item {
  padding: 32rpx;
  text-align: center;
  overflow: hidden;
}

.benefit-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 16rpx;
}

.benefit-name {
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.benefit-desc {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 等级进度 */
.level-section {
  padding: 40rpx;
  margin-bottom: 48rpx;
}

.level-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.level-title {
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  flex-shrink: 0;
}

.level-next {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: var(--color-surface-container);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
  border-radius: var(--radius-full);
  transition: width 0.6s ease;
}

.progress-text {
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}
