/* pages/profile/profile.wxss */

/* ========== 顶部导航 ========== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 24rpx;
  background: var(--color-surface);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.top-bar-left,
.top-bar-right {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.top-bar-right {
  justify-content: flex-end;
}

.top-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.menu-btn,
.qr-btn {
  font-size: 40rpx;
  padding: 8rpx;
}

.main-scroll {
  padding-bottom: 72rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* ========== 用户信息 ========== */
.profile-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
}

.profile-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-full);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
}
.avatar-placeholder {
  border-radius: 9999rpx;
  background: var(--color-surface-container);
}
.edit-avatar-placeholder {
  border-radius: 16rpx;
  background: var(--color-surface-container);
}

.profile-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}

.profile-bio {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
}

.profile-vip-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, #fceabb 0%, #f8b500 50%, #d4940a 100%);
  box-shadow: 0 4rpx 16rpx rgba(212, 148, 10, 0.3);
  flex-shrink: 0;
}
.profile-vip-badge:active {
  transform: scale(0.94);
  opacity: 0.9;
}
.vip-crown {
  font-size: 30rpx;
  line-height: 1;
}
.vip-text {
  font-size: 24rpx;
  font-weight: var(--font-weight-bold);
  color: #5D3A00;
  white-space: nowrap;
}

/* 头像编辑遮罩 */
.avatar-wrap {
  position: relative;
}

.avatar-edit-mask {
  position: absolute;
  inset: 0;
  border-radius: var(--radius-full);
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s;
}

.avatar-wrap:active .avatar-edit-mask {
  opacity: 1;
}

.avatar-edit-icon {
  font-size: 36rpx;
  color: #FFFFFF;
}

/* 昵称行 */
.profile-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.profile-edit-hint {
  font-size: 24rpx;
  color: var(--color-primary);
  opacity: 0.5;
}

/* ========== 会员等级模块 ========== */
.member-tier-section {
  margin: 0 0 24rpx;
}

/* --- 轮播卡片 --- */
.member-swiper {
  height: 380rpx;
}

.tier-card-wrapper {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.tier-card {
  flex: 1;
  margin: 0 32rpx;
  border-radius: 24rpx;
  padding: 32rpx 32rpx 36rpx;
  position: relative;
  z-index: 1;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
}

.tier-card-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.tier-card-header {
  margin-bottom: 16rpx;
}

.tier-status-badge {
  display: inline-flex;
  padding: 6rpx 24rpx;
  border-radius: var(--radius-full);
}

.tier-status-text {
  font-size: 20rpx;
  font-weight: var(--font-weight-semibold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* --- 卡片主体 --- */
.tier-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-bottom: 24rpx;
}

.tier-name {
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 12rpx;
}

.tier-growth-text {
  font-size: 24rpx;
  opacity: 0.75;
}

/* --- 卡片底部 --- */
.tier-card-footer {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tier-lv-row {
  display: flex;
  align-items: center;
}

.tier-lv {
  font-size: 22rpx;
  font-weight: 700;
  opacity: 0.7;
}

.tier-progress-wrap {
  width: 100%;
  height: 8rpx;
  border-radius: var(--radius-full);
  overflow: hidden;
}

.tier-progress-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.5s ease;
}

/* --- 钻石卡片特殊样式 --- */
.tier-card-diamond {
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.tier-card-diamond::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at top right, rgba(255,255,255,0.15), transparent 60%);
  pointer-events: none;
  z-index: 0;
}

/* ========== 资产统计 ========== */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 24rpx 32rpx 24rpx;
  padding: 28rpx 8rpx;
  border-radius: var(--radius-card);
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats-value {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
  line-height: 1.2;
}

.stats-label {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  font-weight: var(--font-weight-medium);
}

.stats-divider {
  width: 2rpx;
  height: 56rpx;
  background: var(--color-outline-variant);
  border-radius: 2rpx;
}

/* ========== 公告浮窗 ========== */
.announce-float {
  position: fixed;
  right: 0;
  top: 35%;
  z-index: 150;
  transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}
.announce-float-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 72rpx;
  padding: 20rpx 12rpx;
  background: var(--color-surface);
  border-radius: 24rpx 0 0 24rpx;
  box-shadow: -4rpx 0 24rpx rgba(0,0,0,0.08);
}
.announce-float-tab:active {
  transform: scale(0.92);
  background: rgba(0,0,0,0.04);
}
.announce-float-tab-icon {
  font-size: 32rpx;
  line-height: 1;
}
.announce-float-tab-text {
  font-size: 20rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
  writing-mode: vertical-rl;
  letter-spacing: 4rpx;
}
.announce-float.expanded {
  right: 16rpx;
  top: 28%;
}
.announce-float-card {
  width: 420rpx;
  background: var(--color-surface);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-modal);
  overflow: hidden;
}
.announce-float-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--color-divider);
}
.announce-float-card-icon {
  font-size: 28rpx;
}
.announce-float-card-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.announce-float-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--color-surface-container-low);
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  flex-shrink: 0;
}
.announce-float-close:active {
  background: var(--color-surface-container-high);
  transform: scale(0.92);
}
.announce-float-card-body {
  display: block;
  padding: 24rpx;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.6;
}

/* ========== 金刚区 ========== */
.grid-actions {
  display: flex;
  justify-content: space-around;
  margin: 0 32rpx 24rpx;
  padding: 28rpx 16rpx;
  border-radius: 24rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.grid-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-xs);
}

.grid-icon-wrap:active {
  transform: scale(0.92);
  transition: transform 0.15s;
}

.grid-icon-red { background: rgba(211, 47, 47, 0.08); }
.grid-icon-gold { background: rgba(251, 192, 45, 0.12); }
.grid-icon-green { background: rgba(56, 142, 60, 0.08); }
.grid-icon-gray { background: var(--color-surface-container); }

.grid-icon {
  width: 64rpx;
  height: 64rpx;
}

.grid-label {
  font-size: 22rpx;
  color: var(--color-on-surface);
}

/* ========== 功能菜单 ========== */
.menu-section {
  padding: 0 32rpx 72rpx;
}

.menu-card {
  border-radius: 24rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.menu-item:active {
  background: var(--color-surface-container-low);
}

.menu-item-last {
  border-bottom: none;
}

.menu-icon {
  width: 52rpx;
  height: 52rpx;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-on-surface);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--color-on-surface-variant);
}

/* ========== 编辑个人信息抽屉 ========== */
.edit-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  visibility: hidden;
}
.edit-overlay.show { visibility: visible; }
.edit-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  opacity: 0;
  transition: opacity 0.3s;
}
.edit-overlay.show::before { opacity: 1; }

.edit-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-surface);
  border-radius: 40rpx 40rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-modal);
}
.edit-drawer.show { transform: translateY(0); }

.edit-drawer-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid var(--color-divider);
  flex-shrink: 0;
}
.edit-drawer-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.edit-drawer-save {
  font-size: 30rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  padding: 8rpx 16rpx;
}

.edit-drawer-body {
  flex: 1;
  padding: 40rpx;
  overflow-y: auto;
}

.edit-avatar-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
  padding: 24rpx;
  border-radius: var(--radius-card);
  background: var(--color-surface-container-low);
}
.edit-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}
.edit-avatar-tip {
  flex: 1;
}
.edit-avatar-tip-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

.edit-field {
  margin-bottom: 32rpx;
}
.edit-field-label {
  display: block;
  font-size: 26rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  margin-bottom: 16rpx;
}
.edit-field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-sm);
  background: var(--color-surface-container-low);
  font-size: 30rpx;
  color: var(--color-on-surface);
}

/* ===== 会员悬浮弹窗 ===== */
.member-overlay {
  position: fixed; inset: 0; z-index: 2000; visibility: hidden;
}
.member-overlay.show { visibility: visible; }
.member-overlay::before {
  content: ''; position: absolute; inset: 0;
  background: rgba(0,0,0,0.5);
  -webkit-backdrop-filter: blur(12rpx); backdrop-filter: blur(12rpx);
  opacity: 0; transition: opacity 0.35s;
}
.member-overlay.show::before { opacity: 1; }

.member-overlay-card {
  position: absolute; left: 24rpx; right: 24rpx; top: 50%;
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg); backdrop-filter: var(--glass-blur-lg);
  border-radius: 48rpx;
  box-shadow: var(--shadow-modal), 0 0 0 2rpx rgba(255,255,255,0.5);
  max-height: 80vh;
  transform: translateY(-50%) scale(0.85);
  opacity: 0;
  transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex; flex-direction: column; overflow: hidden;
}
.member-overlay-card.show { transform: translateY(-50%) scale(1); opacity: 1; }

.member-overlay-close {
  position: sticky; top: 0; right: 0; z-index: 10;
  display: flex; justify-content: flex-end; padding: 24rpx 24rpx 0;
}
.member-overlay-close text {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-full);
  background: rgba(0,0,0,0.06); display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-on-surface-variant); line-height: 64rpx; text-align: center;
}
.member-overlay-close:active text { background: rgba(0,0,0,0.12); transform: scale(0.92); }

.member-overlay-scroll { padding: 0 32rpx 40rpx; overflow-y: auto; flex: 1; }

/* 复用 main.wxss 中的 member-hero / member-card / privilege-* / coupon-banner / plan-* / member-cta-* / footer-link 等类名 */
.member-hero { display: flex; flex-direction: column; align-items: center; padding-top: 8rpx; padding-bottom: 32rpx; }
.member-card { width: 100%; margin-bottom: 24rpx; }
.member-card-inner {
  background: linear-gradient(135deg, #1a1c1c 0%, #303031 100%);
  border-radius: var(--radius-lg); padding: 40rpx; position: relative; overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.06);
  width: 100%; display: flex; flex-direction: column; justify-content: space-between; min-height: 320rpx;
}
.card-glow { position: absolute; top: -80rpx; right: -80rpx; width: 256rpx; height: 256rpx; background: rgba(255,255,255,0.05); border-radius: var(--radius-full); filter: blur(40rpx); pointer-events: none; }
.card-top { display: flex; justify-content: space-between; align-items: flex-start; }
.card-status-label { display: block; font-size: 22rpx; color: #C8C6C5; text-transform: uppercase; letter-spacing: 4rpx; margin-bottom: 8rpx; }
.card-level { font-size: 48rpx; font-weight: var(--font-weight-bold); color: #FFFFFF; letter-spacing: -2rpx; }
.card-badge { width: 88rpx; height: 88rpx; background: rgba(255,255,255,0.1); border-radius: var(--radius-card); border: 1rpx solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; -webkit-backdrop-filter: blur(20rpx); backdrop-filter: blur(20rpx); }
.badge-icon { font-size: 48rpx; }
.card-bottom { display: flex; justify-content: space-between; align-items: flex-end; }
.card-id-label { display: block; font-size: 22rpx; color: #C8C6C5; margin-bottom: 8rpx; }
.card-id { font-size: 30rpx; color: #FFFFFF; letter-spacing: 6rpx; }
.card-qr { width: 96rpx; height: 96rpx; background: #FFFFFF; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; }
.qr-icon { font-size: 56rpx; }
.member-hero-text { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.hero-headline { font-size: 44rpx; font-weight: 800; color: var(--color-on-surface); letter-spacing: -1rpx; line-height: 1.2; }
.hero-subtitle { font-size: 28rpx; color: var(--color-on-surface-variant); font-weight: 400; }

.privileges-section { width: 100%; margin-bottom: 24rpx; }
.privileges-scroll { width: 100%; }
.privileges-row { display: flex; gap: 24rpx; padding: 0 0 12rpx; }
.privilege-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; min-width: 112rpx; flex-shrink: 0; }
.privilege-icon-wrap { width: 112rpx; height: 112rpx; border-radius: 28rpx; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; box-shadow: inset 0 4rpx 8rpx rgba(255,255,255,0.8), 0 4rpx 16rpx rgba(0,0,0,0.06); -webkit-backdrop-filter: blur(16rpx); backdrop-filter: blur(16rpx); transition: transform 0.2s; }
.privilege-icon-wrap:active { transform: translateY(-4rpx); }
.privilege-icon-shine { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.5) 0%, transparent 50%); pointer-events: none; }
.privilege-icon { font-size: 46rpx; position: relative; z-index: 1; filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.1)); }
.privilege-label { font-size: 22rpx; font-weight: 500; color: var(--color-on-surface-variant); }
.privilege-icon-purple { background: rgba(132,85,239,0.2); border: 1rpx solid rgba(132,85,239,0.15); }
.privilege-icon-green { background: rgba(190,242,42,0.3); border: 1rpx solid rgba(190,242,42,0.2); }
.privilege-icon-gold { background: rgba(254,243,199,0.6); border: 1rpx solid rgba(251,192,45,0.25); }
.privilege-icon-pink { background: rgba(252,231,243,0.6); border: 1rpx solid rgba(236,72,153,0.2); }
.privilege-icon-teal { background: rgba(190,242,42,0.2); border: 1rpx solid rgba(16,185,129,0.15); }

.coupon-banner { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 24rpx; margin-bottom: 24rpx; background: rgba(233,233,221,0.4); -webkit-backdrop-filter: blur(24rpx); backdrop-filter: blur(24rpx); border-radius: 24rpx; border: 1rpx solid rgba(255,255,255,0.5); box-shadow: var(--shadow-sm); }
.coupon-banner-left { display: flex; align-items: center; gap: 12rpx; }
.coupon-banner-icon { font-size: 28rpx; }
.coupon-banner-text { font-size: 24rpx; font-weight: 600; color: var(--color-on-surface); }
.coupon-banner-help { width: 40rpx; height: 40rpx; border-radius: var(--radius-full); background: var(--color-surface-container-highest); display: flex; align-items: center; justify-content: center; }
.coupon-help-icon { font-size: 22rpx; font-weight: 700; color: var(--color-on-surface-variant); }

.plans-section { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.plan-card { border-radius: 28rpx; border: 3rpx solid var(--color-surface-container-highest); background: var(--color-surface); box-shadow: var(--shadow-sm); transition: all 0.3s ease; overflow: hidden; }
.plan-card:active { transform: scale(0.985); }
.plan-card-inner { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; position: relative; z-index: 1; }
.plan-selected { border-color: var(--color-primary-container); background: linear-gradient(135deg, #FFFBFB 0%, #FFF0EF 100%); box-shadow: 0 0 0 1rpx var(--color-primary-container), var(--shadow-elevated); }
.plan-selected .plan-card-inner { background: linear-gradient(180deg, rgba(255,255,255,0.6) 0%, transparent 100%); }
.plan-left { display: flex; flex-direction: column; gap: 8rpx; }
.plan-name-row { display: flex; align-items: center; gap: 12rpx; }
.plan-name { font-size: 28rpx; font-weight: 700; color: var(--color-on-surface); }
.plan-badge { font-size: 18rpx; font-weight: 700; color: var(--color-on-primary-container); background: var(--color-primary-container); padding: 4rpx 14rpx; border-radius: var(--radius-full); box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.6); }
.plan-price-row { display: flex; align-items: baseline; gap: 12rpx; }
.plan-price { font-size: 38rpx; font-weight: 800; color: var(--color-on-surface); letter-spacing: -1rpx; line-height: 1; }
.plan-original { font-size: 22rpx; font-weight: 500; color: var(--color-outline-variant); text-decoration: line-through; opacity: 0.7; }
.plan-radio { width: 48rpx; height: 48rpx; border-radius: var(--radius-full); border: 3rpx solid rgba(143,111,108,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.3s ease; box-shadow: var(--shadow-sm); }
.plan-radio.radio-checked { border-color: var(--color-primary-container); background: var(--color-primary-container); }
.plan-check-icon { font-size: 24rpx; font-weight: 700; color: var(--color-on-primary-container); transition: all 0.3s ease; }

.member-cta-section { display: flex; flex-direction: column; gap: 20rpx; padding-bottom: 8rpx; }
.member-cta-btn { width: 100%; padding: 24rpx 32rpx; background: var(--color-primary-container); border-radius: var(--radius-full); display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 12rpx 32rpx rgba(211,47,47,0.2), inset 0 4rpx 0 rgba(255,255,255,0.4); position: relative; overflow: hidden; transition: all 0.2s; border: 1rpx solid rgba(255,255,255,0.3); }
.member-cta-btn:active { transform: scale(0.98); opacity: 0.95; }
.cta-btn-shine { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.25) 0%, transparent 60%); pointer-events: none; }
.cta-main-text { font-size: 30rpx; font-weight: 700; color: var(--color-on-primary-container); position: relative; z-index: 1; letter-spacing: 2rpx; }
.cta-sub-text { font-size: 20rpx; font-weight: 500; color: var(--color-on-primary-container); opacity: 0.7; position: relative; z-index: 1; margin-top: 4rpx; }
.member-footer-links { display: flex; justify-content: center; align-items: center; gap: 20rpx; }
.footer-link { font-size: 20rpx; color: var(--color-on-surface-variant); opacity: 0.5; }
.footer-link:active { color: var(--color-primary); opacity: 0.8; }
.footer-divider { font-size: 18rpx; color: var(--color-on-surface-variant); opacity: 0.2; }
