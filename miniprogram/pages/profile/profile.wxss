/* pages/profile/profile.wxss */

/* ========== 顶部导航 ========== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 24rpx;
  background: var(--color-surface);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.top-bar-left,
.top-bar-right {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.top-bar-right {
  justify-content: flex-end;
}

.top-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.menu-btn,
.qr-btn {
  font-size: 40rpx;
  padding: 8rpx;
}

.main-scroll {
  padding-bottom: 72rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* ========== 用户信息 ========== */
.profile-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
}

.profile-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-full);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
}
.avatar-placeholder {
  border-radius: 9999rpx;
  background: var(--color-surface-container);
}
.edit-avatar-placeholder {
  border-radius: 16rpx;
  background: var(--color-surface-container);
}

.profile-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}

.profile-bio {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
}

/* 头像编辑遮罩 */
.avatar-wrap {
  position: relative;
}

.avatar-edit-mask {
  position: absolute;
  inset: 0;
  border-radius: var(--radius-full);
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s;
}

.avatar-wrap:active .avatar-edit-mask {
  opacity: 1;
}

.avatar-edit-icon {
  font-size: 36rpx;
  color: #FFFFFF;
}

/* 昵称行 */
.profile-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.profile-edit-hint {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
}

/* ========== 会员卡轮播 ========== */
.member-cards-section { margin: 0 0 8rpx; position: relative; }
.member-swiper { height: 340rpx; }

/* ── 卡片主体 ── */
.tier-card-wrap { padding: 0 36rpx; height: 100%; display: flex; align-items: center; box-sizing: border-box; transition: padding 0.3s ease; }
.tier-card-wrap.active { padding: 0 20rpx; }
.tier-card { width: 100%; height: 100%; border-radius: 28rpx; overflow: hidden; position: relative; box-shadow: 0 12rpx 28rpx -8rpx rgba(0,0,0,0.25); transition: opacity 0.3s ease; }

/* 卡片背景图（<image>标签层） */
.tier-card-bg-img {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}
.tier-card-active { opacity: 1; }
.tier-card-inactive { opacity: 0.55; }

/* ── 内容层 ── */
.tier-card-content { position: relative; z-index: 1; padding: 28rpx 32rpx 9rpx; height: 100%; display: flex; flex-direction: column; justify-content: space-between; box-sizing: border-box; }

/* ── 左上角等级标识（紧贴卡片边缘） ── */
.tier-status-pill {
  position: absolute;
  top: 0;
  left: 0;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx 10rpx 14rpx;
  border-radius: 28rpx 0 36rpx 0;
  background: #2f3836;
}
.tier-status-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin-left: 4rpx;
}
.tier-status-dot {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-top: -3rpx;
}
.tier-status-dot-img {
  width: 100%;
  height: 100%;
}

.tier-status-current .tier-status-text { color: #f3d493; }

/* ── 顶部操作按钮（右对齐） ── */
.tier-card-top { display: flex; justify-content: flex-end; }

/* ── 中间区域：等级名称 + 权益标签 ── */
.tier-card-middle { display: flex; flex-direction: column; gap: 10rpx; margin-top: 8rpx; }
.tier-card-title { font-size: 40rpx; font-weight: 800; letter-spacing: 2rpx; text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3); }

/* ── 底部 ── */
.tier-card-footer { margin-top: auto; }
.tier-card-progress-text { font-size: 22rpx; opacity: 0.8; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; padding-right: 12rpx; display: block; }

/* ── 成长进度条 ── */
.tier-progress-bar-wrap {
  margin-top: 10rpx;
  margin-bottom: 22rpx;
}
.tier-progress-bar-bg {
  width: 40%;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  overflow: hidden;
}
.tier-progress-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.6s ease;
}

/* ── 权益标签 ── */
.tier-benefits { display: flex; gap: 8rpx; flex-wrap: wrap; }
.tier-benefit-tag { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 8rpx; background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.85); line-height: 1.4; }
.tier-card-action { display: flex; align-items: center; gap: 4rpx; flex-shrink: 0; }
.tier-card-action-text { font-size: 22rpx; font-weight: 600; }
.tier-card-action-arrow { width: 28rpx; height: 28rpx; }
.tier-card-action:active { opacity: 0.7; }

/* ── 指示器 ── */
.tier-dots { display: flex; justify-content: center; align-items: center; gap: 12rpx; margin-top: 20rpx; }
.tier-dot { width: 12rpx; height: 12rpx; border-radius: 999rpx; background: rgba(0,0,0,0.12); }
.tier-dot.active { width: 28rpx; border-radius: 999rpx; }

/* ========== 公告浮窗 ========== */
.announce-float {
  position: fixed;
  right: 0;
  top: 35%;
  z-index: 150;
  transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}
.announce-float-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 72rpx;
  padding: 20rpx 12rpx;
  background: var(--color-surface);
  border-radius: 24rpx 0 0 24rpx;
  box-shadow: -4rpx 0 24rpx rgba(0,0,0,0.08);
}
.announce-float-tab:active {
  transform: scale(0.92);
  background: rgba(0,0,0,0.04);
}
.announce-float-tab-icon {
  font-size: 32rpx;
  line-height: 1;
}
.announce-float-tab-text {
  font-size: 20rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
  writing-mode: vertical-rl;
  letter-spacing: 4rpx;
}
.announce-float.expanded {
  right: 16rpx;
  top: 28%;
}
.announce-float-card {
  width: 420rpx;
  background: var(--color-surface);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-modal);
  overflow: hidden;
}
.announce-float-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--color-divider);
}
.announce-float-card-icon {
  font-size: 28rpx;
}
.announce-float-card-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.announce-float-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--color-surface-container-low);
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  flex-shrink: 0;
}
.announce-float-close:active {
  background: var(--color-surface-container-high);
  transform: scale(0.92);
}
.announce-float-card-body {
  display: block;
  padding: 24rpx;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.6;
}

/* ========== 金刚区 ========== */
.grid-actions {
  display: flex;
  justify-content: space-around;
  margin: 0 32rpx 24rpx;
  padding: 28rpx 16rpx;
  border-radius: 24rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.grid-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-xs);
}

.grid-icon-wrap:active {
  transform: scale(0.92);
  transition: transform 0.15s;
}

.grid-icon-red { background: rgba(211, 47, 47, 0.08); }
.grid-icon-gold { background: rgba(251, 192, 45, 0.12); }
.grid-icon-green { background: rgba(56, 142, 60, 0.08); }
.grid-icon-gray { background: var(--color-surface-container); }
.grid-icon-blue { background: rgba(25, 118, 210, 0.08); }

.grid-icon {
  width: 64rpx;
  height: 64rpx;
}
.grid-icon-emoji {
  font-size: 40rpx;
  line-height: 1;
}

.grid-label {
  font-size: 22rpx;
  color: var(--color-on-surface);
}

/* ========== 功能菜单 ========== */
.menu-section {
  padding: 0 32rpx 72rpx;
}

.menu-card {
  border-radius: 24rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.menu-item:active {
  background: var(--color-surface-container-low);
}

.menu-item-last {
  border-bottom: none;
}

.menu-icon {
  width: 52rpx;
  height: 52rpx;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-on-surface);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--color-on-surface-variant);
}

/* ========== 编辑个人信息抽屉 ========== */
.edit-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  visibility: hidden;
}
.edit-overlay.show { visibility: visible; }
.edit-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  opacity: 0;
  transition: opacity 0.3s;
}
.edit-overlay.show::before { opacity: 1; }

.edit-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-surface);
  border-radius: 40rpx 40rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-modal);
}
.edit-drawer.show { transform: translateY(0); }

.edit-drawer-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid var(--color-divider);
  flex-shrink: 0;
}
.edit-drawer-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.edit-drawer-save {
  font-size: 30rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  padding: 8rpx 16rpx;
}

.edit-drawer-body {
  flex: 1;
  padding: 40rpx;
  overflow-y: auto;
}

.edit-avatar-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
  padding: 24rpx;
  border-radius: var(--radius-card);
  background: var(--color-surface-container-low);
}
.edit-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}
.edit-avatar-tip {
  flex: 1;
}
.edit-avatar-tip-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

.edit-field {
  margin-bottom: 32rpx;
}
.edit-field-label {
  display: block;
  font-size: 26rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  margin-bottom: 16rpx;
}
.edit-field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-sm);
  background: var(--color-surface-container-low);
  font-size: 30rpx;
  color: var(--color-on-surface);
}
