<!--pages/profile/profile.wxml-->
<view class="page-container" style="padding-top: {{topBarTotalHeight}}px">
  <!-- 顶部导航 -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="top-bar-left">
      <text class="menu-btn" bindtap="onMenu">☰</text>
    </view>
    <text class="top-title">王姐手工披萨</text>
    <view class="top-bar-right">
      <text class="qr-btn" bindtap="onQrCode">📷</text>
    </view>
  </view>

  <scroll-view scroll-y class="main-scroll" enhanced show-scrollbar="{{false}}" style="flex: 1; height: 0;">
    <!-- 用户信息 - 横向布局 -->
    <view class="profile-header">
      <view class="profile-left">
        <view class="avatar-wrap" bindtap="onChooseAvatar">
          <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill" wx:if="{{userInfo.avatar}}"></image>
          <view class="avatar avatar-placeholder" wx:else></view>
          <view class="avatar-edit-mask">
            <text class="avatar-edit-icon">📷</text>
          </view>
        </view>
        <view class="profile-text" bindtap="onOpenEditProfile">
          <view class="profile-name-row">
            <text class="profile-name">{{userInfo.name}}</text>
            <text class="profile-edit-hint">✎</text>
          </view>
          <text class="profile-bio">{{userInfo.bio}}</text>
        </view>
      </view>
      <view class="profile-vip-badge" bindtap="onActivateMember">
        <text class="vip-crown">👑</text>
        <text class="vip-text">开通会员</text>
      </view>
    </view>

    <!-- 会员等级卡片 — Stitch 设计稿 1:1 -->
    <view class="member-tier-section">
      <!-- 横向滑动卡片 (snap) -->
      <scroll-view
        id="tierCardsScroll"
        class="tier-cards-scroll"
        scroll-x
        enhanced
        show-scrollbar="{{false}}"
        bindscroll="onTierCardsScroll"
      >
        <view class="tier-cards-row">
          <view
            class="tier-card"
            wx:for="{{tierCards}}"
            wx:key="key"
            style="background: {{item.gradient}}; color: {{item.textColor}}"
          >
            <view class="tier-card-badge" style="background: {{item.badgeBg}}">
              <text class="tier-card-badge-text">{{item.isCurrent ? '当前等级' : (item.isUnlocked ? '已解锁' : '未解锁')}}</text>
            </view>
            <view class="tier-card-body">
              <text class="tier-card-name">{{item.name}}</text>
              <text class="tier-card-growth">{{item.growthText}}</text>
            </view>
            <view class="tier-card-footer">
              <text class="tier-card-lv">{{item.lv}}</text>
              <view class="tier-progress-bar" style="background: {{item.progressTrack}}">
                <view class="tier-progress-fill" style="width: {{item.progressPercent}}%; background: {{item.progressFill}}"></view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 资产统计 -->
      <view class="stats-row">
        <view class="stats-item" bindtap="onMenuItem" data-action="coupons">
          <text class="stats-value">{{userInfo.coupons}}</text>
          <text class="stats-label">优惠券</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item" bindtap="onMenuItem" data-action="points">
          <text class="stats-value">{{userInfo.points}}</text>
          <text class="stats-label">积分</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value">{{cardCount}}</text>
          <text class="stats-label">卡包</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value">{{userInfo.balanceText}}</text>
          <text class="stats-label">余额</text>
        </view>
      </view>
    </view>

    <!-- 公告浮窗 -->
    <view class="announce-float {{announceOpen ? 'expanded' : ''}}" catchtap="onAnnounceToggle">
      <view class="announce-float-tab" wx:if="{{!announceOpen}}">
        <text class="announce-float-tab-icon">📢</text>
        <text class="announce-float-tab-text">公告</text>
      </view>
      <view class="announce-float-card" wx:if="{{announceOpen}}">
        <view class="announce-float-card-header">
          <text class="announce-float-card-icon">📢</text>
          <text class="announce-float-card-title">公告</text>
          <view class="announce-float-close" catchtap="onAnnounceClose">
            <text>✕</text>
          </view>
        </view>
        <text class="announce-float-card-body">全新手工薄脆披萨上市，限时八折体验！更多新品即将推出，敬请期待～</text>
      </view>
    </view>

    <!-- 金刚区 - 快捷入口 -->
    <view class="grid-actions">
      <view class="grid-item" bindtap="onMenuItem" data-action="points">
        <view class="grid-icon-wrap grid-icon-red">
          <image class="grid-icon" src="/images/grid-points.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">积分商城</text>
      </view>
      <view class="grid-item" bindtap="onMenuItem" data-action="coupons">
        <view class="grid-icon-wrap grid-icon-gold">
          <image class="grid-icon" src="/images/grid-coupons.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">优惠券</text>
      </view>
      <view class="grid-item" bindtap="onMenuItem" data-action="lucky">
        <view class="grid-icon-wrap grid-icon-green">
          <image class="grid-icon" src="/images/grid-lucky.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">幸运转盘</text>
      </view>
      <view class="grid-item" bindtap="onMenuItem" data-action="service">
        <view class="grid-icon-wrap grid-icon-gray">
          <image class="grid-icon" src="/images/grid-service.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">联系客服</text>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-card">
        <view class="menu-item" bindtap="onMenuItem" data-action="settings">
          <image class="menu-icon" src="/images/menu-settings.png" mode="aspectFit"></image>
          <text class="menu-name">设置</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onMenuItem" data-action="address">
          <image class="menu-icon" src="/images/menu-address.png" mode="aspectFit"></image>
          <text class="menu-name">地址管理</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item menu-item-last" bindtap="onMenuItem" data-action="favorites">
          <image class="menu-icon" src="/images/menu-favorites.png" mode="aspectFit"></image>
          <text class="menu-name">我的收藏</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
    <!-- 编辑个人信息抽屉 -->
    <view class="edit-overlay {{editProfileOpen ? 'show' : ''}}" catchtap="onCloseEditProfile">
      <view class="edit-drawer {{editProfileOpen ? 'show' : ''}}" catchtap="noop">
        <view class="edit-drawer-nav">
          <text class="edit-drawer-title">编辑个人信息</text>
          <text class="edit-drawer-save" bindtap="onSaveProfile">保存</text>
        </view>
        <view class="edit-drawer-body">
          <view class="edit-avatar-section" bindtap="onChooseAvatar">
            <image class="edit-avatar-img" src="{{editForm.avatar || userInfo.avatar}}" mode="aspectFill" wx:if="{{editForm.avatar || userInfo.avatar}}"></image>
            <view class="edit-avatar-img edit-avatar-placeholder" wx:else></view>
            <view class="edit-avatar-tip">
              <text class="edit-avatar-tip-text">点击更换头像</text>
            </view>
          </view>
          <view class="edit-field">
            <text class="edit-field-label">昵称</text>
            <input class="edit-field-input" value="{{editForm.name}}" bindinput="onNameInput" placeholder="请输入昵称" maxlength="20"/>
          </view>
          <view class="edit-field">
            <text class="edit-field-label">个性签名</text>
            <input class="edit-field-input" value="{{editForm.bio}}" bindinput="onBioInput" placeholder="请输入个性签名" maxlength="30"/>
          </view>
        </view>
      </view>
    </view>
    <view style="height: calc(120rpx + env(safe-area-inset-bottom))"></view>
  </scroll-view>

  <!-- 会员开通悬浮弹窗 -->
  <view class="member-overlay {{memberOverlayOpen ? 'show' : ''}}" catchtap="onMemberOverlayClose">
    <view class="member-overlay-card {{memberOverlayOpen ? 'show' : ''}}" catchtap="noop">
      <view class="member-overlay-scroll">
        <view class="member-overlay-close" catchtap="onMemberOverlayClose">
          <text>✕</text>
        </view>
        <view class="member-hero">
          <view class="member-card">
            <view class="member-card-inner">
              <view class="card-top">
                <view class="card-status">
                  <text class="card-status-label">Status</text>
                  <text class="card-level">{{userInfo.memberLevel || '金卡会员'}}</text>
                </view>
                <view class="card-badge"><text class="badge-icon">👑</text></view>
              </view>
              <view class="card-bottom">
                <view class="card-id-section">
                  <text class="card-id-label">Member ID</text>
                  <text class="card-id">**** **** 8294</text>
                </view>
                <view class="card-qr"><text class="qr-icon">📱</text></view>
              </view>
              <view class="card-glow"></view>
            </view>
          </view>
          <view class="member-hero-text">
            <text class="hero-headline">成为王姐会员</text>
            <text class="hero-subtitle">解锁全部功能</text>
          </view>
        </view>
        <view class="privileges-section">
          <scroll-view scroll-x class="privileges-scroll" enhanced show-scrollbar="{{false}}">
            <view class="privileges-row">
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-purple"><view class="privilege-icon-shine"></view><text class="privilege-icon">✂️</text></view>
                <text class="privilege-label">专属优惠</text>
              </view>
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-green"><view class="privilege-icon-shine"></view><text class="privilege-icon">⭐</text></view>
                <text class="privilege-label">生日惊喜</text>
              </view>
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-gold"><view class="privilege-icon-shine"></view><text class="privilege-icon">🎨</text></view>
                <text class="privilege-label">双倍积分</text>
              </view>
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-pink"><view class="privilege-icon-shine"></view><text class="privilege-icon">🎵</text></view>
                <text class="privilege-label">优先制作</text>
              </view>
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-teal"><view class="privilege-icon-shine"></view><text class="privilege-icon">📈</text></view>
                <text class="privilege-label">弹跳曲线</text>
              </view>
            </view>
          </scroll-view>
        </view>
        <view class="coupon-banner">
          <view class="coupon-banner-left">
            <text class="coupon-banner-icon">🎫</text>
            <text class="coupon-banner-text">会员每周可领取优惠券</text>
          </view>
          <view class="coupon-banner-help" bindtap="onMemberHelp">
            <text class="coupon-help-icon">?</text>
          </view>
        </view>
        <view class="plans-section">
          <view class="plan-card {{selectedPlan === 'annual' ? 'plan-selected' : ''}}" bindtap="onSelectPlan" data-plan="annual">
            <view class="plan-card-inner">
              <view class="plan-left">
                <view class="plan-name-row"><text class="plan-name">连续包年</text><text class="plan-badge">限时3.2折</text></view>
                <view class="plan-price-row"><text class="plan-price">¥199</text><text class="plan-original">¥620</text></view>
              </view>
              <view class="plan-radio {{selectedPlan === 'annual' ? 'radio-checked' : ''}}"><text class="plan-check-icon">{{selectedPlan === 'annual' ? '✓' : ''}}</text></view>
            </view>
          </view>
          <view class="plan-card {{selectedPlan === 'monthly' ? 'plan-selected' : ''}}" bindtap="onSelectPlan" data-plan="monthly">
            <view class="plan-card-inner">
              <view class="plan-left">
                <view class="plan-name-row"><text class="plan-name">连续包月</text><text class="plan-badge">限时6.9折</text></view>
                <view class="plan-price-row"><text class="plan-price">¥19.9</text><text class="plan-original">¥29</text></view>
              </view>
              <view class="plan-radio {{selectedPlan === 'monthly' ? 'radio-checked' : ''}}"><text class="plan-check-icon">{{selectedPlan === 'monthly' ? '✓' : ''}}</text></view>
            </view>
          </view>
        </view>
        <view class="member-cta-section">
          <view class="member-cta-btn" bindtap="onMemberSubscribe">
            <view class="cta-btn-shine"></view>
            <text class="cta-main-text">开始免费试用</text>
            <text class="cta-sub-text">7天后自动订阅</text>
          </view>
          <view class="member-footer-links">
            <text class="footer-link" bindtap="onMemberTerms">使用条款</text>
            <text class="footer-divider">|</text>
            <text class="footer-link" bindtap="onMemberPrivacy">隐私政策</text>
            <text class="footer-divider">|</text>
            <text class="footer-link" bindtap="onMemberRestore">恢复购买</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
