<!--pages/profile/profile.wxml-->
<view class="page-container" style="padding-top: {{topBarTotalHeight}}px">
  <!-- 顶部导航 -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="top-bar-left">
      <text class="menu-btn" bindtap="onMenu">☰</text>
    </view>
    <text class="top-title">王姐手工披萨</text>
    <view class="top-bar-right">
      <text class="qr-btn" bindtap="onQrCode">📷</text>
    </view>
  </view>

  <scroll-view scroll-y class="main-scroll" enhanced show-scrollbar="{{false}}" style="flex: 1; height: 0;">
    <!-- 个人信息卡片 -->
    <view class="profile-card">
      <!-- 顶部：头像 + 信息 + 统计 -->
      <view class="profile-card-top">
        <view class="avatar-wrap" bindtap="onAvatarTap">
          <image wx:if="{{userInfo.avatar}}" class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
          <view wx:else class="avatar avatar-placeholder"></view>
          <view class="avatar-edit-mask">
            <text class="avatar-edit-icon">📷</text>
          </view>
        </view>
        <view class="profile-info" bindtap="onProfileInfoTap">
          <view class="profile-name-row">
            <text class="profile-name" wx:if="{{userInfo.phone}}">{{userInfo.name}}</text>
            <text class="profile-name profile-name-login" wx:else>点击登录</text>
            <image class="profile-edit-hint" src="/images/edit.png" mode="aspectFit"></image>
          </view>
          <text class="profile-bio" wx:if="{{userInfo.phone}}">{{userInfo.bio}}</text>
          <text class="profile-bio" wx:else>微信一键登录</text>
          <text class="profile-member-id" wx:if="{{userInfo.phone}}">会员编号 #{{userInfo.memberId}}</text>
        </view>
        <view class="profile-stats">
          <view class="profile-stat" bindtap="onMenuItem" data-action="recharge">
            <text class="profile-stat-label">余额</text>
            <text class="profile-stat-value">{{userInfo.balanceText}}</text>
          </view>
          <view class="profile-stats-divider"></view>
          <view class="profile-stat" bindtap="onMenuItem" data-action="points">
            <text class="profile-stat-label">积分</text>
            <text class="profile-stat-value">{{userInfo.points || 0}}</text>
          </view>
        </view>
      </view>

      <!-- 生日行 — 已设置 -->
      <view class="birthday-row {{isBirthdayToday ? 'birthday-today' : ''}}" wx:if="{{hasBirthday}}" bindtap="onBirthdayRowTap">
        <text class="birthday-icon">{{isBirthdayToday ? '🎉' : '🎂'}}</text>
        <text class="birthday-text" wx:if="{{!isBirthdayToday}}">{{birthdayDisplay}} · {{birthdayCountdown}}</text>
        <text class="birthday-celebration" wx:if="{{isBirthdayToday}}">今天是您的生日！生日快乐！ 🎉</text>
        <text class="birthday-lock" wx:if="{{!isBirthdayToday}}">🔒</text>
      </view>
      <!-- 生日行 — 未设置 -->
      <view class="birthday-row birthday-unset" wx:if="{{!hasBirthday}}" bindtap="onBirthdayRowTap">
        <text class="birthday-icon">🎂</text>
        <text class="birthday-prompt">设置生日，享会员生日专属福利</text>
        <text class="birthday-arrow">›</text>
      </view>
    </view>

    <!-- 会员卡轮播 -->
    <view class="member-cards-section" wx:if="{{tierCards.length}}">
      <swiper class="member-swiper"
        bindchange="onTierChange"
        current="{{activeTierIndex}}">
        <swiper-item wx:for="{{tierCards}}" wx:key="levelKey">
          <view class="tier-card-wrap {{item.isActive ? 'active' : ''}}">
            <view class="tier-card {{item.isActive ? 'tier-card-active' : 'tier-card-inactive'}}" style="{{item.bgStyle}}">
              <image wx:if="{{item.bgImage}}" class="tier-card-bg-img" src="{{item.bgImage}}" mode="aspectFill"></image>
              <view class="tier-card-content">
                <!-- 左上角等级标识（紧贴卡片边缘） -->
                <view class="tier-status-pill tier-status-{{item.status}}">
                  <text class="tier-status-text">{{item.status === 'current' ? '当前等级' : item.status === 'achieved' ? '已达成' : '未解锁'}}</text>
                  <view class="tier-status-dot" wx:if="{{item.status === 'current'}}"><image class="tier-status-dot-img" src="/images/tier-badge.png" mode="aspectFit"></image></view>
                </view>
                <!-- 顶部行：操作按钮 -->
                <view class="tier-card-top">
                  <view class="tier-card-action" catchtap="onUpgradeTier" data-level-key="{{item.levelKey}}">
                    <text class="tier-card-action-text" style="color: #ffffff">{{item.actionText}}</text>
                    <image class="tier-card-action-arrow" src="/images/arrow-enter.png" mode="aspectFit"></image>
                  </view>
                </view>
                <!-- 中间：等级名称 + 权益标签 -->
                <view class="tier-card-middle">
                  <text class="tier-card-title" style="color: #ffffff">{{item.name}}</text>
                  <view class="tier-benefits" wx:if="{{item.discountText || item.pointsRewardRate > 1 || item.couponValue > 0}}">
                    <text class="tier-benefit-tag" wx:if="{{item.discountText}}">{{item.discountText}}</text>
                    <text class="tier-benefit-tag" wx:if="{{item.pointsRewardRate > 1}}">{{item.pointsRewardRate}}x积分</text>
                    <text class="tier-benefit-tag" wx:if="{{item.couponValue > 0}}">升级送¥{{item.couponValue}}券</text>
                  </view>
                </view>
                <!-- 底部：进度信息 -->
                <view class="tier-card-footer">
                  <view>
                    <text class="tier-card-progress-text" style="color: rgba(255,255,255,0.8)">{{item.progressText}}</text>
                    <view class="tier-progress-bar-wrap">
                      <view class="tier-progress-bar-bg">
                        <view class="tier-progress-bar-fill" style="width: {{item.progressPercent}}%; background: {{item.accentColor}}"></view>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
      <view class="tier-dots">
        <view class="tier-dot {{activeTierIndex === ti ? 'active' : ''}}"
          wx:for="{{tierCards}}" wx:key="levelKey" wx:for-index="ti"
          style="{{activeTierIndex === ti ? 'background:' + item.accentColor + '; box-shadow: 0 0 8rpx ' + item.accentColor : ''}}">
        </view>
      </view>
    </view>

    <!-- 公告浮窗 -->
    <view class="announce-float {{announceOpen ? 'expanded' : ''}}" catchtap="onAnnounceToggle">
      <view class="announce-float-tab" wx:if="{{!announceOpen}}">
        <text class="announce-float-tab-icon">📢</text>
        <text class="announce-float-tab-text">公告</text>
      </view>
      <view class="announce-float-card" wx:if="{{announceOpen}}">
        <view class="announce-float-card-header">
          <text class="announce-float-card-icon">📢</text>
          <text class="announce-float-card-title">公告</text>
          <view class="announce-float-close" catchtap="onAnnounceClose">
            <text>✕</text>
          </view>
        </view>
        <text class="announce-float-card-body">全新手工薄脆披萨上市，限时八折体验！更多新品即将推出，敬请期待～</text>
      </view>
    </view>

    <!-- 金刚区 - 快捷入口（四列两行） -->
    <view class="grid-actions">
      <view class="grid-item" bindtap="onMenuItem" data-action="points">
        <view class="grid-icon-wrap grid-icon-red">
          <image class="grid-icon" src="/images/grid-points.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">积分商城</text>
      </view>
      <view class="grid-item" bindtap="onMenuItem" data-action="coupons">
        <view class="grid-icon-wrap grid-icon-gold">
          <image class="grid-icon" src="/images/grid-coupons.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">优惠券</text>
      </view>
      <view class="grid-item" bindtap="onMenuItem" data-action="claimcenter">
        <view class="grid-icon-wrap grid-icon-red">
          <image class="grid-icon" src="/images/grid-claim.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">领券中心</text>
      </view>
      <view class="grid-item" bindtap="onMenuItem" data-action="lucky">
        <view class="grid-icon-wrap grid-icon-green">
          <image class="grid-icon" src="/images/grid-lucky.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">幸运转盘</text>
      </view>
      <view class="grid-item" bindtap="onMenuItem" data-action="shopOrders">
        <view class="grid-icon-wrap grid-icon-red">
          <image class="grid-icon" src="/images/grid-shop-orders.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">会员订单</text>
      </view>
      <view class="grid-item" bindtap="onMenuItem" data-action="logistics">
        <view class="grid-icon-wrap grid-icon-blue">
          <image class="grid-icon" src="/images/grid-logistics.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">我的物流</text>
      </view>
      <button class="grid-item contact-btn-reset" open-type="contact" session-from='{"userId":"{{userInfo.id}}","phone":"{{userInfo.phone}}","page":"profile"}' show-message-card="{{true}}" send-message-title="王姐手工披萨 · 在线客服" send-message-path="/pages/main/main">
        <view class="grid-icon-wrap grid-icon-gray">
          <image class="grid-icon" src="/images/grid-service.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">联系客服</text>
      </button>
      <view class="grid-item" bindtap="onMenuItem" data-action="recharge">
        <view class="grid-icon-wrap grid-icon-blue">
          <image class="grid-icon" src="/images/grid-recharge.png" mode="aspectFit"></image>
        </view>
        <text class="grid-label">余额充值</text>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-card">
        <view class="menu-item" bindtap="onMenuItem" data-action="settings">
          <image class="menu-icon" src="/images/menu-settings.png" mode="aspectFit"></image>
          <text class="menu-name">设置</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onMenuItem" data-action="address">
          <image class="menu-icon" src="/images/menu-address.png" mode="aspectFit"></image>
          <text class="menu-name">地址管理</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item menu-item-last" bindtap="onMenuItem" data-action="favorites">
          <image class="menu-icon" src="/images/menu-favorites.png" mode="aspectFit"></image>
          <text class="menu-name">我的收藏</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
    <!-- 编辑个人信息抽屉 -->
    <view class="edit-overlay {{editProfileOpen ? 'show' : ''}}" catchtap="onCloseEditProfile">
      <view class="edit-drawer {{editProfileOpen ? 'show' : ''}}" catchtap="noop">
        <view class="edit-drawer-nav">
          <text class="edit-drawer-title">编辑个人信息</text>
          <text class="edit-drawer-save" bindtap="onSaveProfile">保存</text>
        </view>
        <view class="edit-drawer-body">
          <view class="edit-avatar-section" bindtap="onChooseAvatar">
            <image class="edit-avatar-img" src="{{editForm.avatar || userInfo.avatar}}" mode="aspectFill" wx:if="{{editForm.avatar || userInfo.avatar}}"></image>
            <view class="edit-avatar-img edit-avatar-placeholder" wx:else></view>
            <view class="edit-avatar-tip">
              <text class="edit-avatar-tip-text">点击更换头像</text>
            </view>
          </view>
          <view class="edit-field">
            <text class="edit-field-label">昵称</text>
            <input class="edit-field-input" value="{{editForm.name}}" bindinput="onNameInput" placeholder="请输入昵称" maxlength="20"/>
          </view>
          <view class="edit-field">
            <text class="edit-field-label">个性签名</text>
            <input class="edit-field-input" value="{{editForm.bio}}" bindinput="onBioInput" placeholder="请输入个性签名" maxlength="30"/>
          </view>
          <view class="edit-field" wx:if="{{!userInfo.birthday}}">
            <text class="edit-field-label">生日</text>
            <picker mode="date" value="{{editForm.birthday}}" start="1930-01-01" end="2020-12-31" bindchange="onBirthdayChange">
              <view class="edit-field-picker">
                <text class="edit-field-picker-text {{editForm.birthday ? '' : 'placeholder'}}">{{editForm.birthday || '请选择生日日期'}}</text>
                <text class="edit-field-picker-arrow">›</text>
              </view>
            </picker>
          </view>
        </view>
      </view>
    </view>
    <view style="height: calc(120rpx + env(safe-area-inset-bottom))"></view>
  </scroll-view>
</view>

<!-- 微信快捷登录组件 -->
<quick-login
  visible="{{showQuickLogin}}"
  bind:done="onQuickLoginDone"
  bind:skip="onQuickLoginSkip"
/>
