<view class="page-container" style="padding-top: {{topBarTotalHeight}}px;">
  <!-- Full-screen background photo (reliable <image> layer, not WXSS url()) -->
  <image class="bg-img" src="/images/lucky-bg.jpg" mode="aspectFill"></image>

  <!-- Top bar -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="back-btn" bindtap="onBack">
      <image src="/images/back.png" class="back-icon" mode="aspectFit"></image>
    </view>
    <view class="top-title-wrap">
      <text class="spark">✨</text>
      <text class="top-title">幸运转盘</text>
      <text class="spark">✨</text>
    </view>
    <view class="top-spacer"></view>
  </view>

  <scroll-view scroll-y enhanced bounces="{{false}}" show-scrollbar="{{false}}" style="height: {{scrollViewHeight}}px; position: relative; z-index: 1;">
    <view class="lw-body">

      <!-- User stats card -->
      <view class="stats-card">
        <view class="stat-col" bindtap="onGetMore">
          <view class="stat-head">
            <image class="stat-deco deco-ticket" src="/images/lucky-ticket.png" mode="aspectFit"></image>
            <text class="stat-label">剩余抽奖次数</text>
          </view>
          <view class="stat-num-wrap">
            <text class="stat-num c-draw">{{drawsRemaining}}</text>
            <text class="stat-unit c-draw">次</text>
          </view>
          <view class="stat-btn b-draw">+ 获取更多 ›</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-col" bindtap="onPointsDetail">
          <view class="stat-head">
            <image class="stat-deco deco-coin" src="/images/lucky-points.png" mode="aspectFit"></image>
            <text class="stat-label">我的积分</text>
          </view>
          <view class="stat-num-wrap">
            <text class="stat-num c-point">{{userPoints}}</text>
            <text class="stat-unit c-point">分</text>
          </view>
          <view class="stat-btn b-point">积分明细 ›</view>
        </view>
      </view>

      <!-- The wheel -->
      <view class="wheel-zone">
        <view class="pedestal-glow"></view>
        <view class="pedestal"></view>
        <image class="deco-gift" src="/images/lucky-gift.png" mode="aspectFit"></image>
        <text class="deco-star">⭐</text>

        <view class="wheel-outer">
          <view class="bulb {{spinning ? 'flash' : ''}}" wx:for="{{bulbs}}" wx:key="*this" style="{{item}}"></view>
          <view class="wheel-inner">
            <view class="wheel" style="background-image: {{wheelBg}}; transform: rotate({{rotation}}deg); transition-duration: {{spinning ? '5s' : '0s'}};">
              <view wx:for="{{labels}}" wx:key="id" class="seg-label" style="{{item.style}}">
                <image wx:if="{{item.icon}}" class="seg-icon" src="{{item.icon}}" mode="aspectFit"></image>
                <text class="seg-name">{{item.name}}</text>
              </view>
            </view>
          </view>
          <view class="pointer"></view>
          <view class="spin-btn {{spinning ? 'disabled' : ''}}" bindtap="onSpin">
            <text class="spin-go">{{spinning ? '抽奖' : '开始'}}</text>
            <text class="spin-go2">{{spinning ? '中…' : '抽奖'}}</text>
          </view>
        </view>
      </view>

      <!-- Status line -->
      <view class="status-line">
        <text wx:if="{{freeRemaining > 0}}">今日免费剩 {{freeRemaining}} 次</text>
        <text wx:elif="{{drawsRemaining > 0}}">加抽 {{pointsCost}} 积分/次 · 当前 {{userPoints}} 积分</text>
        <text wx:else>今日次数已用完，明天再来~</text>
      </view>

      <!-- Info links -->
      <view class="info-card">
        <view class="info-item" bindtap="onOpenRules">
          <view class="info-icon icon-rule">📋</view>
          <view class="info-text">
            <text class="info-title">活动规则</text>
            <text class="info-sub">查看详细活动说明</text>
          </view>
          <text class="info-arrow">›</text>
        </view>
        <view class="info-vline"></view>
        <view class="info-item" bindtap="onOpenRecords">
          <view class="info-icon icon-rec">🏆</view>
          <view class="info-text">
            <text class="info-title">中奖记录</text>
            <text class="info-sub">看看谁中奖了</text>
          </view>
          <text class="info-arrow">›</text>
        </view>
      </view>

      <!-- Share: visuals are views/image (no button text-clipping); transparent button overlay catches the tap -->
      <view class="share-card">
        <image class="share-icon" src="/images/share.png" mode="aspectFit"></image>
        <view class="share-mid">
          <text class="share-title">分享活动 邀请好友</text>
          <text class="share-sub">邀请好友一起抽大奖</text>
        </view>
        <text class="share-arrow">›</text>
        <button class="share-hit" open-type="share" hover-class="none"></button>
      </view>

      <!-- Footer -->
      <view class="lw-footer">🛡 公平公正公开 · 中奖概率透明</view>

      <view style="height: calc(120rpx + env(safe-area-inset-bottom))"></view>
    </view>
  </scroll-view>

  <!-- Result modal -->
  <view class="result-overlay {{showResult ? 'show' : ''}}" catchtap="onCloseResult">
    <view class="result-card" catchtap="noop">
      <text class="result-emoji">{{resultBonus ? '🎡' : (resultThanks ? '😔' : '🎉')}}</text>
      <text class="result-title {{resultThanks ? 'result-title-miss' : ''}}">{{resultBonus ? '再来一次！' : (resultThanks ? '很遗憾，未中奖' : '恭喜中奖')}}</text>
      <text class="result-text">{{resultText}}</text>
      <button class="result-btn" hover-class="none" bindtap="onCloseResult">{{resultBonus ? '继续抽奖' : '知道了'}}</button>
    </view>
  </view>

  <!-- Rules modal -->
  <view class="result-overlay {{showRules ? 'show' : ''}}" catchtap="onCloseRules">
    <view class="rules-card" catchtap="noop">
      <text class="result-emoji">📋</text>
      <text class="result-title">活动规则</text>
      <view class="rules-list">
        <view class="rules-row"><text class="rules-dot">①</text><text class="rules-txt">每日有免费抽奖次数，用完后可消耗 {{pointsCost}} 积分加抽一次。</text></view>
        <view class="rules-row"><text class="rules-dot">②</text><text class="rules-txt">中奖奖品（优惠券 / 积分 / 余额）会自动发放到你的账户。</text></view>
        <view class="rules-row"><text class="rules-dot">③</text><text class="rules-txt">抽奖结果由服务器随机产生，公平公正公开。</text></view>
        <view class="rules-row"><text class="rules-dot">④</text><text class="rules-txt">今日剩余可抽 {{drawsRemaining}} 次。</text></view>
      </view>
      <button class="result-btn" hover-class="none" bindtap="onCloseRules">知道了</button>
    </view>
  </view>

  <!-- Records drawer -->
  <view class="records-overlay {{showRecords ? 'show' : ''}}" catchtap="onCloseRecords">
    <view class="records-drawer {{showRecords ? 'show' : ''}}" catchtap="noop">
      <view class="records-head">
        <text>中奖记录</text>
        <text class="records-close" bindtap="onCloseRecords">✕</text>
      </view>
      <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="records-scroll">
        <view wx:if="{{records.length === 0}}" class="records-empty">暂无记录</view>
        <view wx:for="{{records}}" wx:key="id" class="record-item">
          <view class="record-main">
            <text class="record-name">{{item.prizeName}}</text>
            <text class="record-time">{{item.createdAt}}</text>
          </view>
          <text class="record-src">{{item.sourceText}}</text>
        </view>
        <view style="height: calc(40rpx + env(safe-area-inset-bottom))"></view>
      </scroll-view>
    </view>
  </view>
</view>
