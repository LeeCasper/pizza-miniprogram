.page-container {
  min-height: 100vh; box-sizing: border-box; position: relative;
  background-image: linear-gradient(180deg, #F6E4D6 0%, #F7F1E9 42%, #FAF6EF 100%);
}

/* Top bar */
.top-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; padding: 0 24rpx 16rpx;
  background: var(--glass-bg-nav);
}
.back-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; }
.back-icon { width: 40rpx; height: 40rpx; }
.top-title-wrap { flex: 1; display: flex; align-items: center; justify-content: center; gap: 12rpx; }
.top-title { font-size: 34rpx; font-weight: 700; color: var(--color-on-surface); letter-spacing: 4rpx; }
.spark { font-size: 24rpx; }
.rule-pill {
  font-size: 22rpx; color: var(--color-primary); white-space: nowrap;
  padding: 8rpx 20rpx; border-radius: var(--radius-full);
  background: var(--color-primary-container);
  border: 1rpx solid rgba(192, 86, 58, 0.25);
}

.lw-body { display: flex; flex-direction: column; align-items: center; padding: 24rpx 32rpx 0; }

/* ── User stats card ── */
.stats-card {
  width: 100%; box-sizing: border-box;
  display: flex; align-items: stretch;
  background: var(--glass-bg-card); border-radius: var(--radius-lg);
  box-shadow: var(--glass-shadow-card); border: var(--glass-border-subtle);
  padding: 28rpx 16rpx; margin-top: 8rpx;
}
.stat-col {
  flex: 1; position: relative;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.stat-deco {
  position: absolute; top: 50%; left: 18rpx; transform: translateY(-50%);
  font-size: 40rpx; opacity: 0.5;
}
.deco-ticket { transform: translateY(-50%) rotate(-12deg); }
.stat-label { font-size: 22rpx; color: var(--color-on-surface-variant); margin-bottom: 6rpx; }
.stat-num-wrap { display: flex; align-items: flex-end; margin-bottom: 12rpx; }
.stat-num { font-size: 60rpx; line-height: 1; font-weight: 700; }
.stat-unit { font-size: 22rpx; margin-left: 4rpx; margin-bottom: 8rpx; }
.c-draw { color: var(--color-primary); }
.c-point { color: #C6873A; }
.stat-btn {
  font-size: 20rpx; padding: 4rpx 18rpx; border-radius: var(--radius-full);
  display: flex; align-items: center;
}
.b-draw { color: var(--color-primary); background: var(--color-primary-container); }
.b-point { color: #B0742B; background: #FBEFD6; }
.stat-divider { width: 1rpx; background: var(--color-divider); margin: 8rpx 2rpx; }

/* ── Wheel ── */
.wheel-zone {
  position: relative; width: 600rpx; height: 600rpx;
  margin-top: 56rpx; margin-bottom: 40rpx;
  display: flex; align-items: center; justify-content: center;
}
.pedestal-glow {
  position: absolute; bottom: -28rpx; left: 50%; transform: translateX(-50%);
  width: 70%; height: 70rpx; border-radius: 50%;
  background: rgba(192, 86, 58, 0.28); filter: blur(8rpx); z-index: 0;
}
.pedestal {
  position: absolute;
  bottom: -30rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 150rpx;
  border-radius: 0 0 99999rpx 99999rpx;
  background-image: linear-gradient(180deg, #dc6570 0%, #ec1414 100%);
  box-shadow: var(--glass-shadow-card);
  z-index: 0;
}
.deco-gift {
  position: absolute; left: -14rpx; bottom: -6rpx; z-index: 20;
  font-size: 64rpx; transform: rotate(-12deg);
  filter: drop-shadow(0 4rpx 8rpx rgba(120,108,94,0.25));
}
.deco-star {
  position: absolute; right: -10rpx; bottom: 30rpx; z-index: 20;
  font-size: 56rpx; transform: rotate(12deg);
  filter: drop-shadow(0 4rpx 8rpx rgba(120,108,94,0.25));
}

.wheel-outer {
  position: relative; z-index: 10;
  width: 600rpx; height: 600rpx; box-sizing: border-box;
  padding: 18rpx; border-radius: 50%;
  background-image: linear-gradient(135deg, #F4D592 0%, #E6B45E 100%);
  box-shadow: 0 10rpx 28rpx rgba(192, 86, 58, 0.30), inset 0 -6rpx 14rpx rgba(0,0,0,0.10);
  display: flex; align-items: center; justify-content: center;
}
.wheel-inner {
  width: 100%; height: 100%; border-radius: 50%; overflow: hidden;
  background: #FFFFFF; box-shadow: inset 0 2rpx 10rpx rgba(0,0,0,0.12);
  position: relative;
}
.wheel {
  width: 100%; height: 100%; border-radius: 50%; position: relative;
  transition-property: transform;
  transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
}
.seg-label {
  position: absolute; top: 50%; left: 50%; width: 0; height: 0;
  display: flex; justify-content: center;
}
.seg-name {
  font-size: 24rpx; font-weight: 600; color: #5A3A1A;
  white-space: nowrap; transform: translateX(-50%);
}

/* Light bulbs around the gold rim */
.bulb {
  position: absolute; width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #FFF8E8; z-index: 11;
  box-shadow: 0 0 6rpx #FFFFFF, 0 0 12rpx #EBC27A;
}
.bulb.flash { animation: bulbFlash 0.5s infinite alternate; }
@keyframes bulbFlash {
  from { background: #FFF8E8; box-shadow: 0 0 6rpx #FFFFFF, 0 0 12rpx #EBC27A; }
  to   { background: #FFE08A; box-shadow: 0 0 12rpx #FFE08A, 0 0 22rpx #E69A28; }
}

/* Pointer: downward triangle at top (server landing math depends on this) */
.pointer {
  position: absolute; top: -6rpx; left: 50%; transform: translateX(-50%);
  width: 0; height: 0; z-index: 12;
  border-left: 26rpx solid transparent;
  border-right: 26rpx solid transparent;
  border-top: 50rpx solid var(--color-primary);
  filter: drop-shadow(0 3rpx 3rpx rgba(120,108,94,0.30));
}

/* Central spin button */
.spin-btn {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 172rpx; height: 172rpx; border-radius: 50%;
  background-image: linear-gradient(135deg, #D06A4C 0%, #A8492F 100%);
  border: 8rpx solid #FFFFFF;
  box-shadow: 0 6rpx 18rpx rgba(168, 73, 47, 0.50), inset 0 2rpx 6rpx rgba(255,255,255,0.35);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  z-index: 13;
}
.spin-btn.disabled { opacity: 0.7; }
.spin-go { color: #FFFFFF; font-size: 38rpx; font-weight: 700; line-height: 1.15; }
.spin-go2 { color: #FFFFFF; font-size: 38rpx; font-weight: 700; line-height: 1.15; }

.status-line { margin-top: 8rpx; margin-bottom: 28rpx; font-size: 26rpx; color: var(--color-on-surface-variant); }

/* ── Info links card ── */
.info-card {
  width: 100%; box-sizing: border-box; display: flex; align-items: center;
  background: var(--glass-bg-card); border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card); border: var(--glass-border-subtle);
  padding: 20rpx 8rpx; margin-bottom: 28rpx;
}
.info-item { flex: 1; display: flex; align-items: center; justify-content: center; padding: 0 12rpx; }
.info-icon {
  width: 72rpx; height: 72rpx; border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; flex-shrink: 0;
}
.icon-rule { background: var(--color-primary-container); }
.icon-rec { background: #FBEFD6; }
.info-text { display: flex; flex-direction: column; margin-left: 16rpx; }
.info-title { font-size: 28rpx; font-weight: 700; color: var(--color-on-surface); }
.info-sub { font-size: 20rpx; color: var(--color-on-surface-variant); margin-top: 4rpx; }
.info-arrow { font-size: 32rpx; color: var(--color-outline); margin-left: 12rpx; }
.info-vline { width: 1rpx; height: 64rpx; background: var(--color-divider); }

/* ── Share button ── */
.share-btn {
  width: 100%; box-sizing: border-box; margin: 0;
  display: flex; align-items: center;
  padding: 28rpx 32rpx; border-radius: var(--radius-full);
  background-image: var(--glass-bg-primary);
  box-shadow: var(--glass-shadow-button);
  line-height: 1.3;
}
.share-btn::after { border: none; }
.share-icon { font-size: 44rpx; opacity: 0.9; }
.share-mid { flex: 1; display: flex; flex-direction: column; align-items: center; }
.share-title { color: #FFFFFF; font-size: 32rpx; font-weight: 700; letter-spacing: 2rpx; }
.share-sub { color: rgba(255,255,255,0.88); font-size: 22rpx; margin-top: 4rpx; }
.share-arrow { font-size: 36rpx; color: rgba(255,255,255,0.9); }

/* ── Footer ── */
.lw-footer {
  margin-top: 32rpx; text-align: center;
  font-size: 22rpx; color: #9C7A58; opacity: 0.85;
}

/* ── Result / Rules modal ── */
.result-overlay {
  position: fixed; inset: 0; z-index: 200;
  background: var(--glass-bg-overlay);
  display: flex; align-items: center; justify-content: center;
  visibility: hidden; opacity: 0; transition: opacity 0.2s;
}
.result-overlay.show { visibility: visible; opacity: 1; }
.result-card {
  width: 560rpx; box-sizing: border-box;
  background-image: var(--glass-bg-elevated);
  border-radius: var(--radius-lg); padding: 56rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: var(--shadow-modal);
}
.result-emoji { font-size: 80rpx; margin-bottom: 12rpx; }
.result-title { font-size: 40rpx; font-weight: 700; color: var(--color-primary); }
.result-text { margin-top: 20rpx; font-size: 30rpx; color: var(--color-on-surface); text-align: center; }
.result-btn {
  margin-top: 48rpx; width: 320rpx; height: 84rpx; line-height: 84rpx;
  background-image: var(--glass-bg-primary); color: #FFFFFF;
  border-radius: var(--radius-full); font-size: 30rpx; font-weight: 600;
}
.result-btn::after { border: none; }

/* Rules card reuses overlay; wider list body */
.rules-card {
  width: 600rpx; box-sizing: border-box;
  background-image: var(--glass-bg-elevated);
  border-radius: var(--radius-lg); padding: 48rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: var(--shadow-modal);
}
.rules-list { width: 100%; margin-top: 24rpx; }
.rules-row { display: flex; align-items: flex-start; margin-bottom: 20rpx; }
.rules-dot { color: var(--color-primary); font-size: 28rpx; margin-right: 12rpx; flex-shrink: 0; }
.rules-txt { font-size: 26rpx; color: var(--color-on-surface); line-height: 1.5; }

/* ── Records drawer ── */
.records-overlay {
  position: fixed; inset: 0; z-index: 200; background: var(--glass-bg-overlay);
  visibility: hidden; opacity: 0; transition: opacity 0.2s;
}
.records-overlay.show { visibility: visible; opacity: 1; }
.records-drawer {
  position: absolute; left: 0; right: 0; bottom: 0;
  max-height: 70vh; background-image: var(--glass-bg-elevated);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  transform: translateY(100%); transition: transform 0.25s;
  display: flex; flex-direction: column;
}
.records-drawer.show { transform: translateY(0); }
.records-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 32rpx; font-size: 32rpx; font-weight: 700; color: var(--color-on-surface);
}
.records-close { font-size: 36rpx; color: var(--color-on-surface-variant); }
.records-scroll { max-height: 56vh; padding: 0 32rpx; }
.records-empty { text-align: center; color: var(--color-on-surface-variant); padding: 80rpx 0; font-size: 28rpx; }
.record-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 0; border-bottom: 1rpx solid var(--color-divider);
}
.record-main { display: flex; flex-direction: column; }
.record-name { font-size: 30rpx; color: var(--color-on-surface); font-weight: 600; }
.record-time { font-size: 24rpx; color: var(--color-on-surface-variant); margin-top: 8rpx; }
.record-src { font-size: 26rpx; color: var(--color-primary); }
