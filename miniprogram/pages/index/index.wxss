/* pages/index/index.wxss */

/* 顶部导航栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx 24rpx;
  /* background & backdrop-filter 由 inline style {{navBarBg}} 控制 */
  border-bottom: var(--glass-border-subtle);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.brand-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.top-bar-right {
  position: absolute;
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.notify-btn {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  font-size: 40rpx;
}

.notify-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  border: 4rpx solid var(--color-surface);
}

/* 取餐切换 */
.pickup-toggle {
  padding: 32rpx 40rpx 24rpx;
}

.toggle-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  padding: 28rpx 40rpx;
  background: var(--glass-bg-primary-container);
  border: var(--glass-border-colored);
  color: var(--color-on-primary-container);
  border-radius: var(--radius-card);
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  box-shadow: var(--shadow-sm);
}

.toggle-icon-img {
  width: 48rpx;
  height: 48rpx;
}

/* 主视觉Banner轮播 */
.hero-section {
  margin: 0 40rpx 32rpx;
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.hero-swiper {
  border-radius: var(--radius-card);
}
.hero-slide {
  width: 100%;
  height: 100%;
  position: relative;
}
.hero-image {
  width: 100%;
  height: 100%;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  pointer-events: none;
}
.hero-tag {
  align-self: flex-start;
}
.hero-tag text {
  background: var(--color-primary-container);
  color: var(--color-on-primary-container);
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: var(--font-weight-semibold);
  letter-spacing: 2rpx;
}
.hero-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.hero-title {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  line-height: 1.2;
}
.hero-subtitle {
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
}

/* 分类筛选 */
.category-section {
  padding: 16rpx 0;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 40rpx;
  gap: 32rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 16rpx;
}

.category-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-card);
  border: var(--glass-border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  box-shadow: var(--glass-shadow-elevated);
}

.category-icon-wrap.active {
  background: rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.category-icon {
  width: 56rpx;
  height: 56rpx;
}

.category-name {
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
}

.category-name.active {
  color: var(--color-primary);
}

/* 滚动区域 */
.main-scroll {
  padding: 0 0 72rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 商品区域 */
.product-section {
  padding: 16rpx 40rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-background);
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 商品卡片 */
.product-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--glass-bg-card);
  border: var(--glass-border-subtle);
  border-radius: var(--radius-card);
  padding: 24rpx;
  box-shadow: var(--glass-shadow-card);
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: var(--color-surface-container-low);
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.product-meta {
  margin-bottom: 16rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-background);
  display: block;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: 30rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* 加购按钮 */
.add-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-light);
  border: var(--glass-border);
  box-shadow: var(--glass-shadow-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn:active {
  background: var(--color-primary-container);
}

.add-icon {
  font-size: 40rpx;
  color: var(--color-on-surface);
  font-weight: 300;
  line-height: 1;
}

/* 数量调节器 */
.qty-stepper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--glass-bg-card);
  border: var(--glass-border-subtle);
  border-radius: var(--radius-full);
  padding: 8rpx 12rpx;
  box-shadow: var(--shadow-elevated);
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.qty-btn:active {
  transform: scale(0.95);
}

.qty-plus {
  background: var(--color-primary-container);
}

.qty-icon {
  font-size: 36rpx;
  color: var(--color-on-surface);
  font-weight: 400;
  line-height: 1;
}

.qty-plus .qty-icon {
  color: var(--color-on-primary-container);
}

.qty-num {
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  min-width: 32rpx;
  text-align: center;
}

/* 购物车悬浮条 */
.cart-bar {
  position: fixed;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  padding: 0 32rpx;
  z-index: 90;
  transform: translateY(200rpx);
  opacity: 0;
  transition: all 0.3s ease;
}

.cart-bar.show {
  transform: translateY(0);
  opacity: 1;
}

.cart-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--glass-bg-dark);
  border: var(--glass-border-dark);
  color: #F2F0F0;
  border-radius: var(--radius-full);
  padding: 20rpx 20rpx 20rpx 40rpx;
  box-shadow: var(--shadow-modal);
}

.cart-bar-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cart-icon-wrap {
  position: relative;
}

.cart-icon {
  width: 56rpx;
  height: 56rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: var(--color-primary);
  color: var(--color-on-primary);
  font-size: 20rpx;
  font-weight: var(--font-weight-bold);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--color-on-surface);
  padding: 0 8rpx;
}

.cart-total {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
}

.cart-bar-btn {
  background: var(--glass-bg-primary);
  border: 1rpx solid rgba(255,255,255,0.2);
  color: var(--color-on-primary);
  padding: 20rpx 48rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  box-shadow: var(--glass-shadow-button);
}

/* 购物车抽屉 */
.cart-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  visibility: hidden;
}

.cart-overlay.show {
  visibility: visible;
}

.cart-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--glass-bg-overlay);
  opacity: 0;
  transition: opacity 0.3s;
}

.cart-overlay.show::before {
  opacity: 1;
}

.cart-drawer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--glass-bg-elevated);
  border: var(--glass-border);
  border-radius: 48rpx 48rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: var(--shadow-modal);
}

.cart-drawer.show {
  transform: translateY(0);
}

.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid var(--color-divider);
  position: sticky;
  top: 0;
  background: var(--color-surface);
  border-radius: 48rpx 48rpx 0 0;
}

.cart-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
}

.cart-clear {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  padding: 8rpx 16rpx;
}

.cart-items {
  flex: 1;
  padding: 24rpx 40rpx;
  overflow-y: auto;
}

.cart-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-item-name {
  font-size: 30rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-background);
  display: block;
}

.cart-item-price {
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.cart-empty {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-on-surface-variant);
  font-size: 28rpx;
}

.cart-footer {
  padding: 24rpx 40rpx;
  padding-bottom: calc(100rpx + 24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--color-divider);
}

.checkout-btn {
  width: 100%;
  padding: 28rpx;
  background: var(--glass-bg-primary);
  border: 1rpx solid rgba(255,255,255,0.2);
  color: var(--color-on-primary);
  border-radius: var(--radius-full);
  text-align: center;
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  box-shadow: var(--glass-shadow-button);
}

.checkout-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.pay-method-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.pay-method-item {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx;
  padding: 18rpx 16rpx; border-radius: var(--radius-sm);
  border: 2rpx solid var(--color-divider);
  background: rgba(255, 255, 255, 0.5); font-size: 26rpx;
  transition: all 0.2s ease;
}
.pay-method-item.active {
  border-color: var(--color-primary);
  background: rgba(197, 131, 255, 0.06);
  color: var(--color-primary); font-weight: var(--font-weight-semibold);
}
.pay-method-icon { width: 36rpx; height: 36rpx; flex-shrink: 0; }
.pay-method-label { font-size: 26rpx; }

/* ===== 产品详情弹窗 ===== */
.detail-overlay {
  position: fixed;
  inset: 0;
  z-index: 1100;
  visibility: hidden;
}
.detail-overlay.show { visibility: visible; }
.detail-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  /* 弹窗蒙层：半透明暗底，弹窗外页面变暗但仍可见（标准弹窗交互，非全白遮盖） */
  background: var(--glass-bg-overlay);
  opacity: 0;
  transition: opacity 0.3s;
}
.detail-overlay.show::before { opacity: 1; }

.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx 16rpx;
  flex-shrink: 0;
}
.detail-back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--glass-bg-light);
  border: var(--glass-border-subtle);
}
.detail-back-btn:active {
  background: var(--color-surface-container-high);
  transform: scale(0.94);
}
.detail-back-icon {
  width: 36rpx;
  height: 36rpx;
}
.detail-nav-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.detail-nav-spacer {
  width: 72rpx;
}

.detail-drawer {
  position: absolute;
  left: 0;
  right: 0;
  top: 190rpx;
  bottom: 0;
  background: var(--glass-bg-elevated);
  border: var(--glass-border);
  border-radius: 48rpx 48rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: var(--shadow-modal);
  overflow: hidden;
}
.detail-drawer.show { transform: translateY(0); }

.detail-body {
  flex: 1;
  height: 0;
  min-height: 0;
}
.detail-image {
  width: 100%;
  display: block;
  background: var(--color-surface-container-low);
}
.detail-header {
  padding: 32rpx 40rpx 0;
  margin-bottom: 24rpx;
}
.detail-title-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.detail-name {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
  flex: 1;
}
.detail-price {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  flex-shrink: 0;
}
.detail-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.detail-tag {
  font-size: 22rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-primary-container);
  background: var(--color-primary-container);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
}
.detail-size {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  background: var(--color-surface-container-low);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
}
.detail-desc {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.7;
  display: block;
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}
.detail-bottom-spacer {
  height: 24rpx;
}

.detail-footer {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0,0,0,0.06);
  background: var(--glass-bg-elevated);
  flex-shrink: 0;
}
.detail-stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--glass-bg-card);
  border: var(--glass-border-subtle);
  border-radius: var(--radius-full);
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}
.detail-stepper .qty-btn {
  width: 64rpx;
  height: 64rpx;
}
.detail-stepper .qty-icon {
  font-size: 40rpx;
}
.detail-qty-num {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  min-width: 48rpx;
  text-align: center;
}
.detail-add-btn {
  flex: 1;
  background: var(--glass-bg-primary);
  border: 1rpx solid rgba(255,255,255,0.2);
  color: var(--color-on-primary);
  border-radius: var(--radius-full);
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  box-shadow: var(--glass-shadow-button);
  white-space: nowrap;
}
.detail-add-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
