<!--pages/store/store.wxml-->
<view class="page-container" style="padding-top: {{topBarTotalHeight}}px">
  <!-- 顶部导航 -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="onBack">
      <text>←</text>
    </view>
    <text class="top-title">门店自取</text>
    <view class="top-spacer"></view>
  </view>

  <!-- 地图区域 -->
  <view class="map-section">
    <image class="map-image" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQVH-8n2F1qOKWKaD40T2E9oxSqdbkQlenhsxwKgEjhAKy75BVC5_xWjqj21KIQBuWrpDZ9sMEAYovR1lAaNJz8AVDXMrqNVU0pafIWJRozEDicPY7jcqm7LB5gAj6vyMP58DegFWYXWjYyuIPDVYIQ4XDkQg7rJNKKfjjmy7MXeefZ-p-aYyIyIaKiAGQ45COsjiz1KPt_OGIyRu-DdPiPbV_ahBeVatHwGeSMogdhwF4tIaSX6Zk7xktxMxjclkt_0QqnEZ2ND3J" mode="aspectFill"></image>
    <view class="map-actions">
      <view class="map-locate-btn">
        <text>📍</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="main-scroll" style="flex: 1; height: 0;">
    <!-- 门店信息卡片 -->
    <view class="store-card card">
      <view class="store-header">
        <view class="store-title-row">
          <text class="store-icon">🏪</text>
          <text class="store-name">王姐手工披萨</text>
          <text class="store-branch">(爱家店)</text>
        </view>
      </view>

      <!-- 地址 -->
      <view class="info-row">
        <text class="info-icon">📍</text>
        <view class="info-content">
          <text class="info-text">北京市朝阳区三里屯SOHO 1号商场 B1-102</text>
          <text class="info-sub">距离您大约 2.5 公里</text>
        </view>
        <view class="info-action">
          <text>查看地图</text>
        </view>
      </view>

      <!-- 营业时间 -->
      <view class="info-row">
        <text class="info-icon">🕐</text>
        <view class="info-content">
          <text class="info-text">周一至周日 <text class="bold">10:00 - 22:00</text></text>
        </view>
        <view class="status-badge open">
          <text>营业中</text>
        </view>
      </view>

      <!-- 电话 -->
      <view class="info-row">
        <text class="info-icon">📞</text>
        <view class="info-content">
          <text class="info-text">010-8888 8888</text>
        </view>
        <view class="call-btn">
          <text>📞</text>
        </view>
      </view>
    </view>

    <!-- 自取须知 -->
    <view class="info-card card-cream">
      <view class="info-card-header">
        <text class="info-card-icon">ℹ️</text>
        <text class="info-card-title">自取须知</text>
      </view>
      <view class="info-card-list">
        <view class="info-card-item">
          <text class="check-icon">✅</text>
          <text>订单制作通常需要 <text class="bold">15-20 分钟</text>。请根据提示时间前往门店取餐。</text>
        </view>
        <view class="info-card-item">
          <text class="check-icon">✅</text>
          <text>到店后，请向店员出示您的<text class="bold">取餐码</text>或预留手机号。</text>
        </view>
        <view class="info-card-item">
          <text class="check-icon">✅</text>
          <text>为保证比萨口感，建议您在制作完成后 10 分钟内取餐。</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <view class="action-btn outline" bindtap="onContactService">
        <text class="action-icon">🎧</text>
        <text>联系客服</text>
      </view>
      <view class="action-btn primary" bindtap="onStartOrder">
        <text>开始点餐</text>
      </view>
    </view>
  </scroll-view>
</view>
