/* pages/store/store.wxss */

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 24rpx;
  background: var(--glass-bg-nav);
  border-bottom: var(--glass-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-primary);
}
.back-icon { width: 40rpx; height: 40rpx; }

.top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.top-spacer {
  width: 80rpx;
}

/* 地图 */
.map-section {
  height: 400rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.map-component {
  width: 100%;
  height: 100%;
}

.map-actions {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
}

.map-locate-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.map-locate-icon {
  width: 36rpx;
  height: 36rpx;
}

.main-scroll {
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 门店卡片 */
.store-card {
  margin: 32rpx 40rpx;
  padding: 48rpx;
  background: var(--glass-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
}

.store-header {
  margin-bottom: 32rpx;
}

.store-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.store-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.store-name {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}

.store-branch {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon {
  width: 36rpx;
  height: 36rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-text {
  font-size: 28rpx;
  color: var(--color-on-surface);
  line-height: 1.5;
}

.info-sub {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
}

.bold {
  font-weight: var(--font-weight-bold);
}

.info-action {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-card);
  font-size: 22rpx;
  color: var(--color-primary);
  white-space: nowrap;
  align-self: center;
  background: var(--glass-bg-light);
  box-shadow: var(--glass-shadow-elevated);
  border: var(--glass-border);
}

.status-badge {
  padding: 8rpx 20rpx;
  background: var(--glass-bg-card);
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  border: var(--glass-border-subtle);
}

.status-badge.open {
  background: var(--color-tertiary-container);
  color: var(--color-tertiary);
}

.call-btn {
  box-sizing: border-box;
  padding: 12rpx 24rpx;
  background: var(--glass-bg-primary-container);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: var(--glass-border-colored);
  box-shadow: var(--glass-shadow-button);
}

.call-btn-hover {
  opacity: 0.85;
  transform: scale(0.97);
}

.call-btn-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.call-btn-text {
  font-size: 26rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-primary-container);
  line-height: 1;
}

/* 须知卡片 */
.info-card {
  margin: 0 40rpx 32rpx;
  padding: 48rpx;
  background: var(--glass-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
}

.info-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.info-card-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.info-card-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}

.info-card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-card-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.6;
}

.check-icon {
  flex-shrink: 0;
  font-size: 28rpx;
  margin-top: 2rpx;
}
