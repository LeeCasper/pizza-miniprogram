<!-- pages/shop-detail/shop-detail.wxml — 商品详情（Stitch 设计稿 1:1 还原） -->

<!-- 商城停用提示 -->
<view class="sd-page" wx:if="{{!shopEnabled && !loading}}">
  <view class="sd-top-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="sd-back-btn" bindtap="onBack"><text class="sd-back-icon">‹</text></view>
    <text class="sd-top-title">商品详情</text>
    <view class="sd-back-btn sd-back-placeholder"></view>
  </view>
  <view class="shop-closed">
    <image class="shop-closed-img" src="/images/shop-closed.gif" mode="widthFix"></image>
    <text class="shop-closed-title">正在开发中<text class="shop-closed-cursor">|</text></text>
  </view>
</view>

<view class="sd-page" wx:if="{{product}}">

  <!-- ═══ 顶部导航栏（固定 · 黏土风，与 shop-orders 一致） ═══ -->
  <view class="sd-top-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="sd-back-btn" bindtap="onBack"><text class="sd-back-icon">‹</text></view>
    <text class="sd-top-title">商品详情</text>
    <view class="sd-back-btn sd-back-placeholder"></view>
  </view>

  <!-- ═══ 内容滚动区 ═══ -->
  <scroll-view
    class="sd-scroll"
    scroll-y enhanced show-scrollbar="{{false}}"
    style="height: {{scrollViewHeight}}px; padding-top: {{topBarTotalHeight}}px;"
  >

    <!-- ── Hero 大图轮播 ── -->
    <view class="sd-hero">
      <swiper
        class="sd-hero-swiper"
        circular="{{images.length > 1}}"
        indicator-dots="{{false}}"
        bindchange="onHeroSwiperChange"
      >
        <swiper-item wx:for="{{images}}" wx:key="*this">
          <image class="sd-hero-img" src="{{item}}" mode="aspectFit"></image>
        </swiper-item>
      </swiper>
      <!-- 页标 -->
      <view class="sd-hero-counter" wx:if="{{images.length > 1}}">
        <text>{{currentImageIndex + 1}}/{{images.length}}</text>
      </view>
      <!-- 底部渐变过渡 -->
      <view class="sd-hero-fade"></view>
    </view>

    <!-- ── 商品信息卡（叠加 Hero，负 margin 上移） ── -->
    <view class="sd-info-card">
      <!-- 标题行：名称 + 收藏 -->
      <view class="sd-info-header">
        <view class="sd-info-titles">
          <text class="sd-name">{{product.name}}</text>
          <text class="sd-subtitle" wx:if="{{product.subtitle}}">{{product.subtitle}}</text>
        </view>
        <view class="sd-fav-btn {{product.isFavorited ? 'active' : ''}}" bindtap="onToggleFav">
          <text>{{product.isFavorited ? '♥' : '♡'}}</text>
        </view>
      </view>

      <!-- 价格行 -->
      <view class="sd-price-row">
        <view class="sd-price-main">
          <text class="sd-price-sym">¥</text>
          <text class="sd-price">{{product.price}}</text>
          <text class="sd-original" wx:if="{{product.original_price}}">¥{{product.original_price}}</text>
        </view>
        <text class="sd-sales">月销 {{product.sales || 0}}+</text>
      </view>

      <!-- 评分 -->
      <view class="sd-rating" wx:if="{{product.rating}}">
        <text>⭐ {{product.rating}} ({{product.reviewCount || 0}} 条评价)</text>
      </view>
    </view>

    <!-- ── 规格选择区 ── -->
    <view class="sd-selection">
      <!-- 尺寸 -->
      <view class="sd-sel-row">
        <text class="sd-sel-label">规格</text>
        <view class="sd-sel-chips">
          <view
            class="sd-chip {{selectedSize === index ? 'active' : ''}}"
            wx:for="{{sizeOptions}}" wx:key="*this"
            data-index="{{index}}"
            bindtap="onSizeSelect"
          ><text>{{item}}</text></view>
        </view>
      </view>

      <!-- 饼底 -->
      <view class="sd-sel-row">
        <text class="sd-sel-label">饼底</text>
        <view class="sd-sel-chips">
          <view
            class="sd-chip {{selectedCrust === index ? 'active' : ''}}"
            wx:for="{{crustOptions}}" wx:key="*this"
            data-index="{{index}}"
            bindtap="onCrustSelect"
          ><text>{{item}}</text></view>
        </view>
      </view>

      <!-- 数量 -->
      <view class="sd-sel-row">
        <text class="sd-sel-label">数量</text>
        <view class="sd-qty-stepper">
          <view class="sd-qty-btn {{quantity <= 1 ? 'disabled' : ''}}" catchtap="onQtyMinus"><text>−</text></view>
          <text class="sd-qty-val">{{quantity}}</text>
          <view class="sd-qty-btn" catchtap="onQtyPlus"><text>+</text></view>
        </view>
      </view>

      <!-- 配送信息 -->
      <view class="sd-sel-row sd-delivery-row" catchtap="onDeliveryTap">
        <text class="sd-sel-label">配送</text>
        <text class="sd-delivery-text">最快30分钟送达</text>
        <text class="sd-delivery-arrow">›</text>
      </view>
    </view>

    <!-- ── Tab 切换区 ── -->
    <view class="sd-tabs">
      <view class="sd-tab-headers">
        <view
          class="sd-tab-header {{activeTab === 'detail' ? 'active' : ''}}"
          data-tab="detail" bindtap="onTabChange"
        ><text>详情</text></view>
        <view
          class="sd-tab-header {{activeTab === 'ingredients' ? 'active' : ''}}"
          data-tab="ingredients" bindtap="onTabChange"
        ><text>配料</text></view>
        <view
          class="sd-tab-header {{activeTab === 'reviews' ? 'active' : ''}}"
          data-tab="reviews" bindtap="onTabChange"
        ><text>评价({{product.reviewCount || '0'}})</text></view>
      </view>

      <!-- Tab 内容：详情 -->
      <view class="sd-tab-content" hidden="{{activeTab !== 'detail'}}">
        <!-- 详情描述 -->
        <text class="sd-desc-text" wx:if="{{product.detail_desc}}">{{product.detail_desc}}</text>

        <!-- 商品详情图（独立于轮播图） -->
        <view class="sd-detail-gallery" wx:if="{{detailImages.length > 0}}">
          <image
            wx:for="{{detailImages}}"
            wx:key="*this"
            class="sd-detail-img"
            src="{{item}}"
            mode="widthFix"
          ></image>
        </view>

        <!-- 无详情图且无描述 -->
        <view class="sd-tab-placeholder" wx:if="{{!product.detail_desc && detailImages.length === 0}}">
          <text class="sd-placeholder-text">暂无详情信息</text>
        </view>
      </view>

      <!-- Tab 内容：配料 -->
      <view class="sd-tab-content sd-tab-placeholder" hidden="{{activeTab !== 'ingredients'}}">
        <text class="sd-placeholder-text">暂无配料信息</text>
      </view>

      <!-- Tab 内容：评价 -->
      <view class="sd-tab-content sd-tab-placeholder" hidden="{{activeTab !== 'reviews'}}">
        <text class="sd-placeholder-text">暂无评价</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view style="height: calc(200rpx + env(safe-area-inset-bottom));"></view>
  </scroll-view>

  <!-- ═══ 底部操作栏（固定）═ 三按钮：客服 | 加入购物车 | 立即购买 ═══ -->
  <view class="sd-bottom-bar">
    <view class="sd-service-btn" bindtap="onContactService">
      <text class="sd-service-icon">🎧</text>
      <text class="sd-service-label">客服</text>
    </view>
    <view class="sd-cart-btn" bindtap="onAddToCart">
      <text>加入购物车</text>
    </view>
    <view class="sd-buy-btn" bindtap="onBuy">
      <text>立即购买 ¥{{product.price}}</text>
    </view>
  </view>

  <!-- ═══ 确认订单抽屉 ═══ -->
  <view class="checkout-overlay {{checkoutOpen ? 'show' : ''}}" catchtap="onCloseCheckout">
    <view class="checkout-drawer {{checkoutOpen ? 'show' : ''}}" catchtap="noop">

      <!-- 顶栏：返回 + 标题 -->
      <view class="checkout-header">
        <view class="checkout-back-btn" catchtap="onCloseCheckout">
          <text class="checkout-back-icon">‹</text>
        </view>
        <text class="checkout-title">确认订单</text>
        <view class="checkout-back-placeholder"></view>
      </view>

      <scroll-view class="checkout-body" scroll-y enhanced show-scrollbar="{{false}}">

        <!-- ── 商品卡片 ── -->
        <view class="co-card co-product">
          <image class="co-prod-img" src="{{product.main_image}}" mode="aspectFill"></image>
          <view class="co-prod-info">
            <text class="co-prod-name">{{product.name}}</text>
            <view class="co-prod-specs" wx:if="{{sizeOptions[selectedSize] || crustOptions[selectedCrust]}}">
              <text class="co-prod-spec" wx:if="{{sizeOptions[selectedSize]}}">{{sizeOptions[selectedSize]}}</text>
              <text class="co-prod-spec" wx:if="{{crustOptions[selectedCrust]}}">{{crustOptions[selectedCrust]}}</text>
            </view>
            <view class="co-prod-bottom">
              <view class="co-prod-price">
                <text class="co-price-sym">¥</text>
                <text class="co-price-val">{{product.price}}</text>
              </view>
              <text class="co-prod-qty">×{{quantity}}</text>
            </view>
          </view>
        </view>

        <!-- ── 收货地址 / 配送 / 备注 / 支付 — 一体卡片 ── -->
        <view class="co-card co-settings">

          <!-- 收货地址 -->
          <view class="co-set-row" bindtap="onAddressTap">
            <image class="co-set-icon" src="/images/icon-address.png" mode="aspectFit"></image>
            <view class="co-set-body">
              <block wx:if="{{selectedAddress}}">
                <view class="co-set-title">
                  <text class="co-set-label">收货地址</text>
                  <text class="co-set-val">{{selectedAddress.name}} {{selectedAddress.phone}}</text>
                </view>
                <text class="co-set-sub">{{selectedAddress.region[0]}} {{selectedAddress.region[1]}} {{selectedAddress.region[2]}} {{selectedAddress.detail}}</text>
              </block>
              <text class="co-set-placeholder" wx:else>请添加收货地址</text>
            </view>
            <text class="co-set-arrow">›</text>
          </view>

          <!-- 配送方式 -->
          <view class="co-set-row">
            <image class="co-set-icon" src="/images/icon-shipping.png" mode="aspectFit"></image>
            <view class="co-set-body">
              <view class="co-set-title">
                <text class="co-set-label">配送方式</text>
                <text class="co-set-val">快递运输</text>
              </view>
              <text class="co-set-sub">预计 1-3 个工作日送达</text>
            </view>
            <text class="co-set-fee">¥ {{shippingFee}}.00</text>
          </view>

          <!-- 备注 -->
          <view class="co-set-row">
            <image class="co-set-icon" src="/images/icon-notes.png" mode="aspectFit"></image>
            <text class="co-set-label co-set-label-fixed">备注</text>
            <input class="co-set-input" placeholder="选填，请先和商家协商确认" value="{{note}}" bindinput="onNoteInput"/>
          </view>

          <!-- 支付方式 -->
          <view class="co-set-section">
            <view class="co-set-section-head">
              <image class="co-set-icon" src="/images/icon-payment.png" mode="aspectFit"></image>
              <text class="co-set-label">支付方式</text>
            </view>
            <view class="co-pay-list">
              <view class="co-pay-item {{paymentMethod === 'wechat' ? 'active' : ''}}" data-method="wechat" catchtap="onPaymentMethodChange">
                <view class="co-pay-radio">
                  <view class="co-pay-radio-dot" wx:if="{{paymentMethod === 'wechat'}}"></view>
                </view>
                <image class="co-pay-badge-img" src="/images/wechat-pay.png" mode="aspectFit"></image>
                <text class="co-pay-name">微信支付</text>
              </view>
              <view class="co-pay-item {{paymentMethod === 'balance' ? 'active' : ''}}" data-method="balance" catchtap="onPaymentMethodChange">
                <view class="co-pay-radio">
                  <view class="co-pay-radio-dot" wx:if="{{paymentMethod === 'balance'}}"></view>
                </view>
                <image class="co-pay-badge-img" src="/images/balance-pay.png" mode="aspectFit"></image>
                <text class="co-pay-name">余额支付</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 地址选择器（底部弹层） -->
        <view class="co-addr-picker-overlay {{showAddressPicker ? 'show' : ''}}" catchtap="onCloseAddressPicker">
          <view class="co-addr-picker {{showAddressPicker ? 'show' : ''}}" catchtap="noop">
            <view class="co-addr-picker-header">
              <text class="co-addr-picker-title">选择收货地址</text>
              <view class="co-addr-picker-close" catchtap="onCloseAddressPicker">
                <text>✕</text>
              </view>
            </view>
            <scroll-view class="co-addr-picker-list" scroll-y enhanced show-scrollbar="{{false}}">
              <view
                class="co-addr-picker-item {{selectedAddressId === item.id ? 'active' : ''}}"
                wx:for="{{addresses}}"
                wx:key="id"
                data-id="{{item.id}}"
                bindtap="onSelectAddress"
              >
                <view class="co-addr-picker-radio">
                  <view class="co-addr-picker-dot" wx:if="{{selectedAddressId === item.id}}"></view>
                </view>
                <view class="co-addr-picker-info">
                  <view class="co-addr-picker-contact">
                    <text class="co-addr-picker-name">{{item.name}}</text>
                    <text class="co-addr-picker-phone">{{item.phone}}</text>
                    <view class="co-addr-tag" wx:if="{{item.tag}}">
                      <text>{{item.tag}}</text>
                    </view>
                    <view class="co-addr-tag co-addr-tag-default" wx:if="{{item.isDefault}}">
                      <text>默认</text>
                    </view>
                  </view>
                  <text class="co-addr-picker-detail">{{item.region[0]}} {{item.region[1]}} {{item.region[2]}} {{item.detail}}</text>
                </view>
              </view>
            </scroll-view>
            <view class="co-addr-picker-footer">
              <view class="co-addr-manage-btn" bindtap="onManageAddresses">
                <image class="co-addr-manage-icon" src="/images/icon-manage-address.png" mode="aspectFit"></image><text>管理地址</text>
              </view>
            </view>
          </view>
        </view>

        <!-- ── 订单金额明细 ── -->
        <view class="co-card co-summary">
          <view class="co-sum-row">
            <text class="co-sum-label">商品金额</text>
            <text class="co-sum-val">¥ {{product.price}}</text>
          </view>
          <view class="co-sum-row">
            <text class="co-sum-label">运费</text>
            <text class="co-sum-val">¥ {{shippingFee}}.00</text>
          </view>
          <view class="co-sum-row co-sum-coupon" wx:if="{{false}}">
            <text class="co-sum-label">优惠券</text>
            <text class="co-sum-val co-sum-discount">- ¥ 0.00</text>
          </view>
        </view>

        <!-- 底部安全区占位 -->
        <view style="height: calc(160rpx + env(safe-area-inset-bottom));"></view>
      </scroll-view>

      <!-- ── 底部提交栏 ── -->
      <view class="checkout-bottom-bar">
        <view class="co-bottom-total">
          <text class="co-bottom-label">实付款：</text>
          <view class="co-bottom-price">
            <text class="co-bottom-sym">¥</text>
            <text class="co-bottom-val">{{totalPrice}}</text>
          </view>
        </view>
        <view class="co-submit-btn {{submitting ? 'loading' : ''}}" bindtap="onSubmitOrder">
          <text>提交订单</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 加载态 -->
<view class="sd-loading" wx:elif="{{loading}}">
  <text>加载中…</text>
</view>
