/* pages/shop-detail/shop-detail.wxss — 商品详情（Stitch 设计稿 1:1 还原） */

/* ═══ 色值 Token（来自 Stitch 设计系统） ═══
   bg:         #fbf9f8    var(--sd-bg)
   surface:    #ffffff    var(--sd-surface)
   primary:    #a83225    var(--sd-primary)
   on-surface: #1b1c1c    var(--sd-on-surface)
   muted:      #58413e    var(--sd-muted)
   outline:    #8c716d    var(--sd-outline)
   outline-var:#e0bfba    var(--sd-outline-variant)
   surface-container: #f0eded
   ═══════════════════════════════════════════ */
.sd-page {
  --sd-bg: #fbf9f8;
  --sd-surface: #ffffff;
  --sd-primary: #a83225;
  --sd-on-surface: #1b1c1c;
  --sd-muted: #58413e;
  --sd-outline: #8c716d;
  --sd-outline-variant: #e0bfba;
  --sd-surface-container: #f0eded;

  min-height: 100vh;
  background: var(--sd-bg);
  box-sizing: border-box;
}

/* ── 顶部导航栏（固定 · 黏土风，与 shop-orders 一致） ── */
.sd-top-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx 20rpx;
  background: var(--clay-bg-nav);
  border-bottom: var(--clay-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(120, 108, 94, 0.10);
}
.sd-back-btn {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-full);
  background: var(--clay-bg-card); border: var(--clay-border-subtle);
  display: flex; align-items: center; justify-content: center;
}
.sd-back-placeholder { background: transparent; border: none; box-shadow: none; }
.sd-back-icon { font-size: 48rpx; line-height: 1; color: var(--color-on-surface); }
.sd-top-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }

/* ── 滚动区 ── */
.sd-scroll { background: var(--sd-bg); }

/* ═══ Hero 大图 — swiper 800rpx 高，aspectFit 不裁剪 ═══ */
.sd-hero { position: relative; width: 100%; }
.sd-hero-swiper { width: 100%; height: 800rpx; }
.sd-hero-img { width: 100%; height: 100%; }

/* 页标浮层 */
.sd-hero-counter {
  position: absolute; bottom: 48rpx; right: 24rpx; z-index: 10;
  padding: 4rpx 20rpx; border-radius: 100rpx;
  background: rgba(0,0,0,0.5);
}
.sd-hero-counter text { font-size: 22rpx; color: #fff; }

/* 底部渐变（Hero → 背景色过渡） */
.sd-hero-fade {
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 5;
  height: 64rpx;
  background: linear-gradient(to top, var(--sd-bg), transparent);
  pointer-events: none;
}

/* ═══ 商品信息卡（叠加 Hero，负 margin 上移） ═══ */
.sd-info-card {
  position: relative; z-index: 10;
  margin: -48rpx 32rpx 0;
  padding: 32rpx;
  background: var(--sd-surface);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.sd-info-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx; }
.sd-info-titles { flex: 1; }
.sd-name { font-size: 40rpx; font-weight: 700; color: var(--sd-on-surface); display: block; margin-bottom: 8rpx; }
.sd-subtitle { font-size: 24rpx; color: var(--sd-muted); display: block; }

/* 收藏按钮 */
.sd-fav-btn {
  width: 80rpx; height: 80rpx; border-radius: 50%; flex-shrink: 0; margin-left: 16rpx;
  background: rgba(186,26,26,0.08);
  display: flex; align-items: center; justify-content: center;
}
.sd-fav-btn text { font-size: 40rpx; color: #ba1a1a; }
.sd-fav-btn.active { background: rgba(186,26,26,0.15); }

/* 价格行 */
.sd-price-row { display: flex; align-items: baseline; justify-content: space-between; margin-top: 24rpx; }
.sd-price-main { display: flex; align-items: baseline; gap: 4rpx; }
.sd-price-sym { font-size: 28rpx; font-weight: 700; color: var(--sd-primary); }
.sd-price { font-size: 44rpx; font-weight: 700; color: var(--sd-primary); letter-spacing: -0.02em; }
.sd-original { font-size: 24rpx; color: var(--sd-outline); text-decoration: line-through; margin-left: 8rpx; }
.sd-sales { font-size: 24rpx; color: var(--sd-muted); }

/* 评分 */
.sd-rating { margin-top: 12rpx; font-size: 24rpx; color: #715642; display: flex; align-items: center; gap: 4rpx; }

/* ═══ 规格选择区 ═══ */
.sd-selection {
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  background: var(--sd-surface);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.sd-sel-row { display: flex; align-items: center; margin-bottom: 32rpx; }
.sd-sel-row:last-child { margin-bottom: 0; }
.sd-sel-label { width: 96rpx; font-size: 28rpx; font-weight: 400; color: var(--sd-muted); flex-shrink: 0; }

/* 选项 Chip */
.sd-sel-chips { display: flex; flex-wrap: wrap; gap: 16rpx; flex: 1; }
.sd-chip {
  padding: 12rpx 32rpx; border-radius: 100rpx;
  border: 2rpx solid var(--sd-outline-variant);
  background: var(--sd-surface);
}
.sd-chip text { font-size: 28rpx; font-weight: 600; color: var(--sd-on-surface); }
.sd-chip.active {
  border-color: var(--sd-primary);
  background: #ffdad5; /* primary-fixed */
}
.sd-chip.active text { color: var(--sd-primary); }

/* 数量选择器 */
.sd-qty-stepper {
  display: flex; align-items: center;
  background: var(--sd-surface-container);
  border-radius: 100rpx; padding: 4rpx;
}
.sd-qty-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.sd-qty-btn text { font-size: 40rpx; line-height: 1; color: var(--sd-muted); }
.sd-qty-btn.disabled { opacity: 0.3; }
.sd-qty-btn:active { background: #e4e2e1; border-radius: 50%; }
.sd-qty-val {
  width: 64rpx; text-align: center;
  font-size: 30rpx; font-weight: 700; color: var(--sd-on-surface);
}

/* 配送行 */
.sd-delivery-row {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--sd-outline-variant);
  margin-bottom: 0 !important;
}
.sd-delivery-text { font-size: 28rpx; color: var(--sd-on-surface); flex: 1; }
.sd-delivery-arrow { font-size: 36rpx; color: var(--sd-muted); }

/* ═══ Tab 切换区 ═══ */
.sd-tabs {
  margin: 24rpx 32rpx 0;
  background: var(--sd-surface);
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.sd-tab-headers {
  display: flex;
  border-bottom: 1rpx solid var(--sd-outline-variant);
}
.sd-tab-header {
  flex: 1; text-align: center;
  padding: 24rpx 0 20rpx;
  font-size: 28rpx; font-weight: 600; color: var(--sd-muted);
  border-bottom: 4rpx solid transparent;
}
.sd-tab-header.active {
  color: var(--sd-primary); font-weight: 700;
  border-bottom-color: var(--sd-primary);
}

/* Tab 内容 */
.sd-tab-content { padding: 32rpx; }

/* 详情描述 */
.sd-desc-text {
  display: block;
  margin-top: 32rpx; padding: 0 8rpx;
  font-size: 28rpx; color: var(--sd-on-surface);
  line-height: 1.8;
}

/* 商品详情图 */
.sd-detail-gallery {
  margin-top: 32rpx;
}
.sd-detail-img {
  display: block;
  width: 100%;
  border-radius: 12rpx;
}
.sd-detail-img + .sd-detail-img {
  margin-top: 16rpx;
}

/* Tab 占位 */
.sd-tab-placeholder {
  display: flex; align-items: center; justify-content: center;
  padding: 80rpx 0;
}
.sd-placeholder-text { font-size: 28rpx; color: var(--sd-muted); }

/* ═══ 底部操作栏（固定） ═══ */
.sd-bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 100;
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid var(--sd-outline-variant);
  box-shadow: 0 -4rpx 40rpx rgba(0,0,0,0.05);
}

/* 客服按钮 */
.sd-service-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  width: 96rpx; flex-shrink: 0;
}
.sd-service-btn:active { opacity: 0.7; }
.sd-service-icon { font-size: 40rpx; line-height: 1.1; }
.sd-service-label { font-size: 20rpx; color: var(--sd-muted); margin-top: 4rpx; }

/* 加入购物车按钮 */
.sd-cart-btn {
  flex: 1; height: 88rpx; border-radius: 100rpx;
  background: #eae8e7; /* surface-container-high */
  display: flex; align-items: center; justify-content: center;
}
.sd-cart-btn text { font-size: 28rpx; font-weight: 600; color: var(--sd-muted); }
.sd-cart-btn:active { filter: brightness(0.95); }

/* 立即购买按钮 */
.sd-buy-btn {
  flex: 1; height: 88rpx; border-radius: 100rpx;
  background: var(--sd-primary);
  display: flex; align-items: center; justify-content: center;
}
.sd-buy-btn text { font-size: 28rpx; font-weight: 600; color: #ffffff; }
.sd-buy-btn:active { filter: brightness(0.9); }

/* ═══ 确认订单抽屉 ═══ */
.checkout-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200;
  background: rgba(0,0,0,0.35);
  visibility: hidden; opacity: 0;
  transition: visibility 0s 0.3s, opacity 0.3s;
}
.checkout-overlay.show { visibility: visible; opacity: 1; transition: visibility 0s, opacity 0.3s; }

.checkout-drawer {
  position: absolute; left: 0; right: 0; bottom: 0;
  background: var(--clay-bg-nav);
  border-radius: 32rpx 32rpx 0 0;
  height: 92vh; display: flex; flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.checkout-drawer.show { transform: translateY(0); }

/* 顶栏 */
.checkout-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 24rpx 16rpx;
  border-bottom: var(--clay-border-subtle);
  flex-shrink: 0;
}
.checkout-back-btn {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-full);
  background: var(--clay-bg-card); border: var(--clay-border-subtle);
  display: flex; align-items: center; justify-content: center;
}
.checkout-back-icon { font-size: 48rpx; line-height: 1; color: var(--color-on-surface); }
.checkout-back-placeholder { width: 64rpx; height: 64rpx; }
.checkout-title {
  font-size: 34rpx; font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}

/* 滚动区 */
.checkout-body {
  flex: 1; overflow-y: auto;
  padding: 20rpx 24rpx 0;
  display: flex; flex-direction: column; gap: 16rpx;
}

/* ═══ 通用卡片 ═══ */
.co-card {
  background: var(--clay-bg-card);
  border: var(--clay-border-subtle);
  box-shadow: var(--clay-shadow-card);
  border-radius: 24rpx;
  padding: 28rpx;
}

/* ═══ 商品卡片 ═══ */
.co-product { display: flex; gap: 20rpx; }
.co-prod-img {
  width: 160rpx; height: 160rpx; border-radius: 16rpx;
  flex-shrink: 0; background: var(--clay-bg-light);
}
.co-prod-info {
  flex: 1; display: flex; flex-direction: column;
  justify-content: space-between; min-width: 0;
}
.co-prod-name {
  font-size: 28rpx; font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.co-prod-specs { display: flex; gap: 12rpx; margin-top: 4rpx; }
.co-prod-spec {
  font-size: 24rpx; color: var(--color-on-surface-variant);
}
.co-prod-bottom {
  display: flex; align-items: baseline; justify-content: space-between;
}
.co-prod-price { display: flex; align-items: baseline; gap: 2rpx; }
.co-price-sym { font-size: 22rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.co-price-val { font-size: 36rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.co-prod-qty { font-size: 24rpx; color: var(--color-on-surface-variant); }

/* ═══ 地址卡片 ═══ */
.co-address { display: flex; flex-direction: column; gap: 12rpx; }
.co-addr-header { display: flex; align-items: center; gap: 8rpx; }
.co-addr-icon { width: 44rpx; height: 44rpx; flex-shrink: 0; }
.co-addr-label { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); flex: 1; }
.co-addr-arrow { font-size: 40rpx; color: var(--color-on-surface-variant); line-height: 1; }
.co-addr-contact { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.co-addr-name { font-size: 30rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.co-addr-phone { font-size: 28rpx; color: var(--color-on-surface); }
.co-addr-tag {
  font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 8rpx;
  background: rgba(192,86,58,0.10); color: #C0563A;
}
.co-addr-tag-default {
  background: rgba(192,86,58,0.08); color: #C0563A;
}
.co-addr-detail {
  font-size: 24rpx; color: var(--color-on-surface-variant);
  line-height: 1.6;
}
.co-addr-empty { padding: 16rpx 0; }
.co-addr-empty-text { font-size: 28rpx; color: var(--color-on-surface-variant); }

/* ═══ 地址选择器 ═══ */
.co-addr-picker-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300;
  background: rgba(0,0,0,0.35);
  visibility: hidden; opacity: 0;
  transition: visibility 0s 0.3s, opacity 0.3s;
}
.co-addr-picker-overlay.show { visibility: visible; opacity: 1; transition: visibility 0s, opacity 0.3s; }
.co-addr-picker {
  position: absolute; left: 0; right: 0; bottom: 0;
  background: var(--clay-bg-nav);
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh; display: flex; flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.co-addr-picker.show { transform: translateY(0); }
.co-addr-picker-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: var(--clay-border-subtle);
  flex-shrink: 0;
}
.co-addr-picker-title { font-size: 32rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.co-addr-picker-close {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: var(--clay-bg-card); border: var(--clay-border-subtle);
  display: flex; align-items: center; justify-content: center;
}
.co-addr-picker-close text { font-size: 28rpx; color: var(--color-on-surface-variant); }
.co-addr-picker-list {
  flex: 1; overflow-y: auto; padding: 16rpx 24rpx;
  max-height: 480rpx;
}
.co-addr-picker-item {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
  background: var(--clay-bg-card);
  border: var(--clay-border-subtle);
  margin-bottom: 12rpx;
  transition: border-color 0.15s;
}
.co-addr-picker-item.active { border-color: #C0563A; background: #FDF0EB; }
.co-addr-picker-radio {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  border: 2rpx solid rgba(180,160,140,0.40);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-top: 4rpx;
}
.co-addr-picker-item.active .co-addr-picker-radio { border-color: #C0563A; }
.co-addr-picker-dot {
  width: 20rpx; height: 20rpx; border-radius: 50%;
  background: #C0563A;
}
.co-addr-picker-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.co-addr-picker-contact { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.co-addr-picker-name { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.co-addr-picker-phone { font-size: 26rpx; color: var(--color-on-surface); }
.co-addr-picker-detail {
  font-size: 24rpx; color: var(--color-on-surface-variant);
  line-height: 1.5; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.co-addr-picker-footer {
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: var(--clay-border-subtle);
  flex-shrink: 0;
}
.co-addr-manage-btn {
  width: 100%; height: 80rpx; border-radius: 20rpx;
  background: var(--clay-bg-elevated); border: var(--clay-border-subtle);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-on-surface);
}
.co-addr-manage-btn:active { background: var(--clay-bg-light); }

/* ═══ 输入框 ═══ */
.co-input {
  width: 100%; height: 76rpx; padding: 0 20rpx;
  border-radius: 16rpx;
  background: var(--clay-bg-elevated);
  border: var(--clay-border-subtle);
  font-size: 26rpx; color: var(--color-on-surface);
  box-sizing: border-box;
}

/* ═══ 配送方式 ═══ */
.co-shipping { padding: 0; overflow: hidden; }
.co-ship-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 28rpx;
}
.co-ship-left { display: flex; align-items: center; gap: 10rpx; }
.co-ship-icon { width: 44rpx; height: 44rpx; flex-shrink: 0; }
.co-ship-label { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.co-ship-right { display: flex; align-items: baseline; gap: 8rpx; }
.co-ship-name { font-size: 26rpx; color: var(--color-on-surface); }
.co-ship-fee { font-size: 26rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.co-ship-estimate {
  padding: 12rpx 28rpx;
  background: var(--clay-bg-elevated);
  border-top: var(--clay-border-subtle);
}
.co-ship-est-text { font-size: 22rpx; color: var(--color-on-surface-variant); }

/* ═══ 备注 ═══ */
.co-notes { display: flex; flex-direction: column; gap: 14rpx; }
.co-notes-header { display: flex; align-items: center; gap: 8rpx; }
.co-notes-icon { width: 44rpx; height: 44rpx; flex-shrink: 0; }
.co-notes-label { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.co-notes-input { background: var(--clay-bg-elevated); }

/* ═══ 支付方式 ═══ */
.co-payment { display: flex; flex-direction: column; gap: 20rpx; }
.co-pay-header { display: flex; align-items: center; gap: 8rpx; }
.co-pay-icon { width: 44rpx; height: 44rpx; flex-shrink: 0; }
.co-pay-title { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.co-pay-list { display: flex; flex-direction: column; gap: 14rpx; }
.co-pay-item {
  display: flex; align-items: center; gap: 16rpx;
  height: 80rpx; padding: 0 20rpx;
  border-radius: 20rpx;
  background: var(--clay-bg-elevated);
  border: var(--clay-border-subtle);
  transition: border-color 0.15s;
}
.co-pay-item.active { border-color: #C0563A; background: #FDF0EB; }
/* 自定义 radio */
.co-pay-radio {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  border: 2rpx solid rgba(180,160,140,0.40);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.co-pay-item.active .co-pay-radio { border-color: #C0563A; }
.co-pay-radio-dot {
  width: 20rpx; height: 20rpx; border-radius: 50%;
  background: #C0563A;
}
.co-pay-badge-img {
  width: 48rpx; height: 48rpx; flex-shrink: 0;
}
.co-pay-name { font-size: 28rpx; color: var(--color-on-surface); }

/* ═══ 订单金额明细 ═══ */
.co-summary { display: flex; flex-direction: column; gap: 14rpx; }
.co-sum-row { display: flex; justify-content: space-between; align-items: center; }
.co-sum-label { font-size: 26rpx; color: var(--color-on-surface-variant); }
.co-sum-val { font-size: 26rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.co-sum-discount { color: #C0563A; }

/* ═══ 底部提交栏 ═══ */
.checkout-bottom-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--clay-bg-nav);
  border-top: var(--clay-border-subtle);
  box-shadow: var(--clay-shadow-nav);
  flex-shrink: 0;
}
.co-bottom-total { display: flex; align-items: baseline; gap: 4rpx; }
.co-bottom-label { font-size: 26rpx; color: var(--color-on-surface); }
.co-bottom-price { display: flex; align-items: baseline; gap: 2rpx; }
.co-bottom-sym { font-size: 24rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.co-bottom-val { font-size: 44rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.co-submit-btn {
  height: 88rpx; padding: 0 56rpx; border-radius: 100rpx;
  background: var(--clay-bg-primary);
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--clay-shadow-button);
}
.co-submit-btn.loading { opacity: 0.6; }
.co-submit-btn text { font-size: 30rpx; font-weight: var(--font-weight-bold); color: #FFFFFF; }
.co-submit-btn:active { transform: scale(0.97); }

/* 加载态 */
.sd-loading { display: flex; align-items: center; justify-content: center; padding-top: 480rpx; color: var(--sd-muted); font-size: 28rpx; }
