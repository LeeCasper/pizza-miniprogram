<!-- 首页内容片段 -->
<!-- 取餐方式切换 -->
<view class="pickup-toggle">
  <view class="toggle-pill active" bindtap="onPickupToggle">
    <image class="toggle-icon-img" src="/images/store-pickup.png" />
    <text>门店自取</text>
  </view>
</view>

<!-- 主视觉Banner轮播 -->
<view class="hero-section">
  <swiper
    class="hero-swiper"
    autoplay
    circular
    interval="3500"
    duration="500"
    easing-function="easeInOutCubic"
    indicator-dots
    indicator-color="rgba(255,255,255,0.4)"
    indicator-active-color="#FFFFFF"
    bindchange="onBannerChange"
    style="height: 320rpx;"
  >
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="hero-slide" bindtap="onBannerTap" data-product-id="{{item.productId}}">
        <image class="hero-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="hero-overlay">
          <view class="hero-tag">
            <text>{{item.tag}}</text>
          </view>
          <view class="hero-text">
            <text class="hero-title">{{item.title}}</text>
            <text class="hero-subtitle">{{item.subtitle}}</text>
          </view>
        </view>
      </view>
    </swiper-item>
  </swiper>
</view>

<!-- 分类筛选 -->
<view class="category-section">
  <scroll-view scroll-x class="category-scroll" enhanced show-scrollbar="{{false}}">
    <view class="category-list">
      <view wx:for="{{categories}}" wx:key="key"
        class="category-item {{activeCategory === item.key ? 'active' : ''}}"
        bindtap="onCategoryChange" data-key="{{item.key}}">
        <view class="category-icon-wrap {{activeCategory === item.key ? 'active' : ''}}">
          <image class="category-icon" src="{{item.icon}}" mode="aspectFit"></image>
        </view>
        <text class="category-name {{activeCategory === item.key ? 'active' : ''}}">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 商品列表 -->
<view class="product-section">
  <view class="section-header">
    <text class="section-title">{{activeCategory === 'all' ? '全部商品' : activeCategory === 'pizza' ? '披萨' : activeCategory === 'durian' ? '榴莲饼' : '凤梨酥'}}</text>
  </view>
  <view class="product-list">
    <view wx:for="{{filteredProducts}}" wx:key="id" class="product-card" wx:if="{{item.visible !== false}}" bindtap="onProductTap" data-product="{{item}}">
      <image class="product-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="product-info">
        <view class="product-meta">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.desc}}</text>
        </view>
        <view class="product-bottom">
          <text class="product-price">¥ {{item.price}}</text>
          <view wx:if="{{!item.quantity}}" class="add-btn" catchtap="onAddToCart" data-product="{{item}}">
            <text class="add-icon">+</text>
          </view>
          <view wx:else class="qty-stepper">
            <view class="qty-btn" catchtap="onDecrease" data-id="{{item.id}}"><text class="qty-icon">−</text></view>
            <text class="qty-num">{{item.quantity}}</text>
            <view class="qty-btn qty-plus" catchtap="onAddToCart" data-product="{{item}}"><text class="qty-icon">+</text></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 产品详情弹窗 -->
<view class="detail-overlay {{detailOpen ? 'show' : ''}}" catchtap="onDetailClose" style="{{paneDetailStyle}}">
  <view class="detail-drawer {{detailOpen ? 'show' : ''}}" catchtap="noop">
    <!-- 导航行：返回按钮 + 标题，位于页面顶部导航下方 -->
    <view class="detail-nav">
      <view class="detail-back-btn" catchtap="onDetailClose">
        <image src="/images/back.png" class="detail-back-icon" mode="aspectFit"></image>
      </view>
      <text class="detail-nav-title">产品详情</text>
      <view class="detail-nav-spacer"></view>
    </view>

    <!-- 可滚动内容区 -->
    <scroll-view scroll-y class="detail-body" enhanced show-scrollbar="{{false}}">
      <!-- 产品图片 -->
      <image class="detail-image" src="{{detailProduct.image}}" mode="widthFix"></image>

      <!-- 基本信息 -->
      <view class="detail-header">
        <view class="detail-title-row">
          <text class="detail-name">{{detailProduct.name}}</text>
          <text class="detail-price">¥ {{detailProduct.price}}</text>
        </view>
        <view class="detail-tags">
          <text class="detail-tag">{{detailProduct.tag}}</text>
          <text class="detail-size">{{detailProduct.size}}</text>
        </view>
      </view>

      <!-- 详细描述 -->
      <text class="detail-desc">{{detailProduct.detailDesc}}</text>

      <!-- 主要食材 -->
      <view class="detail-ingredients">
        <text class="detail-section-label">主要食材</text>
        <view class="ingredient-list">
          <text wx:for="{{detailProduct.ingredients}}" wx:key="*this" class="ingredient-item">{{item}}</text>
        </view>
      </view>

      <!-- 忌口/过敏选择（一体滚动） -->
      <view class="detail-restrictions">
        <text class="detail-section-label">忌口/过敏选择（选填）</text>
        <scroll-view scroll-x class="restriction-scroll" enhanced show-scrollbar="{{false}}">
          <view class="restriction-row">
            <view
              wx:for="{{dietaryRestrictions}}"
              wx:key="key"
              class="restriction-chip {{selectedRestrictions[detailProduct.id] && selectedRestrictions[detailProduct.id][item.key] ? 'active' : ''}}"
              data-key="{{item.key}}"
              catchtap="onToggleRestriction"
            >
              <text wx:if="{{selectedRestrictions[detailProduct.id] && selectedRestrictions[detailProduct.id][item.key]}}" class="chip-check">✓</text>
              <text>{{item.label}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- 底部留白，防止最后内容被 footer 遮挡 -->
      <view class="detail-bottom-spacer"></view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="detail-footer">
      <view class="detail-stepper">
        <view class="qty-btn" catchtap="onDetailDecrease"><text class="qty-icon">−</text></view>
        <text class="detail-qty-num">{{detailQuantity}}</text>
        <view class="qty-btn qty-plus" catchtap="onDetailAdd"><text class="qty-icon">+</text></view>
      </view>
      <view class="detail-add-btn" catchtap="onDetailAddToCart">
        <text>加入购物车 ¥{{detailProduct.price * detailQuantity}}</text>
      </view>
    </view>
  </view>
</view>
