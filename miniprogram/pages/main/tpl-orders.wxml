<!-- 订单页内容片段 -->
<!-- 整页单一纵向滚动，铺主题渐变（与点单页 .tab-scroll 同款）。
     Tab 条与订单卡片都在渐变之上，故 Tab 条透明即与页面背景一致，无需再单独铺色。 -->
<scroll-view scroll-y class="orders-scroll" enhanced show-scrollbar="{{false}}" style="flex: 1; height: 0;">
  <view class="scroll-inner">
    <!-- 订单状态 Tab（随内容滚动，参考点单页分类条；透明露出渐变背景） -->
    <view class="order-tabs">
      <scroll-view scroll-x class="tabs-scroll" enhanced show-scrollbar="{{false}}">
        <view class="tabs-list">
          <view wx:for="{{tabs}}" wx:key="key"
            class="tab-item {{activeTab === item.key ? 'active' : ''}}"
            bindtap="onTabChange" data-key="{{item.key}}">
            <text>{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 订单列表 -->
    <block wx:if="{{filteredOrders.length > 0}}">
      <view wx:for="{{filteredOrders}}" wx:key="id" class="order-card card order-{{item.status}}">
        <view class="order-header">
          <view class="order-header-left">
            <view class="order-store">
              <image class="order-store-icon" src="/images/store-icon.png" mode="aspectFit"/>
              <text class="order-store-name">王姐的店</text>
            </view>
            <text class="order-no">单号 {{item.id}}</text>
            <text class="order-time">{{item.time}}</text>
            <text class="order-pickup-time" wx:if="{{item.pickupTimeText}}">🕐 取餐 {{item.pickupTimeText}}</text>
          </view>
          <view class="order-header-right">
            <text class="payment-badge {{item.isPaid ? 'paid' : 'unpaid'}}">{{item.paymentStatusText}}</text>
            <view class="order-status {{item.status}}"><text>{{item.statusText}}</text></view>
          </view>
        </view>
        <view class="order-items">
          <view wx:for="{{item.items}}" wx:key="name" wx:for-item="prod" class="order-item">
            <image class="order-item-thumb" src="{{prod.image}}" mode="aspectFill"></image>
            <view class="order-item-main">
              <text class="order-item-name">{{prod.name}}</text>
              <text class="order-item-unit">¥{{prod.price}}</text>
            </view>
            <text class="order-item-count">×{{prod.qty}}</text>
          </view>
        </view>
        <!-- 取餐码 -->
        <view class="pickup-section">
          <block wx:if="{{item.codeRevealed}}">
            <view class="pickup-revealed">
              <text class="pickup-label">取餐码</text>
              <view class="pickup-code-row">
                <text wx:for="{{item.codeDigits}}" wx:key="*this" wx:for-item="digit" class="pickup-digit">{{digit}}</text>
              </view>
              <text class="pickup-hint">请向店员出示此码</text>
              <view class="pickup-hide-btn" bindtap="onHidePickupCode" data-id="{{item.id}}"><text>收起</text></view>
            </view>
          </block>
          <block wx:else>
            <view class="pickup-btn" bindtap="onShowPickupCode" data-id="{{item.id}}">
              <image class="pickup-btn-icon" src="/images/pickup-code.png" mode="aspectFit"></image>
              <text class="pickup-btn-text">查看取餐码</text>
            </view>
          </block>
        </view>
        <view class="order-footer">
          <view class="order-total-wrap">
            <view class="order-discount-btn" wx:if="{{item.discountAmount > 0}}" bindtap="onShowDiscount" data-id="{{item.id}}" data-total="{{item.total}}" data-discount="{{item.discountAmount}}" data-paid="{{item.paidAmount}}">
              <text class="order-discount-btn-text">已优惠 ¥{{item.discountAmount}}</text>
              <text class="order-discount-btn-arrow">›</text>
            </view>
            <text class="order-total">实付 <text class="total-price">¥{{item.paidAmount}}</text></text>
          </view>
          <view class="order-actions">
            <view class="order-action-btn pickup-btn" wx:if="{{item.canPickup}}" bindtap="onPickupComplete" data-id="{{item.id}}"><text>已取餐</text></view>
            <view class="order-action-btn pay-btn" wx:if="{{!item.isPaid && item.status !== 'cancelled'}}" bindtap="onPayOrder" data-id="{{item.id}}"><text>去支付</text></view>
            <view class="order-action-btn outline" wx:if="{{item.canCancel}}" bindtap="onCancelOrder" data-id="{{item.id}}" data-paid="{{item.isPaid}}"><text>{{item.isPaid ? '取消退款' : '取消订单'}}</text></view>
            <view class="order-action-btn disabled" wx:elif="{{item.status !== 'cancelled' && item.status !== 'completed'}}" catchtap="onCancelDisabled"><text>取消订单</text></view>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无订单</text>
      <text class="empty-sub">快去下单吧~</text>
    </view>
  </view>
</scroll-view>

<!-- 优惠明细弹窗 -->
<view class="discount-popup-overlay {{discountPopupOpen ? 'show' : ''}}" catchtap="onCloseDiscount">
  <view class="discount-popup {{discountPopupOpen ? 'show' : ''}}" catchtap="noop">
    <view class="discount-popup-header">
      <text class="discount-popup-title">优惠明细</text>
      <view class="discount-popup-close" catchtap="onCloseDiscount"><text>✕</text></view>
    </view>
    <view class="discount-popup-body">
      <view class="discount-popup-row">
        <text class="discount-popup-label">商品原价</text>
        <text class="discount-popup-val">¥{{discountPopupTotal}}</text>
      </view>
      <view class="discount-popup-divider"></view>
      <view class="discount-popup-row discount-popup-row-save">
        <text class="discount-popup-label">优惠减免</text>
        <text class="discount-popup-val discount-popup-val-save">-¥{{discountPopupAmount}}</text>
      </view>
      <view class="discount-popup-row discount-popup-row-final">
        <text class="discount-popup-label">实付金额</text>
        <view class="discount-popup-final-price">
          <text class="discount-popup-final-sym">¥</text>
          <text class="discount-popup-final-num">{{discountPopupPaid}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
