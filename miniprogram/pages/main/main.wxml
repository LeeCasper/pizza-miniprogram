<!--pages/main/main.wxml-->
<view class="app-root" style="padding-top: {{topBarTotalHeight}}px">
  <!-- 顶部导航栏（按 Tab 切换标题） -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px">
    <block wx:if="{{currentTab === 0}}">
      <view class="top-bar-left"><text class="brand-title">王姐手工披萨</text></view>
    </block>
    <block wx:elif="{{currentTab === 1}}">
      <text class="top-title">订单中心</text>
    </block>
    <block wx:elif="{{currentTab === 2}}">
      <text class="top-title">会员商城</text>
    </block>
    <block wx:else>
      <text class="top-title">个人中心</text>
    </block>
  </view>

  <!-- Swiper 主体 -->
  <swiper
    class="main-swiper"
    current="{{currentTab}}"
    bindchange="onSwiperChange"
    duration="300"
    easing-function="easeInOutCubic"
    style="height: {{scrollViewHeight}}px;"
  >
    <!-- Tab 0: 首页 -->
    <swiper-item>
      <scroll-view scroll-y class="tab-scroll" enhanced show-scrollbar="{{true}}" style="height: {{scrollViewHeight}}px;">
        <include src="tpl-index.wxml"/>
        <view style="height: 120rpx"></view>
      </scroll-view>
    </swiper-item>

    <!-- Tab 1: 订单（含 order-tabs + scroll-view，需 flex 包裹层） -->
    <swiper-item>
      <view style="display: flex; flex-direction: column; height: {{scrollViewHeight}}px;">
        <include src="tpl-orders.wxml"/>
      </view>
    </swiper-item>

    <!-- Tab 2: 商城 -->
    <swiper-item>
      <include src="tpl-shop.wxml"/>
    </swiper-item>

    <!-- Tab 3: 个人 -->
    <swiper-item>
      <include src="tpl-profile.wxml"/>
    </swiper-item>
  </swiper>

  <!-- 底部导航栏（固定，永不重渲染） -->
  <view class="tab-bar">
    <view
      wx:for="{{tabList}}"
      wx:key="index"
      class="tab-bar-item {{currentTab === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onTabTap"
    >
      <image class="tab-icon-img" src="{{item.icon}}"/>
      <text class="tab-label">{{item.text}}</text>
    </view>
  </view>

  <!-- 购物车悬浮条 + 抽屉（仅首页显示） -->
  <block wx:if="{{currentTab === 0}}">
    <view class="cart-bar {{cartCount > 0 ? 'show' : ''}}" wx:if="{{cartCount > 0}}" bindtap="onCartBarTap">
      <view class="cart-bar-inner">
        <view class="cart-bar-left">
          <view class="cart-icon-wrap">
            <image class="cart-icon" src="/images/cart.png" mode="aspectFit"></image>
            <text class="cart-badge">{{cartCount}}</text>
          </view>
          <text class="cart-total">¥ {{cartTotal}}</text>
        </view>
        <view class="cart-bar-btn"><text>去结算</text></view>
      </view>
    </view>

    <view class="cart-overlay {{cartOpen ? 'show' : ''}}" catchtap="onCartClose">
      <view class="cart-drawer {{cartOpen ? 'show' : ''}}" catchtap="noop">
        <view class="cart-header">
          <text class="cart-title">已选商品</text>
          <view class="cart-clear" bindtap="onClearCart"><image class="cart-clear-icon" src="/images/trash.png" mode="aspectFit"></image><text>清空</text></view>
        </view>
        <scroll-view scroll-y class="cart-items" wx:if="{{cartItems.length > 0}}">
          <view wx:for="{{cartItems}}" wx:key="id" class="cart-item">
            <image class="cart-item-img" src="{{item.image}}" mode="aspectFill"></image>
            <view class="cart-item-info">
              <text class="cart-item-name">{{item.name}}</text>
              <view class="cart-item-tags" wx:if="{{item.restrictions && item.restrictions.length > 0}}">
                <text wx:for="{{item.restrictions}}" wx:key="*this" wx:for-item="r" class="cart-item-tag">{{r}}</text>
              </view>
              <text class="cart-item-price">¥ {{item.price * item.quantity}}</text>
            </view>
            <view class="qty-stepper">
              <view class="qty-btn" bindtap="onDecrease" data-id="{{item.id}}"><text class="qty-icon">−</text></view>
              <text class="qty-num">{{item.quantity}}</text>
              <view class="qty-btn qty-plus" bindtap="onAddToCart" data-product="{{item}}"><text class="qty-icon">+</text></view>
            </view>
          </view>
        </scroll-view>
        <view wx:else class="cart-empty"><text>购物车是空的</text></view>
        <view class="cart-footer" wx:if="{{cartItems.length > 0}}">
          <view class="pay-method-row">
            <view class="pay-method-item {{paymentMethod === 'wechat' ? 'active' : ''}}" bindtap="onSwitchPaymentMethod" data-method="wechat">
              <text class="pay-method-icon">💳</text>
              <text class="pay-method-label">微信支付</text>
            </view>
            <view class="pay-method-item {{paymentMethod === 'balance' ? 'active' : ''}}" bindtap="onSwitchPaymentMethod" data-method="balance">
              <text class="pay-method-icon">💰</text>
              <text class="pay-method-label">余额支付</text>
            </view>
          </view>
          <view class="checkout-btn" bindtap="onCheckout"><text>确认下单 ¥{{cartTotal}}</text></view>
        </view>
      </view>
    </view>
  </block>

  <!-- 会员开通悬浮弹窗 -->
  <view class="member-overlay {{memberOverlayOpen ? 'show' : ''}}" catchtap="onMemberOverlayClose">
    <view class="member-overlay-card {{memberOverlayOpen ? 'show' : ''}}" catchtap="noop">
      <view class="member-overlay-scroll">
        <!-- 关闭按钮 -->
        <view class="member-overlay-close" catchtap="onMemberOverlayClose">
          <text>✕</text>
        </view>

        <!-- Hero 区域 -->
        <view class="member-hero">
          <view class="member-card">
            <view class="member-card-inner">
              <view class="card-top">
                <view class="card-status">
                  <text class="card-status-label">Status</text>
                  <text class="card-level">{{userInfo.memberLevel || '金卡会员'}}</text>
                </view>
                <view class="card-badge"><text class="badge-icon">👑</text></view>
              </view>
              <view class="card-bottom">
                <view class="card-id-section">
                  <text class="card-id-label">Member ID</text>
                  <text class="card-id">**** **** 8294</text>
                </view>
                <view class="card-qr"><text class="qr-icon">📱</text></view>
              </view>
              <view class="card-glow"></view>
            </view>
          </view>
          <view class="member-hero-text">
            <text class="hero-headline">成为王姐会员</text>
            <text class="hero-subtitle">解锁全部功能</text>
          </view>
        </view>

        <!-- 会员权益横滑 -->
        <view class="privileges-section">
          <scroll-view scroll-x class="privileges-scroll" enhanced show-scrollbar="{{false}}">
            <view class="privileges-row">
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-purple">
                  <view class="privilege-icon-shine"></view>
                  <text class="privilege-icon">✂️</text>
                </view>
                <text class="privilege-label">专属优惠</text>
              </view>
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-green">
                  <view class="privilege-icon-shine"></view>
                  <text class="privilege-icon">⭐</text>
                </view>
                <text class="privilege-label">生日惊喜</text>
              </view>
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-gold">
                  <view class="privilege-icon-shine"></view>
                  <text class="privilege-icon">🎨</text>
                </view>
                <text class="privilege-label">双倍积分</text>
              </view>
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-pink">
                  <view class="privilege-icon-shine"></view>
                  <text class="privilege-icon">🎵</text>
                </view>
                <text class="privilege-label">优先制作</text>
              </view>
              <view class="privilege-item">
                <view class="privilege-icon-wrap privilege-icon-teal">
                  <view class="privilege-icon-shine"></view>
                  <text class="privilege-icon">📈</text>
                </view>
                <text class="privilege-label">弹跳曲线</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <!-- 优惠券信息条 -->
        <view class="coupon-banner">
          <view class="coupon-banner-left">
            <text class="coupon-banner-icon">🎫</text>
            <text class="coupon-banner-text">会员每周可领取优惠券</text>
          </view>
          <view class="coupon-banner-help" bindtap="onMemberHelp">
            <text class="coupon-help-icon">?</text>
          </view>
        </view>

        <!-- 订阅方案卡片 -->
        <view class="plans-section">
          <view class="plan-card {{selectedPlan === 'annual' ? 'plan-selected' : ''}}" bindtap="onSelectPlan" data-plan="annual">
            <view class="plan-card-inner">
              <view class="plan-left">
                <view class="plan-name-row">
                  <text class="plan-name">连续包年</text>
                  <text class="plan-badge">限时3.2折</text>
                </view>
                <view class="plan-price-row">
                  <text class="plan-price">¥199</text>
                  <text class="plan-original">¥620</text>
                </view>
              </view>
              <view class="plan-radio {{selectedPlan === 'annual' ? 'radio-checked' : ''}}">
                <text class="plan-check-icon">{{selectedPlan === 'annual' ? '✓' : ''}}</text>
              </view>
            </view>
          </view>

          <view class="plan-card {{selectedPlan === 'monthly' ? 'plan-selected' : ''}}" bindtap="onSelectPlan" data-plan="monthly">
            <view class="plan-card-inner">
              <view class="plan-left">
                <view class="plan-name-row">
                  <text class="plan-name">连续包月</text>
                  <text class="plan-badge">限时6.9折</text>
                </view>
                <view class="plan-price-row">
                  <text class="plan-price">¥19.9</text>
                  <text class="plan-original">¥29</text>
                </view>
              </view>
              <view class="plan-radio {{selectedPlan === 'monthly' ? 'radio-checked' : ''}}">
                <text class="plan-check-icon">{{selectedPlan === 'monthly' ? '✓' : ''}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- CTA 按钮 -->
        <view class="member-cta-section">
          <view class="member-cta-btn" bindtap="onMemberSubscribe">
            <view class="cta-btn-shine"></view>
            <text class="cta-main-text">开始免费试用</text>
            <text class="cta-sub-text">7天后自动订阅</text>
          </view>
          <view class="member-footer-links">
            <text class="footer-link" bindtap="onMemberTerms">使用条款</text>
            <text class="footer-divider">|</text>
            <text class="footer-link" bindtap="onMemberPrivacy">隐私政策</text>
            <text class="footer-divider">|</text>
            <text class="footer-link" bindtap="onMemberRestore">恢复购买</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
