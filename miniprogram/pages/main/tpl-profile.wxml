<!-- 个人中心内容片段 -->
<scroll-view scroll-y class="main-scroll" style="height: 100%;">
  <!-- 用户信息 - 横向布局 -->
  <view class="profile-header">
    <view class="profile-left">
      <view class="avatar-wrap" bindtap="onChooseAvatar">
        <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill" wx:if="{{userInfo.avatar}}"></image>
        <view class="avatar avatar-placeholder" wx:else></view>
        <view class="avatar-edit-mask">
          <text class="avatar-edit-icon">📷</text>
        </view>
      </view>
      <view class="profile-text" bindtap="onOpenEditProfile">
        <view class="profile-name-row">
          <text class="profile-name">{{userInfo.name}}</text>
          <text class="profile-edit-hint">✎</text>
        </view>
        <text class="profile-bio">{{userInfo.bio}}</text>
      </view>
    </view>
    <view class="profile-right" bindtap="onQrCode">
      <text class="qr-icon">📷</text>
    </view>
  </view>

  <!-- 会员等级卡片轮播 -->
  <view class="member-tier-section">
    <swiper
      class="member-swiper"
      current="{{currentTierIndex}}"
      bindchange="onTierSwiperChange"
      duration="300"
      easing-function="easeInOutCubic"
      previous-margin="56rpx"
      next-margin="56rpx"
      style="height: 380rpx"
    >
      <swiper-item wx:for="{{tierCards}}" wx:key="key" wx:for-index="idx">
        <view class="tier-card-wrapper" style="transform: translateY({{item.cardOffset}}rpx)">
          <view class="tier-card tier-card-{{item.key}}" style="background: {{item.gradient}}; color: {{item.textColor}}">
            <view class="tier-card-inner">
              <view class="tier-card-header">
                <view class="tier-status-badge" style="background: {{item.badgeBg}}">
                  <text class="tier-status-text">{{userTierIndex === idx ? '当前等级' : '未解锁'}}</text>
                </view>
              </view>
              <view class="tier-card-body">
                <text class="tier-name">{{item.name}}</text>
                <text class="tier-growth-text">积分{{userInfo.points}} {{tierGrowthTexts[idx]}}</text>
              </view>
              <view class="tier-card-footer">
                <view class="tier-lv-row">
                  <text class="tier-lv">Lv{{idx}}</text>
                </view>
                <view class="tier-progress-wrap" style="background: {{item.progressTrackBg}}">
                  <view class="tier-progress-fill" style="width: {{idx === userTierIndex ? tierProgress : (idx < userTierIndex ? 100 : 0)}}%; background: {{item.progressFillBg}}"></view>
                </view>
              </view>
            </view>
          </view>
          <view class="tier-card-arrow" style="background: {{item.gradient}}"></view>
        </view>
      </swiper-item>
    </swiper>

    <!-- 等级曲线联动指示器 -->
    <view class="arc-indicator">
      <view class="arc-curve-container">
        <view class="arc-curve-bg"></view>
        <view class="arc-labels-track" style="transform: translateX({{trackShift}}%)">
          <view
            wx:for="{{arcLabels}}"
            wx:key="key"
            wx:for-index="idx"
            class="arc-label-col {{currentTierIndex === idx ? 'active' : ''}}"
            style="transform: translateY({{item.yOffset}}rpx)"
            bindtap="onSelectTier"
            data-index="{{idx}}"
          >
            <text class="arc-label-text">{{item.label}}</text>
            <view class="arc-dot {{currentTierIndex === idx ? 'active' : ''}}"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 资产统计 -->
    <view class="stats-row">
      <view class="stats-item" bindtap="onMenuItem" data-action="coupons">
        <text class="stats-value">{{userInfo.coupons}}</text>
        <text class="stats-label">优惠券</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item" bindtap="onMenuItem" data-action="points">
        <text class="stats-value">{{userInfo.points}}</text>
        <text class="stats-label">积分</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value">{{cardCount}}</text>
        <text class="stats-label">卡包</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value">{{userInfo.balanceText}}</text>
        <text class="stats-label">余额</text>
      </view>
    </view>
  </view>

  <!-- 公告 -->
  <view class="announce-card">
    <text class="announce-icon">📢</text>
    <view class="announce-badge"><text class="announce-badge-text">公告</text></view>
    <text class="announce-text">全新手工薄脆披萨上市，限时八折体验！</text>
    <text class="announce-arrow">›</text>
  </view>

  <!-- 金刚区 - 快捷入口 -->
  <view class="grid-actions">
    <view class="grid-item" bindtap="onMenuItem" data-action="points">
      <view class="grid-icon-wrap grid-icon-red">
        <image class="grid-icon" src="/images/grid-points.png" mode="aspectFit"></image>
      </view>
      <text class="grid-label">积分商城</text>
    </view>
    <view class="grid-item" bindtap="onMenuItem" data-action="coupons">
      <view class="grid-icon-wrap grid-icon-gold">
        <image class="grid-icon" src="/images/grid-coupons.png" mode="aspectFit"></image>
      </view>
      <text class="grid-label">优惠券</text>
    </view>
    <view class="grid-item" bindtap="onMenuItem" data-action="lucky">
      <view class="grid-icon-wrap grid-icon-green">
        <image class="grid-icon" src="/images/grid-lucky.png" mode="aspectFit"></image>
      </view>
      <text class="grid-label">幸运转盘</text>
    </view>
    <view class="grid-item" bindtap="onMenuItem" data-action="service">
      <view class="grid-icon-wrap grid-icon-gray">
        <image class="grid-icon" src="/images/grid-service.png" mode="aspectFit"></image>
      </view>
      <text class="grid-label">联系客服</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-card">
      <view class="menu-item" bindtap="onMenuItem" data-action="settings">
        <image class="menu-icon" src="/images/menu-settings.png" mode="aspectFit"></image>
        <text class="menu-name">设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onMenuItem" data-action="address">
        <image class="menu-icon" src="/images/menu-address.png" mode="aspectFit"></image>
        <text class="menu-name">地址管理</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item menu-item-last" bindtap="onMenuItem" data-action="favorites">
        <image class="menu-icon" src="/images/menu-favorites.png" mode="aspectFit"></image>
        <text class="menu-name">我的收藏</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
  <!-- 编辑个人信息抽屉 -->
  <view class="edit-overlay {{editProfileOpen ? 'show' : ''}}" catchtap="onCloseEditProfile">
    <view class="edit-drawer {{editProfileOpen ? 'show' : ''}}" catchtap="noop">
      <view class="edit-drawer-nav">
        <text class="edit-drawer-title">编辑个人信息</text>
        <text class="edit-drawer-save" bindtap="onSaveProfile">保存</text>
      </view>
      <view class="edit-drawer-body">
        <view class="edit-avatar-section" bindtap="onChooseAvatar">
          <image class="edit-avatar-img" src="{{editForm.avatar || userInfo.avatar}}" mode="aspectFill" wx:if="{{editForm.avatar || userInfo.avatar}}"></image>
          <view class="edit-avatar-img edit-avatar-placeholder" wx:else></view>
          <view class="edit-avatar-tip">
            <text class="edit-avatar-tip-text">点击更换头像</text>
          </view>
        </view>
        <view class="edit-field">
          <text class="edit-field-label">昵称</text>
          <input class="edit-field-input" value="{{editForm.name}}" bindinput="onNameInput" placeholder="请输入昵称" maxlength="20"/>
        </view>
        <view class="edit-field">
          <text class="edit-field-label">个性签名</text>
          <input class="edit-field-input" value="{{editForm.bio}}" bindinput="onBioInput" placeholder="请输入个性签名" maxlength="30"/>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
