<!-- 商城页 — 会员商城（黏土风；与 pages/shop 同步。商品不入购物车，可收藏，点卡片进详情） -->

<!-- 商城停用提示 -->
<view class="shop-closed" wx:if="{{!shopEnabled}}">
  <image class="shop-closed-img" src="/images/shop-closed.gif" mode="widthFix"></image>
  <text class="shop-closed-title">正在开发中<text class="shop-closed-cursor">|</text></text>
</view>

<scroll-view scroll-y class="shop-scroll" enhanced show-scrollbar="{{false}}" style="height: {{scrollViewHeight}}px;" wx:if="{{shopEnabled}}">
  <view class="shop-scroll-inner">
    <!-- 顶部 Hero（促销 Banner） -->
    <view class="shop-hero" wx:if="{{shopBanners.length > 0}}">
      <swiper class="shop-hero-swiper" autoplay interval="4000" circular indicator-dots indicator-color="rgba(255,255,255,0.35)" indicator-active-color="#C0563A">
        <swiper-item wx:for="{{shopBanners}}" wx:key="id">
          <view
            class="shop-hero-slide"
            bindtap="onShopBannerTap"
            data-link-type="{{item.linkType}}"
            data-product-id="{{item.linkShopProductId || item.linkProductId}}"
            data-link-url="{{item.linkUrl}}"
          >
            <image class="shop-hero-img" src="{{item.image}}" mode="aspectFill"></image>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 分类网格模块（黏土风卡片，独立于精选好物） -->
    <view class="shop-cat-module" wx:if="{{shopCategories.length > 0}}">
      <view class="shop-cat-header">
        <text class="shop-cat-title">商品分类</text>
        <text class="shop-cat-sub">{{shopCategories.length}}个分类</text>
      </view>
      <view class="shop-cat-grid">
        <view
          wx:for="{{shopCategories}}"
          wx:key="key"
          class="shop-cat-card {{shopActiveCat === item.key ? 'active' : ''}}"
          bindtap="onShopCategory"
          data-key="{{item.key}}"
        >
          <view class="shop-cat-card-iconwrap">
            <image wx:if="{{item.icon}}" class="shop-cat-card-img" src="{{item.icon}}" mode="aspectFit"></image>
            <text wx:else class="shop-cat-card-emoji">{{item.emoji || '📦'}}</text>
          </view>
          <text class="shop-cat-card-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 节标题（仅全部分类显示） -->
    <view class="shop-section-header" wx:if="{{shopActiveCat === 'all'}}">
      <text class="shop-section-title">精选好物</text>
      <text class="shop-section-count">{{shopFilteredProducts.length}}件</text>
    </view>

    <!-- 商品网格：2×2 双列布局 -->
    <view class="shop-grid" wx:if="{{shopFilteredProducts.length > 0}}">
      <view class="shop-grid-card" wx:for="{{shopFilteredProducts}}" wx:key="id" bindtap="onShopProductTap" data-id="{{item.id}}">
        <view class="shop-grid-imgwrap">
          <image class="shop-grid-img" src="{{item.main_image}}" mode="aspectFill"></image>
          <view class="shop-grid-badge" wx:if="{{item.tag}}"><text>{{item.tag}}</text></view>
        </view>
        <view class="shop-grid-body">
          <text class="shop-grid-name">{{item.name}}</text>
          <view class="shop-grid-bottom">
            <view class="shop-price-row">
              <text class="shop-price-sym">¥</text>
              <text class="shop-price shop-price-sm">{{item.price}}</text>
              <text class="shop-original" wx:if="{{item.original_price}}">¥{{item.original_price}}</text>
            </view>
            <view class="shop-fav-btn {{item.isFavorited ? 'active' : ''}}" catchtap="onShopToggleFav" data-id="{{item.id}}">
              <text class="shop-fav-icon">{{item.isFavorited ? '♥' : '♡'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="shop-list-end" wx:if="{{shopFilteredProducts.length > 0}}"><text class="shop-list-end-text">没有更多商品了</text></view>

    <!-- 空状态 -->
    <view class="shop-empty" wx:else>
      <image class="shop-empty-img" src="/images/empty-shop.png" mode="widthFix"></image>
      <text class="shop-empty-text">暂无商品</text>
      <text class="shop-empty-sub">敬请期待更多好物上架</text>
    </view>

    <view style="height: calc(140rpx + env(safe-area-inset-bottom))"></view>
  </view>
</scroll-view>
