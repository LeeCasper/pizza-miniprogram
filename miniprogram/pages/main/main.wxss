/* pages/main/main.wxss */

/* ===== 全局布局 ===== */
.app-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx 24rpx;
  background: var(--glass-bg-nav);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  border-bottom: var(--glass-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.top-bar-left { display: flex; align-items: center; }

.brand-title { font-size: 36rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.top-title { font-size: 36rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }


/* ===== Swiper ===== */
.main-swiper { background: var(--color-background); }

.tab-scroll {
  padding: 0 0 72rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* ===== 底部导航栏 ===== */
.tab-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: calc(100rpx + env(safe-area-inset-bottom));
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
  border-top: var(--glass-border-subtle);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 8rpx 0;
  transition: transform 0.15s;
}

.tab-bar-item:active { transform: scale(0.92); }

.tab-icon-img {
  width: 44rpx; height: 44rpx;
  opacity: 0.45;
  transition: opacity 0.2s;
}

.tab-bar-item.active .tab-icon-img { opacity: 1; }

.tab-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #9E9E9E;
  transition: color 0.2s;
}

.tab-bar-item.active .tab-label {
  color: #D32F2F;
  font-weight: 700;
}

/* ===== 首页：取餐切换 ===== */
.pickup-toggle { padding: 32rpx 40rpx 24rpx; }

.toggle-pill {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  width: 100%; padding: 28rpx 40rpx;
  background: var(--glass-bg-primary-container);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  color: var(--color-on-primary-container);
  border-radius: var(--radius-card);
  border: var(--glass-border-colored);
  font-size: 36rpx; font-weight: var(--font-weight-bold);
  box-shadow: var(--shadow-sm);
}

.toggle-icon-img { width: 48rpx; height: 48rpx; }

/* ===== 首页：Banner轮播 ===== */
.hero-section {
  margin: 0 40rpx 32rpx;
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.hero-swiper {
  border-radius: var(--radius-card);
}
.hero-slide {
  width: 100%;
  height: 100%;
  position: relative;
}
.hero-image { width: 100%; height: 100%; }
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
  padding: 24rpx 32rpx; display: flex; flex-direction: column; justify-content: space-between;
  pointer-events: none;
}
.hero-tag { align-self: flex-start; }
.hero-tag text {
  background: var(--color-primary-container); color: var(--color-on-primary-container);
  padding: 8rpx 24rpx; border-radius: var(--radius-full);
  font-size: 22rpx; font-weight: var(--font-weight-semibold); letter-spacing: 2rpx;
}
.hero-text { display: flex; flex-direction: column; gap: 8rpx; }
.hero-title { color: #FFFFFF; font-size: 40rpx; font-weight: var(--font-weight-bold); line-height: 1.2; }
.hero-subtitle { color: rgba(255,255,255,0.8); font-size: 26rpx; }

/* ===== 首页：分类 ===== */
.category-section { padding: 16rpx 0; }
.category-scroll { white-space: nowrap; }
.category-list { display: flex; padding: 0 40rpx; gap: 32rpx; }
.category-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 8rpx 16rpx; }
.category-icon-wrap {
  width: 96rpx; height: 96rpx; border-radius: var(--radius-full);
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s; box-shadow: var(--glass-shadow-elevated);
  border: var(--glass-border-subtle);
}
.category-icon-wrap.active { background: var(--glass-bg-primary-light); border: var(--glass-border-colored); box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08); }
.category-icon { width: 56rpx; height: 56rpx; }
.category-name { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.category-name.active { color: var(--color-primary); }

/* ===== 首页：商品 ===== */
.product-section { padding: 16rpx 40rpx; }
.section-header { margin-bottom: 24rpx; }
.section-title { font-size: 36rpx; font-weight: var(--font-weight-bold); color: var(--color-on-background); }
.product-list { display: flex; flex-direction: column; gap: 24rpx; }
.product-card {
  display: flex; align-items: center; gap: 24rpx;
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur);
  backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-card);
  padding: 24rpx; box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
}
.product-image { width: 160rpx; height: 160rpx; border-radius: 16rpx; flex-shrink: 0; background: var(--color-surface-container-low); }
.product-info { flex: 1; display: flex; flex-direction: column; justify-content: center; min-width: 0; }
.product-meta { margin-bottom: 16rpx; }
.product-name { font-size: 30rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-background); display: block; margin-bottom: 8rpx; }
.product-desc { font-size: 24rpx; color: var(--color-on-surface-variant); }
.product-bottom { display: flex; align-items: center; justify-content: space-between; }
.product-price { font-size: 30rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }

.add-btn {
  width: 72rpx; height: 72rpx; border-radius: var(--radius-full);
  background: var(--glass-bg-light);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  box-shadow: var(--glass-shadow-elevated);
  border: var(--glass-border);
  display: flex; align-items: center; justify-content: center;
}
.add-icon { font-size: 40rpx; color: var(--color-on-surface); font-weight: 300; line-height: 1; }

.qty-stepper {
  display: flex; align-items: center; gap: 20rpx;
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border-radius: var(--radius-full);
  padding: 8rpx 12rpx; box-shadow: var(--glass-shadow-elevated);
  border: var(--glass-border-subtle);
}
.qty-btn {
  width: 56rpx; height: 56rpx; border-radius: var(--radius-full);
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  border: var(--glass-border-subtle);
}
.qty-btn:active { transform: scale(0.95); }
.qty-plus { background: var(--glass-bg-primary-container); border: var(--glass-border-colored); }
.qty-icon { font-size: 36rpx; color: var(--color-on-surface); font-weight: 400; line-height: 1; }
.qty-plus .qty-icon { color: var(--color-on-primary-container); }
.qty-num { font-size: 28rpx; font-weight: var(--font-weight-bold); min-width: 32rpx; text-align: center; }

/* ===== 购物车浮条 ===== */
.cart-bar {
  position: fixed; bottom: calc(100rpx + env(safe-area-inset-bottom));
  left: 0; right: 0; padding: 0 32rpx; z-index: 90;
  transform: translateY(200rpx); opacity: 0; transition: all 0.3s ease;
}
.cart-bar.show { transform: translateY(0); opacity: 1; }
.cart-bar-inner {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--glass-bg-dark);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  color: #F2F0F0;
  border-radius: var(--radius-full); padding: 20rpx 20rpx 20rpx 40rpx;
  box-shadow: var(--shadow-modal);
  border: var(--glass-border-dark);
}
.cart-bar-left { display: flex; align-items: center; gap: 20rpx; }
.cart-icon-wrap { position: relative; }
.cart-icon { width: 56rpx; height: 56rpx; }
.cart-badge {
  position: absolute; top: -8rpx; right: -16rpx; min-width: 36rpx; height: 36rpx;
  background: var(--color-primary); color: var(--color-on-primary);
  font-size: 20rpx; font-weight: var(--font-weight-bold); border-radius: var(--radius-full);
  display: flex; align-items: center; justify-content: center;
  border: 4rpx solid var(--color-on-surface); padding: 0 8rpx;
}
.cart-total { font-size: 32rpx; font-weight: var(--font-weight-bold); }
.cart-bar-btn {
  background: var(--glass-bg-primary);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  color: var(--color-on-primary);
  padding: 20rpx 48rpx; border-radius: var(--radius-full);
  font-size: 28rpx; font-weight: var(--font-weight-bold);
  box-shadow: var(--glass-shadow-button);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

/* ===== 购物车抽屉 ===== */
.cart-overlay { position: fixed; inset: 0; z-index: 1000; visibility: hidden; }
.cart-overlay.show { visibility: visible; }
.cart-overlay::before {
  content: ''; position: absolute; inset: 0;
  background: var(--glass-bg-overlay);
  -webkit-backdrop-filter: blur(6px);
  backdrop-filter: blur(6px);
  opacity: 0; transition: opacity 0.3s;
}
.cart-overlay.show::before { opacity: 1; }
.cart-drawer {
  position: absolute; left: 0; right: 0; bottom: 0;
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  border-radius: 48rpx 48rpx 0 0;
  max-height: 80vh; display: flex; flex-direction: column;
  transform: translateY(100%); transition: transform 0.3s ease;
  box-shadow: var(--shadow-modal);
  border-top: var(--glass-border);
}
.cart-drawer.show { transform: translateY(0); }
.cart-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 40rpx; border-bottom: 1rpx solid var(--color-divider);
  border-radius: 48rpx 48rpx 0 0;
}
.cart-title { font-size: 34rpx; font-weight: var(--font-weight-bold); }
.cart-clear { display: flex; align-items: center; gap: 8rpx; font-size: 26rpx; color: var(--color-on-surface-variant); padding: 8rpx 16rpx; }
.cart-clear-icon { width: 32rpx; height: 32rpx; }
.cart-items { flex: 1; padding: 24rpx 40rpx; overflow-y: auto; }
.cart-item { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 0; border-bottom: 1rpx solid var(--color-divider); }
.cart-item:last-child { border-bottom: none; }
.cart-item-img { width: 96rpx; height: 96rpx; border-radius: 16rpx; flex-shrink: 0; background: var(--color-surface-container-low); }
.cart-item-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.cart-item-name { font-size: 30rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-background); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cart-item-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.cart-item-tag { font-size: 20rpx; color: var(--color-primary); background: var(--glass-bg-primary-light); padding: 4rpx 14rpx; border-radius: 8rpx; border: var(--glass-border-colored); white-space: nowrap; }
.cart-item-price { font-size: 28rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.cart-empty { padding: 80rpx 0; text-align: center; color: var(--color-on-surface-variant); font-size: 28rpx; }
.cart-footer { padding: 24rpx 40rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid var(--color-divider); }
.checkout-btn {
  width: 100%; padding: 28rpx;
  background: var(--glass-bg-primary);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  color: var(--color-on-primary);
  border-radius: var(--radius-full); text-align: center; font-size: 32rpx; font-weight: var(--font-weight-bold);
  box-shadow: var(--glass-shadow-button);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}
.checkout-btn:active { transform: scale(0.98); opacity: 0.9; }

/* Payment method selector — inside cart drawer */
.pay-method-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.pay-method-item {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx;
  padding: 18rpx 16rpx; border-radius: var(--radius-sm);
  border: 2rpx solid var(--color-divider);
  background: rgba(255, 255, 255, 0.5); font-size: 26rpx;
  transition: all 0.2s ease;
}
.pay-method-item.active {
  border-color: var(--color-primary);
  background: rgba(211, 47, 47, 0.06);
  color: var(--color-primary); font-weight: var(--font-weight-semibold);
}
.pay-method-icon { width: 36rpx; height: 36rpx; flex-shrink: 0; }
.pay-method-label { font-size: 26rpx; }

/* ===== 订单 ===== */
.order-tabs { background: var(--glass-bg-nav); -webkit-backdrop-filter: var(--glass-blur); backdrop-filter: var(--glass-blur); border-bottom: var(--glass-border-subtle); padding: 16rpx 0; }
.tabs-scroll { white-space: nowrap; }
.tabs-list { display: flex; padding: 0 40rpx; gap: 16rpx; }
.tab-item {
  padding: 16rpx 36rpx; border-radius: var(--radius-full); font-size: 28rpx;
  font-weight: var(--font-weight-semibold); color: var(--color-on-surface-variant);
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: var(--glass-border-subtle);
  flex-shrink: 0;
}
.tab-item.active { background: var(--glass-bg-primary-container); color: var(--color-on-primary-container); border: var(--glass-border-colored); }

.orders-scroll { padding: 24rpx 0 72rpx; overflow-x: hidden; box-sizing: border-box; }
.scroll-inner { padding: 0 40rpx; }

.order-card { margin-bottom: 24rpx; padding: 32rpx; overflow: hidden; }
.order-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.order-header-left { display: flex; flex-direction: column; gap: 8rpx; flex: 1; overflow: hidden; min-width: 0; }
.order-store { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.order-time { font-size: 24rpx; color: var(--color-on-surface-variant); }
.order-header-right { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.order-status { padding: 8rpx 24rpx; border-radius: var(--radius-full); font-size: 24rpx; font-weight: var(--font-weight-semibold); flex-shrink: 0; }
.order-status.completed { background: var(--color-tertiary-container); color: var(--color-tertiary); }
.order-status.preparing { background: var(--color-secondary-container); color: var(--color-secondary-dark); }
.order-status.waiting { background: var(--color-primary-container); color: var(--color-primary); }
.payment-badge { padding: 6rpx 20rpx; border-radius: var(--radius-full); font-size: 22rpx; font-weight: var(--font-weight-semibold); flex-shrink: 0; }
.payment-badge.paid { background: #E8F5E9; color: #2E7D32; }
.payment-badge.unpaid { background: #FFF3E0; color: #E65100; }

.order-items { border-top: 1rpx solid var(--color-divider); padding-top: 24rpx; }
.order-item { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 0; }
.order-item-name { font-size: 28rpx; color: var(--color-on-surface); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
.order-item-qty { display: flex; align-items: center; gap: 16rpx; font-size: 26rpx; color: var(--color-on-surface-variant); flex-shrink: 0; margin-left: 16rpx; }
.order-item-price { color: var(--color-on-surface); font-weight: var(--font-weight-semibold); min-width: 80rpx; text-align: right; }

/* 取餐码 */
.pickup-section { border-top: 1rpx solid var(--color-divider); padding: 28rpx 0 8rpx; }
.pickup-btn { display: flex; align-items: center; justify-content: center; gap: 12rpx; padding: 24rpx; background: var(--glass-bg-primary-light); -webkit-backdrop-filter: var(--glass-blur-sm); backdrop-filter: var(--glass-blur-sm); border-radius: var(--radius-card); border: 2rpx dashed rgba(0, 0, 0, 0.08); }
.pickup-btn:active { background: rgba(0, 0, 0, 0.04); transform: scale(0.98); }
.pickup-btn-icon { width: 44rpx; height: 44rpx; }
.pickup-btn-text { font-size: 28rpx; color: var(--color-primary); font-weight: var(--font-weight-semibold); }
.pickup-revealed { display: flex; flex-direction: column; align-items: center; gap: 20rpx; padding: 24rpx; background: var(--glass-bg-card); -webkit-backdrop-filter: var(--glass-blur); backdrop-filter: var(--glass-blur); border-radius: var(--radius-card); border: var(--glass-border-subtle); }
.pickup-label { font-size: 22rpx; color: var(--color-on-surface-variant); letter-spacing: 6rpx; text-transform: uppercase; }
.pickup-code-row { display: flex; gap: 16rpx; }
.pickup-digit { width: 64rpx; height: 80rpx; line-height: 80rpx; text-align: center; font-size: 40rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); background: var(--glass-bg-elevated); -webkit-backdrop-filter: var(--glass-blur-sm); backdrop-filter: var(--glass-blur-sm); border-radius: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); border: var(--glass-border-subtle); font-family: 'SF Mono', 'Menlo', 'Courier New', monospace; }
.pickup-hint { font-size: 22rpx; color: var(--color-on-surface-variant); opacity: 0.6; }
.pickup-hide-btn { padding: 12rpx 40rpx; border-radius: var(--radius-full); background: var(--glass-bg-card); -webkit-backdrop-filter: var(--glass-blur-sm); backdrop-filter: var(--glass-blur-sm); font-size: 24rpx; color: var(--color-on-surface-variant); font-weight: var(--font-weight-medium); border: var(--glass-border-subtle); }
.pickup-hide-btn:active { background: var(--color-surface-container-high); transform: scale(0.96); }

.order-footer { display: flex; align-items: center; justify-content: space-between; border-top: 1rpx solid var(--color-divider); padding-top: 24rpx; margin-top: 16rpx; flex-wrap: wrap; gap: 16rpx; }
.order-total { font-size: 28rpx; color: var(--color-on-surface); flex-shrink: 0; }
.total-price { font-size: 32rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.order-actions { display: flex; gap: 16rpx; flex-shrink: 0; }
.order-action-btn { padding: 12rpx 32rpx; border-radius: var(--radius-full); font-size: 26rpx; font-weight: var(--font-weight-semibold); white-space: nowrap; }
.order-action-btn.outline { color: var(--color-on-surface-variant); background: var(--glass-bg-light); -webkit-backdrop-filter: var(--glass-blur-sm); backdrop-filter: var(--glass-blur-sm); box-shadow: var(--glass-shadow-elevated); border: var(--glass-border); }
.order-action-btn.primary { background: var(--glass-bg-primary); -webkit-backdrop-filter: var(--glass-blur-sm); backdrop-filter: var(--glass-blur-sm); color: var(--color-on-primary); border: 1rpx solid rgba(255, 255, 255, 0.2); }
.order-action-btn.pay-btn { background: linear-gradient(135deg, #D32F2F, #b71c1c); color: #FFFFFF; box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.3); }
.order-action-btn.pay-btn:active { transform: scale(0.96); opacity: 0.9; }

.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.empty-text { font-size: 32rpx; color: var(--color-on-surface-variant); margin-bottom: 16rpx; }
.empty-sub { font-size: 26rpx; color: var(--color-on-surface-variant); opacity: 0.7; }

/* ===== 商城 ===== */
.shop-scroll { overflow-x: hidden; box-sizing: border-box; }
.shop-scroll-inner { padding: 0 32rpx; }

/* ── Banner 轮播 ── */
.shop-banner-section { margin: 24rpx 0; border-radius: var(--radius-card); overflow: hidden; box-shadow: var(--shadow-card); }
.shop-banner-swiper { height: 320rpx; border-radius: var(--radius-card); }
.shop-banner-slide { width: 100%; height: 100%; position: relative; }
.shop-banner-img { width: 100%; height: 100%; }
.shop-banner-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%); padding: 40rpx 32rpx 24rpx; display: flex; flex-direction: column; gap: 8rpx; }
.shop-banner-title { font-size: 36rpx; font-weight: var(--font-weight-bold); color: #FFFFFF; }
.shop-banner-sub { font-size: 24rpx; color: rgba(255,255,255,0.8); }

/* ── 分类导航 ── */
.shop-categories { display: flex; flex-wrap: wrap; justify-content: space-around; padding: 24rpx 0 8rpx; }
.shop-cat-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 8rpx 16rpx; width: 20%; margin-bottom: 20rpx; }
.shop-cat-icon-wrap { width: 96rpx; height: 96rpx; border-radius: var(--radius-full); background: var(--glass-bg-card); -webkit-backdrop-filter: var(--glass-blur-sm); backdrop-filter: var(--glass-blur-sm); display: flex; align-items: center; justify-content: center; box-shadow: var(--glass-shadow-elevated); border: var(--glass-border-subtle); transition: all 0.3s; }
.shop-cat-icon-wrap.cat-active { background: var(--glass-bg-primary-light); border: var(--glass-border-colored); box-shadow: 0 2rpx 8rpx rgba(211,47,47,0.15); }
.shop-cat-icon { font-size: 48rpx; line-height: 1; }
.shop-cat-name { font-size: 22rpx; color: var(--color-on-surface); font-weight: 500; }

/* ── 限时优惠横条 ── */
.shop-flash-bar { display: flex; align-items: center; justify-content: space-between; margin: 16rpx 0 24rpx; padding: 24rpx 28rpx; background: linear-gradient(135deg, #FFF5F5 0%, #FFE8E8 100%); border-radius: var(--radius-card); border: 2rpx solid rgba(211,47,47,0.15); }
.flash-bar-left { display: flex; align-items: center; gap: 12rpx; flex: 1; min-width: 0; }
.flash-icon { font-size: 36rpx; }
.flash-title { font-size: 28rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); flex-shrink: 0; }
.flash-desc { font-size: 24rpx; color: var(--color-on-surface-variant); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.flash-bar-btn { padding: 14rpx 36rpx; background: var(--glass-bg-primary); -webkit-backdrop-filter: var(--glass-blur-sm); backdrop-filter: var(--glass-blur-sm); color: var(--color-on-primary); border-radius: var(--radius-full); font-size: 26rpx; font-weight: var(--font-weight-bold); box-shadow: var(--glass-shadow-button); flex-shrink: 0; margin-left: 16rpx; }
.flash-bar-btn:active { transform: scale(0.95); opacity: 0.9; }

/* ── 商品区域 ── */
.shop-products-section { padding-top: 8rpx; }
.shop-section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 24rpx; }
.shop-section-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.shop-section-count { font-size: 24rpx; color: var(--color-on-surface-variant); }

/* 商品网格 (2列) */
.shop-product-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.shop-product-card { width: calc(50% - 10rpx); background: var(--glass-bg-card); -webkit-backdrop-filter: var(--glass-blur); backdrop-filter: var(--glass-blur); border-radius: var(--radius-card); overflow: hidden; box-shadow: var(--glass-shadow-card); border: var(--glass-border-subtle); transition: transform 0.2s; }
.shop-product-card:active { transform: scale(0.97); }
.shop-product-img { width: 100%; height: 280rpx; background: var(--color-surface-container-low); }
.shop-product-info { padding: 20rpx 20rpx 24rpx; display: flex; flex-direction: column; }
.shop-product-name { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 8rpx; }
.shop-product-desc { font-size: 22rpx; color: var(--color-on-surface-variant); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 16rpx; }
.shop-product-bottom { display: flex; align-items: center; justify-content: space-between; }
.shop-product-price-row { display: flex; align-items: baseline; gap: 8rpx; }
.shop-product-price { font-size: 30rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.shop-product-original { font-size: 20rpx; color: var(--color-outline-variant); text-decoration: line-through; }

.shop-add-btn { width: 56rpx; height: 56rpx; border-radius: var(--radius-full); background: var(--glass-bg-primary-light); -webkit-backdrop-filter: var(--glass-blur-sm); backdrop-filter: var(--glass-blur-sm); display: flex; align-items: center; justify-content: center; box-shadow: var(--glass-shadow-elevated); border: var(--glass-border-colored); flex-shrink: 0; transition: all 0.2s; }
.shop-add-btn:active { transform: scale(0.9); }
.shop-add-icon { font-size: 36rpx; color: var(--color-primary); font-weight: 400; line-height: 1; }
.shop-add-btn.has-qty { width: auto; padding: 4rpx 12rpx; border-radius: var(--radius-full); background: var(--glass-bg-card); border: var(--glass-border-subtle); }
.shop-mini-stepper { display: flex; align-items: center; gap: 12rpx; }
.shop-mini-btn { width: 44rpx; height: 44rpx; border-radius: var(--radius-full); background: var(--glass-bg-elevated); display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: var(--color-on-surface); border: var(--glass-border-subtle); }
.shop-mini-btn:active { transform: scale(0.9); }
.shop-mini-plus { background: var(--glass-bg-primary-light); border: var(--glass-border-colored); color: var(--color-primary); }
.shop-mini-qty { font-size: 26rpx; font-weight: var(--font-weight-bold); min-width: 32rpx; text-align: center; }
.shop-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 160rpx; }
.shop-empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.shop-empty-text { font-size: 32rpx; color: var(--color-on-surface-variant); margin-bottom: 12rpx; }
.shop-empty-sub { font-size: 26rpx; color: var(--color-on-surface-variant); opacity: 0.7; }
/* ===== 会员悬浮弹窗 ===== */
.member-overlay { position: fixed; inset: 0; z-index: 2000; visibility: hidden; }
.member-overlay.show { visibility: visible; }
.member-overlay::before { content: ''; position: absolute; inset: 0; background: rgba(0,0,0,0.5); -webkit-backdrop-filter: blur(12rpx); backdrop-filter: blur(12rpx); opacity: 0; transition: opacity 0.35s; }
.member-overlay.show::before { opacity: 1; }

.member-overlay-card {
  position: absolute; left: 24rpx; right: 24rpx; top: 50%;
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  border-radius: 48rpx;
  box-shadow: var(--shadow-modal), 0 0 0 2rpx rgba(255,255,255,0.5);
  max-height: 80vh;
  transform: translateY(-50%) scale(0.85);
  opacity: 0;
  transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex; flex-direction: column; overflow: hidden;
}
.member-overlay-card.show { transform: translateY(-50%) scale(1); opacity: 1; }

.member-overlay-close {
  position: sticky; top: 0; right: 0; z-index: 10;
  display: flex; justify-content: flex-end; padding: 24rpx 24rpx 0;
}
.member-overlay-close text {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-full);
  background: rgba(0,0,0,0.06); display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-on-surface-variant); line-height: 64rpx; text-align: center;
}
.member-overlay-close:active text { background: rgba(0,0,0,0.12); transform: scale(0.92); }

.member-overlay-scroll { padding: 0 32rpx 40rpx; overflow-y: auto; flex: 1; }

/* 会员卡、权益、方案卡片、CTA */
.member-hero { display: flex; flex-direction: column; align-items: center; padding-top: 8rpx; padding-bottom: 32rpx; }
.member-card { width: 100%; margin-bottom: 24rpx; }
.member-card-inner { background: linear-gradient(135deg, #1a1c1c 0%, #303031 100%); border-radius: var(--radius-lg); padding: 40rpx; position: relative; overflow: hidden; box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.06); width: 100%; display: flex; flex-direction: column; justify-content: space-between; min-height: 320rpx; }
.card-glow { position: absolute; top: -80rpx; right: -80rpx; width: 256rpx; height: 256rpx; background: rgba(255,255,255,0.05); border-radius: var(--radius-full); filter: blur(40rpx); pointer-events: none; }
.card-top { display: flex; justify-content: space-between; align-items: flex-start; }
.card-status-label { display: block; font-size: 22rpx; color: #C8C6C5; text-transform: uppercase; letter-spacing: 4rpx; margin-bottom: 8rpx; }
.card-level { font-size: 48rpx; font-weight: var(--font-weight-bold); color: #FFFFFF; letter-spacing: -2rpx; }
.card-badge { width: 88rpx; height: 88rpx; background: rgba(255,255,255,0.1); border-radius: var(--radius-card); border: 1rpx solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; -webkit-backdrop-filter: blur(20rpx); backdrop-filter: blur(20rpx); }
.badge-icon { font-size: 48rpx; }
.card-bottom { display: flex; justify-content: space-between; align-items: flex-end; }
.card-id-label { display: block; font-size: 22rpx; color: #C8C6C5; margin-bottom: 8rpx; }
.card-id { font-size: 30rpx; color: #FFFFFF; letter-spacing: 6rpx; }
.card-qr { width: 96rpx; height: 96rpx; background: #FFFFFF; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; }
.qr-icon { font-size: 56rpx; }
.member-hero-text { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.hero-headline { font-size: 44rpx; font-weight: 800; color: var(--color-on-surface); letter-spacing: -1rpx; line-height: 1.2; }
.hero-subtitle { font-size: 28rpx; color: var(--color-on-surface-variant); font-weight: 400; }

.privileges-section { width: 100%; margin-bottom: 24rpx; }
.privileges-scroll { width: 100%; }
.privileges-row { display: flex; gap: 24rpx; padding: 0 0 12rpx; }
.privilege-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; min-width: 112rpx; flex-shrink: 0; }
.privilege-icon-wrap { width: 112rpx; height: 112rpx; border-radius: 28rpx; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; box-shadow: inset 0 4rpx 8rpx rgba(255,255,255,0.8), 0 4rpx 16rpx rgba(0,0,0,0.06); -webkit-backdrop-filter: blur(16rpx); backdrop-filter: blur(16rpx); transition: transform 0.2s; }
.privilege-icon-wrap:active { transform: translateY(-4rpx); }
.privilege-icon-shine { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.5) 0%, transparent 50%); pointer-events: none; }
.privilege-icon { font-size: 46rpx; position: relative; z-index: 1; filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.1)); }
.privilege-label { font-size: 22rpx; font-weight: 500; color: var(--color-on-surface-variant); }
.privilege-icon-purple { background: rgba(132,85,239,0.2); border: 1rpx solid rgba(132,85,239,0.15); }
.privilege-icon-green { background: rgba(190,242,42,0.3); border: 1rpx solid rgba(190,242,42,0.2); }
.privilege-icon-gold { background: rgba(254,243,199,0.6); border: 1rpx solid rgba(251,192,45,0.25); }
.privilege-icon-pink { background: rgba(252,231,243,0.6); border: 1rpx solid rgba(236,72,153,0.2); }
.privilege-icon-teal { background: rgba(190,242,42,0.2); border: 1rpx solid rgba(16,185,129,0.15); }

.coupon-banner { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 24rpx; margin-bottom: 24rpx; background: rgba(233,233,221,0.4); -webkit-backdrop-filter: blur(24rpx); backdrop-filter: blur(24rpx); border-radius: 24rpx; border: 1rpx solid rgba(255,255,255,0.5); box-shadow: var(--shadow-sm); }
.coupon-banner-left { display: flex; align-items: center; gap: 12rpx; }
.coupon-banner-icon { font-size: 28rpx; }
.coupon-banner-text { font-size: 24rpx; font-weight: 600; color: var(--color-on-surface); }
.coupon-banner-help { width: 40rpx; height: 40rpx; border-radius: var(--radius-full); background: var(--color-surface-container-highest); display: flex; align-items: center; justify-content: center; }
.coupon-help-icon { font-size: 22rpx; font-weight: 700; color: var(--color-on-surface-variant); }

.plans-section { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.plan-card { border-radius: 28rpx; border: 3rpx solid var(--color-surface-container-highest); background: var(--color-surface); box-shadow: var(--shadow-sm); transition: all 0.3s ease; overflow: hidden; }
.plan-card:active { transform: scale(0.985); }
.plan-card-inner { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; position: relative; z-index: 1; }
.plan-selected { border-color: var(--color-primary-container); background: linear-gradient(135deg, #FFFBFB 0%, #FFF0EF 100%); box-shadow: 0 0 0 1rpx var(--color-primary-container), var(--shadow-elevated); }
.plan-selected .plan-card-inner { background: linear-gradient(180deg, rgba(255,255,255,0.6) 0%, transparent 100%); }
.plan-left { display: flex; flex-direction: column; gap: 8rpx; }
.plan-name-row { display: flex; align-items: center; gap: 12rpx; }
.plan-name { font-size: 28rpx; font-weight: 700; color: var(--color-on-surface); }
.plan-badge { font-size: 18rpx; font-weight: 700; color: var(--color-on-primary-container); background: var(--color-primary-container); padding: 4rpx 14rpx; border-radius: var(--radius-full); box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.6); }
.plan-price-row { display: flex; align-items: baseline; gap: 12rpx; }
.plan-price { font-size: 38rpx; font-weight: 800; color: var(--color-on-surface); letter-spacing: -1rpx; line-height: 1; }
.plan-original { font-size: 22rpx; font-weight: 500; color: var(--color-outline-variant); text-decoration: line-through; opacity: 0.7; }
.plan-radio { width: 48rpx; height: 48rpx; border-radius: var(--radius-full); border: 3rpx solid rgba(143,111,108,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.3s ease; box-shadow: var(--shadow-sm); }
.plan-radio.radio-checked { border-color: var(--color-primary-container); background: var(--color-primary-container); }
.plan-check-icon { font-size: 24rpx; font-weight: 700; color: var(--color-on-primary-container); transition: all 0.3s ease; }

.member-cta-section { display: flex; flex-direction: column; gap: 20rpx; padding-bottom: 8rpx; }
.member-cta-btn { width: 100%; padding: 24rpx 32rpx; background: var(--color-primary-container); border-radius: var(--radius-full); display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 12rpx 32rpx rgba(211,47,47,0.2), inset 0 4rpx 0 rgba(255,255,255,0.4); position: relative; overflow: hidden; transition: all 0.2s; border: 1rpx solid rgba(255,255,255,0.3); }
.member-cta-btn:active { transform: scale(0.98); opacity: 0.95; }
.cta-btn-shine { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.25) 0%, transparent 60%); pointer-events: none; }
.cta-main-text { font-size: 30rpx; font-weight: 700; color: var(--color-on-primary-container); position: relative; z-index: 1; letter-spacing: 2rpx; }
.cta-sub-text { font-size: 20rpx; font-weight: 500; color: var(--color-on-primary-container); opacity: 0.7; position: relative; z-index: 1; margin-top: 4rpx; }
.member-footer-links { display: flex; justify-content: center; align-items: center; gap: 20rpx; }
.footer-link { font-size: 20rpx; color: var(--color-on-surface-variant); opacity: 0.5; }
.footer-link:active { color: var(--color-primary); opacity: 0.8; }
.footer-divider { font-size: 18rpx; color: var(--color-on-surface-variant); opacity: 0.2; }

/* ===== 个人中心 ===== */
.profile-header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 32rpx 24rpx; }
.profile-left { display: flex; align-items: center; gap: 24rpx; }
.avatar-wrap { width: 128rpx; height: 128rpx; border-radius: var(--radius-full); overflow: hidden; box-shadow: var(--shadow-sm); flex-shrink: 0; }
.avatar { width: 100%; height: 100%; }
.avatar-placeholder { border-radius: 9999rpx; background: var(--color-surface-container); }
.profile-text { display: flex; flex-direction: column; gap: 6rpx; }
.profile-name { font-size: 36rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.profile-bio { font-size: 24rpx; color: var(--color-on-surface-variant); }
/* 头像编辑遮罩 */
.avatar-wrap { position: relative; }
.avatar-edit-mask { position: absolute; inset: 0; border-radius: var(--radius-full); background: rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; }
.avatar-wrap:active .avatar-edit-mask { opacity: 1; }
.avatar-edit-icon { font-size: 36rpx; color: #FFFFFF; }
.profile-name-row { display: flex; align-items: center; gap: 10rpx; }
.profile-edit-hint { font-size: 24rpx; color: var(--color-primary); opacity: 0.5; }

/* ── 会员卡轮播 ── */
.member-cards-section { margin: 0 0 8rpx; position: relative; }
.member-swiper { height: 340rpx; }
.tier-card-wrap { padding: 0 36rpx; height: 100%; display: flex; align-items: center; box-sizing: border-box; transition: padding 0.3s ease; }
.tier-card-wrap.active { padding: 0 20rpx; }
.tier-card { width: 100%; height: 100%; border-radius: 28rpx; overflow: hidden; position: relative; box-shadow: 0 12rpx 28rpx -8rpx rgba(0,0,0,0.25); transition: opacity 0.3s ease; }

.tier-card-bg-img {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}
.tier-card-active { opacity: 1; }
.tier-card-inactive { opacity: 0.55; }
.tier-card-content { position: relative; z-index: 1; padding: 28rpx 32rpx 9rpx; height: 100%; display: flex; flex-direction: column; justify-content: space-between; box-sizing: border-box; }

/* ── 顶部行：等级标识(左) + 操作按钮(右) ── */
.tier-card-top { display: flex; align-items: center; justify-content: space-between; }
.tier-status-pill { display: inline-flex; align-items: center; gap: 6rpx; padding: 8rpx 20rpx; border-radius: 999rpx; font-size: 22rpx; font-weight: 700; }
.tier-status-icon { font-size: 22rpx; line-height: 1; }
.tier-status-text { font-size: 22rpx; font-weight: 700; letter-spacing: 1rpx; }
/* 当前等级：亮白胶囊底 + accentColor 文字(inline style) */
.tier-status-current { box-shadow: 0 4rpx 16rpx rgba(255,255,255,0.25); }
/* 已达成：半透明白底 */
.tier-status-achieved { background: rgba(255,255,255,0.22); }
.tier-status-achieved .tier-status-icon,
.tier-status-achieved .tier-status-text { color: rgba(255,255,255,0.85); }
/* 未解锁：微透明底 */
.tier-status-locked { background: rgba(255,255,255,0.10); }
.tier-status-locked .tier-status-icon,
.tier-status-locked .tier-status-text { color: rgba(255,255,255,0.5); }

/* ── 中间区域：等级名称 + 权益标签 ── */
.tier-card-middle { display: flex; flex-direction: column; gap: 10rpx; }
.tier-card-title { font-size: 40rpx; font-weight: 800; letter-spacing: 2rpx; text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3); }

/* ── 底部 ── */
.tier-card-footer { margin-top: auto; }
.tier-card-progress-text { font-size: 22rpx; opacity: 0.8; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; padding-right: 12rpx; display: block; }

/* ── 成长进度条 ── */
.tier-progress-bar-wrap {
  margin-top: 10rpx;
  margin-bottom: 22rpx;
}
.tier-progress-bar-bg {
  width: 40%;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  overflow: hidden;
}
.tier-progress-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.6s ease;
}

/* ── 权益标签 ── */
.tier-benefits { display: flex; gap: 8rpx; flex-wrap: wrap; }
.tier-benefit-tag { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 8rpx; background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.85); line-height: 1.4; }
.tier-card-action { display: flex; align-items: center; gap: 4rpx; flex-shrink: 0; }
.tier-card-action-text { font-size: 22rpx; font-weight: 600; }
.tier-card-action-arrow { width: 28rpx; height: 28rpx; }
.tier-card-action:active { opacity: 0.7; }
.tier-dots { display: flex; justify-content: center; align-items: center; gap: 12rpx; margin-top: 20rpx; }
.tier-dot { width: 12rpx; height: 12rpx; border-radius: 999rpx; background: rgba(0,0,0,0.12); }
.tier-dot.active { width: 28rpx; border-radius: 999rpx; }

/* 公告浮窗 */
.announce-float {
  position: fixed;
  right: 0;
  top: 35%;
  z-index: 150;
  transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}
/* 折叠态 — 右侧竖条 */
.announce-float-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 72rpx;
  padding: 20rpx 12rpx;
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  border-radius: 24rpx 0 0 24rpx;
  box-shadow: -4rpx 0 24rpx rgba(0,0,0,0.08);
  border: var(--glass-border-subtle);
  border-right: none;
}
.announce-float-tab:active {
  transform: scale(0.92);
  background: var(--glass-bg-primary-light);
}
.announce-float-tab-icon {
  font-size: 32rpx;
  line-height: 1;
}
.announce-float-tab-text {
  font-size: 20rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
  writing-mode: vertical-lr;
  letter-spacing: 4rpx;
}
/* 展开态 — 浮窗卡片 */
.announce-float.expanded {
  right: 16rpx;
  top: 28%;
}
.announce-float-card {
  width: 420rpx;
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-modal);
  border: var(--glass-border);
  overflow: hidden;
}
.announce-float-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--color-divider);
}
.announce-float-card-icon {
  font-size: 28rpx;
}
.announce-float-card-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.announce-float-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--glass-bg-light);
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  flex-shrink: 0;
}
.announce-float-close:active {
  background: var(--color-surface-container-high);
  transform: scale(0.92);
}
.announce-float-card-body {
  display: block;
  padding: 24rpx;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.6;
}

/* 金刚区 */
.grid-actions { display: flex; justify-content: space-around; margin: 0 32rpx 24rpx; padding: 28rpx 16rpx; border-radius: 24rpx; background: var(--color-surface); box-shadow: var(--shadow-card); }
.grid-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.grid-icon-wrap { width: 96rpx; height: 96rpx; border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; }
.grid-icon-wrap:active { transform: scale(0.92); transition: transform 0.15s; }
.grid-icon-red { background: rgba(211,47,47,0.08); }
.grid-icon-gold { background: rgba(251,192,45,0.15); }
.grid-icon-green { background: rgba(56,142,60,0.1); }
.grid-icon-gray { background: var(--color-surface-container); }
.grid-icon-blue { background: rgba(25, 118, 210, 0.08); }
.grid-icon { width: 64rpx; height: 64rpx; }
.grid-icon-emoji { font-size: 40rpx; line-height: 1; }
.grid-label { font-size: 22rpx; color: var(--color-on-surface); }

/* 功能菜单 */
.menu-section { padding: 0 32rpx 72rpx; }
.menu-card { border-radius: 24rpx; background: var(--color-surface); box-shadow: var(--shadow-card); overflow: hidden; }
.menu-item { display: flex; align-items: center; gap: 24rpx; padding: 28rpx 32rpx; border-bottom: 2rpx solid rgba(0,0,0,0.04); }
.menu-item:active { background: var(--color-surface-container-low); }
.menu-item-last { border-bottom: none; }
.menu-icon { width: 52rpx; height: 52rpx; }
.menu-name { flex: 1; font-size: 30rpx; color: var(--color-on-surface); }
.menu-arrow { font-size: 32rpx; color: var(--color-on-surface-variant); }

/* 编辑个人信息抽屉 */
.edit-overlay { position: fixed; inset: 0; z-index: 200; visibility: hidden; }
.edit-overlay.show { visibility: visible; }
.edit-overlay::before { content: ''; position: absolute; inset: 0; background: rgba(0,0,0,0.45); opacity: 0; transition: opacity 0.3s; }
.edit-overlay.show::before { opacity: 1; }
.edit-drawer { position: absolute; left: 0; right: 0; bottom: 0; background: var(--color-surface); border-radius: 40rpx 40rpx 0 0; transform: translateY(100%); transition: transform 0.3s ease; max-height: 80vh; display: flex; flex-direction: column; box-shadow: var(--shadow-modal); }
.edit-drawer.show { transform: translateY(0); }
.edit-drawer-nav { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 40rpx; border-bottom: 1rpx solid var(--color-divider); flex-shrink: 0; }
.edit-drawer-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.edit-drawer-save { font-size: 30rpx; font-weight: var(--font-weight-semibold); color: var(--color-primary); padding: 8rpx 16rpx; }
.edit-drawer-body { flex: 1; padding: 40rpx; overflow-y: auto; }
.edit-avatar-section { display: flex; align-items: center; gap: 24rpx; margin-bottom: 40rpx; padding: 24rpx; border-radius: var(--radius-card); background: var(--color-surface-container-low); }
.edit-avatar-img { width: 120rpx; height: 120rpx; border-radius: var(--radius-full); flex-shrink: 0; box-shadow: var(--shadow-sm); }
.edit-avatar-tip { flex: 1; }
.edit-avatar-tip-text { font-size: 26rpx; color: var(--color-primary); }
.edit-field { margin-bottom: 32rpx; }
.edit-field-label { display: block; font-size: 26rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); margin-bottom: 16rpx; }
.edit-field-input { width: 100%; height: 88rpx; padding: 0 28rpx; border-radius: var(--radius-sm); background: var(--color-surface-container-low); font-size: 30rpx; color: var(--color-on-surface); }

/* ===== 产品详情弹窗 ===== */
.detail-overlay {
  position: fixed;
  inset: 0;
  z-index: 1100;
  visibility: hidden;
}
.detail-overlay.show { visibility: visible; }
.detail-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--glass-bg-overlay);
  -webkit-backdrop-filter: blur(6px);
  backdrop-filter: blur(6px);
  opacity: 0;
  transition: opacity 0.3s;
}
.detail-overlay.show::before { opacity: 1; }

/* 导航行 — 位于页面 top-bar 下方，紧凑间距 */
.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx 16rpx;
  flex-shrink: 0;
}
.detail-back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--glass-bg-light);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border: var(--glass-border-subtle);
}
.detail-back-btn:active {
  background: var(--glass-bg-elevated);
  transform: scale(0.94);
}
.detail-back-icon {
  font-size: 36rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.detail-nav-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.detail-nav-spacer {
  width: 72rpx;
}

.detail-drawer {
  position: absolute;
  left: 0;
  right: 0;
  top: 190rpx;
  bottom: 0;
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  border-radius: 48rpx 48rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: var(--shadow-modal);
  border-top: var(--glass-border);
  overflow: hidden;
}
.detail-drawer.show { transform: translateY(0); }

/* 可滚动内容区 */
.detail-body {
  flex: 1;
  height: 0;
  min-height: 0;
}

/* 产品大图 — 完整显示不裁剪 */
.detail-image {
  width: 100%;
  display: block;
  background: var(--color-surface-container-low);
}

/* 产品信息 */
.detail-header {
  padding: 32rpx 40rpx 0;
  margin-bottom: 24rpx;
}

.detail-title-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.detail-name {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
  flex: 1;
}
.detail-price {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  flex-shrink: 0;
}

.detail-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.detail-tag {
  font-size: 22rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-primary-container);
  background: var(--glass-bg-primary-container);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  border: var(--glass-border-colored);
}
.detail-size {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  background: var(--glass-bg-light);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  border: var(--glass-border-subtle);
}

/* 详细描述 */
.detail-desc {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.7;
  display: block;
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

/* 食材 */
.detail-ingredients {
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}
.detail-section-label {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 16rpx;
}
.ingredient-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.ingredient-item {
  font-size: 24rpx;
  color: var(--color-on-surface);
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  border: var(--glass-border-subtle);
}

/* 忌口选择区（随内容一体滚动） */
.detail-restrictions {
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}
.detail-restrictions .detail-section-label {
  margin-bottom: 12rpx;
}
.restriction-scroll {
  white-space: nowrap;
}
.restriction-row {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

/* 底部留白，避免被 footer 遮挡 */
.detail-bottom-spacer {
  height: 24rpx;
}
.restriction-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  background: var(--glass-bg-light);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  padding: 14rpx 28rpx;
  border-radius: var(--radius-full);
  border: var(--glass-border-subtle);
  transition: all 0.2s;
  flex-shrink: 0;
  white-space: nowrap;
}
.restriction-chip:active {
  transform: scale(0.96);
}
.restriction-chip.active {
  background: var(--glass-bg-primary-container);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  color: var(--color-on-primary-container);
  font-weight: var(--font-weight-semibold);
  border: var(--glass-border-colored);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}
.chip-check {
  font-size: 20rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* 底部操作栏 */
.detail-footer {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  background: var(--glass-bg-elevated);
  -webkit-backdrop-filter: var(--glass-blur-lg);
  backdrop-filter: var(--glass-blur-lg);
  flex-shrink: 0;
}

.detail-stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--glass-bg-card);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  border-radius: var(--radius-full);
  padding: 8rpx 16rpx;
  border: var(--glass-border-subtle);
  flex-shrink: 0;
}
.detail-stepper .qty-btn {
  width: 64rpx;
  height: 64rpx;
}
.detail-stepper .qty-icon {
  font-size: 40rpx;
}
.detail-qty-num {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  min-width: 48rpx;
  text-align: center;
}

.detail-add-btn {
  flex: 1;
  background: var(--glass-bg-primary);
  -webkit-backdrop-filter: var(--glass-blur-sm);
  backdrop-filter: var(--glass-blur-sm);
  color: var(--color-on-primary);
  border-radius: var(--radius-full);
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  box-shadow: var(--glass-shadow-button);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  white-space: nowrap;
}
.detail-add-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
