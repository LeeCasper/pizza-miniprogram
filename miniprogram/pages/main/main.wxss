/* pages/main/main.wxss */

/* ===== 全局布局 ===== */
.app-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx 24rpx;
  background: var(--glass-bg-nav);
  border-bottom: var(--glass-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.top-bar-left { display: flex; align-items: center; gap: 16rpx; }
.brand-logo { width: 56rpx; height: 56rpx; border-radius: 12rpx; flex-shrink: 0; }

.brand-title { font-size: 36rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }
.top-title { font-size: 36rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); }

/* 商城订单入口 — 固定定位在微信胶囊左侧，与胶囊同高 */
.top-bar-order-btn {
  position: fixed;
  z-index: 101;
  display: flex; align-items: center; gap: 8rpx;
  padding: 0 20rpx;
  border-radius: 32rpx;
  background: var(--glass-bg-card);
  border: var(--glass-border-subtle);
  box-shadow: var(--glass-shadow-card);
}
.top-bar-order-icon { font-size: 26rpx; }
.top-bar-order-label { font-size: 22rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }


/* ===== Swiper ===== */
/* 透明：让 swiper 区域露出 .app-root 的主题渐变，作为全局背景基底。
   原 var(--color-background)（=lighten(主色,42%)≈近白）是不透明层，会盖住主题渐变，
   导致透明的 .order-tabs 等元素露出的是这层近白底而非背景色 —— 这正是「订单状态条还是白色」的真因。
   各 tab 的滚动区（.tab-scroll/.orders-scroll/...）本就自铺主题渐变，不受影响。 */
/* transform 让 .main-swiper 成为内部 position:fixed 的「包含块」——
   还原原 swiper-item 滑动 transform 提供的同款上下文。
   否则首页详情弹层(.detail-overlay, fixed, 在 tab-scroll 内)会逃逸到整屏，
   抽屉 bottom:0 落到屏幕最底、被底部 Tab 栏盖住，「加入购物车」按钮看不见。 */
.main-swiper { background: transparent; transform: translateZ(0); }

/* Tab 切换：swiper 横向滑动已关闭(duration=0 + disable-touch)，无重栅格化卡顿；
   切换瞬间给当前 pane 一个轻量淡入，丝滑不生硬。 */
.swiper-pane.pane-active { animation: paneFadeIn 0.24s ease-out; }
@keyframes paneFadeIn {
  from { opacity: 0.4; }
  to   { opacity: 1; }
}

.tab-scroll {
  padding: 0 0 72rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* ===== 底部导航栏 ===== */
.tab-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: calc(100rpx + env(safe-area-inset-bottom));
  background: var(--glass-bg-nav);
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
  border-top: var(--glass-border-subtle);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 8rpx 0;
  transition: transform 0.15s;
}

.tab-bar-item:active { transform: scale(0.92); }

.tab-icon-img {
  width: 44rpx; height: 44rpx;
  opacity: 0.45;
  transition: opacity 0.2s;
}

.tab-bar-item.active .tab-icon-img { opacity: 1; }

.tab-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #9E9E9E;
  transition: color 0.2s;
}

.tab-bar-item.active .tab-label {
  color: var(--color-primary);
  font-weight: 700;
}

/* ===== 首页：取餐切换 ===== */
.pickup-toggle { padding: 32rpx 40rpx 24rpx; }

.toggle-pill {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  width: 100%; padding: 28rpx 40rpx;
  /* 粘土取餐胶囊：柔紫实底 + 内顶高光 + 内底暗影 + 外柔影 */
  background: linear-gradient(160deg, #F0EADF 0%, #E6DCCB 100%);
  color: var(--color-on-primary-container);
  border-radius: var(--radius-card);
  font-size: 36rpx; font-weight: var(--font-weight-bold);
  box-shadow: inset 3rpx 3rpx 5rpx rgba(255,255,255,0.85), inset -4rpx -5rpx 10rpx rgba(120,108,94,0.14), 0 8rpx 18rpx rgba(120,108,94,0.16);
  transition: transform 0.12s ease;
}
.toggle-pill:active { transform: translateY(2rpx) scale(0.99); }

.toggle-icon-img { width: 48rpx; height: 48rpx; }

/* ===== 首页：Banner轮播 ===== */
.hero-section {
  margin: 0 40rpx 32rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(120,108,94,0.18);
}
.hero-swiper {
  border-radius: 32rpx;
}
.hero-slide {
  width: 100%;
  height: 100%;
  position: relative;
}
.hero-image { width: 100%; height: 100%; }
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
  padding: 24rpx 32rpx; display: flex; flex-direction: column; justify-content: space-between;
  pointer-events: none;
}
.hero-tag { align-self: flex-start; }
.hero-tag text {
  background: var(--color-primary-container); color: var(--color-on-primary-container);
  padding: 8rpx 24rpx; border-radius: var(--radius-full);
  font-size: 22rpx; font-weight: var(--font-weight-semibold); letter-spacing: 2rpx;
}
.hero-text { display: flex; flex-direction: column; gap: 8rpx; }
.hero-title { color: #FFFFFF; font-size: 40rpx; font-weight: var(--font-weight-bold); line-height: 1.2; }
.hero-subtitle { color: rgba(255,255,255,0.8); font-size: 26rpx; }

/* ===== 首页：分类 ===== */
.category-section { padding: 16rpx 0; }
.category-scroll { white-space: nowrap; }
.category-list { display: flex; padding: 0 40rpx; gap: 32rpx; }
.category-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 8rpx 16rpx; }
.category-icon-wrap {
  width: 96rpx; height: 96rpx; border-radius: var(--radius-full);
  /* 粘土分类圆球 */
  background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%);
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  box-shadow: inset 3rpx 3rpx 5rpx rgba(255,255,255,0.92), inset -4rpx -5rpx 9rpx rgba(120,108,94,0.10), 0 6rpx 14rpx rgba(120,108,94,0.12);
}
.category-icon-wrap.active { background: linear-gradient(160deg, #EFE7D8 0%, #E4D9C6 100%); box-shadow: inset 3rpx 3rpx 5rpx rgba(255,255,255,0.82), inset -4rpx -5rpx 9rpx rgba(120,108,94,0.22), 0 8rpx 16rpx rgba(120,108,94,0.22); }
.category-icon { width: 56rpx; height: 56rpx; }
.category-name { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); }
.category-name.active { color: var(--color-primary); }

/* ===== 首页：商品 ===== */
.product-section { padding: 16rpx 40rpx; }
.section-header { margin-bottom: 24rpx; }
.section-title { font-size: 36rpx; font-weight: var(--font-weight-bold); color: var(--color-on-background); }
.product-list { display: flex; flex-direction: column; gap: 24rpx; }
.product-card {
  display: flex; align-items: center; gap: 24rpx;
  /* 粘土商品卡 */
  background: linear-gradient(160deg, #FFFFFF 0%, #F4F0E9 100%);
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(120,108,94,0.10), inset 3rpx 3rpx 5rpx rgba(255,255,255,0.95), inset -4rpx -6rpx 14rpx rgba(120,108,94,0.07);
  transition: transform 0.12s ease;
}
.product-card:active { transform: translateY(2rpx) scale(0.995); }
.product-image { width: 160rpx; height: 160rpx; border-radius: 16rpx; flex-shrink: 0; background: var(--color-surface-container-low); }
.product-info { flex: 1; display: flex; flex-direction: column; justify-content: center; min-width: 0; }
.product-meta { margin-bottom: 16rpx; }
.product-name { font-size: 30rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-background); display: block; margin-bottom: 8rpx; }
.product-desc { font-size: 24rpx; color: var(--color-on-surface-variant); }
.product-bottom { display: flex; align-items: center; justify-content: space-between; }
.product-price { font-size: 30rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }

.add-btn {
  width: 72rpx; height: 72rpx; border-radius: var(--radius-full);
  /* 粘土加购圆球（紫） */
  background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%);
  box-shadow: inset 3rpx 3rpx 5rpx rgba(255,255,255,0.85), inset -3rpx -4rpx 8rpx rgba(120,108,94,0.18), 0 5rpx 12rpx rgba(120,108,94,0.18);
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.12s ease;
}
.add-btn:active { transform: translateY(2rpx) scale(0.92); }
.add-icon { font-size: 40rpx; color: #5E544A; font-weight: 300; line-height: 1; }

.qty-stepper {
  display: flex; align-items: center; gap: 20rpx;
  /* 粘土数量条：柔紫内嵌底 */
  background: #F3EFE8;
  border-radius: var(--radius-full);
  padding: 8rpx 12rpx;
  box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.9), inset -2rpx -2rpx 5rpx rgba(120,108,94,0.10), 0 4rpx 10rpx rgba(120,108,94,0.10);
}
.qty-btn {
  width: 56rpx; height: 56rpx; border-radius: var(--radius-full);
  /* 粘土小球 */
  background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%);
  display: flex; align-items: center; justify-content: center;
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.9), inset -2rpx -2rpx 4rpx rgba(120,108,94,0.12), 0 3rpx 7rpx rgba(120,108,94,0.12);
  transition: transform 0.1s ease;
}
.qty-btn:active { transform: scale(0.9); }
.qty-plus { background: linear-gradient(160deg, #EFE7D8 0%, #E4D9C6 100%); box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.8), inset -3rpx -3rpx 6rpx rgba(120,108,94,0.20), 0 3rpx 8rpx rgba(120,108,94,0.20); }
.qty-icon { font-size: 36rpx; color: var(--color-on-surface); font-weight: 400; line-height: 1; }
.qty-plus .qty-icon { color: #5E544A; }
.qty-num { font-size: 28rpx; font-weight: var(--font-weight-bold); min-width: 32rpx; text-align: center; }

/* ===== 购物车浮条 ===== */
.cart-bar {
  position: fixed; bottom: calc(100rpx + env(safe-area-inset-bottom));
  left: 0; right: 0; padding: 0 32rpx; z-index: 90;
  transform: translateY(200rpx); opacity: 0; transition: all 0.3s ease;
}
.cart-bar.show { transform: translateY(0); opacity: 1; }
.cart-bar-inner {
  display: flex; align-items: center; justify-content: space-between;
  /* 粘土暗色浮条：实底 + 顶微高光 + 内底暗影 + 外柔影 */
  background: linear-gradient(160deg, #3C362F 0%, #2B2722 100%);
  color: #F2F0F0;
  border-radius: var(--radius-full); padding: 20rpx 20rpx 20rpx 40rpx;
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.12), inset -3rpx -4rpx 10rpx rgba(0,0,0,0.35), 0 10rpx 24rpx rgba(40,34,28,0.35);
}
.cart-bar-left { display: flex; align-items: center; gap: 20rpx; }
.cart-icon-wrap { position: relative; }
.cart-icon { width: 56rpx; height: 56rpx; }
.cart-badge {
  position: absolute; top: -8rpx; right: -16rpx; min-width: 36rpx; height: 36rpx;
  background: var(--color-primary); color: var(--color-on-primary);
  font-size: 20rpx; font-weight: var(--font-weight-bold); border-radius: var(--radius-full);
  display: flex; align-items: center; justify-content: center;
  border: 4rpx solid var(--color-on-surface); padding: 0 8rpx;
}
.cart-total { font-size: 32rpx; font-weight: var(--font-weight-bold); }
.cart-bar-btn {
  /* 粘土紫按钮 */
  background: linear-gradient(160deg, #ff5b3e 0%, #e14d33 100%);
  color: var(--color-on-primary);
  padding: 20rpx 48rpx; border-radius: var(--radius-full);
  font-size: 28rpx; font-weight: var(--font-weight-bold);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.45), inset -3rpx -4rpx 8rpx rgba(120,108,94,0.45), 0 6rpx 16rpx rgba(120,108,94,0.40);
  transition: transform 0.12s ease;
}
.cart-bar-btn:active { transform: translateY(2rpx) scale(0.97); }

/* ===== 购物车抽屉 ===== */
.cart-overlay { position: fixed; inset: 0; z-index: 1000; visibility: hidden; }
.cart-overlay.show { visibility: visible; }
.cart-overlay::before {
  content: ''; position: absolute; inset: 0;
  /* 弹窗蒙层：半透明暗底，结算抽屉外的页面变暗但仍可见（标准弹窗交互，非全白遮盖） */
  background: var(--glass-bg-overlay);
  opacity: 0; transition: opacity 0.3s;
}
.cart-overlay.show::before { opacity: 1; }
.cart-drawer {
  position: absolute; left: 0; right: 0; bottom: 0;
  background: linear-gradient(160deg, #FFFFFF 0%, #F4F0E9 100%);
  border-radius: 48rpx 48rpx 0 0;
  max-height: 80vh; display: flex; flex-direction: column;
  transform: translateY(100%); transition: transform 0.3s ease;
  /* 黏土底盘：上缘柔和外投影 + 斜向内顶高光（鼓起），无模糊无描边 */
  box-shadow: 0 -8rpx 32rpx rgba(40, 34, 28, 0.16), inset 4rpx 4rpx 8rpx rgba(255, 255, 255, 0.9);
  border-top: none;
}
.cart-drawer.show { transform: translateY(0); }
.cart-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 40rpx; border-bottom: 1rpx solid var(--color-divider);
  border-radius: 48rpx 48rpx 0 0;
}
.cart-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: #5E5142; }
.cart-clear { display: flex; align-items: center; gap: 8rpx; font-size: 26rpx; color: #8A7B66; padding: 8rpx 16rpx; }
.cart-clear-icon { width: 32rpx; height: 32rpx; }
.cart-items { flex: 1; padding: 24rpx 40rpx; overflow-y: auto; }
.cart-item { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 0; border-bottom: 1rpx solid var(--color-divider); }
.cart-item:last-child { border-bottom: none; }
.cart-item-img { width: 96rpx; height: 96rpx; border-radius: 16rpx; flex-shrink: 0; background: var(--color-surface-container-low); }
.cart-item-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.cart-item-name { font-size: 30rpx; font-weight: var(--font-weight-semibold); color: #5E5142; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cart-item-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.cart-item-tag { font-size: 20rpx; color: #8A7B66; background: #F1ECE3; padding: 4rpx 14rpx; border-radius: 8rpx; box-shadow: inset 2rpx 2rpx 3rpx rgba(255, 255, 255, 0.9), inset -2rpx -2rpx 3rpx rgba(120, 108, 94, 0.12); white-space: nowrap; }
.cart-item-price { font-size: 28rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }
.cart-empty { padding: 80rpx 0; text-align: center; color: #8A7B66; font-size: 28rpx; }
.cart-footer { padding: 24rpx 40rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid var(--color-divider); }
.checkout-btn {
  width: 100%; padding: 28rpx;
  background: linear-gradient(160deg, #f45746 0%, #ed5247 100%);
  color: #FFFFFF;
  border-radius: var(--radius-full); text-align: center; font-size: 32rpx; font-weight: var(--font-weight-bold);
  /* 浓咖主操作：外投影浮起 + 斜向内高光/内暗影模制立体边 */
  box-shadow: 0 10rpx 22rpx rgba(60, 50, 40, 0.30), inset 3rpx 3rpx 5rpx rgba(255, 255, 255, 0.22), inset -4rpx -5rpx 10rpx rgba(30, 24, 18, 0.30);
  border: none;
}
.checkout-btn:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(60, 50, 40, 0.26), inset -3rpx -3rpx 5rpx rgba(255, 255, 255, 0.16), inset 3rpx 4rpx 9rpx rgba(30, 24, 18, 0.34);
}

/* Payment method selector — inside cart drawer */
.pay-method-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.pay-method-item {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx;
  padding: 18rpx 16rpx; border-radius: var(--radius-sm);
  border: none;
  background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); font-size: 26rpx; color: #5E5142;
  box-shadow: 0 4rpx 10rpx rgba(120, 108, 94, 0.14), inset 2rpx 2rpx 4rpx rgba(255, 255, 255, 0.9), inset -3rpx -4rpx 8rpx rgba(120, 108, 94, 0.12);
  transition: all 0.2s ease;
}
.pay-method-item.active {
  background: linear-gradient(160deg, #EFE7D8 0%, #E4D9C6 100%);
  color: #5E5142; font-weight: var(--font-weight-semibold);
  /* 选中=按陷：斜向内暗影在上、内高光在下 */
  box-shadow: inset 3rpx 3rpx 6rpx rgba(120, 108, 94, 0.22), inset -3rpx -3rpx 6rpx rgba(255, 255, 255, 0.7);
}
.pay-method-icon { width: 36rpx; height: 36rpx; flex-shrink: 0; }
.pay-method-label { font-size: 26rpx; }

/* ===== 优惠券选择行 ===== */
.coupon-select-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0; margin-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-divider);
}
.coupon-select-label { font-size: 28rpx; color: #5E5142; flex-shrink: 0; }
.coupon-select-right { display: flex; align-items: center; gap: 8rpx; flex: 1; justify-content: flex-end; }
.coupon-select-value { font-size: 26rpx; color: #8A7B66; }
.coupon-select-value.coupon-active { color: #C0563A; font-weight: var(--font-weight-bold); }
.coupon-select-value.coupon-none { color: #bbb; }
.coupon-select-name { font-size: 24rpx; color: #8A7B66; max-width: 280rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.coupon-arrow { font-size: 32rpx; color: #ccc; margin-left: 4rpx; }

/* ===== 价格明细 ===== */
.price-breakdown {
  padding: 16rpx 0; margin-bottom: 12rpx;
  border-bottom: 1rpx solid var(--color-divider);
}
.price-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 6rpx 0; font-size: 26rpx; color: #8A7B66;
}
.price-row.discount { color: var(--color-tertiary); }
.price-row.total { padding-top: 12rpx; font-size: 28rpx; color: #5E5142; font-weight: var(--font-weight-semibold); }
.final-price { color: var(--color-price); font-size: 32rpx; font-weight: var(--font-weight-bold); }

/* ===== 优惠券选择弹窗 ===== */
.coupon-picker-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: var(--glass-bg-overlay);
  z-index: 1100;
  visibility: hidden; opacity: 0; transition: all 0.3s ease;
}
.coupon-picker-overlay.show { visibility: visible; opacity: 1; }
.coupon-picker {
  position: fixed; left: 0; right: 0; bottom: 0;
  max-height: 65vh; background: linear-gradient(160deg, #FFFFFF 0%, #F4F0E9 100%); /* 黏土底盘，不跟随主题 */
  border: none;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 32rpx rgba(40, 34, 28, 0.16), inset 4rpx 4rpx 8rpx rgba(255, 255, 255, 0.9);
  transform: translateY(100%); transition: transform 0.3s ease;
  z-index: 1101; display: flex; flex-direction: column;
}
.coupon-picker.show { transform: translateY(0); }
.coupon-picker-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 40rpx 20rpx; border-bottom: 1rpx solid var(--color-divider);
  flex-shrink: 0;
}
.coupon-picker-title { font-size: 32rpx; font-weight: var(--font-weight-bold); color: #5E5142; }
.coupon-picker-close { font-size: 36rpx; color: #999; padding: 8rpx; }
.coupon-picker-list { flex: 1; padding: 16rpx 24rpx; max-height: 55vh; }
.coupon-picker-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 24rpx 20rpx; margin-bottom: 16rpx;
  border-radius: var(--radius-sm); background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%);
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(120, 108, 94, 0.14), inset 2rpx 2rpx 4rpx rgba(255, 255, 255, 0.9), inset -3rpx -4rpx 8rpx rgba(120, 108, 94, 0.12);
  transition: all 0.2s ease;
}
.coupon-picker-item.selected {
  background: linear-gradient(160deg, #EFE7D8 0%, #E4D9C6 100%);
  /* 选中=按陷立体边 */
  box-shadow: inset 3rpx 3rpx 6rpx rgba(120, 108, 94, 0.22), inset -3rpx -3rpx 6rpx rgba(255, 255, 255, 0.7);
}
.coupon-picker-item.disabled { opacity: 0.45; }
.coupon-picker-tag {
  width: 130rpx; height: 100rpx; flex-shrink: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  border-radius: 12rpx; color: #fff;
}
.coupon-picker-tag-value { font-size: 28rpx; font-weight: var(--font-weight-bold); }
.coupon-picker-tag-label { font-size: 20rpx; opacity: 0.85; }
.coupon-picker-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.coupon-picker-name { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: #5E5142; }
.coupon-picker-desc { font-size: 22rpx; color: #8A7B66; }
.coupon-picker-desc.warn { color: #ef6c00; }
.coupon-picker-expire { font-size: 22rpx; color: #bbb; }
.coupon-picker-check {
  width: 44rpx; height: 44rpx; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(160deg, #7A6F61 0%, #5C5249 100%); color: #fff; font-size: 24rpx; font-weight: bold;
  box-shadow: 0 3rpx 7rpx rgba(60, 50, 40, 0.26), inset 2rpx 2rpx 3rpx rgba(255, 255, 255, 0.25), inset -2rpx -3rpx 5rpx rgba(30, 24, 18, 0.3);
  border-radius: 50%;
}
.coupon-picker-empty { padding: 80rpx 0; text-align: center; color: #bbb; font-size: 28rpx; }

/* ===== 订单 ===== */
/* Tab 条固定不动：sticky 钉在 .orders-scroll 视口顶部，订单列表在其下滚动。
   毛玻璃底取 --glass-bg-nav（背景渐变均值，与顶/底导航栏同款、跟随后台背景色），
   卡片上滚时被磨砂层盖住不穿透；margin:0 -40rpx 抵消 .scroll-inner 内边距使其满宽铺满。 */
.order-tabs {
  position: sticky; top: 0; z-index: 5;
  margin: 0 -40rpx; padding: 16rpx 40rpx;
  background: var(--glass-bg-nav);
  border-bottom: var(--glass-border-subtle);
}
.tabs-scroll { white-space: nowrap; background: transparent; }
.tabs-list { display: flex; flex-direction: row; flex-wrap: nowrap; gap: 16rpx; }
/* 粘土风胶囊：未选中=debossed（inset 暖阴影+白高光，像压入条面）；选中=raised 陶土粘土（外投影圆角正常，全局已无 backdrop-filter 不会出直角阴影）。 */
.tab-item {
  padding: 16rpx 36rpx; border-radius: var(--radius-full); font-size: 28rpx;
  font-weight: var(--font-weight-semibold); color: var(--color-on-surface-variant);
  background: #EFE7DA;
  box-shadow: inset 2rpx 2rpx 5rpx rgba(120,108,94,0.18), inset -2rpx -2rpx 5rpx rgba(255,255,255,0.85);
  flex-shrink: 0;
  /* 丝滑过渡：底色/文字用 easeOutExpo 平滑渐变，缩放用轻微回弹曲线 */
  transition: background-color 0.32s cubic-bezier(0.22, 1, 0.36, 1),
              color 0.32s cubic-bezier(0.22, 1, 0.36, 1),
              border-color 0.32s cubic-bezier(0.22, 1, 0.36, 1),
              transform 0.28s cubic-bezier(0.34, 1.4, 0.5, 1);
}
.tab-item:active { transform: scale(0.94); }
.tab-item.active { background: linear-gradient(160deg, #C9684C 0%, #A8472E 100%); color: #FFFFFF; box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.3), inset -3rpx -3rpx 7rpx rgba(120,40,28,0.4), 0 5rpx 12rpx rgba(150,60,40,0.3); transform: scale(1.03); }

.orders-scroll { padding: 0 0 63rpx; overflow-x: hidden; box-sizing: border-box; }
.scroll-inner { padding: 0 40rpx; }

/* 订单卡片：粘土风浮起面板——暖白渐变 + 双向 inset（左上白高光 + 右下暖阴影）+ 柔和外投影，从背景鼓出。
   不再有左侧状态色条；订单状态由右上角徽章传达，卡片四边内边距对称。 */
.order-card {
  position: relative;
  margin-bottom: 28rpx;
  padding: 32rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: linear-gradient(160deg, #FFFFFF 0%, #F3EEE5 100%);
  box-shadow: inset 3rpx 3rpx 7rpx rgba(255,255,255,0.85), inset -4rpx -5rpx 11rpx rgba(120,108,94,0.14), 0 8rpx 22rpx rgba(120,108,94,0.16);
}
.order-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.order-header-left { display: flex; flex-direction: column; gap: 8rpx; flex: 1; overflow: hidden; min-width: 0; }
.order-store { display: flex; align-items: center; gap: 10rpx; min-width: 0; }
.order-store-icon { width: 44rpx; height: 44rpx; flex-shrink: 0; border-radius: 8rpx; }
.order-store-name { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.order-no { font-size: 24rpx; color: var(--color-on-surface-variant); }
.order-time { font-size: 24rpx; color: var(--color-on-surface-variant); }
.order-header-right { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.order-status { padding: 8rpx 24rpx; border-radius: var(--radius-full); font-size: 24rpx; font-weight: var(--font-weight-semibold); flex-shrink: 0; box-shadow: inset 1rpx 1rpx 2rpx rgba(255,255,255,0.55), inset -1rpx -1rpx 3rpx rgba(120,108,94,0.2); }
.order-status.completed { background: var(--color-tertiary-container); color: var(--color-tertiary); }
.order-status.preparing { background: var(--color-secondary-container); color: var(--color-secondary-dark); }
.order-status.waiting { background: var(--color-primary-container); color: var(--color-primary); }
.payment-badge { padding: 6rpx 20rpx; border-radius: var(--radius-full); font-size: 22rpx; font-weight: var(--font-weight-semibold); flex-shrink: 0; box-shadow: inset 1rpx 1rpx 2rpx rgba(255,255,255,0.55), inset -1rpx -1rpx 3rpx rgba(120,108,94,0.2); }
.payment-badge.paid { background: var(--color-tertiary-container); color: var(--color-on-tertiary); }
.payment-badge.unpaid { background: var(--color-secondary-container); color: var(--color-secondary-dark); }

.order-items { border-top: 1rpx solid var(--color-divider); padding-top: 20rpx; display: flex; flex-direction: column; gap: 18rpx; }
.order-item { display: flex; align-items: center; gap: 20rpx; }
.order-item-thumb { width: 92rpx; height: 92rpx; border-radius: 18rpx; flex-shrink: 0; background: linear-gradient(160deg, #F4EFE6 0%, #E9E1D4 100%); box-shadow: inset 2rpx 2rpx 5rpx rgba(120,108,94,0.2), inset -2rpx -2rpx 5rpx rgba(255,255,255,0.85); }
.order-item-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.order-item-name { font-size: 28rpx; color: var(--color-on-surface); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.order-item-unit { font-size: 24rpx; color: var(--color-on-surface-variant); }
.order-item-count { font-size: 28rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); flex-shrink: 0; }

/* 取餐码 */
.pickup-section { border-top: 1rpx solid var(--color-divider); padding: 28rpx 0 8rpx; }
.pickup-btn { display: flex; align-items: center; justify-content: center; gap: 12rpx; padding: 24rpx; border-radius: 24rpx; background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); box-shadow: inset 3rpx 3rpx 6rpx rgba(255,255,255,0.85), inset -3rpx -4rpx 8rpx rgba(120,108,94,0.16), 0 5rpx 14rpx rgba(120,108,94,0.14); }
.pickup-btn:active { transform: scale(0.97); box-shadow: inset 3rpx 3rpx 7rpx rgba(120,108,94,0.22), inset -2rpx -2rpx 5rpx rgba(255,255,255,0.7); }
.pickup-btn-icon { width: 44rpx; height: 44rpx; }
.pickup-btn-text { font-size: 28rpx; color: var(--color-primary); font-weight: var(--font-weight-semibold); }
.pickup-revealed { display: flex; flex-direction: column; align-items: center; gap: 20rpx; padding: 28rpx 24rpx; background: #EFE7DA; border-radius: 24rpx; box-shadow: inset 3rpx 3rpx 7rpx rgba(120,108,94,0.2), inset -3rpx -3rpx 7rpx rgba(255,255,255,0.85); }
.pickup-label { font-size: 22rpx; color: var(--color-on-surface-variant); letter-spacing: 6rpx; text-transform: uppercase; }
.pickup-code-row { display: flex; gap: 16rpx; }
.pickup-digit { width: 64rpx; height: 80rpx; line-height: 80rpx; text-align: center; font-size: 40rpx; font-weight: var(--font-weight-bold); color: var(--color-primary); background: linear-gradient(160deg, #FFFFFF 0%, #F4EFE6 100%); border-radius: 14rpx; box-shadow: inset 2rpx 2rpx 5rpx rgba(120,108,94,0.22), inset -2rpx -2rpx 5rpx rgba(255,255,255,0.9); font-family: 'SF Mono', 'Menlo', 'Courier New', monospace; }
.pickup-hint { font-size: 22rpx; color: var(--color-on-surface-variant); opacity: 0.6; }
.pickup-hide-btn { padding: 12rpx 40rpx; border-radius: var(--radius-full); background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); font-size: 24rpx; color: var(--color-on-surface-variant); font-weight: var(--font-weight-medium); box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.85), inset -2rpx -3rpx 6rpx rgba(120,108,94,0.16), 0 3rpx 9rpx rgba(120,108,94,0.12); }
.pickup-hide-btn:active { transform: scale(0.95); box-shadow: inset 2rpx 2rpx 5rpx rgba(120,108,94,0.2), inset -1rpx -1rpx 3rpx rgba(255,255,255,0.7); }

.order-footer { display: flex; align-items: center; justify-content: space-between; border-top: 1rpx solid var(--color-divider); padding-top: 24rpx; margin-top: 16rpx; flex-wrap: wrap; gap: 16rpx; }
.order-total { font-size: 28rpx; color: var(--color-on-surface); flex-shrink: 0; }
.total-price { font-size: 32rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }
.order-actions { display: flex; gap: 16rpx; flex-shrink: 0; }
.order-action-btn { padding: 14rpx 34rpx; border-radius: var(--radius-full); font-size: 26rpx; font-weight: var(--font-weight-semibold); white-space: nowrap; transition: transform 0.12s ease; }
.order-action-btn.outline { color: #8A7B66; background: #EFE7DA; box-shadow: inset 2rpx 2rpx 4rpx rgba(120,108,94,0.18), inset -2rpx -2rpx 4rpx rgba(255,255,255,0.85); }
.order-action-btn.primary { background: linear-gradient(160deg, #C9684C 0%, #A8472E 100%); color: #FFFFFF; box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.28), inset -3rpx -3rpx 7rpx rgba(120,40,28,0.4), 0 5rpx 13rpx rgba(150,60,40,0.28); }
.order-action-btn.pay-btn { background: linear-gradient(160deg, #CE4636 0%, #A22A1E 100%); color: #FFFFFF; box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.3), inset -3rpx -4rpx 8rpx rgba(120,30,20,0.45), 0 6rpx 16rpx rgba(150,40,28,0.4); }
.order-action-btn.pay-btn:active { transform: scale(0.96); opacity: 0.9; }

.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 140rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.empty-text { font-size: 32rpx; color: var(--color-on-surface-variant); margin-bottom: 16rpx; }
.empty-sub { font-size: 26rpx; color: var(--color-on-surface-variant); opacity: 0.7; }

/* ===== 商城（黏土风，仿 Stitch 商城首页布局；与 pages/shop 同步） ===== */
.shop-scroll { overflow-x: hidden; box-sizing: border-box; }
.shop-scroll-inner { padding: 0 32rpx; }

/* ── 顶部 Hero（促销 Banner，黏土卡） ── */
.shop-hero { margin: 24rpx 0 28rpx; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--glass-shadow-elevated); border: var(--glass-border-subtle); }
.shop-hero-swiper { height: 300rpx; }
.shop-hero-slide { width: 100%; height: 100%; position: relative; }
.shop-hero-img { width: 100%; height: 100%; }
.shop-hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(40,28,20,0.72) 0%, transparent 100%); padding: 48rpx 32rpx 28rpx; display: flex; flex-direction: column; gap: 8rpx; }
.shop-hero-title { font-size: 36rpx; font-weight: var(--font-weight-bold); color: #FFFFFF; }
.shop-hero-sub { font-size: 24rpx; color: rgba(255,255,255,0.85); }

/* ── 分类 Tab（下划线式横向滚动） ── */
.shop-cat-tabs { white-space: nowrap; margin: 4rpx 0 16rpx; }
.shop-cat-tab { display: inline-flex; align-items: center; gap: 8rpx; padding: 16rpx 8rpx; margin-right: 44rpx; font-size: 30rpx; color: var(--color-on-surface-variant); position: relative; }
.shop-cat-emoji { font-size: 30rpx; line-height: 1; }
.shop-cat-tab.active { color: var(--color-primary); font-weight: var(--font-weight-bold); }
.shop-cat-tab.active::after { content: ''; position: absolute; left: 8rpx; right: 8rpx; bottom: 2rpx; height: 6rpx; border-radius: var(--radius-full); background: var(--color-primary); }

/* ── 节标题 ── */
.shop-section-header { display: flex; align-items: baseline; justify-content: space-between; margin: 8rpx 0 20rpx; }
.shop-section-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.shop-section-count { font-size: 24rpx; color: var(--color-on-surface-variant); }

/* ── 商品列表 ── */
.shop-list { display: flex; flex-direction: column; gap: 24rpx; }
.shop-feat-card { background: var(--glass-bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--glass-shadow-elevated); border: var(--glass-border-subtle); transition: transform 0.2s; }
.shop-feat-card:active { transform: scale(0.98); }
.shop-feat-imgwrap { position: relative; width: 100%; height: 320rpx; background: var(--color-surface-container-low); }
.shop-feat-img { width: 100%; height: 100%; }
.shop-feat-badge { position: absolute; top: 20rpx; left: 20rpx; padding: 6rpx 18rpx; border-radius: var(--radius-full); background: var(--glass-bg-primary); color: #FFFFFF; font-size: 20rpx; font-weight: var(--font-weight-bold); letter-spacing: 2rpx; box-shadow: var(--glass-shadow-button); }
.shop-feat-body { padding: 24rpx 28rpx 28rpx; display: flex; flex-direction: column; gap: 8rpx; }
.shop-feat-name { font-size: 32rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.shop-feat-desc { font-size: 24rpx; color: var(--color-on-surface-variant); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.shop-feat-divider { height: 1rpx; background: var(--color-divider); margin: 16rpx 0; }
.shop-feat-bottom { display: flex; align-items: center; justify-content: space-between; }
.shop-list-card { display: flex; gap: 24rpx; align-items: center; padding: 20rpx; background: var(--glass-bg-card); border-radius: var(--radius-card); box-shadow: var(--glass-shadow-card); border: var(--glass-border-subtle); transition: transform 0.2s; }
.shop-list-card:active { transform: scale(0.98); }
.shop-list-img { width: 180rpx; height: 180rpx; border-radius: var(--radius-sm); background: var(--color-surface-container-low); flex-shrink: 0; }
.shop-list-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; padding: 4rpx 0; }
.shop-list-name { font-size: 28rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.shop-list-desc { font-size: 22rpx; color: var(--color-on-surface-variant); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.shop-list-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 8rpx; }
.shop-price-row { display: flex; align-items: baseline; gap: 6rpx; }
.shop-price-sym { font-size: 22rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }
.shop-price { font-size: 32rpx; font-weight: var(--font-weight-bold); color: var(--color-price); }
.shop-original { font-size: 20rpx; color: var(--color-outline-variant); text-decoration: line-through; margin-left: 4rpx; }
.shop-add-btn { width: 60rpx; height: 60rpx; border-radius: var(--radius-full); background: var(--glass-bg-primary-light); display: flex; align-items: center; justify-content: center; box-shadow: var(--glass-shadow-elevated); border: var(--glass-border-colored); flex-shrink: 0; transition: all 0.2s; }
.shop-add-btn:active { transform: scale(0.9); }
.shop-add-icon { font-size: 40rpx; color: var(--color-primary); font-weight: 400; line-height: 1; }
.shop-add-btn.has-qty { width: auto; padding: 6rpx 14rpx; border-radius: var(--radius-full); background: var(--glass-bg-elevated); border: var(--glass-border-subtle); }
.shop-mini-stepper { display: flex; align-items: center; gap: 14rpx; }
.shop-mini-btn { width: 48rpx; height: 48rpx; border-radius: var(--radius-full); background: var(--glass-bg-card); display: flex; align-items: center; justify-content: center; font-size: 30rpx; color: var(--color-on-surface); border: var(--glass-border-subtle); }
.shop-mini-btn:active { transform: scale(0.9); }
.shop-mini-plus { background: var(--glass-bg-primary-light); border: var(--glass-border-colored); color: var(--color-primary); }
.shop-mini-qty { font-size: 28rpx; font-weight: var(--font-weight-bold); min-width: 36rpx; text-align: center; }
/* 商城收藏按钮（替代购物车步进器） */
.shop-fav-btn { width: 60rpx; height: 60rpx; border-radius: var(--radius-full); background: var(--glass-bg-card); display: flex; align-items: center; justify-content: center; box-shadow: var(--glass-shadow-card); border: var(--glass-border-subtle); flex-shrink: 0; transition: all 0.2s; }
.shop-fav-btn:active { transform: scale(0.9); }
.shop-fav-btn.active { background: var(--glass-bg-primary-light); border: var(--glass-border-colored); }
.shop-fav-icon { font-size: 34rpx; line-height: 1; color: var(--color-on-surface-variant); }
.shop-fav-btn.active .shop-fav-icon { color: var(--color-primary); }
/* 分类图标改用图片（替代 emoji） */
.shop-cat-icon { width: 36rpx; height: 36rpx; border-radius: var(--radius-sm); }
.shop-list-end { display: flex; justify-content: center; padding: 36rpx 0 8rpx; }
.shop-list-end-text { font-size: 24rpx; color: var(--color-on-surface-variant); opacity: 0.7; }
.shop-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 160rpx; }
.shop-empty-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.shop-empty-text { font-size: 32rpx; color: var(--color-on-surface-variant); margin-bottom: 12rpx; }
.shop-empty-sub { font-size: 26rpx; color: var(--color-on-surface-variant); opacity: 0.7; }
/* ===== 会员悬浮弹窗 ===== */
.member-overlay { position: fixed; inset: 0; z-index: 2000; visibility: hidden; }
.member-overlay.show { visibility: visible; }
.member-overlay::before { content: ''; position: absolute; inset: 0; background: rgba(0,0,0,0.5); opacity: 0; transition: opacity 0.35s; }
.member-overlay.show::before { opacity: 1; }

.member-overlay-card {
  position: absolute; left: 24rpx; right: 24rpx; top: 50%;
  background: var(--glass-bg-elevated);
  border-radius: 48rpx;
  box-shadow: var(--shadow-modal), 0 0 0 2rpx rgba(255,255,255,0.5);
  max-height: 80vh;
  transform: translateY(-50%) scale(0.85);
  opacity: 0;
  transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex; flex-direction: column; overflow: hidden;
}
.member-overlay-card.show { transform: translateY(-50%) scale(1); opacity: 1; }

.member-overlay-close {
  position: sticky; top: 0; right: 0; z-index: 10;
  display: flex; justify-content: flex-end; padding: 24rpx 24rpx 0;
}
.member-overlay-close text {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-full);
  background: rgba(0,0,0,0.06); display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-on-surface-variant); line-height: 64rpx; text-align: center;
}
.member-overlay-close:active text { background: rgba(0,0,0,0.12); transform: scale(0.92); }

.member-overlay-scroll { padding: 0 32rpx 40rpx; overflow-y: auto; flex: 1; }

/* 会员卡、权益、方案卡片、CTA */
.member-hero { display: flex; flex-direction: column; align-items: center; padding-top: 8rpx; padding-bottom: 32rpx; }
.member-card { width: 100%; margin-bottom: 24rpx; }
.member-card-inner { background: linear-gradient(135deg, #1a1c1c 0%, #303031 100%); border-radius: var(--radius-lg); padding: 40rpx; position: relative; overflow: hidden; box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.06); width: 100%; display: flex; flex-direction: column; justify-content: space-between; min-height: 320rpx; }
.card-glow { position: absolute; top: -80rpx; right: -80rpx; width: 256rpx; height: 256rpx; background: rgba(255,255,255,0.05); border-radius: var(--radius-full); filter: blur(40rpx); pointer-events: none; }
.card-top { display: flex; justify-content: space-between; align-items: flex-start; }
.card-status-label { display: block; font-size: 22rpx; color: #C8C6C5; text-transform: uppercase; letter-spacing: 4rpx; margin-bottom: 8rpx; }
.card-level { font-size: 48rpx; font-weight: var(--font-weight-bold); color: #FFFFFF; letter-spacing: -2rpx; }
.card-badge { width: 88rpx; height: 88rpx; background: rgba(255,255,255,0.1); border-radius: var(--radius-card); border: 1rpx solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; }
.badge-icon { font-size: 48rpx; }
.card-bottom { display: flex; justify-content: space-between; align-items: flex-end; }
.card-id-label { display: block; font-size: 22rpx; color: #C8C6C5; margin-bottom: 8rpx; }
.card-id { font-size: 30rpx; color: #FFFFFF; letter-spacing: 6rpx; }
.card-qr { width: 96rpx; height: 96rpx; background: #FFFFFF; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; }
.qr-icon { font-size: 56rpx; }
.member-hero-text { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.hero-headline { font-size: 44rpx; font-weight: 800; color: var(--color-on-surface); letter-spacing: -1rpx; line-height: 1.2; }
.hero-subtitle { font-size: 28rpx; color: var(--color-on-surface-variant); font-weight: 400; }

.privileges-section { width: 100%; margin-bottom: 24rpx; }
.privileges-scroll { width: 100%; }
.privileges-row { display: flex; gap: 24rpx; padding: 0 0 12rpx; }
.privilege-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; min-width: 112rpx; flex-shrink: 0; }
.privilege-icon-wrap { width: 112rpx; height: 112rpx; border-radius: 28rpx; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; box-shadow: inset 0 4rpx 8rpx rgba(255,255,255,0.8), 0 4rpx 16rpx rgba(0,0,0,0.06); transition: transform 0.2s; }
.privilege-icon-wrap:active { transform: translateY(-4rpx); }
.privilege-icon-shine { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.5) 0%, transparent 50%); pointer-events: none; }
.privilege-icon { font-size: 46rpx; position: relative; z-index: 1; filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.1)); }
.privilege-label { font-size: 22rpx; font-weight: 500; color: var(--color-on-surface-variant); }
.privilege-icon-purple { background: rgba(132,85,239,0.2); border: 1rpx solid rgba(132,85,239,0.15); }
.privilege-icon-green { background: rgba(190,242,42,0.3); border: 1rpx solid rgba(190,242,42,0.2); }
.privilege-icon-gold { background: rgba(254,243,199,0.6); border: 1rpx solid rgba(251,192,45,0.25); }
.privilege-icon-pink { background: rgba(252,231,243,0.6); border: 1rpx solid rgba(236,72,153,0.2); }
.privilege-icon-teal { background: rgba(190,242,42,0.2); border: 1rpx solid rgba(16,185,129,0.15); }

.coupon-banner { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 24rpx; margin-bottom: 24rpx; background: rgba(233,233,221,0.4); border-radius: 24rpx; border: 1rpx solid rgba(255,255,255,0.5); box-shadow: var(--shadow-sm); }
.coupon-banner-left { display: flex; align-items: center; gap: 12rpx; }
.coupon-banner-icon { font-size: 28rpx; }
.coupon-banner-text { font-size: 24rpx; font-weight: 600; color: var(--color-on-surface); }
.coupon-banner-help { width: 40rpx; height: 40rpx; border-radius: var(--radius-full); background: var(--color-surface-container-highest); display: flex; align-items: center; justify-content: center; }
.coupon-help-icon { font-size: 22rpx; font-weight: 700; color: var(--color-on-surface-variant); }

.plans-section { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.plan-card { border-radius: 28rpx; border: 3rpx solid var(--color-surface-container-highest); background: var(--color-surface); box-shadow: var(--shadow-sm); transition: all 0.3s ease; overflow: hidden; }
.plan-card:active { transform: scale(0.985); }
.plan-card-inner { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; position: relative; z-index: 1; }
.plan-selected { border-color: var(--color-primary-container); background: linear-gradient(135deg, rgba(244,235,226,0.5), rgba(244,235,226,0.3)); box-shadow: 0 0 0 1rpx var(--color-primary-container), var(--shadow-elevated); }
.plan-selected .plan-card-inner { background: linear-gradient(180deg, rgba(255,255,255,0.6) 0%, transparent 100%); }
.plan-left { display: flex; flex-direction: column; gap: 8rpx; }
.plan-name-row { display: flex; align-items: center; gap: 12rpx; }
.plan-name { font-size: 28rpx; font-weight: 700; color: var(--color-on-surface); }
.plan-badge { font-size: 18rpx; font-weight: 700; color: var(--color-on-primary-container); background: var(--color-primary-container); padding: 4rpx 14rpx; border-radius: var(--radius-full); box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.6); }
.plan-price-row { display: flex; align-items: baseline; gap: 12rpx; }
.plan-price { font-size: 38rpx; font-weight: 800; color: var(--color-on-surface); letter-spacing: -1rpx; line-height: 1; }
.plan-original { font-size: 22rpx; font-weight: 500; color: var(--color-outline-variant); text-decoration: line-through; opacity: 0.7; }
.plan-radio { width: 48rpx; height: 48rpx; border-radius: var(--radius-full); border: 3rpx solid rgba(143,111,108,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.3s ease; box-shadow: var(--shadow-sm); }
.plan-radio.radio-checked { border-color: var(--color-primary-container); background: var(--color-primary-container); }
.plan-check-icon { font-size: 24rpx; font-weight: 700; color: var(--color-on-primary-container); transition: all 0.3s ease; }

.member-cta-section { display: flex; flex-direction: column; gap: 20rpx; padding-bottom: 8rpx; }
.member-cta-btn { width: 100%; padding: 24rpx 32rpx; background: var(--color-primary-container); border-radius: var(--radius-full); display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 12rpx 32rpx rgba(120,108,94,0.2), inset 0 4rpx 0 rgba(255,255,255,0.4); position: relative; overflow: hidden; transition: all 0.2s; border: 1rpx solid rgba(255,255,255,0.3); }
.member-cta-btn:active { transform: scale(0.98); opacity: 0.95; }
.cta-btn-shine { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.25) 0%, transparent 60%); pointer-events: none; }
.cta-main-text { font-size: 30rpx; font-weight: 700; color: var(--color-on-primary-container); position: relative; z-index: 1; letter-spacing: 2rpx; }
.cta-sub-text { font-size: 20rpx; font-weight: 500; color: var(--color-on-primary-container); opacity: 0.7; position: relative; z-index: 1; margin-top: 4rpx; }
.member-footer-links { display: flex; justify-content: center; align-items: center; gap: 20rpx; }
.footer-link { font-size: 20rpx; color: var(--color-on-surface-variant); opacity: 0.5; }
.footer-link:active { color: var(--color-primary); opacity: 0.8; }
.footer-divider { font-size: 18rpx; color: var(--color-on-surface-variant); opacity: 0.2; }

/* ===== 个人中心 ===== */
.profile-card { margin: 16rpx 0 8rpx; padding: 24rpx 32rpx; border-radius: 32rpx; background: transparent; }
.profile-card-top { display: flex; align-items: center; gap: 20rpx; }
.avatar-wrap { width: 112rpx; height: 112rpx; border-radius: var(--radius-full); overflow: hidden; flex-shrink: 0;
  /* 粘土头像：白描边环 + 外柔影 + 顶微高光（鼓起浮起感） */
  box-shadow: 0 0 0 4rpx #FFFFFF, 0 8rpx 16rpx rgba(120, 108, 94, 0.20), 0 -1rpx 4rpx rgba(255, 255, 255, 0.6); }
.avatar { width: 100%; height: 100%; }
.avatar-placeholder { border-radius: 9999rpx; background: var(--color-surface-container); }
.profile-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; min-width: 0; }
.profile-name { font-size: 38rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.profile-bio { font-size: 24rpx; color: var(--color-on-surface-variant); }
/* 会员编号：粘土小药丸（柔紫实底 + 内顶高光 + 内底暗影 + 外柔影） */
.profile-member-id {
  align-self: flex-start;
  display: inline-flex; align-items: center;
  padding: 6rpx 18rpx; border-radius: 9999rpx;
  background: #F1ECE3; color: #8A7B66;
  font-size: 20rpx; font-weight: var(--font-weight-semibold); letter-spacing: 1rpx;
  box-shadow:
    inset 2rpx 2rpx 3rpx rgba(255,255,255,0.9),
    inset -2rpx -2rpx 4rpx rgba(120,108,94,0.16),
    0 3rpx 7rpx rgba(120,108,94,0.16);
}
/* 头像编辑遮罩 */
.avatar-wrap { position: relative; align-self: center; }
.avatar-edit-mask { position: absolute; inset: 0; border-radius: var(--radius-full); background: rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; }
.avatar-wrap:active .avatar-edit-mask { opacity: 1; }
.avatar-edit-icon { font-size: 28rpx; color: #FFFFFF; }
.profile-name-row { display: flex; align-items: center; gap: 10rpx; }
.profile-edit-hint { width: 28rpx; height: 28rpx; opacity: 0.6; }
/* 生日行 */
/* 生日行：粘土内嵌条（柔紫实底 + 内顶高光 + 内底暗影 + 外柔影） */
.birthday-row { display: flex; align-items: center; gap: 12rpx; margin-top: 20rpx; padding: 18rpx 22rpx; border-radius: 22rpx; background: #F3EFE8; transition: transform 0.12s ease;
  box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.9), inset -3rpx -3rpx 7rpx rgba(120,108,94,0.10), 0 5rpx 12rpx rgba(120,108,94,0.10); }
.birthday-today { background: #FFF3D6;
  box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.9), inset -3rpx -3rpx 7rpx rgba(196,134,13,0.16), 0 5rpx 12rpx rgba(196,134,13,0.12); }
.birthday-icon { font-size: 32rpx; line-height: 1; flex-shrink: 0; }
.birthday-icon-img { width: 40rpx; height: 40rpx; flex-shrink: 0; }
.birthday-text { font-size: 24rpx; color: var(--color-on-surface-variant); flex: 1; }
.birthday-celebration { font-size: 26rpx; font-weight: var(--font-weight-bold); color: #C67C00; flex: 1; }
.birthday-row:active { transform: translateY(2rpx) scale(0.99); }
.birthday-unset:active { opacity: 0.85; }
.birthday-prompt { flex: 1; font-size: 24rpx; color: var(--color-primary); }
.birthday-arrow { font-size: 32rpx; color: var(--color-on-surface-variant); flex-shrink: 0; }
/* 右侧统计 */
.profile-stats { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; margin-left: auto; gap: 2rpx; }
.profile-stat { display: flex; flex-direction: row; align-items: baseline; gap: 8rpx; padding: 4rpx 16rpx; }
.profile-stat:active { opacity: 0.7; }
.profile-stat-value { font-size: 28rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); white-space: nowrap; }
.profile-stat-label { font-size: 18rpx; color: var(--color-on-surface-variant); }
.profile-stats-divider { width: 56rpx; height: 1rpx; background: var(--color-divider); flex-shrink: 0; }

/* ===== 钱包卡片：余额 / 积分（粘土风 claymorphism，个人信息右侧竖向堆叠） ===== */
/* 钱包栏：余额(上)+积分(下)竖向；整组相对信息栏【垂直居中】。
   居中在 DevTools(Chromium) 与真机渲染一致；旧方案「父级 align-items:stretch + 本列 justify-content:space-between
   靠拉伸高度把余额钉顶、积分钉底」在真机不可靠——真机不 honor 嵌套列的拉伸高度，列塌成内容高度→两栏不再水平。 */
.wallet-row {
  margin-left: auto; flex-shrink: 0; width: 232rpx;
  display: flex; flex-direction: column; justify-content: center; gap: 14rpx;
}
.wallet-card {
  display: flex; flex-direction: row; align-items: center; gap: 12rpx;
  padding: 10rpx 16rpx; border-radius: 22rpx;   /* 粘土圆角（单行紧凑款，矮于信息栏） */
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}
.wallet-card:active { transform: translateY(2rpx) scale(0.97); }
/* 余额：暖蜜/奶油粘土 —— 外柔影 + 内顶高光(鼓起) + 内底暗影(厚度) */
.wallet-balance {
  background: #FFF1DA;
  box-shadow:
    0 8rpx 16rpx rgba(196, 134, 13, 0.18),
    inset 3rpx 3rpx 5rpx rgba(255, 255, 255, 0.95),
    inset -4rpx -6rpx 12rpx rgba(196, 134, 13, 0.13);
}
.wallet-balance:active {
  box-shadow:
    0 3rpx 8rpx rgba(196, 134, 13, 0.16),
    inset 0 5rpx 9rpx rgba(196, 134, 13, 0.18),
    inset 0 -2rpx 5rpx rgba(255, 255, 255, 0.85);
}
/* 积分：柔紫丁香粘土 */
.wallet-points {
  background: #F1ECE3;
  box-shadow:
    0 8rpx 16rpx rgba(120, 108, 94, 0.18),
    inset 3rpx 3rpx 5rpx rgba(255, 255, 255, 0.95),
    inset -4rpx -6rpx 12rpx rgba(120, 108, 94, 0.15);
}
.wallet-points:active {
  box-shadow:
    0 3rpx 8rpx rgba(120, 108, 94, 0.16),
    inset 0 5rpx 9rpx rgba(120, 108, 94, 0.20),
    inset 0 -2rpx 5rpx rgba(255, 255, 255, 0.85);
}
/* 图标小粘土球 */
.wallet-icon {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.wallet-icon-img { width: 32rpx; height: 32rpx; }
.wallet-icon-balance {
  background: #FFE2AE;
  box-shadow:
    inset 2rpx 2rpx 3rpx rgba(255,255,255,0.9),
    inset -3rpx -3rpx 5rpx rgba(196,134,13,0.25),
    0 3rpx 6rpx rgba(196,134,13,0.16);
}
.wallet-icon-points {
  background: #E8E0D2;
  box-shadow:
    inset 2rpx 2rpx 3rpx rgba(255,255,255,0.9),
    inset -3rpx -3rpx 5rpx rgba(120,108,94,0.28),
    0 3rpx 6rpx rgba(120,108,94,0.16);
}
.wallet-card-body { display: flex; flex-direction: row; align-items: baseline; gap: 8rpx; min-width: 0; }
/* 主数值：粗体 —— 视觉层次焦点 */
.wallet-card-value {
  font-size: 26rpx; font-weight: var(--font-weight-bold);
  line-height: 1.1; letter-spacing: -0.5rpx; white-space: nowrap;
}
.wallet-card-label { font-size: 20rpx; font-weight: var(--font-weight-semibold); letter-spacing: 1rpx; }
.wallet-balance .wallet-card-label { color: #B07810; }
.wallet-points .wallet-card-label { color: #8A7B66; }
/* 主数值：粗体 —— 视觉层次焦点 */
.wallet-card-value {
  font-size: 28rpx; font-weight: var(--font-weight-bold);
  line-height: 1.1; letter-spacing: -0.5rpx; white-space: nowrap;
}
.wallet-balance .wallet-card-value { color: #8A5A00; }
.wallet-points .wallet-card-value { color: #5E5142; }

/* ── 会员卡轮播 ── */
.member-cards-section { margin: 0 0 8rpx; position: relative; }
.member-swiper { height: 340rpx; }
.tier-card-wrap { padding: 0 36rpx; height: 100%; display: flex; align-items: center; box-sizing: border-box; transition: padding 0.3s ease; }
.tier-card-wrap.active { padding: 0 20rpx; }
.tier-card { width: 100%; height: 100%; border-radius: 28rpx; overflow: hidden; position: relative; box-shadow: 0 4rpx 12rpx -4rpx rgba(0,0,0,0.10); transition: opacity 0.3s ease; }

.tier-card-bg-img {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}
.tier-card-active { opacity: 1; }
.tier-card-inactive { opacity: 0.55; }
.tier-card-content { position: relative; z-index: 1; padding: 28rpx 32rpx 9rpx; height: 100%; display: flex; flex-direction: column; justify-content: space-between; box-sizing: border-box; }

/* ── 左上角等级标识（紧贴卡片边缘） ── */
.tier-status-pill {
  position: absolute;
  top: 0;
  left: 0;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx 10rpx 14rpx;
  border-radius: 28rpx 0 36rpx 0;
  background: #2f3836;
}
.tier-status-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin-left: 4rpx;
}
.tier-status-dot {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-top: -3rpx;
}
.tier-status-dot-img {
  width: 100%;
  height: 100%;
}

.tier-status-current .tier-status-text { color: #f3d493; }

/* ── 顶部操作按钮（右对齐） ── */
.tier-card-top { display: flex; justify-content: flex-end; }

/* ── 中间区域：等级名称 + 权益标签 ── */
.tier-card-middle { display: flex; flex-direction: column; gap: 10rpx; margin-top: 8rpx; }
.tier-card-title { font-size: 40rpx; font-weight: 800; letter-spacing: 2rpx; text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3); }

/* ── 底部 ── */
.tier-card-footer { margin-top: auto; }
.tier-card-progress-text { font-size: 22rpx; opacity: 0.8; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; padding-right: 12rpx; display: block; }

/* ── 成长进度条 ── */
.tier-progress-bar-wrap {
  margin-top: 10rpx;
  margin-bottom: 22rpx;
}
.tier-progress-bar-bg {
  width: 40%;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  overflow: hidden;
}
.tier-progress-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.6s ease;
}

/* ── 权益标签 ── */
.tier-benefits { display: flex; gap: 8rpx; flex-wrap: wrap; }
.tier-benefit-tag { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 8rpx; background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.85); line-height: 1.4; }
.tier-card-action { display: flex; align-items: center; gap: 4rpx; flex-shrink: 0; }
.tier-card-action-text { font-size: 22rpx; font-weight: 600; }
.tier-card-action-arrow { width: 28rpx; height: 28rpx; }
.tier-card-action:active { opacity: 0.7; }
.tier-dots { display: flex; justify-content: center; align-items: center; gap: 12rpx; margin-top: 20rpx; }
.tier-dot { width: 12rpx; height: 12rpx; border-radius: 999rpx; background: rgba(0,0,0,0.12); }
.tier-dot.active { width: 28rpx; border-radius: 999rpx; }

/* 公告浮窗 */
.announce-float {
  position: fixed;
  right: 0;
  top: 35%;
  z-index: 150;
  transition: all 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}
/* 折叠态 — 右侧竖条 */
.announce-float-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 72rpx;
  padding: 20rpx 12rpx;
  /* 粘土竖条：实底 + 内顶高光 + 内底暗影 + 左外柔影 */
  background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%);
  border-radius: 28rpx 0 0 28rpx;
  box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.9), inset -3rpx -3rpx 7rpx rgba(120,108,94,0.10), -6rpx 4rpx 18rpx rgba(120,108,94,0.16);
}
.announce-float-tab:active {
  transform: scale(0.92);
}
.announce-float-tab-icon {
  font-size: 32rpx;
  line-height: 1;
}
.announce-float-tab-text {
  font-size: 20rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
  writing-mode: vertical-lr;
  letter-spacing: 4rpx;
}
/* 展开态 — 浮窗卡片 */
.announce-float.expanded {
  right: 16rpx;
  top: 28%;
}
.announce-float-card {
  width: 420rpx;
  /* 粘土卡片：实底 + 内顶高光 + 内底暗影 + 外柔影 */
  background: linear-gradient(160deg, #FFFFFF 0%, #F4F0E9 100%);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 36rpx rgba(120,108,94,0.20), inset 3rpx 3rpx 5rpx rgba(255,255,255,0.95), inset -4rpx -6rpx 14rpx rgba(120,108,94,0.08);
  overflow: hidden;
}
.announce-float-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--color-divider);
}
.announce-float-card-icon {
  font-size: 28rpx;
}
.announce-float-card-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.announce-float-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  /* 粘土关闭球 */
  background: #F1ECE3;
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.9), inset -2rpx -2rpx 4rpx rgba(120,108,94,0.16), 0 3rpx 7rpx rgba(120,108,94,0.14);
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  flex-shrink: 0;
  transition: transform 0.12s ease;
}
.announce-float-close:active {
  transform: scale(0.9);
}
.announce-float-card-body {
  display: block;
  padding: 24rpx;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.6;
}

/* 金刚区 */
/* 金刚区：粘土面板 */
.grid-actions { display: flex; flex-wrap: wrap; row-gap: 28rpx; justify-content: space-around; margin: 0 32rpx 24rpx; padding: 32rpx 16rpx; border-radius: 32rpx; background: linear-gradient(160deg, #FFFFFF 0%, #F4F0E9 100%);
  box-shadow: 0 12rpx 28rpx rgba(120,108,94,0.12), inset 3rpx 3rpx 5rpx rgba(255,255,255,0.95), inset -4rpx -6rpx 14rpx rgba(120,108,94,0.08); }
.grid-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; width: 33.33%; }
/* 金刚区图标：粘土圆球（实底 + 内顶高光 + 内底暗影 + 外柔影） */
.grid-icon-wrap { width: 96rpx; height: 96rpx; border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; transition: transform 0.15s ease, box-shadow 0.15s ease; }
.grid-icon-wrap:active { transform: translateY(2rpx) scale(0.94); }
.grid-icon-red  { background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); box-shadow: inset 3rpx 3rpx 5rpx rgba(255,255,255,0.92), inset -4rpx -5rpx 9rpx rgba(120,108,94,0.14), 0 6rpx 12rpx rgba(120,108,94,0.14); }
.grid-icon-gold { background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); box-shadow: inset 3rpx 3rpx 5rpx rgba(255,255,255,0.92), inset -4rpx -5rpx 9rpx rgba(120,108,94,0.14), 0 6rpx 12rpx rgba(120,108,94,0.14); }
.grid-icon-green{ background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); box-shadow: inset 3rpx 3rpx 5rpx rgba(255,255,255,0.92), inset -4rpx -5rpx 9rpx rgba(120,108,94,0.14), 0 6rpx 12rpx rgba(120,108,94,0.14); }
.grid-icon-gray { background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); box-shadow: inset 3rpx 3rpx 5rpx rgba(255,255,255,0.92), inset -4rpx -5rpx 9rpx rgba(120,108,94,0.14), 0 6rpx 12rpx rgba(120,108,94,0.14); }
.grid-icon-blue { background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%); box-shadow: inset 3rpx 3rpx 5rpx rgba(255,255,255,0.92), inset -4rpx -5rpx 9rpx rgba(120,108,94,0.14), 0 6rpx 12rpx rgba(120,108,94,0.14); }
.grid-icon { width: 64rpx; height: 64rpx; }
.grid-icon-emoji { font-size: 40rpx; line-height: 1; }
.grid-label { font-size: 22rpx; color: var(--color-on-surface); }

/* 功能菜单 */
.menu-section { padding: 0 32rpx 72rpx; }
/* 功能菜单：粘土面板 */
.menu-card { border-radius: 32rpx; background: linear-gradient(160deg, #FFFFFF 0%, #F4F0E9 100%);
  box-shadow: 0 12rpx 28rpx rgba(120,108,94,0.12), inset 3rpx 3rpx 5rpx rgba(255,255,255,0.95), inset -4rpx -6rpx 14rpx rgba(120,108,94,0.08); overflow: hidden; }
.menu-item { display: flex; align-items: center; gap: 24rpx; padding: 28rpx 32rpx; border-bottom: 2rpx solid rgba(120,108,94,0.06); }
.menu-item:active { background: rgba(120,108,94,0.06); }
.menu-item-last { border-bottom: none; }
.menu-icon { width: 52rpx; height: 52rpx; }
.menu-name { flex: 1; font-size: 30rpx; color: var(--color-on-surface); }
.menu-arrow { font-size: 32rpx; color: var(--color-on-surface-variant); }

/* 编辑个人信息抽屉 */
.edit-overlay { position: fixed; inset: 0; z-index: 200; visibility: hidden; }
.edit-overlay.show { visibility: visible; }
.edit-overlay::before { content: ''; position: absolute; inset: 0; background: rgba(0,0,0,0.45); opacity: 0; transition: opacity 0.3s; }
.edit-overlay.show::before { opacity: 1; }
.edit-drawer { position: absolute; left: 0; right: 0; bottom: 0; background: var(--color-surface); border-radius: 40rpx 40rpx 0 0; transform: translateY(100%); transition: transform 0.3s ease; max-height: 80vh; display: flex; flex-direction: column; box-shadow: var(--shadow-modal); }
.edit-drawer.show { transform: translateY(0); }
.edit-drawer-nav { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 40rpx; border-bottom: 1rpx solid var(--color-divider); flex-shrink: 0; }
.edit-drawer-title { font-size: 34rpx; font-weight: var(--font-weight-bold); color: var(--color-on-surface); }
.edit-drawer-save { font-size: 30rpx; font-weight: var(--font-weight-semibold); color: var(--color-primary); padding: 8rpx 16rpx; }
.edit-drawer-body { flex: 1; padding: 40rpx; overflow-y: auto; }
.edit-avatar-section { display: flex; align-items: center; gap: 24rpx; margin-bottom: 40rpx; padding: 24rpx; border-radius: var(--radius-card); background: var(--color-surface-container-low); }
.edit-avatar-img { width: 120rpx; height: 120rpx; border-radius: var(--radius-full); flex-shrink: 0; box-shadow: var(--shadow-sm); }
.edit-avatar-tip { flex: 1; }
.edit-avatar-tip-text { font-size: 26rpx; color: var(--color-primary); }
.edit-field { margin-bottom: 32rpx; }
.edit-field-label { display: block; font-size: 26rpx; font-weight: var(--font-weight-semibold); color: var(--color-on-surface); margin-bottom: 16rpx; }
.edit-field-input { width: 100%; height: 88rpx; padding: 0 28rpx; border-radius: var(--radius-sm); background: var(--color-surface-container-low); font-size: 30rpx; color: var(--color-on-surface); }
/* 日期选择器 */
.edit-field-picker { display: flex; align-items: center; justify-content: space-between; width: 100%; height: 88rpx; padding: 0 28rpx; border-radius: var(--radius-sm); background: var(--color-surface-container-low); box-sizing: border-box; }
.edit-field-picker-text { font-size: 30rpx; color: var(--color-on-surface); }
.edit-field-picker-text.placeholder { color: var(--color-on-surface-variant); opacity: 0.5; }
.edit-field-picker-arrow { font-size: 32rpx; color: var(--color-on-surface-variant); flex-shrink: 0; }

/* ===== 产品详情弹窗 ===== */
.detail-overlay {
  position: fixed;
  inset: 0;
  z-index: 1100;
  visibility: hidden;
}
.detail-overlay.show { visibility: visible; }
.detail-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  /* 弹窗蒙层：半透明暗底，弹窗外页面变暗但仍可见（标准弹窗交互，非全白遮盖） */
  background: var(--glass-bg-overlay);
  opacity: 0;
  transition: opacity 0.3s;
}
.detail-overlay.show::before { opacity: 1; }

/* 导航行 — 位于页面 top-bar 下方，紧凑间距 */
.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx 16rpx;
  flex-shrink: 0;
}
.detail-back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  /* 粘土返回球 */
  background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.9), inset -3rpx -3rpx 6rpx rgba(120,108,94,0.12), 0 4rpx 9rpx rgba(120,108,94,0.14);
  transition: transform 0.12s ease;
}
.detail-back-btn:active {
  transform: scale(0.92);
}
.detail-back-icon {
  width: 36rpx;
  height: 36rpx;
}
.detail-nav-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.detail-nav-spacer {
  width: 72rpx;
}

.detail-drawer {
  position: absolute;
  left: 0;
  right: 0;
  top: 190rpx;
  bottom: 0;
  /* 粘土抽屉：不透明柔白底 + 顶内高光 + 上扬外柔影 */
  background: linear-gradient(180deg, #FFFFFF 0%, #FAF7F2 100%);
  border-radius: 48rpx 48rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -10rpx 30rpx rgba(120,108,94,0.18), inset 3rpx 3rpx 5rpx rgba(255,255,255,0.9);
  overflow: hidden;
}
.detail-drawer.show { transform: translateY(0); }

/* 可滚动内容区 */
.detail-body {
  flex: 1;
  height: 0;
  min-height: 0;
}

/* 产品大图 — 完整显示不裁剪 */
.detail-image {
  width: 100%;
  display: block;
  background: var(--color-surface-container-low);
}

/* 产品信息 */
.detail-header {
  padding: 32rpx 40rpx 0;
  margin-bottom: 24rpx;
}

.detail-title-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.detail-name {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
  flex: 1;
}
.detail-price {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-price);
  flex-shrink: 0;
}

.detail-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.detail-tag {
  font-size: 22rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-primary-container);
  /* 粘土紫标签 */
  background: linear-gradient(160deg, #EFE7D8 0%, #E4D9C6 100%);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.8), inset -2rpx -2rpx 4rpx rgba(120,108,94,0.16), 0 3rpx 7rpx rgba(120,108,94,0.14);
}
.detail-size {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  /* 粘土中性标签 */
  background: #F3EFE8;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.85), inset -2rpx -2rpx 4rpx rgba(120,108,94,0.10), 0 3rpx 6rpx rgba(120,108,94,0.10);
}

/* 详细描述 */
.detail-desc {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.7;
  display: block;
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

/* 食材 */
.detail-ingredients {
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}
.detail-section-label {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 16rpx;
}
.ingredient-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.ingredient-item {
  font-size: 24rpx;
  color: var(--color-on-surface);
  /* 粘土食材胶囊 */
  background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.9), inset -2rpx -2rpx 4rpx rgba(120,108,94,0.10), 0 3rpx 7rpx rgba(120,108,94,0.10);
}

/* 忌口选择区（随内容一体滚动） */
.detail-restrictions {
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}
.detail-restrictions .detail-section-label {
  margin-bottom: 12rpx;
}
.restriction-scroll {
  white-space: nowrap;
}
.restriction-row {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

/* 底部留白，避免被 footer 遮挡 */
.detail-bottom-spacer {
  height: 24rpx;
}
.restriction-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  /* 粘土忌口胶囊 */
  background: linear-gradient(160deg, #FFFFFF 0%, #F1ECE3 100%);
  padding: 14rpx 28rpx;
  border-radius: var(--radius-full);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.9), inset -2rpx -2rpx 4rpx rgba(120,108,94,0.10), 0 3rpx 7rpx rgba(120,108,94,0.10);
  transition: all 0.2s;
  flex-shrink: 0;
  white-space: nowrap;
}
.restriction-chip:active {
  transform: scale(0.96);
}
.restriction-chip.active {
  background: linear-gradient(160deg, #EFE7D8 0%, #E4D9C6 100%);
  color: var(--color-on-primary-container);
  font-weight: var(--font-weight-semibold);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.8), inset -3rpx -3rpx 6rpx rgba(120,108,94,0.22), 0 4rpx 10rpx rgba(120,108,94,0.20);
}
.chip-check {
  font-size: 20rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* 底部操作栏 */
.detail-footer {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  /* 粘土底栏：不透明柔白 + 上沿细分隔 + 上扬柔影 */
  border-top: 1rpx solid rgba(120,108,94,0.08);
  background: linear-gradient(180deg, #FBF8F2 0%, #F3EFE8 100%);
  box-shadow: 0 -4rpx 14rpx rgba(120,108,94,0.06);
  flex-shrink: 0;
}

.detail-stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
  /* 粘土数量条 */
  background: #F3EFE8;
  border-radius: var(--radius-full);
  padding: 8rpx 16rpx;
  box-shadow: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.9), inset -2rpx -2rpx 5rpx rgba(120,108,94,0.10), 0 4rpx 10rpx rgba(120,108,94,0.10);
  flex-shrink: 0;
}
.detail-stepper .qty-btn {
  width: 64rpx;
  height: 64rpx;
}
.detail-stepper .qty-icon {
  font-size: 40rpx;
}
.detail-qty-num {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  min-width: 48rpx;
  text-align: center;
}

.detail-add-btn {
  flex: 1;
  /* 粘土红主按钮 */
  background: linear-gradient(160deg, #CE4636 0%, #A22A1E 100%);
  color: var(--color-on-primary);
  border-radius: var(--radius-full);
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255,255,255,0.35), inset -3rpx -4rpx 8rpx rgba(120,30,20,0.45), 0 6rpx 16rpx rgba(150,40,28,0.40);
  white-space: nowrap;
}
.detail-add-btn:active {
  transform: translateY(2rpx) scale(0.97);
  opacity: 0.95;
}
