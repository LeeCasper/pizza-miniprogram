/* pages/points/points.wxss — 积分商城（Stitch 设计稿 1:1 还原） */

/* ═══ 页面容器 ═══ */
.pts-page {
  min-height: 100vh;
  background: var(--glass-bg-page); /* 浅灰底，匹配 Stitch #f7f8fa */
}

/* ═══ 顶部导航 ═══ */
.pts-top-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx 20rpx;
  background: rgba(247,248,250,0.90); /* Stitch gray-50/90 */
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.pts-back-btn {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-full);
  background: var(--glass-bg-card); border: var(--glass-border-subtle);
  display: flex; align-items: center; justify-content: center;
}
.pts-back-icon { width: 36rpx; height: 36rpx; }
.pts-top-title {
  font-size: 34rpx; font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.pts-top-spacer { width: 64rpx; height: 64rpx; }

/* ═══ 滚动区 ═══ */
.pts-scroll {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  padding-top: 100rpx;
  overflow-x: hidden; box-sizing: border-box;
}

/* ═══ 积分余额卡片 — Stitch 橙色渐变 ═══ */
.pts-balance-card {
  margin: 20rpx 24rpx;
  padding: 36rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffeadd 0%, #ffd4ba 100%);
  position: relative; overflow: hidden;
}
.pts-balance-body {
  position: relative; z-index: 1;
}
.pts-balance-label {
  font-size: 26rpx; color: rgba(140,80,30,0.65);
}
.pts-balance-row {
  display: flex; align-items: baseline; gap: 8rpx;
  margin: 12rpx 0 20rpx;
}
.pts-balance-num {
  font-size: 64rpx; font-weight: 800;
  color: #5C3D2E; line-height: 1;
}
.pts-balance-unit {
  font-size: 28rpx; color: rgba(140,80,30,0.55);
}
.pts-balance-action {
  display: inline-flex; align-items: center; gap: 4rpx;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.55);
  font-size: 24rpx; color: #8C501E; font-weight: var(--font-weight-semibold);
}
.pts-balance-arrow { font-size: 28rpx; }
.pts-balance-decor {
  position: absolute; right: 20rpx; bottom: 10rpx;
  font-size: 140rpx; line-height: 1; z-index: 0; opacity: 0.6;
}

/* ═══ 分类导航 ═══ */
.pts-cat-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx 16rpx;
  border-radius: 24rpx;
  background: var(--glass-bg-card);
  display: flex; justify-content: space-around;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.pts-cat-item {
  display: flex; flex-direction: column; align-items: center; gap: 10rpx;
}
.pts-cat-item.active .pts-cat-name { color: #f58220; font-weight: var(--font-weight-semibold); }
.pts-cat-iconwrap {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.pts-cat-bg-all    { background: rgba(245,130,32,0.10); }
.pts-cat-bg-daily  { background: rgba(52,199,89,0.10); }
.pts-cat-bg-coupon { background: rgba(0,122,255,0.10); }
.pts-cat-bg-goods  { background: rgba(175,130,240,0.10); }
.pts-cat-icon { width: 44rpx; height: 44rpx; }
.pts-cat-emoji { font-size: 40rpx; line-height: 1; }
.pts-cat-name { font-size: 22rpx; color: var(--color-on-surface-variant); }

/* ═══ 精选推荐标题 ═══ */
.pts-section-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8rpx 28rpx 20rpx;
}
.pts-section-title {
  font-size: 34rpx; font-weight: 800; color: var(--color-on-surface);
}

/* ═══ 商品 2 列网格 ═══ */
.pts-grid {
  display: flex; flex-wrap: wrap;
  padding: 0 16rpx;
}
.pts-card {
  width: calc(50% - 16rpx);
  margin: 0 8rpx 20rpx;
  border-radius: 20rpx;
  background: var(--glass-bg-card);
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.pts-card-imgwrap {
  position: relative;
  width: 100%; height: 340rpx;
  background: #f2f2f4;
  display: flex; align-items: center; justify-content: center;
}
.pts-card-img {
  width: 100%; height: 100%;
}
.pts-card-tag {
  position: absolute; top: 16rpx; left: 16rpx;
  padding: 4rpx 14rpx; border-radius: 8rpx;
  background: rgba(245,130,32,0.85);
  font-size: 20rpx; color: #fff;
}
.pts-card-body {
  padding: 20rpx;
}
.pts-card-name {
  font-size: 26rpx; font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  margin-bottom: 16rpx;
}
.pts-card-bottom {
  display: flex; align-items: center; justify-content: space-between;
}
.pts-card-price {
  display: flex; align-items: baseline; gap: 4rpx;
}
.pts-card-points {
  font-size: 30rpx; font-weight: 800; color: #f58220; line-height: 1;
}
.pts-card-unit {
  font-size: 20rpx; color: var(--color-on-surface-variant);
}

/* 兑换按钮 */
.pts-redeem-btn {
  padding: 10rpx 24rpx; border-radius: 40rpx;
  background: #f58220;
  font-size: 22rpx; font-weight: var(--font-weight-semibold); color: #fff;
}
.pts-redeem-btn.disabled { background: rgba(180,160,140,0.30); color: var(--color-on-surface-variant); }
.pts-redeem-btn:active { opacity: 0.85; }

/* 空状态 */
.pts-empty {
  display: flex; align-items: center; justify-content: center;
  padding: 120rpx 0;
}
.pts-empty-text { font-size: 28rpx; color: var(--color-on-surface-variant); }

/* ═══ 详情弹窗 ═══ */
.pts-detail-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300;
  background: rgba(0,0,0,0.35);
  visibility: hidden; opacity: 0;
  transition: visibility 0s 0.3s, opacity 0.3s;
}
.pts-detail-overlay.show { visibility: visible; opacity: 1; transition: visibility 0s, opacity 0.3s; }
.pts-detail-drawer {
  position: absolute; left: 0; right: 0; bottom: 0;
  background: var(--glass-bg-page);
  border-radius: 32rpx 32rpx 0 0;
  height: 90vh; display: flex; flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.pts-detail-drawer.show { transform: translateY(0); }
.pts-detail-nav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 24rpx 20rpx; flex-shrink: 0;
}
.pts-detail-back {
  width: 64rpx; height: 64rpx; border-radius: var(--radius-full);
  background: var(--glass-bg-card); border: var(--glass-border-subtle);
  display: flex; align-items: center; justify-content: center;
}
.pts-detail-nav-title {
  font-size: 32rpx; font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.pts-detail-body { flex: 1; overflow-y: auto; }
.pts-detail-img { width: 100%; display: block; }
.pts-detail-info { padding: 28rpx 32rpx 0; }
.pts-detail-name-row {
  display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx;
}
.pts-detail-name {
  flex: 1; font-size: 34rpx; font-weight: 800; color: var(--color-on-surface);
  line-height: 1.4;
}
.pts-detail-points-badge {
  display: flex; align-items: baseline; gap: 4rpx;
  flex-shrink: 0; padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #f58220;
}
.pts-detail-points-num {
  font-size: 36rpx; font-weight: 800; color: #fff; line-height: 1;
}
.pts-detail-points-unit { font-size: 22rpx; color: rgba(255,255,255,0.8); }
.pts-detail-meta { display: flex; gap: 16rpx; margin-top: 16rpx; }
.pts-detail-tag {
  font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 8rpx;
  background: rgba(245,130,32,0.10); color: #f58220;
}
.pts-detail-stock { font-size: 24rpx; color: var(--color-on-surface-variant); }
.pts-detail-desc {
  display: block; margin: 28rpx 32rpx 0;
  font-size: 28rpx; color: var(--color-on-surface-variant);
  line-height: 1.8;
}
.pts-detail-highlights { margin: 28rpx 32rpx 0; }
.pts-highlights-title {
  font-size: 28rpx; font-weight: var(--font-weight-bold);
  color: var(--color-on-surface); margin-bottom: 16rpx;
}
.pts-highlight-list { display: flex; flex-direction: column; gap: 10rpx; }
.pts-highlight-item { font-size: 26rpx; color: var(--color-on-surface-variant); display: flex; gap: 8rpx; }
.pts-highlight-dot { color: #f58220; flex-shrink: 0; }

/* 详情页底部兑换栏 */
.pts-detail-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--glass-bg-card);
  border-top: var(--glass-border-subtle);
  flex-shrink: 0;
}
.pts-detail-footer-info { display: flex; align-items: baseline; gap: 6rpx; }
.pts-footer-points {
  font-size: 44rpx; font-weight: 800; color: #f58220; line-height: 1;
}
.pts-footer-label { font-size: 26rpx; color: var(--color-on-surface-variant); }
.pts-detail-redeem-btn {
  padding: 18rpx 48rpx; border-radius: 100rpx;
  background: #f58220;
  font-size: 30rpx; font-weight: var(--font-weight-bold); color: #fff;
}
.pts-detail-redeem-btn.disabled { background: rgba(180,160,140,0.30); color: var(--color-on-surface-variant); }
.pts-detail-redeem-btn:active { opacity: 0.85; }
