/* pages/points/points.wxss */

.page-container {
  padding-bottom: 0;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 24rpx;
  /* background & backdrop-filter 由 inline style {{navBarBg}} 控制 */
  border-bottom: var(--glass-border-subtle);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-primary);
}
.back-icon { width: 40rpx; height: 40rpx; }

.top-title {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.top-spacer {
  width: 80rpx;
}

.main-scroll {
  padding: 24rpx 0 48rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

.scroll-inner {
  padding: 0 40rpx;
}

/* 积分头部 */
.points-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx;
  margin-bottom: 32rpx;
  background: var(--glass-bg-card);
  /* 去 backdrop-filter：切回前台 WeChat 重栅格化毛玻璃→闪烁；保留半透明底色 */
  border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
}

.points-header-label {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  text-transform: uppercase;
  letter-spacing: 6rpx;
  display: block;
  margin-bottom: 8rpx;
}

.points-header-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.points-header-value {
  font-size: 64rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
  letter-spacing: -2rpx;
}

.points-header-unit {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
}

.points-header-action {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 16rpx 24rpx;
  border-radius: var(--radius-full);
  background: var(--glass-bg-primary-light);
  border: var(--glass-border-colored);
}

/* 商品网格 */
.mall-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.mall-card {
  overflow: hidden;
  background: var(--glass-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--glass-shadow-card);
  border: var(--glass-border-subtle);
}

.mall-image-wrap {
  position: relative;
  height: 240rpx;
  overflow: hidden;
}

.mall-image {
  width: 100%;
  height: 100%;
}

.mall-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: var(--color-secondary);
  color: var(--color-on-secondary-container);
  font-size: 20rpx;
  font-weight: var(--font-weight-bold);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}

.mall-info {
  padding: 24rpx;
}

.mall-name {
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-surface);
  display: block;
  margin-bottom: 8rpx;
}

.mall-desc {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.mall-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.mall-points {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.points-num {
  font-size: 32rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.points-label {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
}

.mall-stock {
  font-size: 20rpx;
  color: var(--color-on-surface-variant);
}

.redeem-btn {
  width: 100%;
  padding: 20rpx;
  background: var(--glass-bg-primary);
  color: var(--color-on-primary);
  border-radius: var(--radius-full);
  text-align: center;
  font-size: 26rpx;
  font-weight: var(--font-weight-semibold);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.redeem-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.redeem-btn.disabled {
  background: var(--glass-bg-card);
  color: var(--color-on-surface-variant);
  border: var(--glass-border-subtle);
}

.redeem-btn.disabled:active {
  transform: none;
  opacity: 1;
}

/* ======= 产品详情弹窗 ======= */
.detail-overlay {
  position: fixed;
  inset: 0;
  z-index: 1100;
  visibility: hidden;
}
.detail-overlay.show { visibility: visible; }
.detail-overlay::before {
  content: '';
  position: absolute;
  inset: 0;
  /* 弹窗蒙层：半透明暗底，弹窗外页面变暗但仍可见（标准弹窗交互，非全白遮盖） */
  background: var(--glass-bg-overlay);
  opacity: 0;
  transition: opacity 0.3s;
}
.detail-overlay.show::before { opacity: 1; }

.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx 16rpx;
  flex-shrink: 0;
}
.detail-back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--glass-bg-light);
  border: var(--glass-border-subtle);
}
.detail-back-btn:active {
  background: var(--glass-bg-elevated);
  transform: scale(0.94);
}
.detail-back-icon {
  width: 36rpx;
  height: 36rpx;
}
.detail-nav-title {
  font-size: 34rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
}
.detail-nav-spacer { width: 72rpx; }

.detail-drawer {
  position: absolute;
  left: 0;
  right: 0;
  top: 190rpx;
  bottom: 0;
  background: var(--glass-bg-elevated);
  border-radius: 48rpx 48rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: var(--shadow-modal);
  border-top: var(--glass-border);
  overflow: hidden;
}
.detail-drawer.show { transform: translateY(0); }

.detail-body {
  flex: 1;
  height: 0;
  min-height: 0;
}

.detail-image {
  width: 100%;
  display: block;
  background: var(--color-surface-container-low);
}

.detail-header {
  padding: 32rpx 40rpx 0;
  margin-bottom: 24rpx;
}
.detail-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.detail-name {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-on-surface);
  flex: 1;
}

/* 积分徽章 */
.detail-points-badge {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
}
.detail-points-num {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}
.detail-points-label {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
}

.detail-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.detail-tag {
  font-size: 22rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-on-primary-container);
  background: var(--glass-bg-primary-container);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  border: var(--glass-border-colored);
}
.detail-size {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  background: var(--glass-bg-light);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  border: var(--glass-border-subtle);
}

/* 详细描述 */
.detail-desc {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.7;
  display: block;
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

/* 商品亮点 */
.detail-highlights {
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}
.detail-section-label {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  text-transform: uppercase;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 16rpx;
}
.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.highlight-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--color-on-surface);
}
.highlight-dot {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
  font-size: 28rpx;
}

.detail-bottom-spacer { height: 24rpx; }

/* 底部操作栏 */
.detail-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  background: var(--glass-bg-elevated);
  flex-shrink: 0;
}

.detail-footer-info {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  flex-shrink: 0;
}
.footer-points-num {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}
.footer-points-label {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
}

.detail-redeem-btn {
  flex: 1;
  background: var(--glass-bg-primary);
  color: var(--color-on-primary);
  border-radius: var(--radius-full);
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: var(--font-weight-bold);
  box-shadow: var(--glass-shadow-button);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  white-space: nowrap;
}
.detail-redeem-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
.detail-redeem-btn.disabled {
  background: var(--glass-bg-card);
  color: var(--color-on-surface-variant);
  border: var(--glass-border-subtle);
}
.detail-redeem-btn.disabled:active {
  transform: none;
  opacity: 1;
}
