# ===========================================
# 王姐手工披萨 — 生产环境变量
# 复制此文件为 .env 并修改实际值
# ===========================================

# Server
PORT=3000
NODE_ENV=production

# Database (使用专用用户，不用 root)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pizza_app
DB_PASSWORD=your_secure_password
DB_NAME=pizza

# JWT (生成方式: openssl rand -hex 32)
JWT_SECRET=replace-with-random-64-char-string

# WeChat Mini Program (从微信公众平台获取)
WX_APPID=wx553c8f1d7d51e97c
WX_SECRET=your-wechat-app-secret

# Admin Session (生成方式: openssl rand -hex 32)
SESSION_SECRET=replace-with-random-64-char-string

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Cloud Printer (商鹏云打印)
PRINTER_ENABLED=false
PRINTER_APPID=
PRINTER_APPSECRET=
PRINTER_SN=
PRINTER_API_BASE=https://www.spyun.net.cn
PRINTER_COPIES=1
