<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>王姐手工披萨 - 管理后台</title>
  <link rel="stylesheet" href="/admin/assets/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-brand">
        <span class="brand-icon">🍕</span>
        <span class="brand-text">王姐管理</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="nav-item <%= active === 'dashboard' ? 'active' : '' %>">📊 仪表盘</a>
        <a href="/admin/products" class="nav-item <%= active === 'products' ? 'active' : '' %>">🍽️ 商品管理</a>
        <a href="/admin/orders" class="nav-item <%= active === 'orders' ? 'active' : '' %>">📋 订单管理</a>
        <a href="/admin/coupons" class="nav-item <%= active === 'coupons' ? 'active' : '' %>">🎟️ 优惠券</a>
        <a href="/admin/users" class="nav-item <%= active === 'users' ? 'active' : '' %>">👥 用户管理</a>
        <a href="/admin/points" class="nav-item <%= active === 'points' ? 'active' : '' %>">⭐ 积分商城</a>
      </nav>
      <div class="sidebar-footer">
        <span><%= adminUser.displayName || adminUser.username %></span>
        <a href="/admin/logout" class="logout-link">退出</a>
      </div>
    </aside>
    <main class="main-content">
      <%- body %>
    </main>
  </div>
</body>
</html>
