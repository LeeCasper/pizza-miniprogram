<div class="page-header">
  <h2>用户管理</h2>
</div>

<% if (users.length === 0) { %>
  <div class="empty-state">暂无用户</div>
<% } else { %>
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>昵称</th>
          <th>手机</th>
          <th>积分</th>
          <th>等级</th>
          <th>角色</th>
          <th>订单数</th>
          <th>注册时间</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td><%= u.id %></td>
            <td><strong><%= u.name %></strong></td>
            <td><%= u.phone || '-' %></td>
            <td><%= u.points %></td>
            <td><span class="badge"><%= u.member_level %></span></td>
            <td><%= u.role === 'admin' ? '管理员' : '用户' %></td>
            <td><%= u.order_count %></td>
            <td><%= u.created_at ? new Date(u.created_at).toLocaleDateString('zh-CN') : '' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
