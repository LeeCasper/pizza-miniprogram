<div class="page-header">
  <h2><%= product ? '编辑商品' : '新增商品' %></h2>
</div>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form method="POST" action="/admin/api/products<%= product ? '/' + product.id : '' %>" class="admin-form">
  <div class="form-row">
    <div class="form-group">
      <label>商品名称 *</label>
      <input type="text" name="name" value="<%= product ? product.name : '' %>" required>
    </div>
    <div class="form-group">
      <label>分类 *</label>
      <select name="category_key" required>
        <option value="">-- 选择 --</option>
        <option value="pizza" <%= product && product.category_key === 'pizza' ? 'selected' : '' %>>经典披萨</option>
        <option value="durian" <%= product && product.category_key === 'durian' ? 'selected' : '' %>>榴莲系列</option>
        <option value="pineapple" <%= product && product.category_key === 'pineapple' ? 'selected' : '' %>>凤梨系列</option>
      </select>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label>价格 (¥) *</label>
      <input type="number" step="0.01" name="price" value="<%= product ? product.price : '' %>" required>
    </div>
    <div class="form-group">
      <label>规格</label>
      <input type="text" name="size_desc" value="<%= product ? (product.size_desc || '') : '' %>" placeholder="如: 9寸 / 12寸">
    </div>
    <div class="form-group">
      <label>标签</label>
      <select name="tag">
        <option value="">无</option>
        <% ['经典','招牌','爆款','新品','人气','限定'].forEach(t => { %>
          <option value="<%= t %>" <%= product && product.tag === t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>简短描述</label>
    <input type="text" name="desc" value="<%= product ? (product.desc || '') : '' %>">
  </div>

  <div class="form-group">
    <label>详细描述</label>
    <textarea name="detail_desc" rows="3"><%= product ? (product.detail_desc || '') : '' %></textarea>
  </div>

  <div class="form-group">
    <label>图片 URL</label>
    <input type="text" name="image" value="<%= product ? (product.image || '') : '' %>">
    <% if (product && product.image) { %>
      <img src="<%= product.image %>" alt="" class="form-preview">
    <% } %>
  </div>

  <div class="form-group">
    <label>配料 (逗号分隔)</label>
    <input type="text" name="ingredients" value="<%= product && product.ingredients ? (Array.isArray(product.ingredients) ? product.ingredients.join(', ') : product.ingredients) : '' %>" placeholder="圣马扎诺番茄, 莫扎瑞拉芝士, 新鲜罗勒">
  </div>

  <% if (product) { %>
    <div class="form-group">
      <label>状态</label>
      <select name="is_available">
        <option value="1" <%= product.is_available ? 'selected' : '' %>>在售</option>
        <option value="0" <%= !product.is_available ? 'selected' : '' %>>下架</option>
      </select>
    </div>
  <% } %>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">保存</button>
    <a href="/admin/products" class="btn btn-outline">取消</a>
  </div>
</form>
