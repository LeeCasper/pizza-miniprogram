<%
// Normalize product for form display
const pp = product || {};
%>
<div class="page-header">
  <h2><%= product ? 'зј–иҫ‘з§ҜеҲҶе•Ҷе“Ғ' : 'ж–°еўһз§ҜеҲҶе•Ҷе“Ғ' %></h2>
</div>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form method="POST" action="/admin/api/points<%= product ? '/' + product.id : '' %>" class="admin-form">
  <div class="form-row">
    <div class="form-group">
      <label>е•Ҷе“ҒеҗҚз§° *</label>
      <input type="text" name="name" value="<%= pp.name || '' %>" required>
    </div>
    <div class="form-group">
      <label>жүҖйңҖз§ҜеҲҶ *</label>
      <input type="number" name="points" value="<%= pp.points || '' %>" required>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label>зұ»еһӢ</label>
      <select name="redeem_type">
        <option value="coupon" <%= (pp.redeem_type || pp.redeemType || 'coupon') === 'coupon' ? 'selected' : '' %>>з”ҹжҲҗе…‘жҚўеҲё</option>
        <option value="physical" <%= (pp.redeem_type || pp.redeemType) === 'physical' ? 'selected' : '' %>>е®һзү©е•Ҷе“Ғ</option>
      </select>
    </div>
    <div class="form-group">
      <label>еә“еӯҳ (-1=дёҚйҷҗ)</label>
      <input type="number" name="stock" value="<%= pp.stock ?? -1 %>">
    </div>
    <div class="form-group">
      <label>ж Үзӯҫ</label>
      <input type="text" name="tag" value="<%= pp.tag || '' %>" placeholder="зғӯй—Ё / и¶…еҖј / йҷҗйҮҸ">
    </div>
  </div>

  <div class="form-group">
    <label>з®ҖзҹӯжҸҸиҝ°</label>
    <input type="text" name="desc" value="<%= pp.desc || '' %>">
  </div>
  <div class="form-group">
    <label>иҜҰз»ҶжҸҸиҝ°</label>
    <textarea name="detail_desc" rows="3"><%= pp.detail_desc || pp.detailDesc || '' %></textarea>
  </div>
  <div class="form-group">
    <label>еӣҫзүҮ URL</label>
    <input type="text" name="image" value="<%= pp.image || '' %>">
  </div>
  <div class="form-group">
    <label>дә®зӮ№ (йҖ—еҸ·еҲҶйҡ”)</label>
    <input type="text" name="highlights" value="<%= pp.highlights ? (Array.isArray(pp.highlights) ? pp.highlights.join(', ') : pp.highlights) : '' %>" placeholder="д»·еҖј ВҘ68, з»Ҹе…ёзҺӣж јдёҪзү№жҠ«иҗЁ Г—1">
  </div>

  <fieldset class="form-fieldset">
    <legend>е…‘жҚўеҲёжЁЎжқҝ (redeem_type=coupon ж—¶з”ҹж•Ҳ)</legend>
    <div class="form-row">
      <div class="form-group">
        <label>еҲёеҗҚз§°</label>
        <input type="text" name="coupon_name" value="<%= pp.coupon_name || pp.couponName || '' %>">
      </div>
      <div class="form-group">
        <label>еҲёд»·еҖјжҸҸиҝ°</label>
        <input type="text" name="coupon_value" value="<%= pp.coupon_value || pp.couponValue || '' %>" placeholder="з»Ҹе…ёзҺӣж јдёҪзү№жҠ«иҗЁ Г—1">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>еҲёзұ»еҲ«</label>
        <select name="coupon_category">
          <option value="redeem" <%= (pp.coupon_category || pp.couponCategory) === 'redeem' ? 'selected' : '' %>>е…‘жҚўеҲё</option>
          <option value="discount" <%= (pp.coupon_category || pp.couponCategory) === 'discount' ? 'selected' : '' %>>дјҳжғ еҲё</option>
        </select>
      </div>
      <div class="form-group">
        <label>жҠҳжүЈзұ»еһӢ (discountж—¶)</label>
        <select name="coupon_discount_type">
          <option value="">ж— </option>
          <option value="free_redeem" <%= (pp.coupon_discount_type || pp.couponDiscountType) === 'free_redeem' ? 'selected' : '' %>>е…Қиҙ№е…‘жҚў</option>
          <option value="buy_one_get_one" <%= (pp.coupon_discount_type || pp.couponDiscountType) === 'buy_one_get_one' ? 'selected' : '' %>>д№°дёҖйҖҒдёҖ</option>
          <option value="half_price" <%= (pp.coupon_discount_type || pp.couponDiscountType) === 'half_price' ? 'selected' : '' %>>еҚҠд»·</option>
          <option value="fixed_amount" <%= (pp.coupon_discount_type || pp.couponDiscountType) === 'fixed_amount' ? 'selected' : '' %>>еӣәе®ҡйҮ‘йўқ</option>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>жҠҳжүЈеҖј</label>
        <input type="text" name="coupon_discount_value" value="<%= pp.coupon_discount_value || pp.couponDiscountValue || '' %>">
      </div>
      <div class="form-group">
        <label>жңҖдҪҺж¶Ҳиҙ№ (ВҘ)</label>
        <input type="number" step="0.01" name="coupon_min_spend" value="<%= pp.coupon_min_spend || pp.couponMinSpend || 0 %>">
      </div>
      <div class="form-group">
        <label>жңүж•Ҳжңҹ (еӨ©)</label>
        <input type="number" name="coupon_valid_days" value="<%= pp.coupon_valid_days || pp.couponValidDays || 30 %>">
      </div>
    </div>
    <div class="form-group">
      <label>дҪҝз”ЁжҸҗзӨә</label>
      <input type="text" name="use_tip" value="<%= pp.use_tip || pp.useTip || '' %>">
    </div>
  </fieldset>

  <% if (product) { %>
    <div class="form-group">
      <label>зҠ¶жҖҒ</label>
      <select name="is_active">
        <option value="1" <%= pp.is_active || pp.isActive ? 'selected' : '' %>>дёҠжһ¶</option>
        <option value="0" <%= !(pp.is_active || pp.isActive) ? 'selected' : '' %>>дёӢжһ¶</option>
      </select>
    </div>
  <% } %>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">дҝқеӯҳ</button>
    <a href="/admin/points" class="btn btn-outline">еҸ–ж¶Ҳ</a>
  </div>
</form>
