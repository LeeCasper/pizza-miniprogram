<div class="page-header">
  <h2>订单管理</h2>
</div>

<div class="tabs">
  <a href="/admin/orders" class="tab <%= currentStatus === 'all' ? 'active' : '' %>">全部</a>
  <a href="/admin/orders?status=waiting" class="tab <%= currentStatus === 'waiting' ? 'active' : '' %>">待取餐</a>
  <a href="/admin/orders?status=preparing" class="tab <%= currentStatus === 'preparing' ? 'active' : '' %>">制作中</a>
  <a href="/admin/orders?status=completed" class="tab <%= currentStatus === 'completed' ? 'active' : '' %>">已完成</a>
  <a href="/admin/orders?status=cancelled" class="tab <%= currentStatus === 'cancelled' ? 'active' : '' %>">已取消</a>
</div>

<% if (orders.length === 0) { %>
  <div class="empty-state">暂无订单</div>
<% } else { %>
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>订单号</th>
          <th>用户</th>
          <th>金额</th>
          <th>取餐码</th>
          <th>状态</th>
          <th>时间</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(o => { %>
          <tr>
            <td><a href="/admin/orders/<%= o.id %>"><%= o.id %></a></td>
            <td><%= o.user_name || o.userId %></td>
            <td>¥<%= o.total %></td>
            <td><code><%= o.pickupCode %></code></td>
            <td><span class="badge badge-<%= o.status %>"><%= {waiting:'待取餐',preparing:'制作中',completed:'已完成',cancelled:'已取消'}[o.status] %></span></td>
            <td><%= o.createdAt ? new Date(o.createdAt).toLocaleString('zh-CN') : '' %></td>
            <td><a href="/admin/orders/<%= o.id %>" class="btn btn-sm">详情</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
