<div class="page-header">
  <h2>订单详情 <small>#<%= order.id %></small></h2>
  <a href="/admin/orders" class="btn btn-outline">← 返回</a>
</div>

<div class="detail-grid">
  <div class="detail-card">
    <h3>订单信息</h3>
    <div class="detail-row"><span class="label">订单号</span><span><%= order.id %></span></div>
    <div class="detail-row"><span class="label">状态</span>
      <span class="badge badge-<%= order.status %>"><%= {waiting:'待取餐',preparing:'制作中',completed:'已完成',cancelled:'已取消'}[order.status] %></span>
    </div>
    <div class="detail-row"><span class="label">取餐码</span><code style="font-size:1.4em; letter-spacing:8px"><%= order.pickupCode %></code></div>
    <div class="detail-row"><span class="label">门店</span><span><%= order.storeName %></span></div>
    <div class="detail-row"><span class="label">订单总额</span><span>¥<%= order.total %></span></div>
    <% if (order.discountAmount > 0) { %>
      <div class="detail-row"><span class="label">优惠</span><span>-¥<%= order.discountAmount %></span></div>
    <% } %>
    <div class="detail-row"><span class="label">实付</span><strong>¥<%= order.paidAmount %></strong></div>
    <div class="detail-row"><span class="label">创建时间</span><span><%= order.createdAt ? new Date(order.createdAt).toLocaleString('zh-CN') : '' %></span></div>
    <% if (order.note) { %>
      <div class="detail-row"><span class="label">备注</span><span><%= order.note %></span></div>
    <% } %>
  </div>

  <div class="detail-card">
    <h3>商品明细</h3>
    <% if (order.items && order.items.length > 0) { %>
      <table class="data-table">
        <thead><tr><th>商品</th><th>单价</th><th>数量</th><th>小计</th></tr></thead>
        <tbody>
          <% order.items.forEach(item => { %>
            <tr>
              <td><%= item.productName %></td>
              <td>¥<%= item.price %></td>
              <td><%= item.quantity %></td>
              <td>¥<%= (item.price * item.quantity).toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p class="muted">无商品明细</p>
    <% } %>
  </div>

  <% if (order.status !== 'completed' && order.status !== 'cancelled') { %>
    <div class="detail-card">
      <h3>更新状态</h3>
      <form method="POST" action="/admin/api/orders/<%= order.id %>/status" class="status-form">
        <select name="status">
          <option value="waiting" <%= order.status === 'waiting' ? 'selected' : '' %>>待取餐</option>
          <option value="preparing" <%= order.status === 'preparing' ? 'selected' : '' %>>制作中</option>
          <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>已完成</option>
          <option value="cancelled">已取消</option>
        </select>
        <button type="submit" class="btn btn-primary">更新</button>
      </form>
    </div>
  <% } %>
</div>
